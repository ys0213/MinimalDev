---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/health/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort(
    (a, b) =>
      (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title)
  );

const getTool = (href: string) => tools.find((tool) => tool.href === href);
const pickTools = (hrefs: string[]) => hrefs.map(getTool).filter((tool): tool is ToolMeta => !!tool);

const popularTools = pickTools([
  "/health/bmi-calculator/",
  "/health/bmr-calculator/",
  "/health/calorie-needs/",
  "/health/tdee-calculator/",
  "/health/water-intake-calculator/",
  "/health/sleep-calculator/",
  "/health/pace-calculator/",
  "/health/target-heart-rate/",
]);

const toolGroups = [
  {
    title: "Body metrics",
    description: "Estimate common body-related values such as BMI, BMR, body surface area, frame size, and body composition indicators.",
    tools: pickTools([
      "/health/bmi-calculator/",
      "/health/bmr-calculator/",
      "/health/body-fat/",
      "/health/body-frame-size-calculator/",
      "/health/body-surface-area/",
      "/health/lean-body-mass-calculator/",
    ]),
  },
  {
    title: "Calories, hydration, and intake",
    description: "Use these tools for general intake estimates, calorie needs, hydration targets, and nutrition-related planning.",
    tools: pickTools([
      "/health/calorie-needs/",
      "/health/tdee-calculator/",
      "/health/ideal-calorie-deficit/",
      "/health/macro/",
      "/health/protein-intake/",
      "/health/water-intake-calculator/",
      "/health/hydration-calculator/",
    ]),
  },
  {
    title: "Activity and performance",
    description: "Estimate pace, activity calories, target heart rate, and simple movement-related values.",
    tools: pickTools([
      "/health/pace-calculator/",
      "/health/heart-rate/",
      "/health/target-heart-rate/",
      "/health/running-calorie-calculator/",
      "/health/walking-calorie-calculator/",
      "/health/cycling-calorie-calculator/",
      "/health/daily-steps-calculator/",
    ]),
  },
  {
    title: "Sleep and daily planning",
    description: "Use these tools for sleep timing, daily routines, and general wellness planning.",
    tools: pickTools([
      "/health/sleep-calculator/",
    ]),
  },
].filter((group) => group.tools.length);
---

<BaseLayout
  title="Health Calculators — MinimalDev"
  description="Free health calculators for BMI, BMR, calorie needs, hydration, heart rate, pace, sleep, body metrics, and activity estimates."
  canonicalPath="/health/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <h1 class="page-title" style="margin:0 0 8px;">Health Calculators</h1>
      <p class="lead" style="margin:0 0 10px;">
        Estimate common health-related values such as BMI, BMR, calorie needs, hydration,
        heart-rate ranges, pace, sleep timing, and body metrics.
      </p>
      <p class="lead" style="margin:0;">
        These calculators are for quick reference and general awareness only. They are not a substitute
        for medical advice, diagnosis, treatment, or personalized evaluation from a qualified professional.
      </p>
    </section>

    {popularTools.length ? (
      <section class="section">
        <h2>Start with common health calculators</h2>
        <div class="grid">
          {popularTools.map((t) => (
            <section class="card">
              <span class="badge">Popular health tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    {toolGroups.length ? (
      <section class="section">
        <h2>Health calculators by purpose</h2>
        <div class="grid">
          {toolGroups.map((group) => (
            <section class="card">
              <h2>{group.title}</h2>
              <p>{group.description}</p>
              <ul>
                {group.tools.map((t) => (
                  <li><a href={t.href}>{t.title}</a></li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    <section class="section">
      <h2>What these tools are useful for</h2>
      <div class="grid">
        <section class="card">
          <h2>Daily tracking</h2>
          <p>
            Use these calculators to estimate simple metrics such as BMI, calorie needs,
            hydration targets, body measurements, or sleep timing.
          </p>
        </section>

        <section class="card">
          <h2>Planning and awareness</h2>
          <p>
            Compare scenarios such as different activity levels, intake amounts,
            heart-rate ranges, or pace targets.
          </p>
        </section>

        <section class="card">
          <h2>Quick reference</h2>
          <p>
            Use focused calculators to get fast results for common health-related formulas
            and approximations without doing the math manually.
          </p>
        </section>
      </div>
    </section>

    <section class="section">
      <h2>Browse all health tools</h2>
      <p class="lead" style="margin-top:0;">
        Search all available health calculators below if you already know the metric or estimate you need.
      </p>

      <div class="tool-search" style="margin-bottom:16px;">
        <input
          id="toolSearch"
          type="search"
          placeholder="Search tools..."
          aria-label="Search health calculators"
          style="
            width:100%;
            padding:10px 12px;
            border-radius:10px;
            border:1px solid rgba(0,0,0,0.15);
            font-size:14px;
            box-sizing:border-box;
          "
        />
      </div>

      {tools.length ? (
        <div class="grid" data-search-grid>
          {tools.map((t) => (
            <section class="card">
              <span class="badge">Health</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      ) : (
        <p class="note">No tools found in this category yet.</p>
      )}
    </section>

    <section class="section">
      <h2>How to choose the right calculator</h2>
      <div class="card" style="padding:18px;">
        <p style="margin-top:0;">
          If you are checking body-related metrics, start with BMI, BMR, body composition,
          or body measurement calculators. If your focus is nutrition or intake, use calorie,
          macro, protein, or hydration tools. For activity and performance, choose pace,
          heart-rate, step, or calorie-burn calculators.
        </p>
        <p style="margin-bottom:0;">
          Each calculator is focused on one type of estimate so that the result is easier to understand
          and not mixed with unrelated assumptions.
        </p>
      </div>
    </section>

    <section class="section">
      <h2>Important limitations</h2>
      <div class="card" style="padding:18px;">
        <p style="margin-top:0;">
          These calculators provide general estimates based on common formulas and simplified inputs.
          Results may vary depending on health conditions, measurement accuracy, age, activity level,
          body composition, medication, and other factors that simple calculators cannot fully account for.
        </p>
        <p style="margin-bottom:0;">
          This content is for informational purposes only and should not be considered medical advice.
          For diagnosis, treatment, or personal health decisions, consult a qualified healthcare professional.
        </p>
      </div>
    </section>
  </div>

  <script>
    const searchInput = document.getElementById("toolSearch") as HTMLInputElement | null;
    const grid = document.querySelector("[data-search-grid]");

    if (searchInput && grid) {
      const cards = Array.from(grid.querySelectorAll(".card")) as HTMLElement[];

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();

        cards.forEach((card) => {
          const text = card.textContent?.toLowerCase() || "";
          card.style.display = text.includes(query) ? "" : "none";
        });
      });
    }
  </script>
</BaseLayout>