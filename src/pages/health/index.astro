---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/health/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort(
    (a, b) =>
      (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title)
  );
---

<BaseLayout
  title="Health Calculators — MinimalDev"
  description="Free health calculators including BMI, BMR, calories, water intake, and body metrics."
  canonicalPath="/health/"
>
  <div class="container">
    <h1 class="page-title">Health Calculators</h1>
    <p class="lead">
      Quick body and wellness calculators designed for clarity. Informational use only.
    </p>

    {tools.length ? (
      <div class="grid">
        {tools.map((t) => (
          <section class="card">
            <h2>{t.title}</h2>
            <p>{t.description}</p>
            <a class="btn" href={t.href}>Open</a>
          </section>
        ))}
      </div>
    ) : (
      <p class="note">No tools found in this category yet.</p>
    )}

    <section class="section">
      <h2>FAQ</h2>
      <ul>
        <li><strong>Is this medical advice?</strong> No. Results are informational only.</li>
        <li><strong>Which formula is used?</strong> Each tool explains formulas in the “How it works” section.</li>
      </ul>
    </section>
  </div>
</BaseLayout>