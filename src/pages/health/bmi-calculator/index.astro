---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "BMI Calculator",
  description: "Free BMI calculator for adults. Calculate Body Mass Index and see BMI categories instantly.",
  href: "/health/bmi-calculator/",
  order: 10,
};
---

<ToolLayout
  title="BMI Calculator — MinimalDev"
  description="Free BMI calculator using metric or imperial units. Calculate Body Mass Index and view standard BMI categories."
  canonicalPath="/health/bmi-calculator/"
  h1="BMI Calculator"
  intro="Calculate your Body Mass Index (BMI) using metric or imperial units. See your BMI value and category instantly."
>
  <div slot="tool" data-tool="bmi-calculator">
    <div class="form">
      <div class="field">
        <label for="bmi_unit">Units</label>
        <select id="bmi_unit">
          <option value="metric" selected>Metric (cm, kg)</option>
          <option value="imperial">Imperial (in, lb)</option>
        </select>
      </div>

      <div class="field">
        <label for="bmi_height">Height</label>
        <input id="bmi_height" type="number" inputmode="decimal" placeholder="Height (cm)" />
      </div>

      <div class="field">
        <label for="bmi_weight">Weight</label>
        <input id="bmi_weight" type="number" inputmode="decimal" placeholder="Weight (kg)" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn secondary" type="button" id="bmi_clear">Clear</button>
      </div>

      <div class="result" id="bmi_result">Result will appear here.</div>

      <p class="note" style="margin-top:8px;">
        This calculator is for informational purposes only and does not replace medical advice.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      BMI (Body Mass Index) is calculated using height and weight.
    </p>

    <p class="note">
      <strong>Metric formula:</strong> BMI = weight (kg) ÷ height (m)²<br />
      <strong>Imperial formula:</strong> BMI = (weight (lb) ÷ height (in)²) × 703
    </p>

    <p class="note">
      The result is compared against standard adult BMI categories.
    </p>

    <ul>
      <li><strong>Underweight:</strong> Below 18.5</li>
      <li><strong>Normal weight:</strong> 18.5 – 24.9</li>
      <li><strong>Overweight:</strong> 25 – 29.9</li>
      <li><strong>Obesity:</strong> 30 and above</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li>170 cm, 65 kg → BMI ≈ 22.49 (Normal range)</li>
      <li>180 cm, 90 kg → BMI ≈ 27.78 (Overweight)</li>
      <li>70 in, 160 lb → BMI ≈ 22.96</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>Is BMI accurate?</strong> BMI is a screening tool. It does not directly measure body fat or muscle mass.</li>
      <li><strong>Is this for adults?</strong> Yes. BMI categories shown here apply to adults, not children or teens.</li>
      <li><strong>Does BMI consider muscle?</strong> No. Athletes may have a high BMI due to muscle mass.</li>
      <li><strong>Which BMI chart is used?</strong> Standard adult BMI categories commonly referenced by global health organizations.</li>
      <li><strong>Is my data stored?</strong> No. All calculations happen locally in your browser.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/health/water-intake-calculator/">Water Intake Calculator</a></li>
      <li><a href="/health/">Health Calculators</a></li>
    </ul>
  </div>
</ToolLayout>