---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "BMR Calculator",
  description: "Free BMR calculator using Mifflin-St Jeor. Estimate daily basal metabolic rate based on age, sex, height, and weight.",
  href: "/health/bmr-calculator/",
  order: 30,
};
---

<ToolLayout
  title="BMR Calculator — MinimalDev"
  description="Free BMR calculator using the Mifflin-St Jeor equation. Estimate your basal metabolic rate (BMR) in calories/day."
  canonicalPath="/health/bmr-calculator/"
  h1="BMR Calculator"
  intro="Estimate your Basal Metabolic Rate (BMR) using the Mifflin-St Jeor formula. Informational only, not medical advice."
>
  <div slot="tool" data-tool="bmr-calculator">
    <div class="form">
      <div class="field">
        <label for="bmr_sex">Sex</label>
        <select id="bmr_sex">
          <option value="male" selected>Male</option>
          <option value="female">Female</option>
        </select>
      </div>

      <div class="field">
        <label for="bmr_age">Age</label>
        <input id="bmr_age" type="number" inputmode="numeric" min="1" max="120" placeholder="e.g., 30" />
      </div>

      <div class="field">
        <label for="bmr_height">Height (cm)</label>
        <input id="bmr_height" type="number" inputmode="decimal" min="1" placeholder="e.g., 175" />
      </div>

      <div class="field">
        <label for="bmr_weight">Weight (kg)</label>
        <input id="bmr_weight" type="number" inputmode="decimal" min="1" placeholder="e.g., 70" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="bmr_calc">Calculate</button>
        <button class="btn secondary" type="button" id="bmr_clear">Clear</button>
      </div>

      <div class="result" id="bmr_result">Result will appear here.</div>

      <p class="note" style="margin-top:10px;">
        Informational only. Metabolism varies by body composition, hormones, sleep, and health conditions.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This tool uses the <strong>Mifflin-St Jeor</strong> equation (commonly used in nutrition apps).<br/>
      <strong>Male:</strong> BMR = 10×kg + 6.25×cm − 5×age + 5<br/>
      <strong>Female:</strong> BMR = 10×kg + 6.25×cm − 5×age − 161
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>Male, 30y, 175 cm, 70 kg → BMR ≈ 1,649 kcal/day</li>
      <li>Female, 30y, 165 cm, 60 kg → BMR ≈ 1,320 kcal/day</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>What is BMR?</strong> It’s an estimate of calories your body burns at rest to keep basic functions running.</li>
      <li><strong>Is this the same as TDEE?</strong> No. TDEE includes activity; BMR is your baseline.</li>
      <li><strong>Which formula is best?</strong> There are multiple; Mifflin-St Jeor is widely used for general estimates.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/health/tdee-calculator/">TDEE Calculator</a></li>
      <li><a href="/health/calorie-needs-calculator/">Calorie Needs Calculator</a></li>
      <li><a href="/health/bmi-calculator/">BMI Calculator</a></li>
      <li><a href="/health/">All Health Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const sexEl = document.getElementById("bmr_sex");
  const ageEl = document.getElementById("bmr_age");
  const hEl = document.getElementById("bmr_height");
  const wEl = document.getElementById("bmr_weight");
  const calcBtn = document.getElementById("bmr_calc");
  const clearBtn = document.getElementById("bmr_clear");
  const outEl = document.getElementById("bmr_result");

  if (!sexEl || !ageEl || !hEl || !wEl || !calcBtn || !clearBtn || !outEl) return;

  function fmt(n) {
    return Math.round(n).toLocaleString();
  }

  function compute() {
    const sex = sexEl.value;
    const age = parseFloat(ageEl.value);
    const cm = parseFloat(hEl.value);
    const kg = parseFloat(wEl.value);

    if (!isFinite(age) || age <= 0 || !isFinite(cm) || cm <= 0 || !isFinite(kg) || kg <= 0) {
      outEl.textContent = "Please enter valid age, height, and weight.";
      return;
    }

    const base = 10 * kg + 6.25 * cm - 5 * age;
    const bmr = sex === "female" ? (base - 161) : (base + 5);

    outEl.innerHTML =
      "<strong>BMR:</strong> " + fmt(bmr) + " kcal/day<br/>" +
      "<span class='note'>This is your estimated daily calories at rest.</span>";
  }

  calcBtn.addEventListener("click", compute);

  clearBtn.addEventListener("click", function () {
    ageEl.value = "";
    hEl.value = "";
    wEl.value = "";
    outEl.textContent = "Result will appear here.";
  });
});
</script>