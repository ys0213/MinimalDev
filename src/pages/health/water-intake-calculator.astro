---
import ToolLayout from "../../components/ToolLayout.astro";

export const tool = {
  title: "Water Intake Calculator",
  description: "Free water intake calculator to estimate daily water needs based on weight and activity.",
  href: "/health/water-intake-calculator/",
  order: 20,
};
---

<ToolLayout
  title="Water Intake Calculator — MinimalDev"
  description="Free water intake calculator to estimate daily water needs based on weight and activity."
  canonicalPath="/health/water-intake-calculator/"
  h1="Water Intake Calculator"
  intro="Estimate daily water intake using a simple guideline based on weight and activity level."
>
  <div slot="tool" data-tool="water-intake-calculator">
    <div class="form">
      <div class="field">
        <label for="wi_unit">Units</label>
        <select id="wi_unit">
          <option value="metric" selected>Metric (kg)</option>
          <option value="imperial">Imperial (lb)</option>
        </select>
      </div>

      <div class="field">
        <label for="wi_weight">Weight</label>
        <input id="wi_weight" type="number" inputmode="decimal" placeholder="Weight (kg)" />
      </div>

      <div class="field">
        <label for="wi_activity">Activity level</label>
        <select id="wi_activity">
          <option value="low" selected>Low</option>
          <option value="moderate">Moderate</option>
          <option value="high">High</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn secondary" type="button" id="wi_clear">Clear</button>
      </div>

      <div class="result" id="wi_result">Result will appear here.</div>
      <p class="note" style="margin-top:8px;">
        This is a general estimate. Needs vary by climate, health, and activity.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Guideline used: ~35 ml per kg body weight, plus a small adjustment for higher activity.
      Output is shown in liters and approximate cups.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>70 kg, low activity → about 2.45 L</li>
      <li>70 kg, high activity → higher estimate with adjustment</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>Is this a medical recommendation?</strong> No. It’s an informational guideline.</li>
      <li><strong>Why show cups?</strong> It’s a simple approximate measure (~240 ml per cup).</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/health/bmi-calculator/">BMI Calculator</a></li>
      <li><a href="/health/">Health Calculators</a></li>
    </ul>
  </div>
</ToolLayout>