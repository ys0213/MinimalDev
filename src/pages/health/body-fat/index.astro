---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Body Fat Calculator",
  description:
    "Estimate body fat percentage using the U.S. Navy method. Supports metric and imperial units. Free body fat calculator for adults.",
  href: "/health/body-fat/",
  order: 40,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/health/body-fat/";

// FAQ content + JSON-LD (auto)
const faqs = [
  {
    q: "How does this body fat calculator work?",
    a: "It estimates body fat percentage using the U.S. Navy method, which uses circumference measurements and height (and includes neck/waist, plus hip for females).",
  },
  {
    q: "Is this accurate?",
    a: "It’s a practical estimate, but not a medical-grade measurement. Accuracy depends on measurement technique and individual body shape.",
  },
  {
    q: "Who is this calculator for?",
    a: "It’s intended for adults. Body fat estimation methods and healthy ranges differ for children and teens.",
  },
  {
    q: "Do I need to measure in a specific way?",
    a: "Use a flexible tape measure, keep it level, and measure snugly without compressing the skin. Measure in consistent conditions for better comparisons over time.",
  },
  {
    q: "Is my data stored?",
    a: "No. All calculations run locally in your browser. Inputs are not sent to a server.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Body Fat Calculator — ${SITE_NAME}`}
  description="Estimate body fat percentage using the U.S. Navy method (circumference-based). Supports metric and imperial units. Informational only."
  canonicalPath={CANONICAL_PATH}
  h1="Body Fat Calculator"
  intro="Estimate body fat percentage using the U.S. Navy circumference method. Supports metric and imperial units. Informational only."
>
  {/* FAQ Schema (auto from faqs[]) */}
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="body-fat-calculator">
    <div class="form" role="form" aria-describedby="bf_privacy_note">
      <div class="field">
        <label for="bf_units">Units</label>
        <select id="bf_units">
          <option value="metric" selected>Metric (cm)</option>
          <option value="imperial">Imperial (in)</option>
        </select>
      </div>

      <div class="field">
        <label for="bf_sex">Sex</label>
        <select id="bf_sex">
          <option value="male" selected>Male</option>
          <option value="female">Female</option>
        </select>
        <div class="note" id="bf_sex_help">
          Female calculation uses hip circumference in addition to neck and waist.
        </div>
      </div>

      <fieldset style="border:0; padding:0; margin:0;">
        <legend class="note" style="margin:0 0 8px;">Measurements</legend>

        <div class="field">
          <label for="bf_height">Height</label>
          <input id="bf_height" type="number" inputmode="decimal" min="1" placeholder="e.g., 175" autocomplete="off" />
          <div class="note" id="bf_height_help">cm</div>
        </div>

        <div class="field">
          <label for="bf_neck">Neck</label>
          <input id="bf_neck" type="number" inputmode="decimal" min="1" placeholder="e.g., 38" autocomplete="off" />
          <div class="note" id="bf_neck_help">cm</div>
        </div>

        <div class="field">
          <label for="bf_waist">Waist</label>
          <input id="bf_waist" type="number" inputmode="decimal" min="1" placeholder="e.g., 85" autocomplete="off" />
          <div class="note" id="bf_waist_help">cm</div>
        </div>

        <div class="field" id="bf_hip_wrap" style="display:none;">
          <label for="bf_hip">Hip (female only)</label>
          <input id="bf_hip" type="number" inputmode="decimal" min="1" placeholder="e.g., 95" autocomplete="off" />
          <div class="note" id="bf_hip_help">cm</div>
        </div>
      </fieldset>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="bf_calc">Calculate</button>
        <button class="btn secondary" type="button" id="bf_clear">Clear</button>
      </div>

      {/* Error region */}
      <div class="result" id="bf_error" role="alert" aria-live="assertive" style="display:none;"></div>

      {/* Result region */}
      <div class="result" id="bf_result" role="status" aria-live="polite" style="margin-top:12px;">
        Result will appear here.
      </div>

      <p class="note" id="bf_privacy_note" style="margin-top:10px;">
        Informational estimate only (not medical advice). Privacy: runs locally in your browser. No inputs are stored or sent to a server.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This tool uses the <strong>U.S. Navy body fat method</strong> (circumference-based). Measurements should be taken with a flexible tape.
      Keep the tape level and snug (not compressing the skin).
    </p>

    <p class="note">
      The method uses logarithms, so <strong>relative measurement accuracy matters</strong>. Measuring consistently (same time of day, same tape tension) helps when tracking over time.
    </p>

    <ul>
      <li><strong>Male inputs:</strong> height, neck, waist</li>
      <li><strong>Female inputs:</strong> height, neck, waist, hip</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li>Male: Height 175 cm, Neck 38 cm, Waist 85 cm → estimate body fat %</li>
      <li>Female: Height 165 cm, Neck 34 cm, Waist 75 cm, Hip 95 cm → estimate body fat %</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      {faqs.map((f) => (
        <li>
          <strong>{f.q}</strong> {f.a}
        </li>
      ))}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/health/bmi-calculator/">BMI Calculator</a></li>
      <li><a href="/health/ideal-weight/">Ideal Weight Calculator</a></li>
      <li><a href="/health/tdee-calculator/">TDEE Calculator</a></li>
      <li><a href="/health/">All Health Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const unitsEl = document.getElementById("bf_units");
  const sexEl = document.getElementById("bf_sex");
  const hipWrap = document.getElementById("bf_hip_wrap");

  const hEl = document.getElementById("bf_height");
  const neckEl = document.getElementById("bf_neck");
  const waistEl = document.getElementById("bf_waist");
  const hipEl = document.getElementById("bf_hip");

  const hHelp = document.getElementById("bf_height_help");
  const neckHelp = document.getElementById("bf_neck_help");
  const waistHelp = document.getElementById("bf_waist_help");
  const hipHelp = document.getElementById("bf_hip_help");

  const calcBtn = document.getElementById("bf_calc");
  const clearBtn = document.getElementById("bf_clear");

  const errEl = document.getElementById("bf_error");
  const outEl = document.getElementById("bf_result");

  if (
    !unitsEl || !sexEl || !hipWrap ||
    !hEl || !neckEl || !waistEl || !hipEl ||
    !hHelp || !neckHelp || !waistHelp || !hipHelp ||
    !calcBtn || !clearBtn || !errEl || !outEl
  ) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
    outEl.textContent = "Result will appear here.";
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function round1(n) {
    const r = Math.round(n * 10) / 10;
    return r.toLocaleString(undefined, { maximumFractionDigits: 1, minimumFractionDigits: 1 });
  }

  function round0(n) {
    return Math.round(n).toLocaleString();
  }

  function setUnitUX() {
    const u = String(unitsEl.value);
    const unitLabel = (u === "imperial") ? "in" : "cm";

    hHelp.textContent = unitLabel;
    neckHelp.textContent = unitLabel;
    waistHelp.textContent = unitLabel;
    hipHelp.textContent = unitLabel;

    hEl.placeholder = u === "imperial" ? "e.g., 69" : "e.g., 175";
    neckEl.placeholder = u === "imperial" ? "e.g., 15" : "e.g., 38";
    waistEl.placeholder = u === "imperial" ? "e.g., 33" : "e.g., 85";
    hipEl.placeholder = u === "imperial" ? "e.g., 37" : "e.g., 95";
  }

  function setSexUX() {
    const sex = String(sexEl.value);
    hipWrap.style.display = (sex === "female") ? "block" : "none";
  }

  // Convert to inches for formulas (Navy equations use log10; constants typically expressed with inches)
  function toInches(value) {
    const u = String(unitsEl.value);
    if (!Number.isFinite(value)) return NaN;
    return (u === "imperial") ? value : (value / 2.54);
  }

  // U.S. Navy method:
  // Male BF% = 86.010*log10(waist - neck) - 70.041*log10(height) + 36.76
  // Female BF% = 163.205*log10(waist + hip - neck) - 97.684*log10(height) - 78.387
  // Inputs in inches.
  function navyBodyFatPercent(sex, heightIn, neckIn, waistIn, hipIn) {
    const log10 = (x) => Math.log(x) / Math.LN10;

    if (sex === "female") {
      const A = waistIn + hipIn - neckIn;
      if (!(A > 0) || !(heightIn > 0)) return NaN;
      return 163.205 * log10(A) - 97.684 * log10(heightIn) - 78.387;
    } else {
      const A = waistIn - neckIn;
      if (!(A > 0) || !(heightIn > 0)) return NaN;
      return 86.010 * log10(A) - 70.041 * log10(heightIn) + 36.76;
    }
  }

  function classify(sex, bf) {
    // Broad adult categories (approximate; varies by source). Kept conservative and clearly labeled as informational.
    // Male: Essential 2–5, Athletes 6–13, Fitness 14–17, Average 18–24, Obese 25+
    // Female: Essential 10–13, Athletes 14–20, Fitness 21–24, Average 25–31, Obese 32+
    if (!Number.isFinite(bf)) return { label: "Unknown", tone: "neutral", note: "" };

    if (sex === "female") {
      if (bf < 14) return { label: "Very lean", tone: "warn", note: "Below typical athletic ranges for many adults." };
      if (bf < 21) return { label: "Athletic", tone: "good", note: "Common range for many active adults." };
      if (bf < 25) return { label: "Fitness", tone: "good", note: "Often seen in regular exercisers." };
      if (bf < 32) return { label: "Average", tone: "neutral", note: "Typical population range varies widely." };
      return { label: "High", tone: "warn", note: "Consider professional guidance if concerned." };
    } else {
      if (bf < 6) return { label: "Very lean", tone: "warn", note: "Below typical athletic ranges for many adults." };
      if (bf < 14) return { label: "Athletic", tone: "good", note: "Common range for many active adults." };
      if (bf < 18) return { label: "Fitness", tone: "good", note: "Often seen in regular exercisers." };
      if (bf < 25) return { label: "Average", tone: "neutral", note: "Typical population range varies widely." };
      return { label: "High", tone: "warn", note: "Consider professional guidance if concerned." };
    }
  }

  function badgeHTML(tone, text) {
    const base = "display:inline-block; padding:2px 8px; border-radius:999px; font-size:12px; font-weight:700; border:1px solid rgba(255,255,255,0.14);";
    const bg = tone === "good"
      ? "background: rgba(34,197,94,0.12);"
      : tone === "warn"
        ? "background: rgba(245,158,11,0.14);"
        : "background: rgba(255,255,255,0.06);";
    return "<span style='" + base + bg + "'>" + text + "</span>";
  }

  function card(title, value, subtitle, tone) {
    return (
      "<div style='border:1px solid rgba(255,255,255,0.12); border-radius:12px; padding:12px; min-width:220px; flex:1;'>" +
        "<div style='display:flex; justify-content:space-between; gap:10px; align-items:baseline;'>" +
          "<strong>" + title + "</strong>" +
          badgeHTML(tone, title === "Category" ? value : "Estimate") +
        "</div>" +
        (title === "Category"
          ? "<div style='font-size:20px; margin-top:6px; font-weight:800;'>" + value + "</div>"
          : "<div style='font-size:26px; margin-top:6px; font-weight:900;'>" + value + "</div>"
        ) +
        "<div class='note' style='margin-top:6px;'>" + subtitle + "</div>" +
      "</div>"
    );
  }

  function compute() {
    clearError();

    const sex = String(sexEl.value);
    const height = toNum(hEl.value);
    const neck = toNum(neckEl.value);
    const waist = toNum(waistEl.value);
    const hip = toNum(hipEl.value);

    // Basic validation
    if (!Number.isFinite(height) || height <= 0) return showError("Please enter a valid height.");
    if (!Number.isFinite(neck) || neck <= 0) return showError("Please enter a valid neck measurement.");
    if (!Number.isFinite(waist) || waist <= 0) return showError("Please enter a valid waist measurement.");
    if (sex === "female" && (!Number.isFinite(hip) || hip <= 0)) return showError("Please enter a valid hip measurement (female).");

    // Convert to inches
    const heightIn = toInches(height);
    const neckIn = toInches(neck);
    const waistIn = toInches(waist);
    const hipIn = toInches(hip);

    // Additional guardrails for Navy equations:
    // Male: waist must be > neck
    // Female: (waist + hip) must be > neck
    if (sex === "male" && !(waistIn > neckIn)) {
      return showError("For a valid estimate, waist must be greater than neck.");
    }
    if (sex === "female" && !((waistIn + hipIn) > neckIn)) {
      return showError("For a valid estimate, waist + hip must be greater than neck.");
    }

    const bf = navyBodyFatPercent(sex, heightIn, neckIn, waistIn, hipIn);
    if (!Number.isFinite(bf)) return showError("Could not compute body fat with these values.");

    // Plausibility bounds (informational)
    if (bf < 0 || bf > 75) return showError("Result looks implausible. Please re-check measurements and units.");

    const cls = classify(sex, bf);

    // Show converted summary as user entered units
    const unitLabel = String(unitsEl.value) === "imperial" ? "in" : "cm";
    const heightLine = "Height: " + height.toLocaleString() + " " + unitLabel;
    const neckLine = "Neck: " + neck.toLocaleString() + " " + unitLabel;
    const waistLine = "Waist: " + waist.toLocaleString() + " " + unitLabel;
    const hipLine = (sex === "female") ? (" · Hip: " + hip.toLocaleString() + " " + unitLabel) : "";

    const summary =
      "<div style='margin-bottom:12px;'>" +
        "<strong>Estimated body fat:</strong> " + round1(bf) + "%<br/>" +
        "<span class='note'>Method: U.S. Navy · " + heightLine + " · " + neckLine + " · " + waistLine + hipLine + "</span>" +
      "</div>";

    const cards =
      "<div style='display:flex; gap:10px; flex-wrap:wrap;'>" +
        card("Body fat %", round1(bf) + "%", "Circumference-based estimate (not medical-grade).", cls.tone) +
        card("Category", cls.label, cls.note || "Informational category for a broad adult context.", cls.tone) +
        card("Tracking tip", "Consistency", "Measure at the same time of day with the tape level and snug.", "neutral") +
      "</div>";

    const note =
      "<div class='note' style='margin-top:10px;'>" +
        "If your goal is trend tracking, prioritize consistent measurement technique over single-day precision." +
      "</div>";

    outEl.innerHTML = summary + cards + note;
  }

  function clearAll() {
    clearError();
    unitsEl.value = "metric";
    sexEl.value = "male";
    hEl.value = "";
    neckEl.value = "";
    waistEl.value = "";
    hipEl.value = "";
    setUnitUX();
    setSexUX();
    outEl.textContent = "Result will appear here.";
  }

  // UX init
  function init() {
    setUnitUX();
    setSexUX();
  }

  // Events
  unitsEl.addEventListener("change", function () {
    setUnitUX();
    clearError();
    outEl.textContent = "Result will appear here.";
  });

  sexEl.addEventListener("change", function () {
    setSexUX();
    clearError();
    outEl.textContent = "Result will appear here.";
  });

  calcBtn.addEventListener("click", compute);
  clearBtn.addEventListener("click", clearAll);

  // Enter key triggers calculate (a11y/UX)
  [hEl, neckEl, waistEl, hipEl].forEach((el) => {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") compute();
    });
  });

  init();
});
</script>