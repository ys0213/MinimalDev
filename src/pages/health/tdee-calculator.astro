---
import ToolLayout from "../../components/ToolLayout.astro";

export const tool = {
  title: "TDEE Calculator",
  description: "Free TDEE calculator. Estimate daily calorie needs based on BMR and activity level.",
  href: "/health/tdee-calculator/",
  order: 40,
};
---

<ToolLayout
  title="TDEE Calculator — MinimalDev"
  description="Free TDEE calculator. Estimate Total Daily Energy Expenditure using BMR (Mifflin-St Jeor) and activity multiplier."
  canonicalPath="/health/tdee-calculator/"
  h1="TDEE Calculator"
  intro="Estimate your Total Daily Energy Expenditure (TDEE) using BMR and activity level. Informational only."
>
  <div slot="tool" data-tool="tdee-calculator">
    <div class="form">
      <div class="field">
        <label for="tdee_sex">Sex</label>
        <select id="tdee_sex">
          <option value="male" selected>Male</option>
          <option value="female">Female</option>
        </select>
      </div>

      <div class="field">
        <label for="tdee_age">Age</label>
        <input id="tdee_age" type="number" inputmode="numeric" min="1" max="120" placeholder="e.g., 30" />
      </div>

      <div class="field">
        <label for="tdee_height">Height (cm)</label>
        <input id="tdee_height" type="number" inputmode="decimal" min="1" placeholder="e.g., 175" />
      </div>

      <div class="field">
        <label for="tdee_weight">Weight (kg)</label>
        <input id="tdee_weight" type="number" inputmode="decimal" min="1" placeholder="e.g., 70" />
      </div>

      <div class="field">
        <label for="tdee_activity">Activity level</label>
        <select id="tdee_activity">
          <option value="1.2" selected>Sedentary (little or no exercise)</option>
          <option value="1.375">Light (1–3 days/week)</option>
          <option value="1.55">Moderate (3–5 days/week)</option>
          <option value="1.725">Very active (6–7 days/week)</option>
          <option value="1.9">Athlete (very intense training)</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="tdee_calc">Calculate</button>
        <button class="btn secondary" type="button" id="tdee_clear">Clear</button>
      </div>

      <div class="result" id="tdee_result">Result will appear here.</div>

      <p class="note" style="margin-top:10px;">
        Informational only. Activity multipliers are approximations and vary by individual.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      1) Calculate <strong>BMR</strong> via Mifflin-St Jeor.<br/>
      2) Multiply by an <strong>activity factor</strong> to estimate TDEE.<br/>
      <strong>TDEE = BMR × activity multiplier</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>Male 30y, 175 cm, 70 kg, moderate → TDEE ≈ 2,556 kcal/day</li>
      <li>Female 30y, 165 cm, 60 kg, light → TDEE ≈ 1,815 kcal/day</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>What is TDEE?</strong> Estimated calories your body uses per day including activity.</li>
      <li><strong>Can I use TDEE for weight loss?</strong> It helps estimate a starting point; adjust based on real results.</li>
      <li><strong>Is this medical advice?</strong> No. It’s an informational estimate.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/health/bmr-calculator/">BMR Calculator</a></li>
      <li><a href="/health/calorie-needs-calculator/">Calorie Needs Calculator</a></li>
      <li><a href="/health/bmi-calculator/">BMI Calculator</a></li>
      <li><a href="/health/">All Health Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const sexEl = document.getElementById("tdee_sex");
  const ageEl = document.getElementById("tdee_age");
  const hEl = document.getElementById("tdee_height");
  const wEl = document.getElementById("tdee_weight");
  const actEl = document.getElementById("tdee_activity");
  const calcBtn = document.getElementById("tdee_calc");
  const clearBtn = document.getElementById("tdee_clear");
  const outEl = document.getElementById("tdee_result");

  if (!sexEl || !ageEl || !hEl || !wEl || !actEl || !calcBtn || !clearBtn || !outEl) return;

  function round0(n) { return Math.round(n).toLocaleString(); }

  function bmr(sex, age, cm, kg) {
    const base = 10 * kg + 6.25 * cm - 5 * age;
    return sex === "female" ? (base - 161) : (base + 5);
  }

  function compute() {
    const sex = sexEl.value;
    const age = parseFloat(ageEl.value);
    const cm = parseFloat(hEl.value);
    const kg = parseFloat(wEl.value);
    const mult = parseFloat(actEl.value);

    if (!isFinite(age) || age <= 0 || !isFinite(cm) || cm <= 0 || !isFinite(kg) || kg <= 0 || !isFinite(mult) || mult <= 0) {
      outEl.textContent = "Please enter valid values.";
      return;
    }

    const B = bmr(sex, age, cm, kg);
    const T = B * mult;

    outEl.innerHTML =
      "<strong>TDEE:</strong> " + round0(T) + " kcal/day<br/>" +
      "<span class='note'>BMR ≈ " + round0(B) + " kcal/day · Multiplier " + mult + "</span>";
  }

  calcBtn.addEventListener("click", compute);

  clearBtn.addEventListener("click", function () {
    ageEl.value = "";
    hEl.value = "";
    wEl.value = "";
    outEl.textContent = "Result will appear here.";
  });
});
</script>