---
import ToolLayout from "../../components/ToolLayout.astro";

export const tool = {
  title: "Days Between Dates",
  description: "Calculate the number of days between two dates instantly. Date difference calculator for planning and deadlines.",
  href: "/date-time/days-between-dates/",
  order: 10,
};
---

<ToolLayout
  title="Days Between Dates Calculator — MinimalDev"
  description="Free days between two dates calculator. Find how many days from one date to another instantly."
  canonicalPath="/date-time/days-between-dates/"
  h1="Days Between Dates"
  intro="Calculate how many days are between two calendar dates. Useful for planning, deadlines, projects, and date tracking."
>
  <div slot="tool" data-tool="days-between-dates">
    <div class="form">
      <div class="field">
        <label for="dbd_a">Start date</label>
        <input id="dbd_a" type="date" />
      </div>

      <div class="field">
        <label for="dbd_b">End date</label>
        <input id="dbd_b" type="date" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn secondary" type="button" id="dbd_clear">Clear</button>
      </div>

      <div class="result" id="dbd_result">Result will appear here.</div>

      <p class="note" style="margin-top:8px;">
        This tool runs entirely in your browser. No dates are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      The calculator finds the absolute difference between the two selected dates and converts it into days.
      Dates are normalized to midnight (UTC) to ensure consistent results across time zones.
    </p>

    <ul>
      <li><strong>Leap years:</strong> Automatically handled.</li>
      <li><strong>Time zones:</strong> Calculation is based on calendar dates, not time of day.</li>
      <li><strong>Order does not matter:</strong> The result is always the positive difference.</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>How many days between Jan 1 and Jan 31, 2026?</strong> → 30 days</li>
      <li><strong>Days from Feb 1 to Feb 15, 2026?</strong> → 14 days</li>
      <li><strong>Days between Mar 10, 2025 and Apr 1, 2025?</strong> → 22 days</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>Does the order of dates matter?</strong> No. The calculator uses the absolute difference between the two dates.</li>
      <li><strong>Does it include the start date?</strong> The result shows the difference in calendar days between the selected dates.</li>
      <li><strong>Does it count leap years?</strong> Yes. February 29 is automatically included when applicable.</li>
      <li><strong>Is this a business days calculator?</strong> No. This tool counts all calendar days, including weekends.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/date-time/age-calculator/">Age Calculator</a></li>
      <li><a href="/date-time/work-days-calculator/">Work Days Calculator</a></li>
      <li><a href="/date-time/">Date & Time Tools</a></li>
    </ul>
  </div>
</ToolLayout>