---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/date-time/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort(
    (a, b) =>
      (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title)
  );

const getTool = (href: string) => tools.find((tool) => tool.href === href);
const pickTools = (hrefs: string[]) => hrefs.map(getTool).filter((tool): tool is ToolMeta => !!tool);

const popularTools = pickTools([
  "/date-time/date-difference-calculator/",
  "/date-time/days-between-dates/",
  "/date-time/business-days-calculator/",
  "/date-time/age-calculator/",
  "/date-time/time-zone-converter/",
  "/date-time/unix-timestamp-converter/",
  "/date-time/unix-time-to-date/",
  "/date-time/time-duration-calculator/",
]);

const toolGroups = [
  {
    title: "Date differences and workdays",
    description: "Calculate days between dates, business days, work days, or calendar ranges for planning and scheduling.",
    tools: pickTools([
      "/date-time/date-difference-calculator/",
      "/date-time/days-between-dates/",
      "/date-time/business-days-calculator/",
      "/date-time/work-days-calculator/",
      "/date-time/weeks-between-dates-calculator/",
      "/date-time/months-between-dates-calculator/",
    ]),
  },
  {
    title: "Personal dates and countdowns",
    description: "Use these tools for birthdays, age checks, future events, milestones, and personal date tracking.",
    tools: pickTools([
      "/date-time/age-calculator/",
      "/date-time/birthday-countdown/",
      "/date-time/add-subtract-days-calculator/",
      "/date-time/add-months-calculator/",
    ]),
  },
  {
    title: "Time, zones, and timestamps",
    description: "Work with exact times, durations, time zones, Unix timestamps, and time-based records.",
    tools: pickTools([
      "/date-time/time-zone-converter/",
      "/date-time/time-duration-calculator/",
      "/date-time/time-between-times/",
      "/date-time/hours-between-times/",
      "/date-time/unix-timestamp-converter/",
      "/date-time/unix-time-to-date/",
    ]),
  },
].filter((group) => group.tools.length);
---

<BaseLayout
  title="Date & Time Tools — MinimalDev"
  description="Free date and time tools for date differences, business days, age calculation, countdowns, time zones, timestamps, and duration calculations."
  canonicalPath="/date-time/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <h1 class="page-title" style="margin:0 0 8px;">Date & Time Tools</h1>
      <p class="lead" style="margin:0 0 10px;">
        Calculate date differences, business days, ages, countdowns, time durations, time zones,
        and Unix timestamps. This category is grouped around planning, scheduling, personal tracking,
        and technical time workflows.
      </p>
      <p class="lead" style="margin:0;">
        Use the grouped sections when you need help choosing between calendar-date tools, workday calculators,
        time duration tools, and timestamp utilities.
      </p>
    </section>

    {popularTools.length ? (
      <section class="section">
        <h2>Start with common date and time tools</h2>
        <div class="grid">
          {popularTools.map((t) => (
            <section class="card">
              <span class="badge">Popular date tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    {toolGroups.length ? (
      <section class="section">
        <h2>Date and time tools by task</h2>
        <div class="grid">
          {toolGroups.map((group) => (
            <section class="card">
              <h2>{group.title}</h2>
              <p>{group.description}</p>
              <ul>
                {group.tools.map((t) => (
                  <li><a href={t.href}>{t.title}</a></li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    <section class="section">
      <h2>What these tools are useful for</h2>
      <div class="grid">
        <section class="card">
          <h2>Planning and scheduling</h2>
          <p>
            Measure the time between deadlines, appointments, trips, project dates,
            billing cycles, and recurring events.
          </p>
        </section>

        <section class="card">
          <h2>Personal tracking</h2>
          <p>
            Age, countdown, and duration tools are useful for birthdays, milestones, goals,
            waiting periods, and long-term progress checks.
          </p>
        </section>

        <section class="card">
          <h2>Work and record keeping</h2>
          <p>
            Timestamp, weekday, and duration calculations can help with logs, reports,
            planning windows, and practical date comparisons.
          </p>
        </section>
      </div>
    </section>

    <section class="section">
      <h2>Browse all date and time tools</h2>
      <p class="lead" style="margin-top:0;">
        Search all available tools below if you already know the type of calculation you need.
      </p>

      <div class="tool-search" style="margin-bottom:16px;">
        <input
          id="toolSearch"
          type="search"
          placeholder="Search tools..."
          aria-label="Search date and time tools"
          style="
            width:100%;
            padding:10px 12px;
            border-radius:10px;
            border:1px solid rgba(0,0,0,0.15);
            font-size:14px;
            box-sizing:border-box;
          "
        />
      </div>

      {tools.length ? (
        <div class="grid" data-search-grid>
          {tools.map((t) => (
            <section class="card">
              <span class="badge">Date & Time</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      ) : (
        <p class="note">No tools found in this category yet.</p>
      )}
    </section>

    <section class="section">
      <h2>How to choose the right date or time tool</h2>
      <div class="card" style="padding:18px;">
        <p style="margin-top:0;">
          If you want to know how many days separate two calendar dates, choose a date difference tool.
          If you need weekday-based planning, choose a business-day or workday tool. If you are working with logs,
          APIs, or technical records, choose a timestamp tool.
        </p>
        <p style="margin-bottom:0;">
          Date and time calculations can depend on weekdays, month lengths, time zones, and context,
          so focused pages are easier to check than one overloaded calculator.
        </p>
      </div>
    </section>
  </div>

  <script>
    const searchInput = document.getElementById("toolSearch") as HTMLInputElement | null;
    const grid = document.querySelector("[data-search-grid]");

    if (searchInput && grid) {
      const cards = Array.from(grid.querySelectorAll(".card")) as HTMLElement[];

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();

        cards.forEach((card) => {
          const text = card.textContent?.toLowerCase() || "";
          card.style.display = text.includes(query) ? "" : "none";
        });
      });
    }
  </script>
</BaseLayout>