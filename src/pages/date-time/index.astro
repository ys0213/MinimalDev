---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/date-time/";

// date-time 폴더 기준으로 pages 전체(상위 포함)에서 tool export 있는 파일을 모음
const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY) // 허브 자체 제외
  .sort(
    (a, b) =>
      (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title)
  );
---

<BaseLayout
  title="Date & Time Tools — MinimalDev"
  description="Free date and time tools for age calculation, countdowns, business days, time zones, timestamps, and duration calculations."
  canonicalPath="/date-time/"
>
  <div class="container">
    <h1 class="page-title">Date & Time Tools</h1>
    <p class="lead">
      Free date and time tools for age, countdowns, business days, timestamps, time zones, and duration calculations.
      Use these tools to measure date differences, convert timestamps, and plan schedules more easily.
      All date and time tools run instantly in your browser.
    </p>

    <div class="tool-search" style="margin-bottom:16px;">
      <input
          id="toolSearch"
          type="search"
          placeholder="Search tools..."
          style="
          width:100%;
          padding:10px 12px;
          border-radius:10px;
          border:1px solid rgba(0,0,0,0.15);
          font-size:14px;
          "
      />
    </div>

    {tools.length ? (
      <div class="grid">
        {tools.map((t) => (
          <section class="card">
            <h2>{t.title}</h2>
            <p>{t.description}</p>
            <a class="btn" href={t.href}>Open</a>
          </section>
        ))}
      </div>
    ) : (
      <p class="note">No tools found in this category yet.</p>
    )}

    <section class="section">
      <h2>FAQ</h2>
      <ul>
        <li><strong>Do tools include time zones?</strong> Tools use your device locale unless stated otherwise.</li>
        <li><strong>Are holidays excluded?</strong> Work days exclude weekends; holiday calendars may be added later.</li>
      </ul>
    </section>
  </div>
</BaseLayout>