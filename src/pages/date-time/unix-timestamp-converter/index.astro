---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Unix Timestamp Converter",
  description:
    "Convert Unix timestamps to readable dates, or convert dates into Unix time for development and logging.",
  href: "/date-time/unix-timestamp-converter/",
  order: 140,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/date-time/unix-timestamp-converter/";

const faqs = [
  {
    q: "What is a Unix timestamp?",
    a: "A Unix timestamp is the number of seconds or milliseconds elapsed since 1970-01-01 00:00:00 UTC, also known as the Unix epoch.",
  },
  {
    q: "Seconds vs milliseconds: what is the difference?",
    a: "Seconds timestamps are often 10 digits for modern dates. Milliseconds timestamps are often 13 digits. This tool can auto-detect or let you choose the unit.",
  },
  {
    q: "Does this show UTC or local time?",
    a: "You can choose either UTC or local time. UTC is consistent across time zones, while local time uses your device or browser timezone.",
  },
  {
    q: "Why is my converted date different from another site?",
    a: "The most common reasons are timezone selection and whether the timestamp is interpreted as seconds or milliseconds.",
  },
  {
    q: "Can this convert dates back into Unix timestamps?",
    a: "Yes. Use Date/Time → Timestamp mode to generate Unix seconds or Unix milliseconds from a selected date and time.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. The conversion runs locally in your browser and your input is not sent to a server.",
  },
];

---

<ToolLayout
  title={`Unix Timestamp Converter — ${SITE_NAME}`}
  description="Convert Unix timestamps to readable UTC or local dates, and convert date/time values back into Unix seconds or milliseconds."
  canonicalPath={CANONICAL_PATH}
  h1="Unix Timestamp Converter"
  intro="Convert Unix time to readable dates, or convert dates back into Unix timestamps. Supports seconds, milliseconds, UTC display, and local time display."
  faq={faqs}
  categoryName="Date & Time"
>
  <div slot="tool" data-tool="unix-timestamp-converter">
    <div class="privacy-note">
      <strong>Privacy First:</strong> This tool runs locally in your browser.
      <strong>Your input values are never sent to any server.</strong>
    </div>

    <div class="form" role="form" aria-describedby="utc_hint">
      <div class="field">
        <label for="utc_mode">Mode</label>
        <select id="utc_mode">
          <option value="ts_to_date" selected>Timestamp → Date/Time</option>
          <option value="date_to_ts">Date/Time → Timestamp</option>
        </select>
      </div>

      <div class="field">
        <label for="utc_tz">Timezone</label>
        <select id="utc_tz">
          <option value="local" selected>Local time (your device)</option>
          <option value="utc">UTC</option>
        </select>
        <p class="note" id="utc_hint" style="margin-top:6px;">
          If results look off by several hours, check whether you are viewing UTC or local time.
        </p>
      </div>

      <div class="field" id="utc_ts_block">
        <label for="utc_ts">Unix timestamp</label>
        <input id="utc_ts" type="text" inputmode="numeric" placeholder="e.g., 1700000000 or 1700000000000" />
        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:8px; align-items:center;">
          <label style="display:flex; gap:8px; align-items:center; font-weight:650; color: var(--muted);">
            <input type="checkbox" id="utc_auto" checked />
            Auto-detect seconds vs milliseconds
          </label>
          <select id="utc_unit" aria-label="Timestamp unit">
            <option value="auto" selected>Auto</option>
            <option value="s">Seconds</option>
            <option value="ms">Milliseconds</option>
          </select>
        </div>
      </div>

      <div class="field" id="utc_date_block" style="display:none;">
        <label>Date & time</label>

        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
          <div class="field">
            <label for="utc_date">Date</label>
            <input id="utc_date" type="date" />
          </div>

          <div class="field">
            <label for="utc_time">Time</label>
            <input id="utc_time" type="time" step="1" />
          </div>
        </div>

        <div class="field" style="margin-top:6px;">
          <label for="utc_out_unit">Output timestamp unit</label>
          <select id="utc_out_unit">
            <option value="s" selected>Seconds</option>
            <option value="ms">Milliseconds</option>
          </select>
        </div>

        <div class="note" style="margin-top:6px;">
          If time is empty, 00:00:00 is used.
        </div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="utc_calc">Convert</button>
        <button class="btn secondary" type="button" id="utc_now">Use current time</button>
        <button class="btn secondary" type="button" id="utc_clear">Clear</button>
      </div>

      <div class="result" id="utc_error" role="alert" style="display:none; margin-top:12px;"></div>

      <div class="result" id="utc_result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div class="result" id="utc_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Field</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="utc_table"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div slot="how">
    <h2>How Unix timestamp conversion works</h2>

    <p class="note">
      Unix time counts elapsed time from the Unix epoch: 1970-01-01 00:00:00 UTC. Many APIs, logs, databases, and event systems store time as Unix seconds or Unix milliseconds.
    </p>

    <ul>
      <li><strong>Timestamp → Date:</strong> interpret the value as seconds or milliseconds since the Unix epoch</li>
      <li><strong>Date → Timestamp:</strong> build a date and time, then convert it into Unix seconds or milliseconds</li>
      <li><strong>UTC vs Local:</strong> UTC is timezone-independent; local time depends on your browser or device settings</li>
      <li><strong>Common mistake:</strong> treating a 13-digit millisecond timestamp as seconds, or a 10-digit seconds timestamp as milliseconds</li>
    </ul>

    <p class="note">
      If a converted date looks far in the future or near 1970 unexpectedly, the timestamp unit is probably wrong.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1700000000</strong> → interpreted as Unix seconds when auto-detected</li>
      <li><strong>1700000000000</strong> → interpreted as Unix milliseconds when auto-detected</li>
      <li><strong>2026-01-01 00:00:00</strong> → convert a date/time into Unix seconds or milliseconds</li>
      <li><strong>UTC vs Local:</strong> compare the same timestamp in a fixed UTC view and your local timezone</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/date-time/days-between-dates/">Days Between Dates</a></li>
      <li><a href="/date-time/date-difference/">Date Difference Calculator</a></li>
      <li><a href="/converter/time-converter/">Time Converter</a></li>
      <li><a href="/developer-tools/json-validator/">JSON Validator</a></li>
      <li><a href="/date-time/">All Date & Time Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const modeEl = document.getElementById("utc_mode");
  const tzEl = document.getElementById("utc_tz");

  const tsBlock = document.getElementById("utc_ts_block");
  const tsEl = document.getElementById("utc_ts");
  const autoEl = document.getElementById("utc_auto");
  const unitEl = document.getElementById("utc_unit");

  const dateBlock = document.getElementById("utc_date_block");
  const dateEl = document.getElementById("utc_date");
  const timeEl = document.getElementById("utc_time");
  const outUnitEl = document.getElementById("utc_out_unit");

  const calcBtn = document.getElementById("utc_calc");
  const nowBtn = document.getElementById("utc_now");
  const clearBtn = document.getElementById("utc_clear");

  const errEl = document.getElementById("utc_error");
  const resEl = document.getElementById("utc_result");
  const cardsEl = document.getElementById("utc_cards");
  const tbodyEl = document.getElementById("utc_table");

  if (!modeEl || !tzEl || !tsBlock || !tsEl || !autoEl || !unitEl || !dateBlock || !dateEl || !timeEl || !outUnitEl || !calcBtn || !nowBtn || !clearBtn || !errEl || !resEl || !cardsEl || !tbodyEl) return;

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function badge(text, kind) {
    const border = kind === "warn"
      ? "rgba(251,146,60,0.55)"
      : kind === "good"
      ? "rgba(34,197,94,0.55)"
      : "rgba(255,255,255,0.2)";
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid ${border}; font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setModeUI() {
    const m = String(modeEl.value);
    if (m === "ts_to_date") {
      tsBlock.style.display = "";
      dateBlock.style.display = "none";
      tsEl.setAttribute("aria-required", "true");
      dateEl.removeAttribute("aria-required");
    } else {
      tsBlock.style.display = "none";
      dateBlock.style.display = "";
      dateEl.setAttribute("aria-required", "true");
      tsEl.removeAttribute("aria-required");
    }
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
    clearError();
    resEl.textContent = "Result will appear here.";
  }

  function normalizeDigits(s) {
    return String(s || "").trim().replace(/[,\s]/g, "");
  }

  function detectUnit(tsDigits) {
    const len = tsDigits.length;
    if (len >= 13) return "ms";
    if (len <= 10) return "s";
    return len >= 12 ? "ms" : "s";
  }

  function parseTimestamp() {
    const raw = normalizeDigits(tsEl.value);
    if (!raw) return { ok: false, msg: "Please enter a Unix timestamp." };

    const isNeg = raw.startsWith("-");
    const digits = isNeg ? raw.slice(1) : raw;

    if (!/^\d+$/.test(digits)) {
      return { ok: false, msg: "Timestamp must contain only digits, optionally with a leading minus sign." };
    }

    if (digits.length > 16) {
      return { ok: false, msg: "Timestamp is too long for reliable conversion in the browser." };
    }

    let unit = String(unitEl.value);
    const auto = !!autoEl.checked;
    if (unit === "auto" || auto) unit = detectUnit(digits);

    const n = Number(raw);
    if (!Number.isFinite(n)) return { ok: false, msg: "Timestamp is not a valid number." };

    const ms = unit === "ms" ? n : (n * 1000);
    if (!Number.isFinite(ms)) return { ok: false, msg: "Timestamp is out of range." };

    return { ok: true, ms, unit };
  }

  function pad2(x) {
    return String(x).padStart(2, "0");
  }

  function formatLocal(d) {
    const yyyy = d.getFullYear();
    const mm = pad2(d.getMonth() + 1);
    const dd = pad2(d.getDate());
    const hh = pad2(d.getHours());
    const mi = pad2(d.getMinutes());
    const ss = pad2(d.getSeconds());
    return `${yyyy}-${mm}-${dd} ${hh}:${mi}:${ss}`;
  }

  function formatUTC(d) {
    const yyyy = d.getUTCFullYear();
    const mm = pad2(d.getUTCMonth() + 1);
    const dd = pad2(d.getUTCDate());
    const hh = pad2(d.getUTCHours());
    const mi = pad2(d.getUTCMinutes());
    const ss = pad2(d.getUTCSeconds());
    return `${yyyy}-${mm}-${dd} ${hh}:${mi}:${ss} UTC`;
  }

  function isoUTC(d) {
    return d.toISOString();
  }

  function buildRow(k, v) {
    const tr = document.createElement("tr");
    const td1 = document.createElement("td");
    const td2 = document.createElement("td");
    td1.textContent = k;
    td2.textContent = v;
    tr.appendChild(td1);
    tr.appendChild(td2);
    tbodyEl.appendChild(tr);
  }

  function tsToDate() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const parsed = parseTimestamp();
    if (!parsed.ok) {
      showError(parsed.msg);
      resEl.textContent = "Result will appear here.";
      return;
    }

    const tz = String(tzEl.value);
    const d = new Date(parsed.ms);
    if (Number.isNaN(d.getTime())) {
      showError("Timestamp could not be converted to a valid date.");
      resEl.textContent = "Result will appear here.";
      return;
    }

    const shown = tz === "utc" ? formatUTC(d) : formatLocal(d);

    const ms = Math.trunc(parsed.ms);
    const s = Math.trunc(parsed.ms / 1000);

    resEl.innerHTML =
      "<strong>Date/Time:</strong> " + shown + "<br/>" +
      "<span class='note'>ISO (UTC): " + isoUTC(d) + "</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge("Input: " + parsed.unit, "neutral")}
        ${badge("Display: " + (tz === "utc" ? "UTC" : "Local"), "neutral")}
        ${badge("Converted", "good")}
      </div>
    `;

    buildRow("Input timestamp", normalizeDigits(tsEl.value));
    buildRow("Interpreted as", parsed.unit === "ms" ? "milliseconds" : "seconds");
    buildRow("Unix seconds", String(s));
    buildRow("Unix milliseconds", String(ms));
    buildRow("Displayed", shown);
    buildRow("ISO (UTC)", isoUTC(d));
  }

  function parseDateTime() {
    const tz = String(tzEl.value);
    const dStr = String(dateEl.value || "").trim();
    if (!dStr) return { ok: false, msg: "Please choose a date." };

    const tStr = String(timeEl.value || "").trim();
    const parts = tStr ? tStr.split(":") : ["0", "0", "0"];

    const hh = parseInt(parts[0] || "0", 10);
    const mi = parseInt(parts[1] || "0", 10);
    const ss = parseInt(parts[2] || "0", 10);

    if (![hh, mi, ss].every(Number.isFinite)) return { ok: false, msg: "Time is invalid." };
    if (hh < 0 || hh > 23 || mi < 0 || mi > 59 || ss < 0 || ss > 59) return { ok: false, msg: "Time must be within 00:00:00 to 23:59:59." };

    const [Y, M, D] = dStr.split("-").map((x) => parseInt(x, 10));
    if (![Y, M, D].every(Number.isFinite)) return { ok: false, msg: "Date is invalid." };

    let dt;
    if (tz === "utc") {
      dt = new Date(Date.UTC(Y, (M - 1), D, hh, mi, ss, 0));
    } else {
      dt = new Date(Y, (M - 1), D, hh, mi, ss, 0);
    }

    if (Number.isNaN(dt.getTime())) return { ok: false, msg: "Date/time could not be converted." };

    return { ok: true, dt, tz };
  }

  function dateToTs() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const parsed = parseDateTime();
    if (!parsed.ok) {
      showError(parsed.msg);
      resEl.textContent = "Result will appear here.";
      return;
    }

    const outUnit = String(outUnitEl.value);
    const ms = Math.trunc(parsed.dt.getTime());
    const s = Math.trunc(ms / 1000);

    const outVal = outUnit === "ms" ? ms : s;

    resEl.innerHTML =
      "<strong>Unix timestamp:</strong> " + String(outVal) + "<br/>" +
      "<span class='note'>Also: " + (outUnit === "ms" ? (s + " seconds") : (ms + " milliseconds")) + "</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge("Input: " + (parsed.tz === "utc" ? "UTC" : "Local"), "neutral")}
        ${badge("Output: " + (outUnit === "ms" ? "milliseconds" : "seconds"), "neutral")}
        ${badge("Converted", "good")}
      </div>
    `;

    const shown = parsed.tz === "utc" ? formatUTC(parsed.dt) : formatLocal(parsed.dt);

    buildRow("Input date/time", shown);
    buildRow("Unix seconds", String(s));
    buildRow("Unix milliseconds", String(ms));
    buildRow("ISO (UTC)", isoUTC(parsed.dt));
    buildRow("Output", String(outVal) + (outUnit === "ms" ? " (ms)" : " (s)"));
  }

  function compute() {
    const m = String(modeEl.value);
    if (m === "ts_to_date") tsToDate();
    else dateToTs();
  }

  function useNow() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const now = new Date();
    const tz = String(tzEl.value);

    if (String(modeEl.value) === "ts_to_date") {
      tsEl.value = String(now.getTime());
      unitEl.value = "ms";
      autoEl.checked = false;
      unitEl.disabled = false;
      compute();
      return;
    }

    let yyyy;
    let mm;
    let dd;
    let hh;
    let mi;
    let ss;

    if (tz === "utc") {
      yyyy = now.getUTCFullYear();
      mm = now.getUTCMonth() + 1;
      dd = now.getUTCDate();
      hh = now.getUTCHours();
      mi = now.getUTCMinutes();
      ss = now.getUTCSeconds();
    } else {
      yyyy = now.getFullYear();
      mm = now.getMonth() + 1;
      dd = now.getDate();
      hh = now.getHours();
      mi = now.getMinutes();
      ss = now.getSeconds();
    }

    dateEl.value = `${yyyy}-${pad2(mm)}-${pad2(dd)}`;
    timeEl.value = `${pad2(hh)}:${pad2(mi)}:${pad2(ss)}`;
    compute();
  }

  function reset() {
    clearError();
    tsEl.value = "";
    autoEl.checked = true;
    unitEl.value = "auto";
    unitEl.disabled = true;

    dateEl.value = "";
    timeEl.value = "";
    outUnitEl.value = "s";

    resEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  modeEl.addEventListener("change", setModeUI);

  tzEl.addEventListener("change", function () {
    const m = String(modeEl.value);
    if (m === "ts_to_date" && String(tsEl.value || "").trim()) compute();
    if (m === "date_to_ts" && String(dateEl.value || "").trim()) compute();
  });

  autoEl.addEventListener("change", function () {
    unitEl.disabled = !!autoEl.checked;
    unitEl.value = autoEl.checked ? "auto" : unitEl.value;
  });

  calcBtn.addEventListener("click", compute);
  nowBtn.addEventListener("click", useNow);
  clearBtn.addEventListener("click", reset);

  const keyHandler = function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  };

  tsEl.addEventListener("keydown", keyHandler);
  dateEl.addEventListener("keydown", keyHandler);
  timeEl.addEventListener("keydown", keyHandler);

  unitEl.disabled = !!autoEl.checked;
  setModeUI();
});
</script>