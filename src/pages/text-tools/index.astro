---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/text-tools/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort((a, b) => (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title));

const getTool = (href: string) => tools.find((tool) => tool.href === href);
const pickTools = (hrefs: string[]) => hrefs.map(getTool).filter((tool): tool is ToolMeta => !!tool);

const popularTools = pickTools([
  "/text-tools/word-frequency-analyzer/",
  "/text-tools/line-counter/",
  "/text-tools/remove-duplicate-lines/",
  "/text-tools/sort-lines/",
  "/text-tools/text-compare/",
  "/text-tools/text-diff-checker/",
  "/text-tools/reading-time-calculator/",
  "/text-tools/whitespace-remover/",
]);

const toolGroups = [
  {
    title: "Counting and analysis",
    description: "Measure text length, reading time, word usage, frequency, or other basic text properties.",
    tools: pickTools([
      "/utility/word-counter/",
      "/utility/character-counter/",
      "/text-tools/line-counter/",
      "/text-tools/sentence-counter/",
      "/text-tools/reading-time-calculator/",
      "/text-tools/word-frequency-analyzer/",
    ]),
  },
  {
    title: "Cleanup and formatting",
    description: "Clean spacing, remove duplicate lines, sort lines, or normalize text before using it elsewhere.",
    tools: pickTools([
      "/text-tools/remove-duplicate-lines/",
      "/text-tools/sort-lines/",
      "/text-tools/whitespace-remover/",
      "/text-tools/text-cleaner/",
      "/text-tools/case-converter-advanced/",
    ]),
  },
  {
    title: "Comparison and review",
    description: "Compare two blocks of text, inspect differences, or check whether copied content changed.",
    tools: pickTools([
      "/text-tools/text-compare/",
      "/text-tools/text-diff-checker/",
    ]),
  },
].filter((group) => group.tools.length);
---

<BaseLayout
  title="Text Tools — MinimalDev"
  description="Free text tools for cleanup, line counting, duplicate removal, sorting, comparison, word analysis, reading time, and text formatting."
  canonicalPath="/text-tools/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <h1 class="page-title" style="margin:0 0 8px;">Text Tools</h1>
      <p class="lead" style="margin:0 0 10px;">
        Work with text more efficiently using tools for cleanup, counting, sorting, comparison,
        formatting, and simple analysis. This category is useful for writing, development, editing,
        data preparation, and content review.
      </p>
      <p class="lead" style="margin:0;">
        Start with a task group if you are not sure which tool fits your situation, or use the full list
        when you already know the operation you need.
      </p>
    </section>

    {popularTools.length ? (
      <section class="section">
        <h2>Start with common text tools</h2>
        <div class="grid">
          {popularTools.map((t) => (
            <section class="card">
              <span class="badge">Popular text tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    {toolGroups.length ? (
      <section class="section">
        <h2>Text tools by task</h2>
        <div class="grid">
          {toolGroups.map((group) => (
            <section class="card">
              <h2>{group.title}</h2>
              <p>{group.description}</p>
              <ul>
                {group.tools.map((t) => (
                  <li><a href={t.href}>{t.title}</a></li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    <section class="section">
      <h2>What these tools are useful for</h2>
      <div class="grid">
        <section class="card">
          <h2>Text formatting and cleanup</h2>
          <p>
            Convert case styles, remove duplicates, normalize spacing,
            sort lines, and clean up text for documents, code, lists, or publishing.
          </p>
        </section>

        <section class="card">
          <h2>Comparison and analysis</h2>
          <p>
            Compare text differences, count words or characters,
            and measure properties such as reading time, sentence count, or line count.
          </p>
        </section>

        <section class="card">
          <h2>Data preparation</h2>
          <p>
            Prepare text for import, export, structured input, documentation,
            or workflows where consistent formatting is required.
          </p>
        </section>
      </div>
    </section>

    <section class="section">
      <h2>Browse all text tools</h2>
      <p class="lead" style="margin-top:0;">
        Search all available text tools below if you already know the operation you need.
      </p>

      <div class="tool-search" style="margin-bottom:16px;">
        <input
          id="toolSearch"
          type="search"
          placeholder="Search tools..."
          aria-label="Search text tools"
          style="
            width:100%;
            padding:10px 12px;
            border-radius:10px;
            border:1px solid rgba(0,0,0,0.15);
            font-size:14px;
            box-sizing:border-box;
          "
        />
      </div>

      {tools.length ? (
        <div class="grid" data-search-grid>
          {tools.map((t) => (
            <section class="card">
              <span class="badge">Text Tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      ) : (
        <p class="note">No tools found in this category yet.</p>
      )}
    </section>

    <section class="section">
      <h2>How to choose the right text tool</h2>
      <div class="card" style="padding:18px;">
        <p style="margin-top:0;">
          If your task is about cleaning or formatting text, choose a tool that modifies structure,
          such as duplicate removal, whitespace cleanup, sorting, or case conversion. If your task is about
          understanding text, use counting or analysis tools. For reviewing changes, use comparison tools.
        </p>
        <p style="margin-bottom:0;">
          Focused tools make results easier to check because each page handles one clear text operation.
        </p>
      </div>
    </section>
  </div>

  <script>
    const searchInput = document.getElementById("toolSearch") as HTMLInputElement | null;
    const grid = document.querySelector("[data-search-grid]");

    if (searchInput && grid) {
      const cards = Array.from(grid.querySelectorAll(".card")) as HTMLElement[];

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();

        cards.forEach((card) => {
          const text = card.textContent?.toLowerCase() || "";
          card.style.display = text.includes(query) ? "" : "none";
        });
      });
    }
  </script>
</BaseLayout>