---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Line Counter",
  description:
    "Count lines, empty lines, words, characters, and paragraphs in pasted text.",
  href: "/text-tools/line-counter/",
  order: 50,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/text-tools/line-counter/";

const faqs = [
  {
    q: "What does this line counter do?",
    a: "It counts total lines, non-empty lines, empty lines, words, characters, characters without spaces, and paragraphs.",
  },
  {
    q: "How are empty lines counted?",
    a: "A line is counted as empty when it contains no visible characters after trimming whitespace.",
  },
  {
    q: "How are paragraphs counted?",
    a: "Paragraphs are counted by splitting text blocks on one or more blank lines.",
  },
  {
    q: "Does character count include spaces?",
    a: "Yes. The total character count includes spaces and line breaks. The tool also shows a separate count without spaces.",
  },
  {
    q: "Can I use this for code or logs?",
    a: "Yes. It can count lines in plain text, code snippets, logs, CSV-like text, lists, and drafts.",
  },
  {
    q: "Is my text stored?",
    a: "No. Counting runs locally in your browser and your text is not sent to a server.",
  },
];

---

<ToolLayout
  title={`Line Counter — ${SITE_NAME}`}
  description="Count lines, non-empty lines, blank lines, words, characters, and paragraphs for text drafts, code snippets, logs, lists, and data cleanup."
  canonicalPath={CANONICAL_PATH}
  h1="Line Counter"
  intro="Count lines and related text metrics such as words, characters, empty lines, non-empty lines, and paragraphs. Useful for documents, code snippets, logs, lists, and text cleanup."
  faq={faqs}
  categoryName="Text Tools"
>
  <div slot="tool" data-tool="line-counter">
    <style is:inline>
      #lc_input {
        width: 100%;
        min-width: 0;
      }

      .lc-cards-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
        margin-top: 12px;
      }

      .lc-card {
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        padding: 12px;
        min-width: 0;
      }

      .lc-card strong {
        display: block;
      }

      .lc-card .big {
        font-size: 28px;
        font-weight: 900;
        margin-top: 6px;
      }

      @media (min-width: 760px) {
        .lc-cards-grid {
          grid-template-columns: 1fr 1fr 1fr;
        }
      }
    </style>

    <div class="privacy-note">
      <strong>Privacy First:</strong> This tool runs locally in your browser.
      <strong>Your input values are never sent to any server.</strong>
    </div>

    <div class="form" role="form" aria-describedby="lc_help">
      <div class="field">
        <label for="lc_input">Input text</label>
        <textarea id="lc_input" rows="14" spellcheck="false" placeholder="Paste or type text here..."></textarea>
      </div>

      <p class="note" id="lc_help" style="margin-top:6px;">
        Count lines in drafts, logs, code snippets, lists, CSV-like text, or any plain text block.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="lc_count">Count Text</button>
        <button class="btn secondary" type="button" id="lc_clear">Clear</button>
      </div>

      <div class="result" id="lc_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="lc_result" role="status" style="margin-top:12px;">Result will appear here.</div>

      <div id="lc_cards" class="lc-cards-grid" style="display:none;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="lc_tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div slot="how">
    <h2>How line counting works</h2>

    <p class="note">
      This tool treats line breaks as line separators, then calculates several related text metrics. It is useful when you need more than a simple character or word count.
    </p>

    <ul>
      <li><strong>Total lines:</strong> every line separated by a line break, including empty lines</li>
      <li><strong>Non-empty lines:</strong> lines that contain visible text after trimming whitespace</li>
      <li><strong>Empty lines:</strong> lines with no visible characters</li>
      <li><strong>Words:</strong> text groups separated by whitespace</li>
      <li><strong>Paragraphs:</strong> text blocks separated by one or more blank lines</li>
    </ul>

    <p class="note">
      For code or logs, total and non-empty line counts are usually the most useful. For writing drafts, words, paragraphs, and characters may be more useful.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Logs:</strong> count total and non-empty lines in copied log output</li>
      <li><strong>Code snippets:</strong> check how many lines a small function or pasted block contains</li>
      <li><strong>Lists:</strong> count one item per line after cleaning a list</li>
      <li><strong>Writing drafts:</strong> review words, characters, and paragraph count</li>
      <li><strong>Data cleanup:</strong> find whether blank lines are included in pasted text</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/text-tools/word-counter/">Word Counter</a></li>
      <li><a href="/text-tools/character-counter/">Character Counter</a></li>
      <li><a href="/text-tools/sentence-counter/">Sentence Counter</a></li>
      <li><a href="/text-tools/remove-duplicate-lines/">Remove Duplicate Lines</a></li>
      <li><a href="/text-tools/">All Text Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inputEl = document.getElementById("lc_input");
  const countBtn = document.getElementById("lc_count");
  const clearBtn = document.getElementById("lc_clear");
  const errEl = document.getElementById("lc_error");
  const resultEl = document.getElementById("lc_result");
  const cardsEl = document.getElementById("lc_cards");
  const tbodyEl = document.getElementById("lc_tbody");

  if (!inputEl || !countBtn || !clearBtn || !errEl || !resultEl || !cardsEl || !tbodyEl) return;

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function resetOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function card(title, value, note) {
    return (
      '<div class="lc-card">' +
        '<strong>' + escapeHtml(title) + '</strong>' +
        '<div class="big">' + escapeHtml(value) + '</div>' +
        '<div class="note" style="margin-top:4px;">' + escapeHtml(note) + '</div>' +
      '</div>'
    );
  }

  function countText() {
    resetOutput();

    const raw = String(inputEl.value || "");
    if (!raw) {
      showError("Please enter text to count.");
      return;
    }

    const lines = raw.split(/\r?\n/);
    const nonEmptyLines = lines.filter(function (line) {
      return line.trim() !== "";
    }).length;
    const emptyLines = lines.length - nonEmptyLines;
    const words = raw.trim() ? raw.trim().split(/\s+/).length : 0;
    const chars = raw.length;
    const charsNoSpaces = raw.replace(/\s/g, "").length;
    const paragraphs = raw.trim() ? raw.trim().split(/\n\s*\n/).filter(Boolean).length : 0;

    resultEl.innerHTML = "<strong>Text counted successfully.</strong>";
    cardsEl.style.display = "grid";
    cardsEl.innerHTML =
      card("Total lines", String(lines.length), "Includes empty lines.") +
      card("Words", String(words), "Split by whitespace.") +
      card("Characters", String(chars), "Includes spaces and line breaks.");

    fillTable([
      ["Total lines", String(lines.length)],
      ["Non-empty lines", String(nonEmptyLines)],
      ["Empty lines", String(emptyLines)],
      ["Words", String(words)],
      ["Characters (with spaces)", String(chars)],
      ["Characters (without spaces)", String(charsNoSpaces)],
      ["Paragraphs", String(paragraphs)],
    ]);
  }

  function clearAll() {
    inputEl.value = "";
    resetOutput();
    inputEl.focus();
  }

  countBtn.addEventListener("click", countText);
  clearBtn.addEventListener("click", clearAll);

  inputEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") countText();
  });
});
</script>