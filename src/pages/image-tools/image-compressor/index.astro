---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Image Compressor",
  description:
    "Compress images by adjusting quality. Preview size difference and download optimized image.",
  href: "/image-tools/image-compressor/",
  order: 2,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/image-tools/image-compressor/";

const faqs = [
  {
    q: "How does compression work?",
    a: "It reduces image quality to lower file size using browser-based encoding.",
  },
  {
    q: "Is the image uploaded?",
    a: "No. Everything runs locally in your browser.",
  },
  {
    q: "Does it support all formats?",
    a: "Most common formats like JPEG and PNG are supported.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Image Compressor — ${SITE_NAME}`}
  description="Compress images with adjustable quality and preview file size reduction."
  canonicalPath={CANONICAL_PATH}
  h1="Image Compressor"
  intro="Reduce image file size by adjusting quality. Preview results before downloading."
  faq={faqs}
  categoryName="Image Tools"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool">
    <style is:inline>
      canvas {
        max-width:100%;
        border-radius:10px;
      }
    </style>

    <div class="form">
      <input type="file" id="ic_file" accept="image/*"/>

      <label>Quality</label>
      <input type="range" id="ic_quality" min="0.1" max="1" step="0.1" value="0.8"/>
      <div id="ic_quality_val">0.8</div>

      <button class="btn" id="ic_compress">Compress</button>
      <button class="btn secondary" id="ic_download">Download</button>

      <div id="ic_info" class="result">Upload image to start.</div>

      <canvas id="ic_canvas"></canvas>
    </div>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", ()=>{

const fileInput = document.getElementById("ic_file");
const canvas = document.getElementById("ic_canvas");
const ctx = canvas.getContext("2d");
const qualityInput = document.getElementById("ic_quality");
const qualityVal = document.getElementById("ic_quality_val");
const info = document.getElementById("ic_info");

let img = new Image();
let originalSize = 0;

qualityInput.oninput = ()=>{
  qualityVal.textContent = qualityInput.value;
};

fileInput.onchange = e=>{
  const file = e.target.files[0];
  if(!file) return;

  originalSize = file.size;

  const reader = new FileReader();
  reader.onload = ev=>{
    img.onload = ()=>{
      canvas.width = img.width;
      canvas.height = img.height;
      ctx.drawImage(img,0,0);
    };
    img.src = ev.target.result;
  };
  reader.readAsDataURL(file);
};

document.getElementById("ic_compress").onclick = ()=>{
  const q = Number(qualityInput.value);

  if(!img.src){
    info.textContent = "Upload image first";
    return;
  }

  canvas.toBlob(blob=>{
    const newSize = blob.size;

    info.innerHTML =
      `Original: ${(originalSize/1024).toFixed(1)} KB<br>` +
      `Compressed: ${(newSize/1024).toFixed(1)} KB<br>` +
      `Reduction: ${((1 - newSize/originalSize)*100).toFixed(1)}%`;

  }, "image/jpeg", q);
};

document.getElementById("ic_download").onclick = ()=>{
  canvas.toBlob(blob=>{
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "compressed.jpg";
    a.click();
  }, "image/jpeg", Number(qualityInput.value));
};

});
</script>