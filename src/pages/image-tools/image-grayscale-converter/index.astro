---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Image Grayscale Converter",
  description:
    "Convert images to grayscale with adjustable intensity, preview, export options, result cards, and FAQ schema.",
  href: "/image-tools/image-grayscale-converter/",
  order: 140,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/image-tools/image-grayscale-converter/";

const faqs = [
  {
    q: "What does this grayscale converter do?",
    a: "It converts a color image into grayscale locally in your browser. You can also control how strongly the grayscale effect is applied.",
  },
  {
    q: "Can I keep some original color?",
    a: "Yes. The intensity slider lets you blend between the original image and a full grayscale result.",
  },
  {
    q: "Does this upload my image?",
    a: "No. Everything runs locally in your browser. Your image is not uploaded or stored.",
  },
  {
    q: "Which export formats are supported?",
    a: "You can export the processed image as PNG, JPEG, or WebP depending on browser support.",
  },
  {
    q: "Will transparency be preserved?",
    a: "Transparency is preserved in preview and PNG/WebP export. JPEG does not support transparency, so a background fill option is available.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Image Grayscale Converter — ${SITE_NAME}`}
  description="Convert an image to grayscale, blend effect intensity, preview before and after, and download the result. Includes FAQ schema and local processing."
  canonicalPath={CANONICAL_PATH}
  h1="Image Grayscale Converter"
  intro="Upload an image and convert it to grayscale with adjustable intensity. This tool is useful for design mockups, monochrome previews, print preparation, documentation images, and quick visual edits."
  faq={faqs}
  categoryName="Image Tools"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="image-grayscale-converter">
    <style is:inline>
      #igc_file,
      #igc_intensity,
      #igc_quality,
      #igc_format {
        width: 100%;
        min-width: 0;
      }
      .igc-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .igc-grid > * {
        min-width: 0;
      }
      .igc-preview-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        margin-top: 14px;
      }
      .igc-preview-card {
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 14px;
        padding: 12px;
        min-width: 0;
        overflow: hidden;
      }
      .igc-preview-card canvas {
        display: block;
        width: 100%;
        height: auto;
        max-width: 100%;
        border-radius: 10px;
        background: rgba(255,255,255,0.03);
      }
      .igc-metrics {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
      }
      .igc-metric {
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 12px;
        padding: 12px;
        min-width: 0;
      }
      .igc-big {
        font-size: 26px;
        font-weight: 900;
        margin-top: 6px;
        line-height: 1.1;
        word-break: break-word;
      }
      .igc-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      @media (min-width: 920px) {
        .igc-grid {
          grid-template-columns: repeat(3, 1fr);
        }
        .igc-preview-grid {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>

    <div class="form" role="form" aria-describedby="igc_help igc_privacy">
      <div class="field">
        <label for="igc_file">Image file</label>
        <input id="igc_file" type="file" accept="image/*" />
      </div>

      <div class="igc-grid">
        <div class="field">
          <label for="igc_intensity">Grayscale intensity</label>
          <input id="igc_intensity" type="range" min="0" max="100" step="1" value="100" />
          <p class="note" id="igc_intensity_note" style="margin-top:6px;">Current intensity: 100%</p>
        </div>

        <div class="field">
          <label for="igc_format">Output format</label>
          <select id="igc_format">
            <option value="image/png">PNG</option>
            <option value="image/jpeg" selected>JPEG</option>
            <option value="image/webp">WebP</option>
          </select>
        </div>

        <div class="field">
          <label for="igc_quality">Export quality (JPEG/WebP)</label>
          <input id="igc_quality" type="range" min="0.1" max="1" step="0.05" value="0.9" />
          <p class="note" id="igc_quality_note" style="margin-top:6px;">Current quality: 0.90</p>
        </div>
      </div>

      <div class="igc-row">
        <label>
          <input id="igc_live" type="checkbox" checked />
          Update preview automatically
        </label>
        <label>
          <input id="igc_fill_bg" type="checkbox" checked />
          Fill transparent background when exporting JPEG
        </label>
      </div>

      <p class="note" id="igc_help" style="margin-top:6px;">
        0% keeps the original image. 100% produces a full grayscale version. Intermediate values blend between the two.
      </p>

      <div class="igc-row">
        <button class="btn" type="button" id="igc_apply">Apply Grayscale</button>
        <button class="btn secondary" type="button" id="igc_download">Download Result</button>
        <button class="btn secondary" type="button" id="igc_reset">Reset Controls</button>
        <button class="btn secondary" type="button" id="igc_clear">Clear</button>
      </div>

      <div class="result" id="igc_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="igc_result" role="status" style="margin-top:12px;">Processed image details will appear here.</div>
      <div class="result" id="igc_cards" style="display:none; margin-top:12px;"></div>

      <div class="igc-preview-grid">
        <div class="igc-preview-card">
          <strong>Original preview</strong>
          <canvas id="igc_original_canvas" aria-label="Original uploaded image preview"></canvas>
        </div>
        <div class="igc-preview-card">
          <strong>Grayscale preview</strong>
          <canvas id="igc_output_canvas" aria-label="Grayscale converted image preview"></canvas>
        </div>
      </div>

      <p class="note" id="igc_privacy" style="margin-top:10px;">
        Privacy: grayscale conversion runs locally in your browser. No image file is uploaded, transmitted, or stored.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This tool reads the image into a browser canvas, calculates grayscale luminance from the original red, green, and blue values,
      and then blends the grayscale result with the original image based on the selected intensity.
    </p>
    <ul>
      <li><strong>0% intensity:</strong> original image, no grayscale effect</li>
      <li><strong>50% intensity:</strong> partial desaturation and muted color look</li>
      <li><strong>100% intensity:</strong> full grayscale output</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li>Create monochrome previews for UI or print layouts</li>
      <li>Remove color distraction from documentation screenshots</li>
      <li>Prepare images for black-and-white design mockups</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/image-tools/image-brightness-adjuster/">Image Brightness Adjuster</a></li>
      <li><a href="/image-tools/image-contrast-adjuster/">Image Contrast Adjuster</a></li>
      <li><a href="/image-tools/image-blur/">Image Blur</a></li>
      <li><a href="/image-tools/image-sharpen/">Image Sharpen</a></li>
      <li><a href="/image-tools/">All Image Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const fileEl = document.getElementById("igc_file");
  const intensityEl = document.getElementById("igc_intensity");
  const intensityNoteEl = document.getElementById("igc_intensity_note");
  const qualityEl = document.getElementById("igc_quality");
  const qualityNoteEl = document.getElementById("igc_quality_note");
  const formatEl = document.getElementById("igc_format");
  const liveEl = document.getElementById("igc_live");
  const fillBgEl = document.getElementById("igc_fill_bg");

  const applyBtn = document.getElementById("igc_apply");
  const downloadBtn = document.getElementById("igc_download");
  const resetBtn = document.getElementById("igc_reset");
  const clearBtn = document.getElementById("igc_clear");

  const errorEl = document.getElementById("igc_error");
  const resultEl = document.getElementById("igc_result");
  const cardsEl = document.getElementById("igc_cards");

  const originalCanvas = document.getElementById("igc_original_canvas");
  const outputCanvas = document.getElementById("igc_output_canvas");
  const originalCtx = originalCanvas.getContext("2d");
  const outputCtx = outputCanvas.getContext("2d");

  if (
    !fileEl || !intensityEl || !intensityNoteEl || !qualityEl || !qualityNoteEl ||
    !formatEl || !liveEl || !fillBgEl || !applyBtn || !downloadBtn || !resetBtn || !clearBtn ||
    !errorEl || !resultEl || !cardsEl || !originalCanvas || !outputCanvas || !originalCtx || !outputCtx
  ) return;

  const sourceCanvas = document.createElement("canvas");
  const sourceCtx = sourceCanvas.getContext("2d");

  let currentImage = null;
  let currentFileName = "";
  let originalFileSize = 0;
  let lastBlob = null;
  let debounceTimer = null;

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function resetMessages() {
    clearError();
    resultEl.textContent = "Processed image details will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
  }

  function formatBytes(bytes) {
    const n = Number(bytes || 0);
    if (n < 1024) return n + " B";
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + " KB";
    return (n / (1024 * 1024)).toFixed(2) + " MB";
  }

  function badge(text, kind) {
    const border =
      kind === "good" ? "rgba(34,197,94,.55)" :
      kind === "warn" ? "rgba(251,146,60,.55)" :
      "rgba(255,255,255,.2)";
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid ' + border + ';font-size:12px;font-weight:900;">' + text + "</span>";
  }

  function metricCard(label, value, sub) {
    return (
      '<div class="igc-metric">' +
        "<strong>" + label + "</strong>" +
        '<div class="igc-big">' + value + "</div>" +
        '<div class="note" style="margin-top:4px;">' + sub + "</div>" +
      "</div>"
    );
  }

  function updateControlLabels() {
    intensityNoteEl.textContent = "Current intensity: " + String(intensityEl.value) + "%";
    qualityNoteEl.textContent = "Current quality: " + Number(qualityEl.value || 0.9).toFixed(2);
  }

  function clamp(v) {
    return Math.max(0, Math.min(255, v));
  }

  function loadImage(file) {
    return new Promise(function (resolve, reject) {
      const reader = new FileReader();
      reader.onload = function (ev) {
        const img = new Image();
        img.onload = function () { resolve(img); };
        img.onerror = function () { reject(new Error("Could not decode the selected image.")); };
        img.src = String(ev.target.result || "");
      };
      reader.onerror = function () {
        reject(new Error("Could not read the selected file."));
      };
      reader.readAsDataURL(file);
    });
  }

  function drawOriginal() {
    if (!currentImage || !sourceCtx) return;
    const w = currentImage.naturalWidth || currentImage.width;
    const h = currentImage.naturalHeight || currentImage.height;

    sourceCanvas.width = w;
    sourceCanvas.height = h;
    originalCanvas.width = w;
    originalCanvas.height = h;

    sourceCtx.clearRect(0, 0, w, h);
    sourceCtx.drawImage(currentImage, 0, 0);

    originalCtx.clearRect(0, 0, w, h);
    originalCtx.drawImage(currentImage, 0, 0);
  }

  async function renderGrayscale() {
    clearError();

    if (!currentImage || !sourceCtx) {
      showError("Please choose an image file first.");
      return;
    }

    const w = sourceCanvas.width;
    const h = sourceCanvas.height;
    if (!w || !h) {
      showError("Source image is not ready yet.");
      return;
    }

    const intensity = Number(intensityEl.value || 0) / 100;
    const mime = String(formatEl.value || "image/jpeg");
    const quality = Number(qualityEl.value || 0.9);

    const srcData = sourceCtx.getImageData(0, 0, w, h);
    const data = srcData.data;

    for (let i = 0; i < data.length; i += 4) {
      const r = data[i];
      const g = data[i + 1];
      const b = data[i + 2];
      const gray = Math.round(0.299 * r + 0.587 * g + 0.114 * b);

      data[i] = clamp(r * (1 - intensity) + gray * intensity);
      data[i + 1] = clamp(g * (1 - intensity) + gray * intensity);
      data[i + 2] = clamp(b * (1 - intensity) + gray * intensity);
    }

    outputCanvas.width = w;
    outputCanvas.height = h;

    if (mime === "image/jpeg" && fillBgEl.checked) {
      outputCtx.fillStyle = "#FFFFFF";
      outputCtx.fillRect(0, 0, w, h);
    } else {
      outputCtx.clearRect(0, 0, w, h);
    }

    outputCtx.putImageData(srcData, 0, 0);

    resultEl.innerHTML =
      "<strong>Grayscale conversion applied.</strong>" +
      '<div class="note" style="margin-top:6px;">Compare the original and converted previews, then export the version you want.</div>';

    try {
      const blob = await new Promise(function (resolve, reject) {
        outputCanvas.toBlob(function (b) {
          if (!b) {
            reject(new Error("Could not encode the converted image."));
            return;
          }
          resolve(b);
        }, mime, quality);
      });

      lastBlob = blob;

      cardsEl.style.display = "block";
      cardsEl.innerHTML =
        '<div class="igc-metrics">' +
          metricCard("Intensity", Math.round(intensity * 100) + "%", "Grayscale blend amount") +
          metricCard("Output format", mime.replace("image/", "").toUpperCase(), "Selected export format") +
          metricCard("Original size", formatBytes(originalFileSize), "Uploaded file size") +
          metricCard("Output size", formatBytes(blob.size), "Current rendered file") +
        "</div>" +
        '<div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap;">' +
          badge(intensity === 1 ? "Full grayscale" : intensity === 0 ? "Original color" : "Partial grayscale", intensity > 0 ? "good" : "neutral") +
          badge(mime === "image/png" ? "Lossless container" : "Quality " + quality.toFixed(2), mime === "image/png" ? "neutral" : "good") +
        "</div>";
    } catch (err) {
      showError(err && err.message ? err.message : "Could not create the export file.");
    }
  }

  async function downloadResult() {
    clearError();

    if (!currentImage) {
      showError("Please upload an image first.");
      return;
    }

    if (!lastBlob) {
      await renderGrayscale();
      if (!lastBlob) return;
    }

    const ext = String(formatEl.value || "image/jpeg").replace("image/", "").replace("jpeg", "jpg");
    const base = (currentFileName || "image").replace(/\.[^.]+$/, "");
    const a = document.createElement("a");
    a.href = URL.createObjectURL(lastBlob);
    a.download = base + "-grayscale." + ext;
    a.click();
    URL.revokeObjectURL(a.href);
  }

  function scheduleRender() {
    updateControlLabels();
    if (!liveEl.checked || !currentImage) return;
    if (debounceTimer) window.clearTimeout(debounceTimer);
    debounceTimer = window.setTimeout(function () {
      renderGrayscale();
    }, 120);
  }

  function resetControls() {
    intensityEl.value = "100";
    qualityEl.value = "0.9";
    formatEl.value = "image/jpeg";
    liveEl.checked = true;
    fillBgEl.checked = true;
    updateControlLabels();
    if (currentImage) renderGrayscale();
    else resetMessages();
  }

  function clearAll() {
    fileEl.value = "";
    currentImage = null;
    currentFileName = "";
    originalFileSize = 0;
    lastBlob = null;
    sourceCanvas.width = 0;
    sourceCanvas.height = 0;
    originalCanvas.width = 0;
    originalCanvas.height = 0;
    outputCanvas.width = 0;
    outputCanvas.height = 0;

    intensityEl.value = "100";
    qualityEl.value = "0.9";
    formatEl.value = "image/jpeg";
    liveEl.checked = true;
    fillBgEl.checked = true;
    updateControlLabels();
    resetMessages();
    fileEl.focus();
  }

  fileEl.addEventListener("change", async function () {
    resetMessages();

    const file = fileEl.files && fileEl.files[0];
    if (!file) return;

    if (!file.type || !file.type.startsWith("image/")) {
      showError("Please select a valid image file.");
      return;
    }

    try {
      currentImage = await loadImage(file);
      currentFileName = file.name || "image";
      originalFileSize = Number(file.size || 0);
      drawOriginal();

      if (liveEl.checked) {
        renderGrayscale();
      } else {
        resultEl.innerHTML =
          "<strong>Image loaded.</strong>" +
          '<div class="note" style="margin-top:6px;">Adjust settings, then click “Apply Grayscale”.</div>';
      }
    } catch (err) {
      showError(err && err.message ? err.message : "Could not load the image.");
    }
  });

  intensityEl.addEventListener("input", scheduleRender);
  qualityEl.addEventListener("input", scheduleRender);
  formatEl.addEventListener("change", scheduleRender);
  liveEl.addEventListener("change", scheduleRender);
  fillBgEl.addEventListener("change", scheduleRender);

  applyBtn.addEventListener("click", renderGrayscale);
  downloadBtn.addEventListener("click", downloadResult);
  resetBtn.addEventListener("click", resetControls);
  clearBtn.addEventListener("click", clearAll);

  updateControlLabels();
});
</script>