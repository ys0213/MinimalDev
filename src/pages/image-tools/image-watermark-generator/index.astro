---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Image Watermark Generator",
  description:
    "Add text or image watermarks to images for labeling and ownership marks.",
  href: "/image-tools/image-watermark-generator/",
  order: 142,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/image-tools/image-watermark-generator/";

const faqs = [
  {
    q: "What does this watermark generator do?",
    a: "It adds a text overlay directly onto your image using canvas rendering. The watermark becomes part of the final exported image.",
  },
  {
    q: "How should I choose watermark opacity?",
    a: "Use low opacity (0.2–0.4) for subtle branding. Use higher opacity (0.5–0.8) when you need stronger copyright protection or proof images.",
  },
  {
    q: "Which position is best?",
    a: "Corner positions are less intrusive for normal use. Center placement is more visible and is commonly used for proof images or previews.",
  },
  {
    q: "Does this upload my image?",
    a: "No. All processing happens locally in your browser. No data is sent to any server.",
  },
  {
    q: "Will watermarking reduce image quality?",
    a: "The watermark itself does not reduce quality. However, exporting as JPEG or WebP may introduce compression depending on the selected quality setting.",
  },
  {
    q: "Which format should I export?",
    a: "Use PNG for lossless quality. Use JPEG or WebP for smaller file size with adjustable compression.",
  },
];

---

<ToolLayout
  title={`Image Watermark Generator — ${SITE_NAME}`}
  description="Create watermarked images by adding text or image overlays for drafts, previews, branding, and content labeling."
  canonicalPath={CANONICAL_PATH}
  h1="Image Watermark Generator"
  intro="Apply a customizable text watermark to your image. Control size, opacity, position, and export format with live preview."
  faq={faqs}
  categoryName="Image Tools"
>
  <div slot="tool" data-tool="image-watermark-generator">
    <style is:inline>
      #iwg_file,
      #iwg_text,
      #iwg_font_size,
      #iwg_opacity,
      #iwg_margin,
      #iwg_quality,
      #iwg_format,
      #iwg_color,
      #iwg_position,
      #iwg_font_weight {
        width: 100%;
        min-width: 0;
      }
      .iwg-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .iwg-grid > * {
        min-width: 0;
      }
      .iwg-preview-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        margin-top: 14px;
      }
      .iwg-preview-card {
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 14px;
        padding: 12px;
        min-width: 0;
        overflow: hidden;
      }
      .iwg-preview-card canvas {
        display: block;
        width: 100%;
        height: auto;
        max-width: 100%;
        border-radius: 10px;
        background: rgba(255,255,255,0.03);
      }
      .iwg-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
      }
      .iwg-card {
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 12px;
        padding: 12px;
      }
      .iwg-big {
        font-size: 26px;
        font-weight: 900;
        margin-top: 6px;
        line-height: 1.1;
        word-break: break-word;
      }
      .iwg-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      @media (min-width: 920px) {
        .iwg-grid {
          grid-template-columns: repeat(3, 1fr);
        }
        .iwg-preview-grid {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>

    <div class="form" role="form" aria-describedby="iwg_help iwg_privacy">
      <div class="field">
        <label for="iwg_file">Image file</label>
        <input id="iwg_file" type="file" accept="image/*" />
      </div>

      <div class="field">
        <label for="iwg_text">Watermark text</label>
        <input id="iwg_text" type="text" value="Sample Watermark" maxlength="120" placeholder="Enter watermark text" />
      </div>

      <div class="iwg-grid">
        <div class="field">
          <label for="iwg_font_size">Font size</label>
          <input id="iwg_font_size" type="range" min="10" max="120" step="1" value="32" />
          <p class="note" id="iwg_font_size_note" style="margin-top:6px;">Current size: 32 px</p>
        </div>

        <div class="field">
          <label for="iwg_opacity">Opacity</label>
          <input id="iwg_opacity" type="range" min="0.05" max="1" step="0.05" value="0.35" />
          <p class="note" id="iwg_opacity_note" style="margin-top:6px;">Current opacity: 0.35</p>
        </div>

        <div class="field">
          <label for="iwg_margin">Margin</label>
          <input id="iwg_margin" type="range" min="0" max="120" step="1" value="20" />
          <p class="note" id="iwg_margin_note" style="margin-top:6px;">Current margin: 20 px</p>
        </div>
      </div>

      <div class="iwg-grid">
        <div class="field">
          <label for="iwg_position">Position</label>
          <select id="iwg_position">
            <option value="top-left">Top left</option>
            <option value="top-right">Top right</option>
            <option value="center" selected>Center</option>
            <option value="bottom-left">Bottom left</option>
            <option value="bottom-right">Bottom right</option>
          </select>
        </div>

        <div class="field">
          <label for="iwg_font_weight">Font weight</label>
          <select id="iwg_font_weight">
            <option value="400">Regular</option>
            <option value="600" selected>Semi-bold</option>
            <option value="700">Bold</option>
            <option value="800">Extra bold</option>
          </select>
        </div>

        <div class="field">
          <label for="iwg_color">Text color</label>
          <input id="iwg_color" type="color" value="#FFFFFF" />
        </div>
      </div>

      <div class="iwg-grid">
        <div class="field">
          <label for="iwg_format">Output format</label>
          <select id="iwg_format">
            <option value="image/png">PNG</option>
            <option value="image/jpeg" selected>JPEG</option>
            <option value="image/webp">WebP</option>
          </select>
        </div>

        <div class="field">
          <label for="iwg_quality">Export quality (JPEG/WebP)</label>
          <input id="iwg_quality" type="range" min="0.1" max="1" step="0.05" value="0.9" />
          <p class="note" id="iwg_quality_note" style="margin-top:6px;">Current quality: 0.90</p>
        </div>

        <div class="field">
          <label>&nbsp;</label>
          <label>
            <input id="iwg_live" type="checkbox" checked />
            Update preview automatically
          </label>
        </div>
      </div>

      <p class="note" id="iwg_help" style="margin-top:6px;">
        Use a lighter opacity for subtle branding or copyright marks. Larger font sizes and margins work better on high-resolution images.
      </p>

      <div class="iwg-row">
        <button class="btn" type="button" id="iwg_apply">Apply Watermark</button>
        <button class="btn secondary" type="button" id="iwg_download">Download Result</button>
        <button class="btn secondary" type="button" id="iwg_reset">Reset Controls</button>
        <button class="btn secondary" type="button" id="iwg_clear">Clear</button>
      </div>

      <div class="result" id="iwg_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="iwg_result" role="status" style="margin-top:12px;">Watermarked image details will appear here.</div>
      <div class="result" id="iwg_cards" style="display:none; margin-top:12px;"></div>

      <div class="iwg-preview-grid">
        <div class="iwg-preview-card">
          <strong>Original preview</strong>
          <canvas id="iwg_original_canvas" aria-label="Original uploaded image preview"></canvas>
        </div>
        <div class="iwg-preview-card">
          <strong>Watermarked preview</strong>
          <canvas id="iwg_output_canvas" aria-label="Image preview with text watermark"></canvas>
        </div>
      </div>

      <p class="note" id="iwg_privacy" style="margin-top:10px;">
        Privacy: watermark generation runs locally in your browser. No image is uploaded, transmitted, or stored.
      </p>
    </div>

    <section class="section">
      <h2>Learn more about images</h2>
      <p class="note">
        Understanding formats and optimization helps you get better results when converting or editing images.
      </p>

      <ul>
        <li><a href="/guides/image-format-comparison/">PNG vs JPG vs WebP</a></li>
        <li><a href="/guides/reduce-image-size/">Reduce Image Size</a></li>
        <li><a href="/guides/why-use-webp/">Why WebP</a></li>
        <li><a href="/guides/image-optimization-for-web/">Image Optimization</a></li>
      </ul>
    </section>
  </div>

  <div slot="how">
    <p class="note">
      This tool applies a text watermark directly onto your image using browser-based canvas rendering. 
      The watermark is permanently embedded into the exported file.
    </p>

    <ul>
      <li><strong>Font size:</strong> Larger values increase visibility, especially on high-resolution images</li>
      <li><strong>Opacity:</strong> Controls transparency. Lower values are subtle, higher values are more visible</li>
      <li><strong>Position:</strong> Corner placement is cleaner, center placement is stronger for protection</li>
      <li><strong>Margin:</strong> Distance from edges. Useful for avoiding clipping</li>
      <li><strong>Result interpretation:</strong> Export size depends on format and compression quality</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Portfolio protection:</strong> Add a small bottom-right watermark to prevent unauthorized reuse</li>
      <li><strong>Client preview:</strong> Place a large semi-transparent center watermark for draft sharing</li>
      <li><strong>Branding:</strong> Add consistent corner watermark to social media images</li>
      <li><strong>Proof images:</strong> Use high opacity and center placement for temporary previews</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/image-tools/image-compressor/">Image Compressor</a></li>
      <li><a href="/image-tools/image-resizer/">Image Resizer</a></li>
      <li><a href="/image-tools/image-cropper/">Image Cropper</a></li>
      <li><a href="/image-tools/image-flip/">Image Flip</a></li>
      <li><a href="/image-tools/">All Image Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const fileEl = document.getElementById("iwg_file");
  const textEl = document.getElementById("iwg_text");
  const fontSizeEl = document.getElementById("iwg_font_size");
  const fontSizeNoteEl = document.getElementById("iwg_font_size_note");
  const opacityEl = document.getElementById("iwg_opacity");
  const opacityNoteEl = document.getElementById("iwg_opacity_note");
  const marginEl = document.getElementById("iwg_margin");
  const marginNoteEl = document.getElementById("iwg_margin_note");
  const positionEl = document.getElementById("iwg_position");
  const fontWeightEl = document.getElementById("iwg_font_weight");
  const colorEl = document.getElementById("iwg_color");
  const formatEl = document.getElementById("iwg_format");
  const qualityEl = document.getElementById("iwg_quality");
  const qualityNoteEl = document.getElementById("iwg_quality_note");
  const liveEl = document.getElementById("iwg_live");

  const applyBtn = document.getElementById("iwg_apply");
  const downloadBtn = document.getElementById("iwg_download");
  const resetBtn = document.getElementById("iwg_reset");
  const clearBtn = document.getElementById("iwg_clear");

  const errorEl = document.getElementById("iwg_error");
  const resultEl = document.getElementById("iwg_result");
  const cardsEl = document.getElementById("iwg_cards");

  const originalCanvas = document.getElementById("iwg_original_canvas");
  const outputCanvas = document.getElementById("iwg_output_canvas");
  const originalCtx = originalCanvas.getContext("2d");
  const outputCtx = outputCanvas.getContext("2d");

  if (
    !fileEl || !textEl || !fontSizeEl || !fontSizeNoteEl || !opacityEl || !opacityNoteEl ||
    !marginEl || !marginNoteEl || !positionEl || !fontWeightEl || !colorEl ||
    !formatEl || !qualityEl || !qualityNoteEl || !liveEl || !applyBtn || !downloadBtn ||
    !resetBtn || !clearBtn || !errorEl || !resultEl || !cardsEl ||
    !originalCanvas || !outputCanvas || !originalCtx || !outputCtx
  ) return;

  const sourceCanvas = document.createElement("canvas");
  const sourceCtx = sourceCanvas.getContext("2d");

  let currentImage = null;
  let currentFileName = "";
  let originalFileSize = 0;
  let lastBlob = null;
  let debounceTimer = null;

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function resetMessages() {
    clearError();
    resultEl.textContent = "Watermarked image details will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
  }

  function formatBytes(bytes) {
    const n = Number(bytes || 0);
    if (n < 1024) return n + " B";
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + " KB";
    return (n / (1024 * 1024)).toFixed(2) + " MB";
  }

  function badge(text, kind) {
    const border =
      kind === "good" ? "rgba(34,197,94,.55)" :
      kind === "warn" ? "rgba(251,146,60,.55)" :
      "rgba(255,255,255,.2)";
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid ' + border + ';font-size:12px;font-weight:900;">' + text + "</span>";
  }

  function metricCard(label, value, sub) {
    return (
      '<div class="iwg-card">' +
        "<strong>" + label + "</strong>" +
        '<div class="iwg-big">' + value + "</div>" +
        '<div class="note" style="margin-top:4px;">' + sub + "</div>" +
      "</div>"
    );
  }

  function updateControlLabels() {
    fontSizeNoteEl.textContent = "Current size: " + String(fontSizeEl.value) + " px";
    opacityNoteEl.textContent = "Current opacity: " + Number(opacityEl.value || 0.35).toFixed(2);
    marginNoteEl.textContent = "Current margin: " + String(marginEl.value) + " px";
    qualityNoteEl.textContent = "Current quality: " + Number(qualityEl.value || 0.9).toFixed(2);
  }

  function loadImage(file) {
    return new Promise(function (resolve, reject) {
      const reader = new FileReader();
      reader.onload = function (ev) {
        const img = new Image();
        img.onload = function () { resolve(img); };
        img.onerror = function () { reject(new Error("Could not decode the selected image.")); };
        img.src = String(ev.target.result || "");
      };
      reader.onerror = function () {
        reject(new Error("Could not read the selected file."));
      };
      reader.readAsDataURL(file);
    });
  }

  function drawOriginal() {
    if (!currentImage || !sourceCtx) return;
    const w = currentImage.naturalWidth || currentImage.width;
    const h = currentImage.naturalHeight || currentImage.height;

    sourceCanvas.width = w;
    sourceCanvas.height = h;
    originalCanvas.width = w;
    originalCanvas.height = h;

    sourceCtx.clearRect(0, 0, w, h);
    sourceCtx.drawImage(currentImage, 0, 0);

    originalCtx.clearRect(0, 0, w, h);
    originalCtx.drawImage(currentImage, 0, 0);
  }

  function getWatermarkPosition(ctx, canvasW, canvasH, text, fontSize, margin, position) {
    ctx.font = String(fontWeightEl.value || "600") + " " + fontSize + "px system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif";
    const metrics = ctx.measureText(text);
    const textW = metrics.width;
    const textH = fontSize;

    let x = margin;
    let y = margin + textH;

    if (position === "top-right") {
      x = canvasW - textW - margin;
      y = margin + textH;
    } else if (position === "center") {
      x = (canvasW - textW) / 2;
      y = (canvasH + textH) / 2;
    } else if (position === "bottom-left") {
      x = margin;
      y = canvasH - margin;
    } else if (position === "bottom-right") {
      x = canvasW - textW - margin;
      y = canvasH - margin;
    }

    return { x, y, textW, textH };
  }

  async function renderWatermark() {
    clearError();

    if (!currentImage || !sourceCtx) {
      showError("Please choose an image file first.");
      return;
    }

    const w = sourceCanvas.width;
    const h = sourceCanvas.height;
    if (!w || !h) {
      showError("Source image is not ready yet.");
      return;
    }

    const text = String(textEl.value || "").trim();
    if (!text) {
      showError("Please enter watermark text.");
      return;
    }

    const fontSize = Number(fontSizeEl.value || 32);
    const opacity = Number(opacityEl.value || 0.35);
    const margin = Number(marginEl.value || 20);
    const color = String(colorEl.value || "#FFFFFF");
    const position = String(positionEl.value || "center");
    const fontWeight = String(fontWeightEl.value || "600");
    const mime = String(formatEl.value || "image/jpeg");
    const quality = Number(qualityEl.value || 0.9);

    outputCanvas.width = w;
    outputCanvas.height = h;
    outputCtx.clearRect(0, 0, w, h);
    outputCtx.drawImage(sourceCanvas, 0, 0);

    outputCtx.save();
    outputCtx.globalAlpha = opacity;
    outputCtx.fillStyle = color;
    outputCtx.textBaseline = "alphabetic";
    outputCtx.font = fontWeight + " " + fontSize + "px system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif";

    const pos = getWatermarkPosition(outputCtx, w, h, text, fontSize, margin, position);
    outputCtx.fillText(text, pos.x, pos.y);
    outputCtx.restore();

    resultEl.innerHTML =
      "<strong>Watermark applied successfully.</strong>" +
      '<div class="note" style="margin-top:6px;">Preview the placement and export the watermarked image when ready.</div>';

    try {
      const blob = await new Promise(function (resolve, reject) {
        outputCanvas.toBlob(function (b) {
          if (!b) {
            reject(new Error("Could not encode the watermarked image."));
            return;
          }
          resolve(b);
        }, mime, quality);
      });

      lastBlob = blob;

      cardsEl.style.display = "block";
      cardsEl.innerHTML =
        '<div class="iwg-cards">' +
          metricCard("Text length", String(text.length), "Characters in watermark") +
          metricCard("Font size", fontSize + " px", "Current watermark text size") +
          metricCard("Opacity", opacity.toFixed(2), "Current transparency level") +
          metricCard("Output file", formatBytes(blob.size), "Current rendered output size") +
        "</div>" +
        '<div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap;">' +
          badge("Position: " + position.replace("-", " "), "good") +
          badge("Weight: " + fontWeight, "neutral") +
          badge(mime === "image/png" ? "Lossless container" : "Quality " + quality.toFixed(2), mime === "image/png" ? "neutral" : "good") +
        "</div>";
    } catch (err) {
      showError(err && err.message ? err.message : "Could not create the export file.");
    }
  }

  async function downloadResult() {
    clearError();

    if (!currentImage) {
      showError("Please upload an image first.");
      return;
    }

    if (!lastBlob) {
      await renderWatermark();
      if (!lastBlob) return;
    }

    const ext = String(formatEl.value || "image/jpeg").replace("image/", "").replace("jpeg", "jpg");
    const base = (currentFileName || "image").replace(/\.[^.]+$/, "");
    const a = document.createElement("a");
    a.href = URL.createObjectURL(lastBlob);
    a.download = base + "-watermarked." + ext;
    a.click();
    URL.revokeObjectURL(a.href);
  }

  function scheduleRender() {
    updateControlLabels();
    if (!liveEl.checked || !currentImage) return;
    if (debounceTimer) window.clearTimeout(debounceTimer);
    debounceTimer = window.setTimeout(function () {
      renderWatermark();
    }, 120);
  }

  function resetControls() {
    textEl.value = "Sample Watermark";
    fontSizeEl.value = "32";
    opacityEl.value = "0.35";
    marginEl.value = "20";
    positionEl.value = "center";
    fontWeightEl.value = "600";
    colorEl.value = "#FFFFFF";
    formatEl.value = "image/jpeg";
    qualityEl.value = "0.9";
    liveEl.checked = true;
    updateControlLabels();
    if (currentImage) renderWatermark();
    else resetMessages();
  }

  function clearAll() {
    fileEl.value = "";
    currentImage = null;
    currentFileName = "";
    originalFileSize = 0;
    lastBlob = null;
    sourceCanvas.width = 0;
    sourceCanvas.height = 0;
    originalCanvas.width = 0;
    originalCanvas.height = 0;
    outputCanvas.width = 0;
    outputCanvas.height = 0;

    textEl.value = "Sample Watermark";
    fontSizeEl.value = "32";
    opacityEl.value = "0.35";
    marginEl.value = "20";
    positionEl.value = "center";
    fontWeightEl.value = "600";
    colorEl.value = "#FFFFFF";
    formatEl.value = "image/jpeg";
    qualityEl.value = "0.9";
    liveEl.checked = true;

    updateControlLabels();
    resetMessages();
    fileEl.focus();
  }

  fileEl.addEventListener("change", async function () {
    resetMessages();

    const file = fileEl.files && fileEl.files[0];
    if (!file) return;

    if (!file.type || !file.type.startsWith("image/")) {
      showError("Please select a valid image file.");
      return;
    }

    try {
      currentImage = await loadImage(file);
      currentFileName = file.name || "image";
      originalFileSize = Number(file.size || 0);
      drawOriginal();

      if (liveEl.checked) {
        renderWatermark();
      } else {
        resultEl.innerHTML =
          "<strong>Image loaded.</strong>" +
          '<div class="note" style="margin-top:6px;">Adjust watermark settings, then click “Apply Watermark”.</div>';
      }
    } catch (err) {
      showError(err && err.message ? err.message : "Could not load the image.");
    }
  });

  textEl.addEventListener("input", scheduleRender);
  fontSizeEl.addEventListener("input", scheduleRender);
  opacityEl.addEventListener("input", scheduleRender);
  marginEl.addEventListener("input", scheduleRender);
  positionEl.addEventListener("change", scheduleRender);
  fontWeightEl.addEventListener("change", scheduleRender);
  colorEl.addEventListener("input", scheduleRender);
  formatEl.addEventListener("change", scheduleRender);
  qualityEl.addEventListener("input", scheduleRender);
  liveEl.addEventListener("change", scheduleRender);

  applyBtn.addEventListener("click", renderWatermark);
  downloadBtn.addEventListener("click", downloadResult);
  resetBtn.addEventListener("click", resetControls);
  clearBtn.addEventListener("click", clearAll);

  updateControlLabels();
});
</script>