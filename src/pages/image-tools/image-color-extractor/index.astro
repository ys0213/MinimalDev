---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Image Color Extractor",
  description: "Extract dominant colors with clustering, preview, and export options.",
  href: "/image-tools/image-color-extractor/",
};

const SITE_NAME="MinimalDev";
const CANONICAL_PATH="/image-tools/image-color-extractor/";

const faqs=[
 {q:"How are colors extracted?",a:"Colors are extracted by sampling pixels and grouping similar values to approximate dominant colors."},
 {q:"Is the result perfectly accurate?",a:"No. It is an approximation designed to represent visually dominant colors rather than exact color distribution."},
 {q:"What affects accuracy?",a:"Image size, compression, gradients, and color complexity can affect results."},
 {q:"Is upload required?",a:"No, everything runs locally in your browser."},
 {q:"How many colors should I extract?",a:"Use fewer colors (3–5) for simple palettes and more (6–12) for detailed images."}
];

const faqJsonLd={
 "@context":"https://schema.org",
 "@type":"FAQPage",
 mainEntity:faqs.map(f=>({
  "@type":"Question",
  name:f.q,
  acceptedAnswer:{ "@type":"Answer", text:f.a }
 }))
};
---

<ToolLayout
title={`Image Color Extractor — ${SITE_NAME}`}
description="Extract dominant colors from an image with palette preview and HEX export."
canonicalPath={CANONICAL_PATH}
h1="Image Color Extractor"
intro="Upload an image and extract its dominant colors. Preview the palette and copy HEX values for design, UI, or branding use."
faq={faqs}
categoryName="Image Tools"
>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<div slot="tool">
<style is:inline>
.grid{display:grid;gap:10px}
.palette{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:10px}
.card{border:1px solid rgba(255,255,255,.15);border-radius:12px;padding:10px;text-align:center}
.swatch{height:50px;border-radius:8px;margin-bottom:6px}
textarea{width:100%;min-height:80px}
canvas{max-width:100%}
</style>

<div class="form">

<input type="file" id="file" accept="image/*"/>

<label>Number of colors</label>
<input type="range" id="count" min="3" max="12" value="6"/>

<p class="note">
Lower values give a simpler palette. Higher values capture more detail but may include similar shades.
</p>

<canvas id="canvas"></canvas>

<div style="display:flex;gap:10px;flex-wrap:wrap;">
<button class="btn" id="extract">Extract</button>
<button class="btn secondary" id="copy">Copy HEX</button>
<button class="btn secondary" id="clear">Clear</button>
</div>

<div id="error" class="result" style="display:none;"></div>
<div id="summary" class="result"></div>

<div id="palette" class="palette"></div>

<textarea id="hexOutput" placeholder="HEX list"></textarea>

<p class="note" style="text-align: left;">
Tip: Use these colors for UI themes, branding palettes, or quick design references.
</p>

</div>

<section class="section" style="text-align:left;">
  <h2>Learn more about images</h2>
  <p class="note">
    Understanding formats and optimization helps you get better results when converting or editing images.
  </p>

  <ul>
    <li><a href="/guides/image-format-comparison/">PNG vs JPG vs WebP</a></li>
    <li><a href="/guides/reduce-image-size/">Reduce Image Size</a></li>
    <li><a href="/guides/why-use-webp/">Why WebP</a></li>
    <li><a href="/guides/image-optimization-for-web/">Image Optimization</a></li>
  </ul>
</section>
</div>

<div slot="how">
<p class="note">
This tool samples pixels from the image and groups similar RGB values to identify dominant colors.
Instead of analyzing every pixel, it skips pixels at intervals to improve performance.
</p>

<ul>
<li><strong>Sampling:</strong> reduces processing time by skipping pixels</li>
<li><strong>Grouping:</strong> similar colors are clustered together</li>
<li><strong>Sorting:</strong> most frequent colors are selected</li>
<li><strong>Result interpretation:</strong> extracted colors represent visual dominance, not exact percentages</li>
</ul>

<p class="note">
Images with gradients or noise may produce similar shades. Reducing the color count can create a cleaner palette.
</p>
</div>

<div slot="examples">
<ul>
<li><strong>UI design:</strong> extract main colors from a screenshot to build a consistent theme</li>
<li><strong>Brand analysis:</strong> identify dominant colors from logos or marketing images</li>
<li><strong>Photography:</strong> generate a palette from a photo for color grading reference</li>
<li><strong>Inspiration:</strong> quickly explore color combinations from real-world images</li>
</ul>
</div>

<div slot="related">
<ul>
<li><a href="/image-tools/image-palette-generator/">Palette Generator</a></li>
<li><a href="/image-tools/image-color-extractor/">Image Color Extractor</a></li>
<li><a href="/image-tools/image-compressor/">Image Compressor</a></li>
<li><a href="/image-tools/">All Image Tools</a></li>
</ul>
</div>

</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded",()=>{

const file=document.getElementById("file");
const canvas=document.getElementById("canvas");
const ctx=canvas.getContext("2d");
const paletteDiv=document.getElementById("palette");
const hexOutput=document.getElementById("hexOutput");
const error=document.getElementById("error");
const summary=document.getElementById("summary");

let img=new Image();

function showError(msg){
 error.style.display="block";
 error.textContent=msg;
}
function clearError(){error.style.display="none"}

file.onchange=e=>{
 clearError();
 const f=e.target.files[0];
 if(!f || !f.type.startsWith("image/")){
   showError("Invalid image");
   return;
 }
 const r=new FileReader();
 r.onload=ev=>{
   img.onload=()=>{
     canvas.width=img.width;
     canvas.height=img.height;
     ctx.drawImage(img,0,0);
     summary.textContent="Image loaded. Click extract to generate palette.";
   };
   img.src=ev.target.result;
 };
 r.readAsDataURL(f);
};

function rgbToHex(r,g,b){
 return "#"+[r,g,b].map(v=>Number(v).toString(16).padStart(2,"0")).join("");
}

document.getElementById("extract").onclick=()=>{
 clearError();
 if(!canvas.width){showError("Upload image first");return;}

 const data=ctx.getImageData(0,0,canvas.width,canvas.height).data;
 const map={};

 for(let i=0;i<data.length;i+=32){
   const key=`${data[i]},${data[i+1]},${data[i+2]}`;
   map[key]=(map[key]||0)+1;
 }

 const count=document.getElementById("count").value;
 const sorted=Object.entries(map).sort((a,b)=>b[1]-a[1]).slice(0,count);

 paletteDiv.innerHTML="";
 let hexList=[];

 sorted.forEach(([rgb])=>{
   const [r,g,b]=rgb.split(",");
   const hex=rgbToHex(r,g,b);
   hexList.push(hex);

   const div=document.createElement("div");
   div.className="card";
   div.innerHTML=`
     <div class="swatch" style="background:${hex}"></div>
     <strong>${hex}</strong>
   `;
   paletteDiv.appendChild(div);
 });

 hexOutput.value=hexList.join(", ");
 summary.innerHTML=`Extracted ${hexList.length} dominant colors.`;

};

document.getElementById("copy").onclick=async()=>{
 if(!hexOutput.value)return;
 await navigator.clipboard.writeText(hexOutput.value);
 summary.innerHTML="<strong>HEX values copied</strong>";
};

document.getElementById("clear").onclick=()=>{
 paletteDiv.innerHTML="";
 hexOutput.value="";
 summary.textContent="";
 canvas.width=0;
};

});
</script>