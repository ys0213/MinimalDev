---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/image-tools/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort((a, b) => (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title));
---

<BaseLayout
  title="Image Tools — MinimalDev"
  description="Free online image tools including resizer, compressor, cropper, converter, and metadata utilities. Works locally in your browser."
  canonicalPath="/image-tools/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <h1 class="page-title" style="margin:0 0 8px;">Image Tools</h1>

      <p class="lead" style="margin:0 0 10px;">
        This category provides browser-based tools for common image editing and processing tasks
        such as resizing, compression, cropping, format conversion, and metadata handling.
      </p>

      <p class="lead" style="margin:0;">
        These tools are designed for quick adjustments and simple workflows where opening a full
        image editor is unnecessary. You can make changes directly in your browser with immediate results.
      </p>
    </section>

    <section class="section">
      <h2>What these tools are useful for</h2>
      <div class="grid">
        <section class="card">
          <h2>Quick editing tasks</h2>
          <p>
            Resize, crop, or convert images when preparing assets for websites, apps,
            documents, or sharing platforms.
          </p>
        </section>

        <section class="card">
          <h2>File size optimization</h2>
          <p>
            Compression tools help reduce file size for faster loading,
            smaller uploads, and better performance in web environments.
          </p>
        </section>

        <section class="card">
          <h2>Format and metadata handling</h2>
          <p>
            Convert between formats or remove metadata such as EXIF data
            when you need cleaner files or better compatibility.
          </p>
        </section>
      </div>
    </section>

    <section class="section">
      <h2>Browse image tools</h2>
      <p class="lead" style="margin-top:0;">
        Search the available tools below if you already know the type of image task you want to perform.
      </p>

      <div class="tool-search" style="margin-bottom:16px;">
        <input
          id="toolSearch"
          type="search"
          placeholder="Search image tools..."
          aria-label="Search image tools"
          style="
            width:100%;
            padding:10px 12px;
            border-radius:10px;
            border:1px solid rgba(0,0,0,0.15);
            font-size:14px;
            box-sizing:border-box;
          "
        />
      </div>

      {tools.length ? (
        <div class="grid" data-search-grid>
          {tools.map((t) => (
            <section class="card">
              <span class="badge">Tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      ) : (
        <p class="note">No image tools available yet.</p>
      )}
    </section>

    <section class="section">
      <h2>What you can do</h2>
      <ul>
        <li>Resize images to exact dimensions</li>
        <li>Compress images to reduce file size</li>
        <li>Crop and adjust images visually</li>
        <li>Convert between formats (PNG, JPG, WebP)</li>
        <li>Remove metadata (EXIF)</li>
      </ul>
    </section>

    <section class="section">
      <h2>Image Guides</h2>
      <p class="note">
        Learn how to choose the right format, reduce image size, and optimize images for better performance.
      </p>

      <ul>
        <li><a href="/guides/image-format-comparison/">PNG vs JPG vs WebP</a></li>
        <li><a href="/guides/reduce-image-size/">How to Reduce Image Size</a></li>
        <li><a href="/guides/why-use-webp/">Why Use WebP</a></li>
        <li><a href="/guides/jpg-vs-png/">JPG vs PNG</a></li>
        <li><a href="/guides/convert-image-without-losing-quality/">Convert Without Losing Quality</a></li>
        <li><a href="/guides/online-vs-offline-image-tools/">Online vs Offline Tools</a></li>
        <li><a href="/guides/image-resize-guide/">Image Resize Guide</a></li>
        <li><a href="/guides/how-to-crop-image/">How to Crop Images</a></li>
        <li><a href="/guides/free-image-tools/">Free Image Tools</a></li>
        <li><a href="/guides/image-optimization-for-web/">Image Optimization for Web</a></li>
      </ul>
    </section>

    <section class="section">
      <h2>Privacy</h2>
      <p class="note">
        All tools run locally in your browser. No images are uploaded or stored.
      </p>
    </section>
  </div>
</BaseLayout>