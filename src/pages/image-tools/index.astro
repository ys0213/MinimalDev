---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/image-tools/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort((a, b) => (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title));

const getTool = (href: string) => tools.find((tool) => tool.href === href);
const pickTools = (hrefs: string[]) => hrefs.map(getTool).filter((tool): tool is ToolMeta => !!tool);

const popularTools = pickTools([
  "/image-tools/image-compressor/",
  "/image-tools/image-resizer/",
  "/image-tools/image-cropper/",
  "/image-tools/image-size-calculator/",
  "/image-tools/image-dpi-converter/",
  "/image-tools/image-to-base64/",
  "/image-tools/base64-to-image/",
  "/image-tools/jpg-to-webp/",
]);

const toolGroups = [
  {
    title: "Resize, crop, and optimize",
    description: "Prepare images for websites, apps, uploads, documents, or sharing by adjusting size and dimensions.",
    tools: pickTools([
      "/image-tools/image-resizer/",
      "/image-tools/image-cropper/",
      "/image-tools/image-compressor/",
      "/image-tools/image-size-calculator/",
      "/image-tools/image-aspect-ratio-calculator/",
    ]),
  },
  {
    title: "Format conversion",
    description: "Convert images between common formats when compatibility, file size, or publishing requirements matter.",
    tools: pickTools([
      "/image-tools/jpg-to-png/",
      "/image-tools/png-to-jpg/",
      "/image-tools/jpg-to-webp/",
      "/image-tools/webp-to-jpg/",
    ]),
  },
  {
    title: "Base64 and metadata",
    description: "Use these tools for embedded image data, image metadata, privacy cleanup, or technical inspection.",
    tools: pickTools([
      "/image-tools/image-to-base64/",
      "/image-tools/base64-to-image/",
      "/utility/exif-remover/",
      "/utility/image-metadata-viewer/",
    ]),
  },
].filter((group) => group.tools.length);
---

<BaseLayout
  title="Image Tools — MinimalDev"
  description="Free browser-based image tools for resizing, compression, cropping, format conversion, Base64 conversion, metadata checks, and image optimization."
  canonicalPath="/image-tools/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <h1 class="page-title" style="margin:0 0 8px;">Image Tools</h1>

      <p class="lead" style="margin:0 0 10px;">
        Edit, convert, inspect, and optimize images directly in your browser. This category includes tools
        for resizing, compression, cropping, format conversion, image size checks, Base64 conversion,
        and metadata-related tasks.
      </p>

      <p class="lead" style="margin:0;">
        Start with a task group if you are preparing images for a website, app, document, upload,
        or technical workflow.
      </p>
    </section>

    {popularTools.length ? (
      <section class="section">
        <h2>Start with common image tools</h2>
        <div class="grid">
          {popularTools.map((t) => (
            <section class="card">
              <span class="badge">Popular image tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    {toolGroups.length ? (
      <section class="section">
        <h2>Image tools by task</h2>
        <div class="grid">
          {toolGroups.map((group) => (
            <section class="card">
              <h2>{group.title}</h2>
              <p>{group.description}</p>
              <ul>
                {group.tools.map((t) => (
                  <li><a href={t.href}>{t.title}</a></li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    <section class="section">
      <h2>Browse all image tools</h2>
      <p class="lead" style="margin-top:0;">
        Search all available image tools below if you already know the exact image task you want to perform.
      </p>

      <div class="tool-search" style="margin-bottom:16px;">
        <input
          id="toolSearch"
          type="search"
          placeholder="Search image tools..."
          aria-label="Search image tools"
          style="
            width:100%;
            padding:10px 12px;
            border-radius:10px;
            border:1px solid rgba(0,0,0,0.15);
            font-size:14px;
            box-sizing:border-box;
          "
        />
      </div>

      {tools.length ? (
        <div class="grid" data-search-grid>
          {tools.map((t) => (
            <section class="card">
              <span class="badge">Image Tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      ) : (
        <p class="note">No image tools available yet.</p>
      )}
    </section>

    <section class="section">
      <h2>Image guides</h2>
      <p class="note">
        These guides explain common image decisions such as format choice, image size reduction,
        WebP usage, cropping, and web optimization.
      </p>

      <ul>
        <li><a href="/guides/image-format-comparison/">PNG vs JPG vs WebP</a></li>
        <li><a href="/guides/reduce-image-size/">How to Reduce Image Size</a></li>
        <li><a href="/guides/why-use-webp/">Why Use WebP</a></li>
        <li><a href="/guides/jpg-vs-png/">JPG vs PNG</a></li>
        <li><a href="/guides/convert-image-without-losing-quality/">Convert Images With Minimal Quality Loss</a></li>
        <li><a href="/guides/online-vs-offline-image-tools/">Online vs Offline Image Tools</a></li>
        <li><a href="/guides/image-resize-guide/">Image Resize Guide</a></li>
        <li><a href="/guides/how-to-crop-image/">How to Crop Images</a></li>
        <li><a href="/guides/free-image-tools/">Free Image Tools</a></li>
        <li><a href="/guides/image-optimization-for-web/">Image Optimization for Web</a></li>
      </ul>
    </section>

    <section class="section">
      <h2>Privacy</h2>
      <p class="note">
        Image tools are designed to run locally in your browser when possible. For ordinary use,
        your selected images are processed in the browser and are not uploaded to MinimalDev servers.
      </p>
    </section>
  </div>

  <script>
    const searchInput = document.getElementById("toolSearch") as HTMLInputElement | null;
    const grid = document.querySelector("[data-search-grid]");

    if (searchInput && grid) {
      const cards = Array.from(grid.querySelectorAll(".card")) as HTMLElement[];

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();

        cards.forEach((card) => {
          const text = card.textContent?.toLowerCase() || "";
          card.style.display = text.includes(query) ? "" : "none";
        });
      });
    }
  </script>
</BaseLayout>