---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Image Contrast Adjuster",
  description:
    "Adjust image contrast in your browser with live preview, export options, result cards, and FAQ schema.",
  href: "/image-tools/image-contrast-adjuster/",
  order: 132,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/image-tools/image-contrast-adjuster/";

const faqs = [
  {
    q: "What does contrast adjustment do?",
    a: "It increases or decreases the difference between light and dark areas in the image.",
  },
  {
    q: "When should I increase contrast?",
    a: "Increase contrast when an image looks flat or washed out and needs more separation between shadows and highlights.",
  },
  {
    q: "When should I reduce contrast?",
    a: "Reduce contrast when shadows are too harsh, highlights are too intense, or you want a softer appearance.",
  },
  {
    q: "Is my image uploaded anywhere?",
    a: "No. Everything runs locally in your browser.",
  },
  {
    q: "Can I export the adjusted image?",
    a: "Yes. You can export the current result as PNG, JPEG, or WebP.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Image Contrast Adjuster — ${SITE_NAME}`}
  description="Increase or decrease image contrast with browser-based preview, export, result cards, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Image Contrast Adjuster"
  intro="Upload an image, adjust contrast, preview the result, and download the processed version. This is useful for improving readability in screenshots, making scans look clearer, or softening overly harsh images."
  faq={faqs}
  categoryName="Image Tools"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="image-contrast-adjuster">
    <style is:inline>
      #ica_file,
      #ica_amount,
      #ica_quality,
      #ica_format {
        width: 100%;
        min-width: 0;
      }
      .ica-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .ica-grid > * {
        min-width: 0;
      }
      .ica-canvases {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        margin-top: 14px;
      }
      .ica-panel {
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 14px;
        padding: 12px;
        min-width: 0;
        overflow: hidden;
      }
      .ica-panel canvas {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 10px;
        background: rgba(255,255,255,0.03);
      }
      .ica-card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
      }
      .ica-mini-card {
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 12px;
        padding: 12px;
      }
      .ica-big {
        font-size: 26px;
        font-weight: 900;
        margin-top: 6px;
        line-height: 1.1;
      }
      .ica-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      @media (min-width: 900px) {
        .ica-grid {
          grid-template-columns: repeat(3, 1fr);
        }
        .ica-canvases {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>

    <div class="form" role="form" aria-describedby="ica_help ica_privacy">
      <div class="field">
        <label for="ica_file">Image file</label>
        <input id="ica_file" type="file" accept="image/*" />
      </div>

      <div class="ica-grid">
        <div class="field">
          <label for="ica_amount">Contrast adjustment</label>
          <input id="ica_amount" type="range" min="-100" max="100" step="1" value="0" />
          <p class="note" id="ica_amount_note" style="margin-top:6px;">Current adjustment: 0</p>
        </div>

        <div class="field">
          <label for="ica_format">Output format</label>
          <select id="ica_format">
            <option value="image/png">PNG</option>
            <option value="image/jpeg" selected>JPEG</option>
            <option value="image/webp">WebP</option>
          </select>
        </div>

        <div class="field">
          <label for="ica_quality">Export quality (JPEG/WebP)</label>
          <input id="ica_quality" type="range" min="0.1" max="1" step="0.05" value="0.9" />
          <p class="note" id="ica_quality_note" style="margin-top:6px;">Current quality: 0.90</p>
        </div>
      </div>

      <div class="ica-row">
        <label>
          <input id="ica_live" type="checkbox" checked />
          Update preview automatically
        </label>
        <label>
          <input id="ica_fill_bg" type="checkbox" checked />
          Fill transparent background when exporting JPEG
        </label>
      </div>

      <p class="note" id="ica_help" style="margin-top:6px;">
        Negative values reduce contrast for a softer look. Positive values increase separation between dark and light areas.
      </p>

      <div class="ica-row">
        <button class="btn" type="button" id="ica_apply">Apply Contrast</button>
        <button class="btn secondary" type="button" id="ica_download">Download Result</button>
        <button class="btn secondary" type="button" id="ica_reset">Reset Controls</button>
        <button class="btn secondary" type="button" id="ica_clear">Clear</button>
      </div>

      <div class="result" id="ica_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="ica_result" role="status" style="margin-top:12px;">Adjusted image details will appear here.</div>
      <div class="result" id="ica_cards" style="display:none; margin-top:12px;"></div>

      <div class="ica-canvases">
        <div class="ica-panel">
          <strong>Original preview</strong>
          <canvas id="ica_original_canvas" aria-label="Original image preview"></canvas>
        </div>
        <div class="ica-panel">
          <strong>Adjusted preview</strong>
          <canvas id="ica_output_canvas" aria-label="Contrast-adjusted image preview"></canvas>
        </div>
      </div>

      <p class="note" id="ica_privacy" style="margin-top:10px;">
        Privacy: contrast adjustment runs locally in your browser. No image is uploaded, stored, or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This tool adjusts contrast by remapping pixel values around the midpoint. Increasing contrast pushes darker pixels darker
      and lighter pixels lighter, while decreasing contrast pulls values closer together.
    </p>
    <ul>
      <li><strong>Higher contrast:</strong> stronger shadows and highlights</li>
      <li><strong>Lower contrast:</strong> softer transitions and flatter tone</li>
      <li><strong>Moderate settings:</strong> usually best for screenshots and document images</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li>Increase contrast in a washed-out screenshot</li>
      <li>Reduce contrast in a harshly lit photo</li>
      <li>Improve readability in scans and receipts</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/image-tools/image-brightness-adjuster/">Image Brightness Adjuster</a></li>
      <li><a href="/image-tools/image-sharpen/">Image Sharpen Tool</a></li>
      <li><a href="/image-tools/image-blur/">Image Blur</a></li>
      <li><a href="/image-tools/image-compressor/">Image Compressor</a></li>
      <li><a href="/image-tools/">All Image Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const fileEl = document.getElementById("ica_file");
  const amountEl = document.getElementById("ica_amount");
  const qualityEl = document.getElementById("ica_quality");
  const formatEl = document.getElementById("ica_format");
  const liveEl = document.getElementById("ica_live");
  const fillBgEl = document.getElementById("ica_fill_bg");

  const applyBtn = document.getElementById("ica_apply");
  const downloadBtn = document.getElementById("ica_download");
  const resetBtn = document.getElementById("ica_reset");
  const clearBtn = document.getElementById("ica_clear");

  const amountNoteEl = document.getElementById("ica_amount_note");
  const qualityNoteEl = document.getElementById("ica_quality_note");

  const errorEl = document.getElementById("ica_error");
  const resultEl = document.getElementById("ica_result");
  const cardsEl = document.getElementById("ica_cards");

  const originalCanvas = document.getElementById("ica_original_canvas");
  const outputCanvas = document.getElementById("ica_output_canvas");
  const originalCtx = originalCanvas.getContext("2d");
  const outputCtx = outputCanvas.getContext("2d");

  if (
    !fileEl || !amountEl || !qualityEl || !formatEl || !liveEl || !fillBgEl ||
    !applyBtn || !downloadBtn || !resetBtn || !clearBtn ||
    !amountNoteEl || !qualityNoteEl || !errorEl || !resultEl || !cardsEl ||
    !originalCanvas || !outputCanvas || !originalCtx || !outputCtx
  ) return;

  const sourceCanvas = document.createElement("canvas");
  const sourceCtx = sourceCanvas.getContext("2d");

  let currentImage = null;
  let currentFileName = "";
  let originalFileSize = 0;
  let lastBlob = null;
  let debounceTimer = null;

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function resetMessages() {
    clearError();
    resultEl.textContent = "Adjusted image details will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
  }

  function formatBytes(bytes) {
    const n = Number(bytes || 0);
    if (n < 1024) return n + " B";
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + " KB";
    return (n / (1024 * 1024)).toFixed(2) + " MB";
  }

  function badge(text, kind) {
    const border =
      kind === "good" ? "rgba(34,197,94,.55)" :
      kind === "warn" ? "rgba(251,146,60,.55)" :
      "rgba(255,255,255,.2)";
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid ' + border + ';font-size:12px;font-weight:900;">' + text + "</span>";
  }

  function miniCard(label, value, sub) {
    return (
      '<div class="ica-mini-card">' +
        "<strong>" + label + "</strong>" +
        '<div class="ica-big">' + value + "</div>" +
        '<div class="note" style="margin-top:4px;">' + sub + "</div>" +
      "</div>"
    );
  }

  function updateControlLabels() {
    amountNoteEl.textContent = "Current adjustment: " + String(amountEl.value);
    qualityNoteEl.textContent = "Current quality: " + Number(qualityEl.value).toFixed(2);
  }

  function clamp(v) {
    return Math.max(0, Math.min(255, v));
  }

  function loadImage(file) {
    return new Promise(function (resolve, reject) {
      const reader = new FileReader();
      reader.onload = function (ev) {
        const img = new Image();
        img.onload = function () { resolve(img); };
        img.onerror = function () { reject(new Error("Could not decode the selected image.")); };
        img.src = String(ev.target.result || "");
      };
      reader.onerror = function () {
        reject(new Error("Could not read the selected file."));
      };
      reader.readAsDataURL(file);
    });
  }

  function drawOriginal() {
    if (!currentImage || !sourceCtx) return;
    const w = currentImage.naturalWidth || currentImage.width;
    const h = currentImage.naturalHeight || currentImage.height;

    sourceCanvas.width = w;
    sourceCanvas.height = h;
    originalCanvas.width = w;
    originalCanvas.height = h;

    sourceCtx.clearRect(0, 0, w, h);
    sourceCtx.drawImage(currentImage, 0, 0);

    originalCtx.clearRect(0, 0, w, h);
    originalCtx.drawImage(currentImage, 0, 0);
  }

  async function renderContrast() {
    clearError();

    if (!currentImage || !sourceCtx) {
      showError("Please choose an image file first.");
      return;
    }

    const w = sourceCanvas.width;
    const h = sourceCanvas.height;
    if (!w || !h) {
      showError("Source image is not ready yet.");
      return;
    }

    const amount = Number(amountEl.value || 0);
    const factor = (259 * (amount + 255)) / (255 * (259 - amount || 1));
    const mime = String(formatEl.value || "image/jpeg");
    const quality = Number(qualityEl.value || 0.9);

    const srcData = sourceCtx.getImageData(0, 0, w, h);
    const data = srcData.data;

    for (let i = 0; i < data.length; i += 4) {
      data[i] = clamp(factor * (data[i] - 128) + 128);
      data[i + 1] = clamp(factor * (data[i + 1] - 128) + 128);
      data[i + 2] = clamp(factor * (data[i + 2] - 128) + 128);
    }

    outputCanvas.width = w;
    outputCanvas.height = h;

    if (mime === "image/jpeg" && fillBgEl.checked) {
      outputCtx.fillStyle = "#FFFFFF";
      outputCtx.fillRect(0, 0, w, h);
    } else {
      outputCtx.clearRect(0, 0, w, h);
    }

    outputCtx.putImageData(srcData, 0, 0);

    resultEl.innerHTML =
      "<strong>Contrast adjustment applied.</strong>" +
      '<div class="note" style="margin-top:6px;">Compare the original and adjusted previews, then export the version you prefer.</div>';

    try {
      const blob = await new Promise(function (resolve, reject) {
        outputCanvas.toBlob(function (b) {
          if (!b) {
            reject(new Error("Could not encode the adjusted image."));
            return;
          }
          resolve(b);
        }, mime, quality);
      });

      lastBlob = blob;

      cardsEl.style.display = "block";
      cardsEl.innerHTML =
        '<div class="ica-card-grid">' +
          miniCard("Adjustment", String(amount), "Contrast amount") +
          miniCard("Output format", mime.replace("image/", "").toUpperCase(), "Selected export format") +
          miniCard("Original size", formatBytes(originalFileSize), "Uploaded file size") +
          miniCard("Output size", formatBytes(blob.size), "Current rendered file") +
        "</div>" +
        '<div style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">' +
          badge(amount === 0 ? "Neutral" : amount > 0 ? "Higher contrast" : "Lower contrast", amount === 0 ? "neutral" : "good") +
          badge(mime === "image/png" ? "Lossless container" : "Quality " + quality.toFixed(2), mime === "image/png" ? "neutral" : "good") +
        "</div>";
    } catch (err) {
      showError(err && err.message ? err.message : "Could not create the export file.");
    }
  }

  async function downloadResult() {
    clearError();

    if (!currentImage) {
      showError("Please upload an image first.");
      return;
    }

    if (!lastBlob) {
      await renderContrast();
      if (!lastBlob) return;
    }

    const ext = String(formatEl.value || "image/jpeg").replace("image/", "").replace("jpeg", "jpg");
    const base = (currentFileName || "image").replace(/\.[^.]+$/, "");
    const a = document.createElement("a");
    a.href = URL.createObjectURL(lastBlob);
    a.download = base + "-contrast-adjusted." + ext;
    a.click();
    URL.revokeObjectURL(a.href);
  }

  function scheduleRender() {
    updateControlLabels();
    if (!liveEl.checked || !currentImage) return;
    if (debounceTimer) window.clearTimeout(debounceTimer);
    debounceTimer = window.setTimeout(function () {
      renderContrast();
    }, 120);
  }

  function resetControls() {
    amountEl.value = "0";
    qualityEl.value = "0.9";
    formatEl.value = "image/jpeg";
    liveEl.checked = true;
    fillBgEl.checked = true;
    updateControlLabels();
    if (currentImage) renderContrast();
    else resetMessages();
  }

  function clearAll() {
    fileEl.value = "";
    currentImage = null;
    currentFileName = "";
    originalFileSize = 0;
    lastBlob = null;
    sourceCanvas.width = 0;
    sourceCanvas.height = 0;
    originalCanvas.width = 0;
    originalCanvas.height = 0;
    outputCanvas.width = 0;
    outputCanvas.height = 0;
    amountEl.value = "0";
    qualityEl.value = "0.9";
    formatEl.value = "image/jpeg";
    liveEl.checked = true;
    fillBgEl.checked = true;
    updateControlLabels();
    resetMessages();
    fileEl.focus();
  }

  fileEl.addEventListener("change", async function () {
    resetMessages();

    const file = fileEl.files && fileEl.files[0];
    if (!file) return;

    if (!file.type || !file.type.startsWith("image/")) {
      showError("Please select a valid image file.");
      return;
    }

    try {
      currentImage = await loadImage(file);
      currentFileName = file.name || "image";
      originalFileSize = Number(file.size || 0);
      drawOriginal();
      if (liveEl.checked) renderContrast();
      else {
        resultEl.innerHTML =
          "<strong>Image loaded.</strong>" +
          '<div class="note" style="margin-top:6px;">Adjust settings, then click “Apply Contrast”.</div>';
      }
    } catch (err) {
      showError(err && err.message ? err.message : "Could not load the image.");
    }
  });

  amountEl.addEventListener("input", scheduleRender);
  qualityEl.addEventListener("input", scheduleRender);
  formatEl.addEventListener("change", scheduleRender);
  liveEl.addEventListener("change", scheduleRender);
  fillBgEl.addEventListener("change", scheduleRender);

  applyBtn.addEventListener("click", renderContrast);
  downloadBtn.addEventListener("click", downloadResult);
  resetBtn.addEventListener("click", resetControls);
  clearBtn.addEventListener("click", clearAll);

  updateControlLabels();
});
</script>