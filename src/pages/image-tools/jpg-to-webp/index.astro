---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "JPG to WebP Converter",
  description: "Convert JPG images to WebP with better compression.",
  href: "/image-tools/jpg-to-webp/",
  order: 9,
};

const SITE_NAME="MinimalDev";
const CANONICAL_PATH="/image-tools/jpg-to-webp/";
---

<ToolLayout
title={`JPG to WebP — ${SITE_NAME}`}
description="Convert JPG to WebP with better compression."
canonicalPath={CANONICAL_PATH}
h1="JPG to WebP Converter"
intro="Convert JPG images into efficient WebP format."
categoryName="Image Tools"
>
<div slot="tool">
<div class="form">
<input type="file" id="file" accept="image/jpeg"/>

<label>Quality</label>
<input type="range" id="quality" min="0.1" max="1" step="0.1" value="0.8"/>

<canvas id="canvas"></canvas>

<div id="info" class="result">Upload JPG image.</div>

<button class="btn" id="convert">Convert</button>
<button class="btn secondary" id="download">Download WebP</button>
</div>
</div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded",()=>{

const file=document.getElementById("file");
const canvas=document.getElementById("canvas");
const ctx=canvas.getContext("2d");
const quality=document.getElementById("quality");
const info=document.getElementById("info");

let img=new Image();
let originalSize=0;

file.onchange=e=>{
 const f=e.target.files[0];
 if(!f) return;

 originalSize=f.size;

 const r=new FileReader();
 r.onload=ev=>{
   img.onload=()=>{
     canvas.width=img.width;
     canvas.height=img.height;
     ctx.drawImage(img,0,0);
   };
   img.src=ev.target.result;
 };
 r.readAsDataURL(f);
};

document.getElementById("convert").onclick=()=>{
 canvas.toBlob(blob=>{
   info.innerHTML=
   `Original: ${(originalSize/1024).toFixed(1)} KB<br>
    WebP: ${(blob.size/1024).toFixed(1)} KB<br>
    Saved: ${((1-blob.size/originalSize)*100).toFixed(1)}%`;
 },"image/webp",Number(quality.value));
};

document.getElementById("download").onclick=()=>{
 canvas.toBlob(blob=>{
   const a=document.createElement("a");
   a.href=URL.createObjectURL(blob);
   a.download="converted.webp";
   a.click();
 },"image/webp",Number(quality.value));
};

});
</script>