---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Image Size Calculator",
  description:
    "Estimate image size from dimensions, color depth, and format assumptions.",
  href: "/image-tools/image-size-calculator/",
  order: 152,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/image-tools/image-size-calculator/";

const faqs = [
  {
    q: "What does this image size calculator estimate?",
    a: "It estimates raw uncompressed image size and approximate compressed sizes using width, height, channels, and bit depth.",
  },
  {
    q: "Is this exact for JPEG, PNG, or WebP files?",
    a: "No. Real file sizes depend on compression algorithms, metadata, and image content.",
  },
  {
    q: "What is raw image size?",
    a: "Raw size is the total number of bytes required to store pixel data without compression.",
  },
  {
    q: "Why do two images with the same dimensions have different sizes?",
    a: "Because compression efficiency varies based on detail, noise, color variation, and metadata.",
  },
  {
    q: "When should I use this calculator?",
    a: "Use it when planning uploads, storage requirements, or estimating export sizes before generating images.",
  },
  {
    q: "What compression ratio should I use?",
    a: "Typical values: JPEG (5–15), PNG (1.5–3), WebP (4–10). Actual results vary.",
  },
];

---

<ToolLayout
  title={`Image Size Calculator — ${SITE_NAME}`}
  description="Calculate estimated image size from width, height, pixel count, color depth, and storage assumptions for planning or comparison."
  canonicalPath={CANONICAL_PATH}
  h1="Image Size Calculator"
  intro="Estimate how large an image file may be before exporting. Useful for storage planning, upload limits, and optimizing image workflows."
  faq={faqs}
  categoryName="Image Tools"
>

  <div slot="tool" data-tool="image-size-calculator">
    <style is:inline>
      #isc_width,
      #isc_height,
      #isc_channels,
      #isc_bit_depth,
      #isc_compression_ratio,
      #isc_unit_base {
        width: 100%;
        min-width: 0;
      }
      .isc-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .isc-grid > * {
        min-width: 0;
      }
      .isc-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
      }
      .isc-card {
        border: 1px solid rgba(255,255,255,.14);
        border-radius: 12px;
        padding: 12px;
      }
      .isc-big {
        font-size: 26px;
        font-weight: 900;
        margin-top: 6px;
        line-height: 1.1;
        word-break: break-word;
      }
      .isc-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
      }
      .isc-list-item {
        border: 1px solid rgba(255,255,255,.14);
        border-radius: 12px;
        padding: 12px;
      }
      @media (min-width: 900px) {
        .isc-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
    </style>

    <div class="form" role="form" aria-describedby="isc_help isc_privacy">
      <div class="isc-grid">
        <div class="field">
          <label for="isc_width">Width (px)</label>
          <input id="isc_width" type="number" inputmode="numeric" min="1" step="1" placeholder="e.g. 4000" />
        </div>
        <div class="field">
          <label for="isc_height">Height (px)</label>
          <input id="isc_height" type="number" inputmode="numeric" min="1" step="1" placeholder="e.g. 3000" />
        </div>
      </div>

      <div class="isc-grid">
        <div class="field">
          <label for="isc_channels">Color channels</label>
          <select id="isc_channels">
            <option value="1">1 channel (grayscale)</option>
            <option value="3" selected>3 channels (RGB)</option>
            <option value="4">4 channels (RGBA)</option>
            <option value="5">5 channels (CMYKA approximation)</option>
          </select>
        </div>
        <div class="field">
          <label for="isc_bit_depth">Bit depth per channel</label>
          <select id="isc_bit_depth">
            <option value="1">1-bit</option>
            <option value="8" selected>8-bit</option>
            <option value="10">10-bit</option>
            <option value="12">12-bit</option>
            <option value="16">16-bit</option>
            <option value="32">32-bit</option>
          </select>
        </div>
      </div>

      <div class="isc-grid">
        <div class="field">
          <label for="isc_compression_ratio">Estimated compression ratio</label>
          <input id="isc_compression_ratio" type="number" inputmode="decimal" min="1" step="0.1" value="4" />
          <p class="note" style="margin-top:6px;">Example: 4 means the compressed file is estimated at one quarter of the raw size.</p>
        </div>
        <div class="field">
          <label for="isc_unit_base">Display unit base</label>
          <select id="isc_unit_base">
            <option value="1024" selected>Binary units (KiB, MiB, GiB)</option>
            <option value="1000">Decimal units (KB, MB, GB)</option>
          </select>
        </div>
      </div>

      <p class="note" id="isc_help" style="margin-top:6px;">
        This tool estimates pixel-data size only. Real file sizes vary by format, metadata, transparency, image complexity, and encoder settings.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="isc_calculate">Calculate Size</button>
        <button class="btn secondary" type="button" id="isc_copy">Copy Summary</button>
        <button class="btn secondary" type="button" id="isc_clear">Clear</button>
      </div>

      <div class="result" id="isc_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="isc_result" role="status" style="margin-top:12px;">Image size estimates will appear here.</div>
      <div class="result" id="isc_cards" style="display:none; margin-top:12px;"></div>
      <div class="result" id="isc_breakdown" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="isc_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="isc_privacy" style="margin-top:10px;">
        Privacy: this calculator uses only the values you enter and runs locally in your browser. No data is uploaded or stored.
      </p>
    </div>

    <section class="section">
      <h2>Learn more about images</h2>
      <p class="note">
        Understanding formats and optimization helps you get better results when converting or editing images.
      </p>

      <ul>
        <li><a href="/guides/image-format-comparison/">PNG vs JPG vs WebP</a></li>
        <li><a href="/guides/reduce-image-size/">Reduce Image Size</a></li>
        <li><a href="/guides/why-use-webp/">Why WebP</a></li>
        <li><a href="/guides/image-optimization-for-web/">Image Optimization</a></li>
      </ul>
    </section>
  </div>

<div slot="how">
  <p class="note">
    This calculator estimates image size using a simple formula:
    <strong> width × height × channels × bit depth ÷ 8 </strong>.
  </p>
  <ul>
    <li><strong>Width × Height:</strong> total number of pixels</li>
    <li><strong>Channels:</strong> grayscale (1), RGB (3), RGBA (4)</li>
    <li><strong>Bit depth:</strong> color precision per channel</li>
    <li><strong>Result interpretation:</strong> raw size shows memory usage, compressed estimate shows expected file size</li>
  </ul>
</div>

<div slot="examples">
  <ul>
    <li><strong>4000×3000 RGB 8-bit:</strong> estimate photo storage size</li>
    <li><strong>RGBA images:</strong> understand transparency cost</li>
    <li><strong>Compression planning:</strong> test different ratios before exporting</li>
    <li><strong>Web optimization:</strong> estimate upload size limits</li>
    <li><strong>Print workflow:</strong> predict file sizes for high-resolution images</li>
  </ul>
</div>

<div slot="related">
  <ul>
    <li><a href="/image-tools/image-compressor/">Image Compressor</a></li>
    <li><a href="/image-tools/image-resizer/">Image Resizer</a></li>
    <li><a href="/image-tools/image-dpi-converter/">Image DPI Converter</a></li>
    <li><a href="/image-tools/image-aspect-ratio-calculator/">Aspect Ratio Calculator</a></li>
    <li><a href="/image-tools/">All Image Tools</a></li>
  </ul>
</div>

</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const widthEl = document.getElementById("isc_width");
  const heightEl = document.getElementById("isc_height");
  const channelsEl = document.getElementById("isc_channels");
  const bitDepthEl = document.getElementById("isc_bit_depth");
  const compressionEl = document.getElementById("isc_compression_ratio");
  const unitBaseEl = document.getElementById("isc_unit_base");
  const calcBtn = document.getElementById("isc_calculate");
  const copyBtn = document.getElementById("isc_copy");
  const clearBtn = document.getElementById("isc_clear");
  const errorEl = document.getElementById("isc_error");
  const resultEl = document.getElementById("isc_result");
  const cardsEl = document.getElementById("isc_cards");
  const breakdownEl = document.getElementById("isc_breakdown");
  const tbodyEl = document.getElementById("isc_tbody");

  if (!widthEl || !heightEl || !channelsEl || !bitDepthEl || !compressionEl || !unitBaseEl || !calcBtn || !copyBtn || !clearBtn || !errorEl || !resultEl || !cardsEl || !breakdownEl || !tbodyEl) return;

  let lastSummary = "";

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function resetOutput() {
    clearError();
    resultEl.textContent = "Image size estimates will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    breakdownEl.style.display = "none";
    breakdownEl.innerHTML = "";
    tbodyEl.innerHTML = "";
    lastSummary = "";
  }

  function parsePositiveNumber(value) {
    const n = Number(value);
    if (!Number.isFinite(n) || n <= 0) return null;
    return n;
  }

  function formatBytes(bytes, base) {
    const b = Number(bytes || 0);
    const units = base === 1000
      ? ["B", "KB", "MB", "GB", "TB"]
      : ["B", "KiB", "MiB", "GiB", "TiB"];

    if (b < base) return b.toFixed(0) + " " + units[0];

    let value = b;
    let index = 0;
    while (value >= base && index < units.length - 1) {
      value /= base;
      index++;
    }
    return value.toFixed(2) + " " + units[index];
  }

  function badge(text, kind) {
    const border =
      kind === "good" ? "rgba(34,197,94,.55)" :
      kind === "warn" ? "rgba(251,146,60,.55)" :
      "rgba(255,255,255,.2)";
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid ' + border + ';font-size:12px;font-weight:900;">' + text + '</span>';
  }

  function card(label, value, sub) {
    return (
      '<div class="isc-card">' +
        '<strong>' + label + '</strong>' +
        '<div class="isc-big">' + value + '</div>' +
        '<div class="note" style="margin-top:4px;">' + sub + '</div>' +
      '</div>'
    );
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function calculate() {
    resetOutput();

    const width = parsePositiveNumber(widthEl.value);
    const height = parsePositiveNumber(heightEl.value);
    const channels = parsePositiveNumber(channelsEl.value);
    const bitDepth = parsePositiveNumber(bitDepthEl.value);
    const compressionRatio = parsePositiveNumber(compressionEl.value);
    const base = Number(unitBaseEl.value || 1024);

    if (!width || !height || !channels || !bitDepth || !compressionRatio) {
      showError("Please enter valid positive values for width, height, channels, bit depth, and compression ratio.");
      return;
    }

    const pixels = width * height;
    const bitsPerPixel = channels * bitDepth;
    const bytesPerPixel = bitsPerPixel / 8;
    const rawBytes = pixels * bytesPerPixel;
    const estimatedCompressedBytes = rawBytes / compressionRatio;

    const rgb8Reference = pixels * 3;
    const rgba8Reference = pixels * 4;

    resultEl.innerHTML =
      "<strong>Image size estimated.</strong>" +
      '<div class="note" style="margin-top:6px;">Use the raw size for memory planning and the compressed estimate for rough file-size expectations.</div>';

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      '<div class="isc-cards">' +
        card("Raw size", formatBytes(rawBytes, base), "Uncompressed pixel data estimate") +
        card("Compressed estimate", formatBytes(estimatedCompressedBytes, base), "Based on your compression ratio") +
        card("Pixels", pixels.toLocaleString(), "Width × height") +
        card("Bytes per pixel", bytesPerPixel.toFixed(2), "Channels × bit depth ÷ 8") +
      '</div>' +
      '<div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap;">' +
        badge(channels + " channels", channels >= 4 ? "warn" : "good") +
        badge(bitDepth + "-bit", bitDepth > 8 ? "warn" : "good") +
        badge("Compression " + compressionRatio + ":1", compressionRatio >= 8 ? "good" : compressionRatio >= 4 ? "neutral" : "warn") +
      '</div>';

    breakdownEl.style.display = "block";
    breakdownEl.innerHTML =
      "<strong>Reference comparisons</strong>" +
      '<div class="isc-list" style="margin-top:10px;">' +
        '<div class="isc-list-item"><strong>RGB 8-bit reference</strong><div class="note" style="margin-top:6px;">' + formatBytes(rgb8Reference, base) + ' raw pixel data for the same dimensions</div></div>' +
        '<div class="isc-list-item"><strong>RGBA 8-bit reference</strong><div class="note" style="margin-top:6px;">' + formatBytes(rgba8Reference, base) + ' raw pixel data for the same dimensions</div></div>' +
        '<div class="isc-list-item"><strong>Estimated compressed file</strong><div class="note" style="margin-top:6px;">' + formatBytes(estimatedCompressedBytes, base) + ' using your chosen compression assumption</div></div>' +
      '</div>';

    fillTable([
      ["Width", String(width)],
      ["Height", String(height)],
      ["Pixel count", pixels.toLocaleString()],
      ["Channels", String(channels)],
      ["Bit depth per channel", String(bitDepth)],
      ["Bits per pixel", String(bitsPerPixel)],
      ["Bytes per pixel", bytesPerPixel.toFixed(4)],
      ["Raw bytes", rawBytes.toFixed(0)],
      ["Compressed estimate bytes", estimatedCompressedBytes.toFixed(0)],
      ["Display base", base === 1000 ? "1000 (decimal)" : "1024 (binary)"],
    ]);

    lastSummary =
      "Dimensions: " + width + " × " + height + "\n" +
      "Pixels: " + pixels + "\n" +
      "Channels: " + channels + "\n" +
      "Bit depth: " + bitDepth + "-bit\n" +
      "Bytes per pixel: " + bytesPerPixel.toFixed(4) + "\n" +
      "Raw size: " + formatBytes(rawBytes, base) + "\n" +
      "Compressed estimate: " + formatBytes(estimatedCompressedBytes, base) + "\n" +
      "Compression ratio: " + compressionRatio + ":1";
  }

  async function copySummary() {
    clearError();
    if (!lastSummary) {
      showError("No image size summary to copy yet.");
      return;
    }
    try {
      await navigator.clipboard.writeText(lastSummary);
      resultEl.innerHTML = "<strong>Copied image size summary.</strong>";
    } catch (_) {
      showError("Clipboard copy failed in this browser.");
    }
  }

  function clearAll() {
    widthEl.value = "";
    heightEl.value = "";
    channelsEl.value = "3";
    bitDepthEl.value = "8";
    compressionEl.value = "4";
    unitBaseEl.value = "1024";
    resetOutput();
    widthEl.focus();
  }

  calcBtn.addEventListener("click", calculate);
  copyBtn.addEventListener("click", copySummary);
  clearBtn.addEventListener("click", clearAll);
});
</script>