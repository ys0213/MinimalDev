---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Base64 Encoder/Decoder",
  description:
    "Encode or decode Base64 text for data, URLs, and development workflows.",
  href: "/utility/base64/",
  order: 40,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/utility/base64/";

const faqs = [
  {
    q: "Is this Base64 tool private?",
    a: "Yes. Encoding and decoding run locally in your browser. No inputs are uploaded or stored by this tool.",
  },
  {
    q: "What is Base64 used for?",
    a: "Base64 converts binary data into text so it can be safely included in places that expect plain text, such as JSON, HTML, URLs, or API payloads.",
  },
  {
    q: "Does Base64 encrypt data?",
    a: "No. Base64 is not encryption. It is only an encoding method and can be reversed easily.",
  },
  {
    q: "What is URL-safe Base64?",
    a: "URL-safe Base64 replaces '+' with '-' and '/' with '_' and often omits '=' padding so it can be used in URLs without extra escaping.",
  },
  {
    q: "Can I encode files?",
    a: "Yes. You can encode a file to Base64 and decode Base64 back to a file for download, as long as the browser can handle the file size.",
  },
  {
    q: "Why would I use Base64 instead of plain text?",
    a: "Base64 is useful when a system only accepts text but you need to transfer binary data such as images, documents, or attachments.",
  },
  {
    q: "Can I decode Base64 back to normal text?",
    a: "Yes. If the original input was text, decoding can recover readable text again. If the original input was binary data, you may need to download it as a file.",
  },
  {
    q: "Is padding always required?",
    a: "No. Some systems require '=' padding, while others use unpadded Base64, especially in URL-safe contexts.",
  },
];
---

<ToolLayout
  title={`Base64 Encoder/Decoder — ${SITE_NAME}`}
  description="Encode text to Base64 or decode Base64 back to readable text for development, testing, data handling, and quick reference."
  canonicalPath={CANONICAL_PATH}
  h1="Base64 Encoder/Decoder"
  intro="Encode text or files to Base64, or decode Base64 back to text and downloadable files. Supports URL-safe mode, UTF-8 text handling, validation, and private local processing."
  faq={faqs}
  categoryName="Utilities"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Base64 Encoder/Decoder",
    "description": "Encode and decode Base64 text and files locally in the browser. Supports URL-safe Base64 and file downloads.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />
  <div slot="tool" data-tool="base64">
    <div class="privacy-note">
      <strong>Privacy First:</strong> This tool runs locally in your browser.
      <strong>Your input values are never sent to any server.</strong>
    </div>

    <div class="form" role="form" aria-describedby="b64_privacy b64_help">
      <div class="field">
        <label for="b64_mode">Mode</label>
        <select id="b64_mode">
          <option value="encode" selected>Encode (text/file → Base64)</option>
          <option value="decode">Decode (Base64 → text/file)</option>
        </select>
        <p class="note" id="b64_help" style="margin-top:6px;">
          Use Encode for plain text or a file. Use Decode to recover text or download a decoded file.
        </p>
      </div>

      <div style="display:grid; grid-template-columns:1fr; gap:10px;">
        <div class="field">
          <label for="b64_input">Input</label>
          <textarea
            id="b64_input"
            rows="7"
            style="width:100%; resize:vertical;"
            placeholder="Paste text or Base64 here..."
            spellcheck="false"
            autocomplete="off"
            autocapitalize="off"
          ></textarea>
          <p class="note" style="margin-top:6px;">
            Tip: For Base64 decoding, whitespace is ignored. For very large inputs, file mode is recommended.
          </p>
        </div>

        <div class="field" id="b64_file_row">
          <label for="b64_file">File (optional)</label>
          <input id="b64_file" type="file" />
          <p class="note" style="margin-top:6px;">
            If a file is selected in Encode mode, the textarea input is ignored.
          </p>
        </div>
      </div>

      <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end; margin-top:6px;">
        <div class="field" style="min-width:240px;">
          <label>
            <input id="b64_urlsafe" type="checkbox" />
            URL-safe Base64 (- and _)
          </label>
          <p class="note" style="margin-top:6px;">
            In URL-safe mode, '+' becomes '-' and '/' becomes '_'.
          </p>
        </div>

        <div class="field" style="min-width:240px;">
          <label>
            <input id="b64_padding" type="checkbox" checked />
            Keep '=' padding
          </label>
          <p class="note" style="margin-top:6px;">
            Some systems require padding. Many URL-safe uses omit it.
          </p>
        </div>

        <div class="field" style="min-width:240px;">
          <label for="b64_charset">Text decoding</label>
          <select id="b64_charset">
            <option value="utf8" selected>UTF-8 (recommended)</option>
            <option value="latin1">Latin-1 (legacy)</option>
          </select>
          <p class="note" style="margin-top:6px;">
            Use UTF-8 for normal text. Use Latin-1 only for legacy cases.
          </p>
        </div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:8px;">
        <button class="btn" type="button" id="b64_run">Run</button>
        <button class="btn secondary" type="button" id="b64_copy">Copy output</button>
        <button class="btn secondary" type="button" id="b64_download">Download file</button>
        <button class="btn secondary" type="button" id="b64_clear">Clear</button>
      </div>

      <div class="result" id="b64_error" role="alert" style="display:none; margin-top:12px;"></div>

      <div class="result" id="b64_summary" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div class="result" id="b64_cards" style="display:none; margin-top:12px;"></div>

      <div class="field" style="margin-top:12px;">
        <label for="b64_output">Output</label>
        <textarea
          id="b64_output"
          rows="7"
          style="width:100%; resize:vertical;"
          readonly
          spellcheck="false"
        ></textarea>
      </div>
    </div>
  </div>

  <div slot="how">
    <h2>How Base64 Encoding Works</h2>

    <p class="note">
      Base64 is an encoding that converts bytes into ASCII characters. It is reversible and not encryption.
    </p>

    <ul>
      <li><strong>Encode:</strong> bytes → Base64 text</li>
      <li><strong>Decode:</strong> Base64 text → bytes (or text if it was text originally)</li>
      <li><strong>URL-safe:</strong> uses '-' and '_' instead of '+' and '/'</li>
    </ul>

    <div class="prose" style="margin-top:20px;">
      <h2>What Base64 Is Used For</h2>
      <p>
        Base64 is used when binary data needs to travel through a system that expects plain text.
        This happens often in web development, APIs, email systems, authentication tokens, and file transport.
        For example, an image or PDF cannot be pasted directly into JSON as raw bytes, but it can be converted into a Base64 string and safely transferred as text.
      </p>

      <p>
        That does not mean Base64 is always the best option. Encoding increases size because binary data becomes a longer text representation.
        In many practical cases, the encoded result is around one-third larger than the original binary data.
        Base64 is useful for compatibility, not for compression.
      </p>

      <p>
      If you are working with structured data, you may also need to format JSON properly.
      See our <a href="/utility/json-formatter/">JSON Formatter</a> for handling API responses.
      </p>

      <h2>Base64 vs Encryption</h2>
      <p>
        One of the most common misunderstandings is treating Base64 as a security feature.
        Base64 does not protect data. It does not hide meaning in a secure way, and anyone can reverse it using the same decoding process.
        If you need confidentiality, you need encryption. If you need safe text transport, Base64 is the correct tool.
      </p>

      <h2>When URL-Safe Base64 Matters</h2>
      <p>
        Standard Base64 includes the characters <code>+</code> and <code>/</code>, which are not always convenient inside URLs or query parameters.
        URL-safe Base64 replaces those characters with <code>-</code> and <code>_</code>. Some systems also remove the trailing <code>=</code> padding.
        This is common in tokens, signed URLs, and some authentication flows.
      </p>

      <h2>Real-World Use Cases</h2>
      <ul>
        <li><strong>Embedding data:</strong> Convert small binary assets to text for transport in JSON or HTML</li>
        <li><strong>API workflows:</strong> Send file contents through systems that only accept text payloads</li>
        <li><strong>Debugging:</strong> Inspect whether a Base64 string decodes to readable text or binary data</li>
        <li><strong>URL tokens:</strong> Use URL-safe Base64 for values placed inside links or query strings</li>
      </ul>

      <h2>How to Interpret Results</h2>
      <p>
        If you encode plain text, the output should be a Base64 string that can later be reversed to the same text.
        If you decode Base64 and the output appears readable, the original data was likely text.
        If the decoded output is not readable, it may represent a file or binary content instead.
        In that case, downloading the decoded bytes as a file is usually the correct next step.
      </p>

      <p>
        This tool is especially useful because it runs locally in the browser. That matters for privacy-sensitive data such as tokens,
        configuration strings, private API samples, or internal files that should not be uploaded to a third-party server.
      </p>
    </div>
  </div>

  <div slot="examples">
    <p class="note"><strong>Real example:</strong></p>
    <ul>
      <li><strong>Input:</strong> "MinimalDev"</li>
      <li><strong>Encoded:</strong> TWluaW1hbERldg==</li>
      <li><strong>Use case:</strong> Sending text safely inside a JSON API payload</li>
    </ul>

    <ul>
      <li><strong>Encode:</strong> "hello" → aGVsbG8=</li>
      <li><strong>Decode:</strong> aGVsbG8= → "hello"</li>
      <li><strong>URL-safe:</strong> replace '+' and '/' with '-' and '_' (and optionally remove '=')</li>
    </ul>

    <p class="note"><strong>Practical examples:</strong></p>
    <ul>
      <li>Convert a short text sample into Base64 before placing it into a JSON field</li>
      <li>Decode a token or payload you received from an API for debugging</li>
      <li>Recover an uploaded file from a Base64 string and download it again as binary data</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/utility/json-formatter/">JSON Formatter</a></li>
      <li><a href="/utility/url-encoder-decoder/">URL Encoder / Decoder</a></li>
      <li><a href="/utility/random-string-generator/">Random String Generator</a></li>
      <li><a href="/math/percent-calculator/">Percent Calculator</a></li>
      <li><a href="/finance/compound-interest-calculator/">Compound Interest Calculator</a></li>
      <li><a href="/utility/">All Utility Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const modeEl = document.getElementById("b64_mode");
  const inputEl = document.getElementById("b64_input");
  const fileEl = document.getElementById("b64_file");
  const fileRowEl = document.getElementById("b64_file_row");
  const urlSafeEl = document.getElementById("b64_urlsafe");
  const paddingEl = document.getElementById("b64_padding");
  const charsetEl = document.getElementById("b64_charset");

  const runBtn = document.getElementById("b64_run");
  const copyBtn = document.getElementById("b64_copy");
  const dlBtn = document.getElementById("b64_download");
  const clearBtn = document.getElementById("b64_clear");

  const errEl = document.getElementById("b64_error");
  const summaryEl = document.getElementById("b64_summary");
  const cardsEl = document.getElementById("b64_cards");
  const outEl = document.getElementById("b64_output");

  if (
    !modeEl || !inputEl || !fileEl || !fileRowEl || !urlSafeEl || !paddingEl || !charsetEl ||
    !runBtn || !copyBtn || !dlBtn || !clearBtn || !errEl || !summaryEl || !cardsEl || !outEl
  ) return;

  let latestBytes = null;
  let latestFilename = null;
  let latestMime = "application/octet-stream";

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function escapeHtml(str) {
    return String(str)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function badge(text, kind) {
    const border =
      kind === "good"
        ? "rgba(34,197,94,0.55)"
        : kind === "warn"
        ? "rgba(251,146,60,0.55)"
        : "rgba(255,255,255,0.2)";
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid ${border}; font-size:12px; font-weight:900;">${escapeHtml(text)}</span>`;
  }

  function setModeUI() {
    const mode = String(modeEl.value);
    fileRowEl.style.display = mode === "encode" ? "block" : "none";
    dlBtn.disabled = mode !== "decode";
    dlBtn.setAttribute("aria-disabled", mode !== "decode" ? "true" : "false");
  }

  function readFileAsBytes(file) {
    return new Promise((resolve, reject) => {
      const r = new FileReader();
      r.onload = () => resolve(new Uint8Array(r.result));
      r.onerror = () => reject(new Error("Failed to read file."));
      r.readAsArrayBuffer(file);
    });
  }

  function bytesToBase64(bytes) {
    let bin = "";
    const chunk = 0x8000;
    for (let i = 0; i < bytes.length; i += chunk) {
      const slice = bytes.subarray(i, i + chunk);
      bin += String.fromCharCode.apply(null, Array.from(slice));
    }
    return btoa(bin);
  }

  function base64ToBytes(b64) {
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return bytes;
  }

  function toUrlSafe(b64, keepPadding) {
    let s = String(b64).replace(/\+/g, "-").replace(/\//g, "_");
    if (!keepPadding) s = s.replace(/=+$/g, "");
    return s;
  }

  function fromUrlSafe(b64) {
    let s = String(b64).replace(/-/g, "+").replace(/_/g, "/");
    const mod = s.length % 4;
    if (mod === 2) s += "==";
    else if (mod === 3) s += "=";
    else if (mod === 1) throw new Error("Invalid Base64 length (mod 4 = 1).");
    return s;
  }

  function normalizeB64Input(s) {
    return String(s ?? "").replace(/\s+/g, "").trim();
  }

  function decodeBytesToText(bytes, charset) {
    if (charset === "latin1") {
      let out = "";
      for (let i = 0; i < bytes.length; i++) out += String.fromCharCode(bytes[i]);
      return out;
    }

    try {
      return new TextDecoder("utf-8", { fatal: true }).decode(bytes);
    } catch (e) {
      throw new Error("Decoded bytes are not valid UTF-8 text. Switch to Latin-1 or download as a file.");
    }
  }

  function guessMimeFromBytes(bytes) {
    if (!bytes || bytes.length < 4) return "application/octet-stream";
    const b0 = bytes[0], b1 = bytes[1], b2 = bytes[2], b3 = bytes[3];

    if (b0 === 0x89 && b1 === 0x50 && b2 === 0x4E && b3 === 0x47) return "image/png";
    if (b0 === 0xFF && b1 === 0xD8 && b2 === 0xFF) return "image/jpeg";
    if (b0 === 0x47 && b1 === 0x49 && b2 === 0x46) return "image/gif";
    if (b0 === 0x25 && b1 === 0x50 && b2 === 0x44 && b3 === 0x46) return "application/pdf";
    if (b0 === 0x50 && b1 === 0x4B && (b2 === 0x03 || b2 === 0x05 || b2 === 0x07) && (b3 === 0x04 || b3 === 0x06 || b3 === 0x08)) return "application/zip";
    return "application/octet-stream";
  }

  function updateCards(opts) {
    const { mode, inLen, outLen, urlSafe, keepPad, bytesLen, mimeHint, noteBadge } = opts;

    const safety =
      bytesLen > 5_000_000
        ? { t: "Large output", k: "warn" }
        : bytesLen > 500_000
        ? { t: "Medium output", k: "neutral" }
        : { t: "Small output", k: "good" };

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:10px;">
        <div class="result" style="border-radius:12px;">
          <strong>Mode</strong>
          <div style="margin-top:8px; display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
            ${badge(mode === "encode" ? "ENCODE" : "DECODE", "neutral")}
            ${urlSafe ? badge("URL-safe", "good") : badge("Standard", "neutral")}
            ${badge(keepPad ? "Padding" : "No padding", "neutral")}
            ${noteBadge ? badge(noteBadge.text, noteBadge.kind) : ""}
          </div>
        </div>
        <div class="result" style="border-radius:12px;">
          <strong>Size</strong>
          <div class="note" style="margin-top:6px;">
            Input: ${Number(inLen).toLocaleString()} chars · Output: ${Number(outLen).toLocaleString()} chars
          </div>
          <div class="note" style="margin-top:6px;">
            Bytes: ${Number(bytesLen).toLocaleString()} · ${badge(safety.t, safety.k)}
          </div>
        </div>
        <div class="result" style="border-radius:12px;">
          <strong>Decoded file hint</strong>
          <div class="note" style="margin-top:6px;">
            MIME: ${escapeHtml(mimeHint || "unknown")} (best-effort)
          </div>
        </div>
      </div>
    `;
  }

  function resetOutput() {
    latestBytes = null;
    latestFilename = null;
    latestMime = "application/octet-stream";
    outEl.value = "";
    summaryEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
  }

  async function run() {
    clearError();
    resetOutput();

    const mode = String(modeEl.value);
    const urlSafe = !!urlSafeEl.checked;
    const keepPad = !!paddingEl.checked;
    const charset = String(charsetEl.value);

    try {
      if (mode === "encode") {
        const file = fileEl.files && fileEl.files[0] ? fileEl.files[0] : null;

        let bytes;
        let srcLabel = "Text";

        if (file) {
          bytes = await readFileAsBytes(file);
          srcLabel = `File: ${file.name}`;
        } else {
          const txt = String(inputEl.value ?? "");
          if (!txt.trim()) throw new Error("Please enter some text (or choose a file) to encode.");
          bytes = new TextEncoder().encode(txt);
        }

        let b64 = bytesToBase64(bytes);
        if (urlSafe) b64 = toUrlSafe(b64, keepPad);
        else if (!keepPad) b64 = b64.replace(/=+$/g, "");

        outEl.value = b64;

        summaryEl.innerHTML = `
          <strong>Encoded to Base64.</strong>
          <div class="note" style="margin-top:6px;">
            Source: ${escapeHtml(srcLabel)} · Output is Base64 text.
          </div>
        `;

        updateCards({
          mode,
          inLen: file ? String(file.size) : String(String(inputEl.value ?? "").length),
          outLen: b64.length,
          urlSafe,
          keepPad,
          bytesLen: bytes.length,
          mimeHint: file ? (file.type || "application/octet-stream") : "text/plain; charset=utf-8",
          noteBadge: file ? { text: "Binary → Base64", kind: "neutral" } : { text: "UTF-8 text", kind: "neutral" }
        });

        latestBytes = null;
        latestFilename = null;
        latestMime = "application/octet-stream";
        return;
      }

      const raw = normalizeB64Input(inputEl.value);
      if (!raw) throw new Error("Please paste Base64 input to decode.");

      let b64 = raw;
      const maybeUrlSafe = /[-_]/.test(b64) && !/[+/]/.test(b64);
      const useUrlSafe = urlSafe || maybeUrlSafe;

      if (useUrlSafe) b64 = fromUrlSafe(b64);

      if (!/={0,2}$/.test(b64)) {
        const mod = b64.length % 4;
        if (mod === 2) b64 += "==";
        else if (mod === 3) b64 += "=";
        else if (mod === 1) throw new Error("Invalid Base64 length.");
      }

      if (!/^[A-Za-z0-9+/]+={0,2}$/.test(b64)) {
        throw new Error("Invalid Base64 characters detected.");
      }

      const bytes = base64ToBytes(b64);
      latestBytes = bytes;
      latestMime = guessMimeFromBytes(bytes);

      let textOut = "";
      let textBadge = null;

      try {
        textOut = decodeBytesToText(bytes, charset);
        outEl.value = textOut;
        textBadge = { text: charset === "latin1" ? "Latin-1 text" : "UTF-8 text", kind: "neutral" };
      } catch (e) {
        outEl.value = "";
        textBadge = { text: "Binary data", kind: "warn" };
        summaryEl.innerHTML = `
          <strong>Decoded to bytes.</strong>
          <div class="note" style="margin-top:6px;">
            The decoded data does not appear to be valid text for the selected charset. Use “Download file”.
          </div>
        `;
      }

      latestFilename = "decoded.bin";
      if (latestMime === "image/png") latestFilename = "decoded.png";
      else if (latestMime === "image/jpeg") latestFilename = "decoded.jpg";
      else if (latestMime === "image/gif") latestFilename = "decoded.gif";
      else if (latestMime === "application/pdf") latestFilename = "decoded.pdf";
      else if (latestMime === "application/zip") latestFilename = "decoded.zip";

      if (!summaryEl.innerHTML || summaryEl.textContent === "Result will appear here.") {
        summaryEl.innerHTML = `
          <strong>Decoded successfully.</strong>
          <div class="note" style="margin-top:6px;">
            Output shown as text when possible. Use “Download file” for binary data.
          </div>
        `;
      }

      updateCards({
        mode,
        inLen: raw.length,
        outLen: outEl.value.length,
        urlSafe: useUrlSafe,
        keepPad,
        bytesLen: bytes.length,
        mimeHint: latestMime,
        noteBadge: textBadge
      });

    } catch (e) {
      resetOutput();
      showError(e && e.message ? e.message : "Failed to process input.");
    }
  }

  async function copyOutput() {
    clearError();
    const v = String(outEl.value ?? "");
    if (!v) {
      showError("Nothing to copy.");
      return;
    }

    try {
      await navigator.clipboard.writeText(v);
      summaryEl.innerHTML = "<strong>Copied.</strong> <span class='note'>Output copied to clipboard.</span>";
    } catch {
      showError("Copy failed (browser permission). Select the output and copy manually.");
    }
  }

  function downloadDecoded() {
    clearError();
    if (!latestBytes || !latestBytes.length) {
      showError("Nothing to download. Decode Base64 first.");
      return;
    }

    const blob = new Blob([latestBytes], { type: latestMime || "application/octet-stream" });
    const a = document.createElement("a");
    const url = URL.createObjectURL(blob);
    a.href = url;
    a.download = latestFilename || "decoded.bin";
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  }

  function clearAll() {
    clearError();
    modeEl.value = "encode";
    inputEl.value = "";
    fileEl.value = "";
    urlSafeEl.checked = false;
    paddingEl.checked = true;
    charsetEl.value = "utf8";
    resetOutput();
    setModeUI();
  }

  modeEl.addEventListener("change", function () {
    setModeUI();
    clearError();
    resetOutput();
  });

  runBtn.addEventListener("click", run);
  copyBtn.addEventListener("click", copyOutput);
  dlBtn.addEventListener("click", downloadDecoded);
  clearBtn.addEventListener("click", clearAll);

  inputEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") run();
  });

  setModeUI();
  clearAll();
});
</script>