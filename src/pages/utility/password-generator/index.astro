---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Strong Password Generator",
  description: "Free secure password generator. Create strong random passwords online using cryptographic randomness.",
  href: "/utility/password-generator/",
  order: 20, // ✅ keep as-is
};
---

<ToolLayout
  title="Strong Password Generator — MinimalDev"
  description="Free secure password generator. Create strong random passwords online using browser cryptographic APIs. Fully private."
  canonicalPath="/utility/password-generator/"
  h1="Strong Password Generator"
  intro="Generate strong, secure random passwords locally in your browser. Choose length and character types with guaranteed inclusion."
>
  <div slot="tool" data-tool="password-generator">
    <div class="form">
      <div class="field">
        <label for="pw_len">Length (8–64)</label>
        <input
          id="pw_len"
          type="number"
          inputmode="numeric"
          value="16"
          min="8"
          max="64"
          step="1"
          aria-describedby="pw_help pw_error"
        />
      </div>

      <fieldset class="field" style="margin:0; padding:0; border:0;">
        <legend class="note" style="margin:0 0 6px; font-weight:600;">Character types</legend>

        <label style="display:flex; gap:10px; align-items:center;">
          <input id="pw_upper" type="checkbox" checked />
          <span>Uppercase (A–Z)</span>
        </label>

        <label style="display:flex; gap:10px; align-items:center; margin-top:6px;">
          <input id="pw_lower" type="checkbox" checked />
          <span>Lowercase (a–z)</span>
        </label>

        <label style="display:flex; gap:10px; align-items:center; margin-top:6px;">
          <input id="pw_num" type="checkbox" checked />
          <span>Numbers (0–9)</span>
        </label>

        <label style="display:flex; gap:10px; align-items:center; margin-top:6px;">
          <input id="pw_sym" type="checkbox" />
          <span>Symbols (!@#$...)</span>
        </label>

        <div id="pw_error" class="note" style="margin-top:8px;" aria-live="polite"></div>
      </fieldset>

      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:12px;">
        <button class="btn" type="button" id="pw_generate">Generate</button>
        <button class="btn secondary" type="button" id="pw_copy" disabled>Copy</button>
        <button class="btn secondary" type="button" id="pw_clear">Clear</button>
      </div>

      <div class="field" style="margin-top:12px;">
        <label for="pw_result">Generated password</label>
        <input
          id="pw_result"
          type="text"
          readonly
          autocapitalize="off"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          inputmode="text"
          aria-describedby="pw_strength pw_help"
        />
        <div id="pw_strength" class="note" style="margin-top:6px;" aria-live="polite">
          Result will appear here.
        </div>
      </div>

      <!-- Screen-reader summary -->
      <div
        class="note"
        id="pw_sr_summary"
        style="position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;"
      ></div>

      <p class="note" id="pw_help" style="margin-top:10px;">
        Generated entirely in your browser using cryptographically secure randomness. No passwords are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This tool uses the browser’s secure cryptographic APIs (<code>crypto.getRandomValues()</code>) to generate random characters.
      It guarantees at least one character from each selected character set.
    </p>

    <ul>
      <li><strong>Custom length:</strong> 8–64 characters</li>
      <li><strong>Character sets:</strong> uppercase, lowercase, numbers, symbols</li>
      <li><strong>High entropy:</strong> Longer passwords with more character sets increase security</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Length 16</strong> + letters + numbers → strong general account password</li>
      <li><strong>Length 24</strong> + symbols → high-entropy password for critical accounts</li>
      <li><strong>Length 32+</strong> → maximum security for password managers</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>Is this password generator secure?</strong> Yes. It uses cryptographically secure randomness provided by your browser.</li>
      <li><strong>Is this an online password generator?</strong> Yes, but generation happens locally in your browser, not on a server.</li>
      <li><strong>Are generated passwords stored?</strong> No. Nothing is saved or transmitted.</li>
      <li><strong>What is a strong password?</strong> A password that is long, random, and includes multiple character types.</li>
      <li><strong>Should I reuse passwords?</strong> No. Always use unique passwords for each account.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/utility/uuid-generator/">UUID Generator</a></li>
      <li><a href="/utility/random-number-generator/">Random Number Generator</a></li>
      <li><a href="/utility/">Utility Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<!-- FAQ schema (auto-generated from a single source of truth in this file) -->
<script is:inline type="application/ld+json" id="pw_faq_schema"></script>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const lenEl = document.getElementById("pw_len");
  const upperEl = document.getElementById("pw_upper");
  const lowerEl = document.getElementById("pw_lower");
  const numEl = document.getElementById("pw_num");
  const symEl = document.getElementById("pw_sym");
  const genBtn = document.getElementById("pw_generate");
  const copyBtn = document.getElementById("pw_copy");
  const clearBtn = document.getElementById("pw_clear");
  const outEl = document.getElementById("pw_result");
  const strengthEl = document.getElementById("pw_strength");
  const errEl = document.getElementById("pw_error");
  const srEl = document.getElementById("pw_sr_summary");
  const faqSchemaEl = document.getElementById("pw_faq_schema");

  if (
    !lenEl || !upperEl || !lowerEl || !numEl || !symEl ||
    !genBtn || !copyBtn || !clearBtn || !outEl || !strengthEl || !errEl || !srEl || !faqSchemaEl
  ) return;

  // Single source of truth for FAQ content (schema uses this)
  const FAQ = [
    {
      q: "Is this password generator secure?",
      a: "Yes. It uses your browser’s cryptographically secure random number generator (crypto.getRandomValues). Passwords are generated locally on your device.",
    },
    {
      q: "Is this an online password generator?",
      a: "Yes, but generation happens locally in your browser (no server-side generation).",
    },
    {
      q: "Are generated passwords stored?",
      a: "No. Inputs and results are not stored or transmitted by this page.",
    },
    {
      q: "What is a strong password?",
      a: "A strong password is long, random, and uses a mix of character types. Longer length generally increases security more than adding complexity alone.",
    },
    {
      q: "Should I reuse passwords?",
      a: "No. Use a unique password for each account to reduce risk if one site is compromised.",
    },
  ];

  function renderFaqSchema() {
    const json = {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: FAQ.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    };
    faqSchemaEl.textContent = JSON.stringify(json);
  }

  const SETS = {
    upper: "ABCDEFGHIJKLMNOPQRSTUVWXYZ",
    lower: "abcdefghijklmnopqrstuvwxyz",
    num: "0123456789",
    // Conservative symbol set to avoid whitespace and ambiguous chars
    sym: "!@#$%^&*()-_=+[]{};:,.?/<>~",
  };

  function toInt(v) {
    const n = parseInt(String(v), 10);
    return Number.isFinite(n) ? n : NaN;
  }

  function clearError() {
    lenEl.removeAttribute("aria-invalid");
    errEl.textContent = "";
  }

  function setError(msg) {
    errEl.textContent = msg;
    lenEl.setAttribute("aria-invalid", "true");
  }

  function selectedSets() {
    const picks = [];
    if (upperEl.checked) picks.push(SETS.upper);
    if (lowerEl.checked) picks.push(SETS.lower);
    if (numEl.checked) picks.push(SETS.num);
    if (symEl.checked) picks.push(SETS.sym);
    return picks;
  }

  function randInt(maxExclusive) {
    // uniform sampling using rejection to avoid modulo bias
    if (!Number.isFinite(maxExclusive) || maxExclusive <= 0) return 0;
    const max = maxExclusive >>> 0;
    const limit = Math.floor(0x100000000 / max) * max;

    const buf = new Uint32Array(1);
    while (true) {
      crypto.getRandomValues(buf);
      const x = buf[0];
      if (x < limit) return x % max;
    }
  }

  function shuffle(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = randInt(i + 1);
      const tmp = arr[i];
      arr[i] = arr[j];
      arr[j] = tmp;
    }
    return arr;
  }

  function estimateEntropyBits(length, poolSize) {
    // bits ≈ length * log2(poolSize)
    if (!Number.isFinite(length) || !Number.isFinite(poolSize) || length <= 0 || poolSize <= 1) return 0;
    return length * (Math.log(poolSize) / Math.log(2));
  }

  function formatBits(bits) {
    const b = Math.round(bits);
    return b.toLocaleString() + " bits (approx.)";
  }

  function strengthLabel(bits) {
    // Conservative coarse labeling (informational only)
    if (bits >= 120) return "Very strong";
    if (bits >= 80) return "Strong";
    if (bits >= 60) return "Good";
    if (bits >= 40) return "Weak";
    return "Very weak";
  }

  function updateButtons() {
    copyBtn.disabled = !String(outEl.value || "").length;
  }

  function updateStrengthDisplay(length, poolSize) {
    const bits = estimateEntropyBits(length, poolSize);
    const label = strengthLabel(bits);
    strengthEl.innerHTML =
      "<strong>" + label + "</strong> <span class='note' style='margin-left:6px;'>" +
      formatBits(bits) + " · " + length.toLocaleString() + " chars · pool " + poolSize.toLocaleString() +
      "</span>";
  }

  function buildPool(sets) {
    // De-duplicate characters across sets just in case
    const all = sets.join("");
    const uniq = Array.from(new Set(all.split("")));
    return uniq.join("");
  }

  function generatePassword() {
    clearError();

    if (!("crypto" in window) || !crypto.getRandomValues) {
      setError("Your browser does not support secure randomness (crypto.getRandomValues).");
      return null;
    }

    const length = toInt(lenEl.value);
    if (!Number.isFinite(length) || length < 8 || length > 64) {
      setError("Please choose a length between 8 and 64.");
      return null;
    }

    const sets = selectedSets();
    if (sets.length === 0) {
      errEl.textContent = "Select at least one character type.";
      outEl.value = "";
      strengthEl.textContent = "Result will appear here.";
      updateButtons();
      return null;
    }

    if (length < sets.length) {
      setError("Length must be at least the number of selected character types (" + sets.length + ").");
      return null;
    }

    const pool = buildPool(sets);
    const poolSize = pool.length;

    // Guaranteed inclusion: pick 1 from each selected set
    const chars = [];

    for (let i = 0; i < sets.length; i++) {
      const s = sets[i];
      chars.push(s.charAt(randInt(s.length)));
    }

    // Fill the rest from the full pool
    while (chars.length < length) {
      chars.push(pool.charAt(randInt(poolSize)));
    }

    shuffle(chars);
    const pw = chars.join("");

    outEl.value = pw;
    updateStrengthDisplay(length, poolSize);
    srEl.textContent = "Password generated. " + length + " characters. " + strengthLabel(estimateEntropyBits(length, poolSize)) + ".";
    updateButtons();

    return pw;
  }

  async function copyPassword() {
    const pw = String(outEl.value || "");
    if (!pw) return;

    try {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        await navigator.clipboard.writeText(pw);
      } else {
        // Fallback for older browsers
        outEl.focus();
        outEl.select();
        const ok = document.execCommand && document.execCommand("copy");
        if (!ok) throw new Error("copy_failed");
        outEl.setSelectionRange(outEl.value.length, outEl.value.length);
      }
      errEl.textContent = "";
      strengthEl.innerHTML = "<strong>Copied</strong> <span class='note' style='margin-left:6px;'>Clipboard updated.</span>";
      srEl.textContent = "Password copied to clipboard.";
    } catch (e) {
      errEl.textContent = "Copy failed. Please copy manually.";
      srEl.textContent = "Copy failed.";
      outEl.focus();
      outEl.select();
    }
  }

  function clearAll() {
    lenEl.value = "16";
    upperEl.checked = true;
    lowerEl.checked = true;
    numEl.checked = true;
    symEl.checked = false;
    outEl.value = "";
    clearError();
    strengthEl.textContent = "Result will appear here.";
    srEl.textContent = "";
    updateButtons();
    lenEl.focus();
  }

  // Events
  genBtn.addEventListener("click", function () {
    const pw = generatePassword();
    if (!pw) {
      // focus guidance
      if (lenEl.getAttribute("aria-invalid") === "true") lenEl.focus();
    }
  });

  copyBtn.addEventListener("click", function () { copyPassword(); });

  clearBtn.addEventListener("click", function () { clearAll(); });

  // UX: if user changes options after generating, keep result but refresh strength estimate for the new pool
  function refreshStrengthIfPresent() {
    clearError();
    const pw = String(outEl.value || "");
    if (!pw) return;
    const length = pw.length;
    const sets = selectedSets();
    if (!sets.length) {
      strengthEl.textContent = "Select at least one character type.";
      return;
    }
    const pool = buildPool(sets);
    updateStrengthDisplay(length, pool.length);
  }

  lenEl.addEventListener("input", function () {
    // validate live but don't block typing
    const length = toInt(lenEl.value);
    if (!String(lenEl.value || "").trim()) {
      clearError();
      return;
    }
    if (!Number.isFinite(length) || length < 8 || length > 64) {
      setError("Length must be 8–64.");
      return;
    }
    clearError();
    refreshStrengthIfPresent();
  });

  [upperEl, lowerEl, numEl, symEl].forEach((el) => {
    el.addEventListener("change", function () {
      // Prevent "no set selected" state from being silent
      if (selectedSets().length === 0) {
        errEl.textContent = "Select at least one character type.";
      } else {
        errEl.textContent = "";
      }
      refreshStrengthIfPresent();
    });
  });

  // Init
  renderFaqSchema();
  updateButtons();
});
</script>