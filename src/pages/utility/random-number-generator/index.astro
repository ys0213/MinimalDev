---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Random Number Generator",
  description: "Generate random numbers with real-world usage explanations and result interpretation.",
  href: "/utility/random-number-generator/",
  order: 90,
};

const faqs = [
  {
    q: "Is this random generator secure?",
    a: "It uses crypto.getRandomValues for randomness, which is suitable for general use but not for cryptographic keys.",
  },
  {
    q: "Are min and max included?",
    a: "Yes. The range is inclusive, meaning both min and max can appear.",
  },
  {
    q: "Can numbers repeat?",
    a: "Yes by default. Enable unique mode to prevent duplicates.",
  },
  {
    q: "What is the difference between unique and non-unique?",
    a: "Unique mode ensures no duplicates, while non-unique allows repeated values.",
  },
  {
    q: "When should I use unique mode?",
    a: "Use it for raffles, lotteries, or picking winners where duplicates are not allowed.",
  },
  {
    q: "Is this tool suitable for security?",
    a: "No. For passwords or tokens, use a dedicated secure generator.",
  },
  {
    q: "Is my data stored?",
    a: "No. Everything runs locally in your browser.",
  },
];
---

<ToolLayout
  title="Random Number Generator — MinimalDev"
  description="Generate random numbers and understand how to use them for real-world scenarios."
  canonicalPath="/utility/random-number-generator/"
  h1="Random Number Generator"
  intro="Generate random numbers and learn how to use them in scenarios like games, selection, and simulations."
  faq={faqs}
  categoryName="Utilities"
>
  <div slot="tool" data-tool="random-number-generator">
    <div class="form">
      <div class="field">
        <label for="rng_min">Min</label>
        <input
          id="rng_min"
          type="number"
          inputmode="numeric"
          step="1"
          placeholder="e.g., 1"
          aria-describedby="rng_hint rng_error"
        />
      </div>

      <div class="field">
        <label for="rng_max">Max</label>
        <input
          id="rng_max"
          type="number"
          inputmode="numeric"
          step="1"
          placeholder="e.g., 100"
          aria-describedby="rng_hint rng_error"
        />
      </div>

      <div class="field">
        <label for="rng_count">Count</label>
        <input
          id="rng_count"
          type="number"
          inputmode="numeric"
          value="1"
          min="1"
          max="100"
          step="1"
          aria-describedby="rng_hint rng_error"
        />
      </div>

      <fieldset class="field" style="margin:0; padding:0; border:0;">
        <legend class="note" style="margin:0 0 6px; font-weight:600;">Options</legend>

        <label style="display:flex; gap:10px; align-items:center;">
          <input id="rng_unique" type="checkbox" />
          <span>Unique numbers (no duplicates)</span>
        </label>

        <div id="rng_hint" class="note" style="margin-top:8px;">
          Range is inclusive. If unique numbers is on, count must be less than or equal to max − min + 1.
        </div>

        <div id="rng_error" class="note" style="margin-top:6px;" aria-live="polite"></div>
      </fieldset>

      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:12px;">
        <button class="btn" type="button" id="rng_generate">Generate</button>
        <button class="btn secondary" type="button" id="rng_copy" disabled>Copy</button>
        <button class="btn secondary" type="button" id="rng_clear">Clear</button>
      </div>

      <div class="result" id="rng_result" style="margin-top:12px;" aria-live="polite">
        Result will appear here.
      </div>

      <div
        class="note"
        id="rng_sr_summary"
        style="position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;"
      ></div>

      <p class="note" style="margin-top:8px;">
        Privacy: runs locally in your browser. No inputs or results are stored.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This tool generates random integers within a selected range.
    </p>

    <p class="note">
      <strong>How it works:</strong><br/>
      - Select minimum and maximum values<br/>
      - Choose how many numbers to generate<br/>
      - Optionally prevent duplicates
    </p>

    <p class="note">
      <strong>How to interpret results:</strong><br/>
      - Single value → random selection<br/>
      - Multiple values → sampling from a range<br/>
      - Unique mode → no repeated results
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Dice simulation:</strong> Min 1, Max 6, Count 5 → e.g. 3, 1, 6, 2, 4</li>
      <li><strong>Raffle:</strong> Min 1, Max 100, Count 3 (unique) → pick winners</li>
      <li><strong>Random test data:</strong> Min 1000, Max 9999 → generate sample numbers</li>
    </ul>

    <p class="note"><strong>Example:</strong></p>
    <ul>
      <li>Min 1, Max 10, Count 3 → 2, 7, 5</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/utility/random-string-generator/">Random String Generator</a></li>
      <li><a href="/utility/password-generator/">Password Generator</a></li>
      <li><a href="/utility/pin-generator/">PIN Generator</a></li>
      <li><a href="/utility/">All Utility Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const minEl = document.getElementById("rng_min");
  const maxEl = document.getElementById("rng_max");
  const countEl = document.getElementById("rng_count");
  const uniqueEl = document.getElementById("rng_unique");
  const genBtn = document.getElementById("rng_generate");
  const copyBtn = document.getElementById("rng_copy");
  const clearBtn = document.getElementById("rng_clear");
  const outEl = document.getElementById("rng_result");
  const errEl = document.getElementById("rng_error");
  const srEl = document.getElementById("rng_sr_summary");

  if (
    !minEl || !maxEl || !countEl || !uniqueEl ||
    !genBtn || !copyBtn || !clearBtn || !outEl || !errEl || !srEl
  ) return;

  function toInt(v) {
    const n = parseInt(String(v), 10);
    return Number.isFinite(n) ? n : NaN;
  }

  function clearError() {
    errEl.textContent = "";
    [minEl, maxEl, countEl].forEach((el) => el && el.removeAttribute("aria-invalid"));
  }

  function setError(msg, focusEl) {
    errEl.textContent = msg;
    if (focusEl) {
      focusEl.setAttribute("aria-invalid", "true");
      focusEl.focus();
    }
  }

  function randIntInclusive(min, max) {
    const range = max - min + 1;
    const maxU32 = 0x100000000;
    const limit = Math.floor(maxU32 / range) * range;
    const buf = new Uint32Array(1);

    while (true) {
      crypto.getRandomValues(buf);
      const x = buf[0];
      if (x < limit) return min + (x % range);
    }
  }

  function validate() {
    clearError();

    if (!("crypto" in window) || !crypto.getRandomValues) {
      setError("Your browser does not support secure randomness (crypto.getRandomValues).");
      return null;
    }

    const min = toInt(minEl.value);
    const max = toInt(maxEl.value);
    const count = toInt(countEl.value);
    const unique = !!uniqueEl.checked;

    if (!Number.isFinite(min)) {
      setError("Please enter a valid integer for Min.", minEl);
      return null;
    }
    if (!Number.isFinite(max)) {
      setError("Please enter a valid integer for Max.", maxEl);
      return null;
    }
    if (min > max) {
      setError("Min must be less than or equal to Max.", minEl);
      return null;
    }
    if (!Number.isFinite(count) || count < 1 || count > 100) {
      setError("Count must be between 1 and 100.", countEl);
      return null;
    }

    const size = max - min + 1;
    if (unique && count > size) {
      setError("With unique numbers on, count must be ≤ " + size.toLocaleString() + ".", countEl);
      return null;
    }

    return { min, max, count, unique, size };
  }

  function formatList(nums) {
    return nums.map((n) => n.toLocaleString()).join(", ");
  }

  function renderResult(nums, meta) {
    const list = formatList(nums);

    outEl.innerHTML =
      "<strong>Result:</strong> " + list + "<br/>" +
      "<span class='note'>Range " + meta.min.toLocaleString() + "–" + meta.max.toLocaleString() +
      " · " + meta.count.toLocaleString() + " number" + (meta.count === 1 ? "" : "s") +
      (meta.unique ? " · unique" : " · duplicates allowed") +
      "</span>";

    srEl.textContent = "Generated " + meta.count + " number" + (meta.count === 1 ? "" : "s") + ": " + list + ".";
    copyBtn.disabled = nums.length === 0;
  }

  function generate() {
    const meta = validate();
    if (!meta) return;

    const { min, max, count, unique, size } = meta;
    let nums = [];

    if (!unique) {
      for (let i = 0; i < count; i++) {
        nums.push(randIntInclusive(min, max));
      }
      renderResult(nums, meta);
      return;
    }

    if (count > size / 2) {
      nums = [];
      for (let v = min; v <= max; v++) nums.push(v);

      for (let i = nums.length - 1; i > 0; i--) {
        const j = randIntInclusive(0, i);
        const tmp = nums[i];
        nums[i] = nums[j];
        nums[j] = tmp;
      }

      nums = nums.slice(0, count);
      renderResult(nums, meta);
      return;
    }

    const seen = new Set();
    while (seen.size < count) {
      seen.add(randIntInclusive(min, max));
    }

    nums = Array.from(seen);
    renderResult(nums, meta);
  }

  async function copy() {
    const text = outEl.textContent || "";
    const match = text.match(/Result:\s*(.*)\s*Range/i);
    const payload = match && match[1] ? match[1].trim() : text.trim();

    if (!payload) return;

    try {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        await navigator.clipboard.writeText(payload);
      } else {
        const ta = document.createElement("textarea");
        ta.value = payload;
        ta.setAttribute("readonly", "true");
        ta.style.position = "absolute";
        ta.style.left = "-9999px";
        document.body.appendChild(ta);
        ta.select();
        const ok = document.execCommand && document.execCommand("copy");
        document.body.removeChild(ta);
        if (!ok) throw new Error("copy_failed");
      }

      errEl.textContent = "";
      srEl.textContent = "Copied to clipboard.";
    } catch (_) {
      errEl.textContent = "Copy failed. Please select and copy manually.";
      srEl.textContent = "Copy failed.";
    }
  }

  function clearAll() {
    minEl.value = "";
    maxEl.value = "";
    countEl.value = "1";
    uniqueEl.checked = false;
    clearError();
    outEl.textContent = "Result will appear here.";
    srEl.textContent = "";
    copyBtn.disabled = true;
    minEl.focus();
  }

  genBtn.addEventListener("click", generate);
  copyBtn.addEventListener("click", function () { copy(); });
  clearBtn.addEventListener("click", clearAll);

  [minEl, maxEl, countEl].forEach((el) => {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") generate();
    });
  });

  [minEl, maxEl, countEl].forEach((el) => {
    el.addEventListener("input", function () {
      if (!String(minEl.value || "").trim() || !String(maxEl.value || "").trim()) {
        clearError();
        return;
      }
      validate();
    });
  });

  copyBtn.disabled = true;
});
</script>