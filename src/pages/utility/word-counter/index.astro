---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Word Counter",
  description:
    "Count words, characters, sentences, and reading time with practical usage explanations.",
  href: "/utility/word-counter/",
  order: 50,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/utility/word-counter/";

const faqs = [
  {
    q: "What does this word counter measure?",
    a: "It counts words, characters, sentences, paragraphs, and estimates reading time.",
  },
  {
    q: "How are words counted?",
    a: "Words are split by whitespace. Multiple spaces and line breaks are handled correctly.",
  },
  {
    q: "How accurate is sentence counting?",
    a: "It uses punctuation heuristics and may differ slightly from grammar tools.",
  },
  {
    q: "How is reading time calculated?",
    a: "Reading time = word count ÷ WPM (words per minute).",
  },
  {
    q: "What is a typical reading speed?",
    a: "Most adults read between 150–250 WPM depending on content difficulty.",
  },
  {
    q: "When should I use this tool?",
    a: "For writing, SEO optimization, content planning, and readability checks.",
  },
  {
    q: "Is my text stored?",
    a: "No. All processing happens locally in your browser.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Word Counter — ${SITE_NAME}`}
  description="Count words and understand how to use the results for writing, SEO, and readability."
  canonicalPath={CANONICAL_PATH}
  h1="Word Counter"
  intro="Analyze your text and understand how word count and reading time affect real-world writing and content performance."
  faq={faqs}
  categoryName="Utilities"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="word-counter">
    <div class="form" role="form" aria-describedby="wc_privacy wc_help">
      <div class="field">
        <label for="wc_text">Text</label>
        <textarea
          id="wc_text"
          rows="10"
          placeholder="Paste or type your text here..."
          style="width:100%; resize:vertical;"
          aria-describedby="wc_help"
        ></textarea>
        <p class="note" id="wc_help" style="margin-top:6px;">
          Tip: line breaks are used to estimate paragraphs. Sentence counting is a heuristic.
        </p>
      </div>

      <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <div class="field" style="min-width:220px;">
          <label for="wc_wpm">Reading speed (WPM)</label>
          <input id="wc_wpm" type="number" inputmode="numeric" min="50" max="1000" step="10" value="200" />
          <p class="note" style="margin-top:6px;">Typical range: 150–250 WPM (adjust as needed).</p>
        </div>

        <div class="field" style="min-width:240px;">
          <label for="wc_mode">Count mode</label>
          <select id="wc_mode">
            <option value="standard" selected>Standard (whitespace-separated words)</option>
            <option value="strict">Strict (ignore punctuation-only tokens)</option>
          </select>
          <p class="note" style="margin-top:6px;">Strict mode can reduce counts for symbol-heavy text.</p>
        </div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:6px;">
        <button class="btn" type="button" id="wc_copy_stats">Copy stats</button>
        <button class="btn secondary" type="button" id="wc_clear">Clear</button>
      </div>

      <div class="result" id="wc_error" role="alert" style="display:none; margin-top:12px;"></div>

      <div class="result" id="wc_summary" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div class="result" id="wc_cards" style="margin-top:12px; display:none;"></div>

      <p class="note" id="wc_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No text is stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This tool analyzes your text and calculates multiple metrics.
    </p>

    <p class="note">
      <strong>How it works:</strong><br/>
      - Words: split by whitespace<br/>
      - Characters: includes and excludes spaces<br/>
      - Sentences: detected using punctuation (. ! ?)<br/>
      - Paragraphs: separated by blank lines<br/>
      - Reading time: words ÷ WPM
    </p>

    <p class="note">
      <strong>How to interpret results:</strong><br/>
      - Word count → content length<br/>
      - Reading time → user engagement expectation<br/>
      - Sentence count → writing complexity<br/>
      - Paragraphs → readability structure
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Blog writing:</strong> Aim for 1,000–2,000 words for SEO articles.</li>
      <li><strong>Emails:</strong> Keep under 200 words for quick reading.</li>
      <li><strong>Social media:</strong> Shorter content improves engagement.</li>
    </ul>

    <p class="note"><strong>Example:</strong></p>
    <ul>
      <li>500 words → about 2–3 minutes reading time</li>
      <li>1500 words → about 6–8 minutes reading time</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/utility/character-counter/">Character Counter</a></li>
      <li><a href="/utility/lorem-ipsum-generator/">Lorem Ipsum Generator</a></li>
      <li><a href="/utility/json-formatter/">JSON Formatter</a></li>
      <li><a href="/utility/">All Utility Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const textEl = document.getElementById("wc_text");
  const wpmEl = document.getElementById("wc_wpm");
  const modeEl = document.getElementById("wc_mode");
  const copyBtn = document.getElementById("wc_copy_stats");
  const clearBtn = document.getElementById("wc_clear");
  const errEl = document.getElementById("wc_error");
  const summaryEl = document.getElementById("wc_summary");
  const cardsEl = document.getElementById("wc_cards");

  if (!textEl || !wpmEl || !modeEl || !copyBtn || !clearBtn || !errEl || !summaryEl || !cardsEl) return;

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }
  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }
  function escapeHtml(str) {
    return String(str)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function clamp(n, min, max) {
    return Math.min(max, Math.max(min, n));
  }

  function badge(text, kind) {
    // kind: "good" | "warn" | "neutral"
    const border =
      kind === "good" ? "rgba(34,197,94,0.55)" :
      kind === "warn" ? "rgba(251,146,60,0.55)" :
      "rgba(255,255,255,0.2)";
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid ${border}; font-size:12px; font-weight:900;">${escapeHtml(text)}</span>`;
  }

  function card(title, big, sub) {
    return `
      <div style="border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:12px; flex:1; min-width:160px;">
        <strong>${escapeHtml(title)}</strong>
        <div style="font-size:28px; font-weight:900; margin-top:6px;">${escapeHtml(big)}</div>
        <div class="note" style="margin-top:4px;">${sub}</div>
      </div>
    `;
  }

  function isPunctOnlyToken(t) {
    // If it has no letters/numbers and has at least one non-space char, treat as punctuation-only.
    // Works for many Latin scripts; for full Unicode letter classes we'd need a heavier regex.
    return t.length > 0 && !/[A-Za-z0-9]/.test(t);
  }

  function countWords(text, mode) {
    const trimmed = text.trim();
    if (!trimmed) return 0;

    const tokens = trimmed.split(/\s+/).filter(Boolean);
    if (mode === "strict") {
      return tokens.filter(t => !isPunctOnlyToken(t)).length;
    }
    return tokens.length;
  }

  function countChars(text) {
    // JS length counts UTF-16 code units; for typical use this is acceptable.
    return text.length;
  }

  function countCharsNoSpaces(text) {
    return text.replace(/\s/g, "").length;
  }

  function countParagraphs(text) {
    const trimmed = text.trim();
    if (!trimmed) return 0;
    // Split on blank lines (one or more empty/whitespace-only lines)
    const parts = trimmed.split(/\n\s*\n+/).map(s => s.trim()).filter(Boolean);
    return parts.length;
  }

  function countSentences(text) {
    const trimmed = text.trim();
    if (!trimmed) return 0;

    // Heuristic: count occurrences of . ! ? that end a segment with at least one letter/number before it.
    // Avoid counting "..." as 3 sentences by compressing runs.
    const normalized = trimmed.replace(/([.!?]){2,}/g, "$1");
    const matches = normalized.match(/[A-Za-z0-9][^.!?]*[.!?]+/g);
    if (matches && matches.length) return matches.length;

    // If no end punctuation but there's text, assume 1 sentence.
    return trimmed.length ? 1 : 0;
  }

  function readingTime(words, wpm) {
    if (!words || !wpm) return { minutes: 0, seconds: 0, text: "0 sec" };
    const totalMinutes = words / wpm;
    const totalSeconds = Math.round(totalMinutes * 60);

    const minutes = Math.floor(totalSeconds / 60);
    const seconds = totalSeconds % 60;

    if (minutes <= 0) return { minutes, seconds, text: `${seconds} sec` };
    if (seconds === 0) return { minutes, seconds, text: `${minutes} min` };
    return { minutes, seconds, text: `${minutes} min ${seconds} sec` };
  }

  function render(stats) {
    const { words, chars, charsNoSpaces, sentences, paragraphs, wpm, mode, rt } = stats;

    // Category highlight
    const density = charsNoSpaces > 0 ? (words / charsNoSpaces) : 0;
    let densityLabel = "Normal";
    let densityKind = "neutral";
    // Very rough buckets (heuristic)
    if (density > 0.23) { densityLabel = "Wordy"; densityKind = "warn"; }
    else if (density < 0.12) { densityLabel = "Sparse"; densityKind = "warn"; }
    else { densityLabel = "Balanced"; densityKind = "good"; }

    summaryEl.innerHTML = `
      <div style="display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap; align-items:center;">
        <strong>Summary</strong>
        <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
          ${badge(`${words.toLocaleString()} words`, "good")}
          ${badge(`Reading: ${escapeHtml(rt.text)}`, "neutral")}
          ${badge(`${densityLabel}`, densityKind)}
        </div>
      </div>
      <div class="note" style="margin-top:8px;">
        Mode: <strong>${escapeHtml(mode)}</strong> · WPM: <strong>${escapeHtml(String(wpm))}</strong>
      </div>
    `;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:stretch;">
        ${card("Words", words.toLocaleString(), "Whitespace-separated words")}
        ${card("Characters", chars.toLocaleString(), "Includes spaces and newlines")}
        ${card("Chars (no spaces)", charsNoSpaces.toLocaleString(), "Excludes all whitespace")}
        ${card("Sentences", sentences.toLocaleString(), "Heuristic from . ! ?")}
        ${card("Paragraphs", paragraphs.toLocaleString(), "Separated by blank lines")}
      </div>
    `;
  }

  function compute() {
    clearError();

    const text = String(textEl.value || "");
    const mode = String(modeEl.value || "standard");

    const rawWpm = Number(String(wpmEl.value || "").trim());
    if (!Number.isFinite(rawWpm)) {
      showError("Please enter a valid WPM (reading speed).");
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      summaryEl.textContent = "Result will appear here.";
      return;
    }
    const wpm = clamp(Math.round(rawWpm), 50, 1000);
    if (wpm !== rawWpm) wpmEl.value = String(wpm);

    const words = countWords(text, mode);
    const chars = countChars(text);
    const charsNoSpaces = countCharsNoSpaces(text);
    const sentences = countSentences(text);
    const paragraphs = countParagraphs(text);
    const rt = readingTime(words, wpm);

    render({ words, chars, charsNoSpaces, sentences, paragraphs, wpm, mode, rt });
  }

  async function copyStats() {
    clearError();
    const text = String(textEl.value || "");
    if (!text.trim()) {
      showError("Enter some text first.");
      return;
    }

    // Make sure UI stats are up-to-date
    compute();

    // Read numbers from rendered cards would be fragile; recompute instead.
    const mode = String(modeEl.value || "standard");
    const wpm = clamp(Math.round(Number(String(wpmEl.value || "").trim())), 50, 1000);

    const words = countWords(text, mode);
    const chars = countChars(text);
    const charsNoSpaces = countCharsNoSpaces(text);
    const sentences = countSentences(text);
    const paragraphs = countParagraphs(text);
    const rt = readingTime(words, wpm);

    const payload =
      `Words: ${words}\n` +
      `Characters (with spaces): ${chars}\n` +
      `Characters (no spaces): ${charsNoSpaces}\n` +
      `Sentences: ${sentences}\n` +
      `Paragraphs: ${paragraphs}\n` +
      `Reading time (@${wpm} WPM): ${rt.text}\n` +
      `Mode: ${mode}`;

    try {
      await navigator.clipboard.writeText(payload);
      summaryEl.innerHTML = `
        <strong>Copied.</strong>
        <div class="note" style="margin-top:6px;">Stats copied to clipboard (not the text).</div>
      `;
    } catch (e) {
      showError("Could not copy. Your browser may block clipboard access on this page.");
    }
  }

  function clearAll() {
    clearError();
    textEl.value = "";
    summaryEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    wpmEl.value = "200";
    modeEl.value = "standard";
    textEl.focus();
  }

  // Live updates (debounced)
  let t = null;
  function scheduleCompute() {
    if (t) window.clearTimeout(t);
    t = window.setTimeout(function () {
      if (String(textEl.value || "").trim()) compute();
      else {
        clearError();
        summaryEl.textContent = "Result will appear here.";
        cardsEl.style.display = "none";
        cardsEl.innerHTML = "";
      }
    }, 120);
  }

  textEl.addEventListener("input", scheduleCompute);
  wpmEl.addEventListener("input", scheduleCompute);
  modeEl.addEventListener("change", scheduleCompute);

  copyBtn.addEventListener("click", copyStats);
  clearBtn.addEventListener("click", clearAll);

  clearAll();
});
</script>