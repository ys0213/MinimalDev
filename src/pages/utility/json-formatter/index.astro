---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "JSON Formatter",
  description:
    "Format, validate, and minify JSON for easier reading and debugging.",
  href: "/utility/json-formatter/",
  order: 70,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/utility/json-formatter/";

const faqs = [
  {
    q: "What does this JSON formatter do?",
    a: "It formats JSON for readability, validates syntax, and can minify JSON to reduce size.",
  },
  {
    q: "Is my JSON uploaded?",
    a: "No. All processing happens locally in your browser.",
  },
  {
    q: "Why is my JSON invalid?",
    a: "Common issues include trailing commas, comments, missing quotes, or invalid values like NaN.",
  },
  {
    q: "When should I use minify?",
    a: "Minified JSON is useful for APIs and production environments to reduce file size.",
  },
  {
    q: "When should I use pretty print?",
    a: "Pretty format is ideal for debugging and reading JSON during development.",
  },
  {
    q: "Does it reorder keys?",
    a: "Only if you choose sorting. Otherwise original order is preserved.",
  },
  {
    q: "What is JSON used for?",
    a: "JSON is widely used for APIs, configuration files, and data exchange between systems.",
  },
  {
    q: "Can I format large JSON?",
    a: "Very large JSON may impact browser performance. This tool includes size limits for stability.",
  },
];

---

<ToolLayout
  title={`JSON Formatter — ${SITE_NAME}`}
  description="Format, validate, minify, and inspect JSON data for API responses, configuration files, debugging, and development workflows."
  canonicalPath={CANONICAL_PATH}
  h1="JSON Formatter"
  intro="Paste JSON to format (pretty-print), minify, and validate. This tool helps developers debug APIs, inspect data structures, and optimize JSON for production use."
  faq={faqs}
  categoryName="Utilities"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JSON Formatter",
    "description": "Format, validate, and minify JSON online. Useful for API debugging, configuration files, and developer workflows.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <div slot="tool" data-tool="json-formatter">
    <div style="background: #f0fdf4; border: 1px solid #bbf7d0; padding: 10px; border-radius: 6px; margin-bottom: 20px;">
      <strong>Privacy First:</strong> Everything is processed locally in your browser. <strong>Your data is never sent to our servers.</strong>
    </div>
    <div class="form" role="form" aria-describedby="jf_hint jf_privacy">
      <div class="field">
        <label for="jf_input">Input JSON</label>
        <textarea
          id="jf_input"
          rows="10"
          placeholder='e.g., {"name":"MinimalDev","tools":100}'
          style="resize:vertical;"
          spellcheck="false"
          autocapitalize="off"
          autocomplete="off"
        ></textarea>
        <p class="note" id="jf_hint" style="margin-top:6px;">
          Standard JSON only (no comments, no trailing commas, keys must be in double quotes).
          Press <kbd>Ctrl</kbd>/<kbd>Cmd</kbd> + <kbd>Enter</kbd> to format.
        </p>
      </div>

      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
        <div class="field">
          <label for="jf_indent">Indent</label>
          <select id="jf_indent">
            <option value="2" selected>2 spaces</option>
            <option value="4">4 spaces</option>
            <option value="tab">Tab</option>
          </select>
        </div>

        <div class="field">
          <label for="jf_sort">Key order</label>
          <select id="jf_sort">
            <option value="none" selected>Keep as parsed</option>
            <option value="asc">Sort keys (A → Z)</option>
          </select>
        </div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <button class="btn" type="button" id="jf_pretty">Pretty print</button>
        <button class="btn secondary" type="button" id="jf_minify">Minify</button>
        <button class="btn secondary" type="button" id="jf_validate">Validate</button>
        <button class="btn secondary" type="button" id="jf_copy">Copy output</button>
        <button class="btn secondary" type="button" id="jf_clear">Clear</button>
      </div>

      <div class="result" id="jf_error" role="alert" style="display:none; margin-top:12px;"></div>

      <div class="result" id="jf_result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div class="result" id="jf_cards" style="display:none; margin-top:12px;"></div>

      <div class="field" style="margin-top:10px;">
        <label for="jf_output">Output</label>
        <textarea
          id="jf_output"
          rows="10"
          placeholder="Formatted JSON will appear here."
          style="resize:vertical;"
          spellcheck="false"
          autocapitalize="off"
          autocomplete="off"
          readonly
        ></textarea>
      </div>

      <p class="note" id="jf_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No JSON is stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This tool uses JSON.parse to validate syntax and JSON.stringify to format or minify data.
    </p>

    <p class="note">
      <strong>How it works:</strong><br/>
      - Validate: checks if JSON is syntactically correct<br/>
      - Pretty print: adds indentation for readability<br/>
      - Minify: removes whitespace to reduce size
    </p>

    <p class="note">
      <strong>How to interpret results:</strong><br/>
      - Valid JSON → safe to use in APIs or configs<br/>
      - Pretty JSON → easier debugging and editing<br/>
      - Minified JSON → optimized for performance and transfer size
    </p>

    <div class="prose" style="margin-top:16px;">
      <h2>What is JSON and Why It Matters</h2>
      <p>
        JSON (JavaScript Object Notation) is a lightweight data format used for exchanging information between systems. It is widely used in APIs, web applications, configuration files, and modern backend services. Unlike XML, JSON is easier to read and write, making it the default format for most web-based data communication.
      </p>

      <p>
        For developers, JSON is essential when working with REST APIs, frontend frameworks, or databases. However, raw JSON data is often difficult to read due to lack of formatting. This is where a JSON formatter becomes critical.
      </p>

      <h2>Pretty Print vs Minify: Key Differences</h2>
      <p>
        JSON data can be represented in two main ways depending on the use case: formatted (pretty) or minified.
      </p>

      <ul>
        <li><strong>Pretty Print:</strong> Adds indentation and line breaks to improve readability. Ideal for debugging and development.</li>
        <li><strong>Minify:</strong> Removes unnecessary whitespace to reduce file size. Best for production and network efficiency.</li>
      </ul>

      <p>
        The trade-off is simple: readability versus performance. During development, readability is more important. In production, smaller payload size improves load speed and reduces bandwidth usage.
      </p>

      <h2>Real-World Use Cases</h2>
      <p>
        Developers frequently encounter unformatted JSON when working with APIs. For example, when calling an API endpoint, the response is often returned as a single-line JSON string. This makes debugging difficult.
      </p>

      <p>
        Using a formatter allows you to quickly convert that raw response into a structured format, making it easier to identify fields, nested objects, and data inconsistencies.
      </p>

      <ul>
        <li><strong>API debugging:</strong> Inspect responses and detect missing or incorrect fields</li>
        <li><strong>Configuration editing:</strong> Validate JSON before saving config files</li>
        <li><strong>Performance optimization:</strong> Minify JSON before sending it over the network</li>
      </ul>

      <h2>Common JSON Errors Explained</h2>
      <p>
        Many JSON validation errors come from small syntax mistakes. Understanding these can save significant debugging time.
      </p>

      <ul>
        <li>Trailing commas (e.g., <code>&#123;"name":"John",&#125;</code>)</li>
        <li>Missing double quotes around keys</li>
        <li>Using comments (JSON does not support comments)</li>
        <li>Invalid values such as NaN or undefined</li>
      </ul>

      <p>
        This tool helps identify these issues by pointing to the approximate location of the error, allowing you to fix problems quickly.
      </p>

      <h2>Why Use a Local JSON Formatter</h2>
      <p>
        Many online tools send your data to a server for processing. This can be a concern when working with sensitive information. This tool runs entirely in your browser, ensuring that your data never leaves your device.
      </p>

      <p>
        This makes it suitable for handling API keys, private configurations, and any confidential JSON data without security risks.
      </p>

      <h2>When to Use This JSON Formatter</h2>
      <p>
      This tool is useful whenever you need to inspect, validate, or optimize JSON data.
      It is commonly used during API development, debugging responses, or preparing JSON for production environments.
      </p>

      <p>
      Use pretty print when readability matters, such as debugging or reviewing data structures.
      Use minify when performance matters, especially when sending JSON over networks.
      </p>
    </div>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>API debugging:</strong> Format messy API responses to readable structure.</li>
      <li><strong>Production optimization:</strong> Minify JSON before sending to reduce bandwidth.</li>
      <li><strong>Validation:</strong> Check if JSON is valid before using in code.</li>
    </ul>

    <p class="note"><strong>Example:</strong></p>
    <ul>
      <li>Input: <code>&#123;"name":"app","users":[1,2]&#125;</code></li>
      <li>Pretty → structured output with indentation</li>
      <li>Minify → compact version without spaces</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/utility/base64/">Base64 Encoder / Decoder</a></li>
      <li><a href="/utility/url-encoder-decoder/">URL Encoder / Decoder</a></li>
      <li><a href="/utility/random-string-generator/">Random String Generator</a></li>
      <li><a href="/math/percent-calculator/">Percent Calculator</a></li>
      <li><a href="/finance/compound-interest-calculator/">Compound Interest Calculator</a></li>
      <li><a href="/utility/">All Utility Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("jf_input");
  const outEl = document.getElementById("jf_output");

  const indentEl = document.getElementById("jf_indent");
  const sortEl = document.getElementById("jf_sort");

  const prettyBtn = document.getElementById("jf_pretty");
  const minifyBtn = document.getElementById("jf_minify");
  const validateBtn = document.getElementById("jf_validate");
  const copyBtn = document.getElementById("jf_copy");
  const clearBtn = document.getElementById("jf_clear");

  const errEl = document.getElementById("jf_error");
  const resEl = document.getElementById("jf_result");
  const cardsEl = document.getElementById("jf_cards");

  if (!inEl || !outEl || !indentEl || !sortEl || !prettyBtn || !minifyBtn || !validateBtn || !copyBtn || !clearBtn || !errEl || !resEl || !cardsEl) return;

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }
  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function badge(text, kind) {
    const border = kind === "warn"
      ? "rgba(251,146,60,0.55)"
      : kind === "good"
      ? "rgba(34,197,94,0.55)"
      : "rgba(255,255,255,0.2)";
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid ${border}; font-size:12px; font-weight:900;">${text}</span>`;
  }

  function bytesApprox(str) {
    // Approx UTF-8 byte length
    try {
      return new TextEncoder().encode(str).length;
    } catch (_) {
      // fallback: rough estimate
      return str.length;
    }
  }

  function fmtBytes(n) {
    if (!Number.isFinite(n)) return "—";
    if (n < 1024) return n + " B";
    const kb = n / 1024;
    if (kb < 1024) return (Math.round(kb * 10) / 10) + " KB";
    const mb = kb / 1024;
    return (Math.round(mb * 10) / 10) + " MB";
  }

  function extractLineColFromMessage(msg) {
    // Typical message: "Unexpected token ... in JSON at position 123"
    const m = String(msg || "").match(/position\s+(\d+)/i);
    if (!m) return null;
    const pos = parseInt(m[1], 10);
    if (!Number.isFinite(pos) || pos < 0) return null;

    const text = String(inEl.value || "");
    let line = 1;
    let col = 1;
    for (let i = 0; i < text.length && i < pos; i++) {
      const ch = text[i];
      if (ch === "\n") { line++; col = 1; }
      else col++;
    }
    return { pos, line, col };
  }

  function sortKeysDeep(value) {
    if (Array.isArray(value)) return value.map(sortKeysDeep);
    if (value && typeof value === "object") {
      const out = {};
      const keys = Object.keys(value).sort((a, b) => a.localeCompare(b));
      for (const k of keys) out[k] = sortKeysDeep(value[k]);
      return out;
    }
    return value;
  }

  function parseJsonStrict() {
    const raw = String(inEl.value || "").trim();
    if (!raw) return { ok: false, msg: "Please paste JSON into the input box." };

    // Guardrail: huge inputs can freeze the UI
    if (raw.length > 2_000_000) {
      return { ok: false, msg: "Input is too large (over 2,000,000 characters). Please use a smaller JSON." };
    }

    try {
      const parsed = JSON.parse(raw);
      return { ok: true, value: parsed, raw };
    } catch (e) {
      const msg = (e && e.message) ? e.message : "Invalid JSON.";
      const lc = extractLineColFromMessage(msg);
      const hint = lc ? ` (approx line ${lc.line}, col ${lc.col})` : "";
      return { ok: false, msg: "Invalid JSON: " + msg + hint };
    }
  }

  function setCards(info) {
    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(info.status, info.statusKind)}
        ${badge("Input: " + info.inputSize, "neutral")}
        ${badge("Output: " + info.outputSize, "neutral")}
        ${badge(info.mode, "neutral")}
        ${badge(info.keyOrder, "neutral")}
      </div>
    `;
  }

  function setResult(html) {
    resEl.innerHTML = html;
  }

  function validateOnly() {
    clearError();
    const parsed = parseJsonStrict();
    if (!parsed.ok) {
      showError(parsed.msg);
      setResult("Result will appear here.");
      outEl.value = "";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      return;
    }

    const inputBytes = bytesApprox(parsed.raw);
    setResult("<strong>Valid JSON.</strong> <span class='note'>Parsed successfully.</span>");
    setCards({
      status: "Valid",
      statusKind: "good",
      inputSize: fmtBytes(inputBytes),
      outputSize: "—",
      mode: "Validate",
      keyOrder: (String(sortEl.value) === "asc" ? "Keys: sorted" : "Keys: as parsed"),
    });
  }

  function prettyPrint() {
    clearError();
    const parsed = parseJsonStrict();
    if (!parsed.ok) {
      showError(parsed.msg);
      setResult("Result will appear here.");
      outEl.value = "";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      return;
    }

    const sortMode = String(sortEl.value);
    let value = parsed.value;
    if (sortMode === "asc") value = sortKeysDeep(value);

    const indentMode = String(indentEl.value);
    const space = indentMode === "tab" ? "\t" : parseInt(indentMode, 10);
    const indent = (space === "\t" || Number.isFinite(space)) ? space : 2;

    let out = "";
    try {
      out = JSON.stringify(value, null, indent);
    } catch (_) {
      showError("Could not stringify this value. (Possible circular structure.)");
      setResult("Result will appear here.");
      outEl.value = "";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      return;
    }

    outEl.value = out;

    const inputBytes = bytesApprox(parsed.raw);
    const outputBytes = bytesApprox(out);
    setResult("<strong>Formatted.</strong> <span class='note'>Pretty-printed JSON output is ready.</span>");
    setCards({
      status: "OK",
      statusKind: "good",
      inputSize: fmtBytes(inputBytes),
      outputSize: fmtBytes(outputBytes),
      mode: "Pretty print",
      keyOrder: (sortMode === "asc" ? "Keys: sorted" : "Keys: as parsed"),
    });
  }

  function minify() {
    clearError();
    const parsed = parseJsonStrict();
    if (!parsed.ok) {
      showError(parsed.msg);
      setResult("Result will appear here.");
      outEl.value = "";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      return;
    }

    const sortMode = String(sortEl.value);
    let value = parsed.value;
    if (sortMode === "asc") value = sortKeysDeep(value);

    let out = "";
    try {
      out = JSON.stringify(value);
    } catch (_) {
      showError("Could not stringify this value. (Possible circular structure.)");
      setResult("Result will appear here.");
      outEl.value = "";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      return;
    }

    outEl.value = out;

    const inputBytes = bytesApprox(parsed.raw);
    const outputBytes = bytesApprox(out);

    const saved = inputBytes - outputBytes;
    const savedPct = inputBytes > 0 ? (saved / inputBytes) * 100 : 0;

    const savedText =
      (saved > 0)
        ? `Reduced by ${fmtBytes(saved)} (${(Math.round(savedPct * 10) / 10)}%).`
        : "No reduction (input may already be compact).";

    setResult("<strong>Minified.</strong> <span class='note'>" + savedText + "</span>");
    setCards({
      status: "OK",
      statusKind: "good",
      inputSize: fmtBytes(inputBytes),
      outputSize: fmtBytes(outputBytes),
      mode: "Minify",
      keyOrder: (sortMode === "asc" ? "Keys: sorted" : "Keys: as parsed"),
    });
  }

  async function copyOutput() {
    clearError();
    const text = String(outEl.value || "");
    if (!text) {
      showError("Nothing to copy. Generate output first.");
      return;
    }
    try {
      await navigator.clipboard.writeText(text);
      setResult("<strong>Copied.</strong> <span class='note'>Output copied to clipboard.</span>");
    } catch (_) {
      showError("Could not copy. Your browser may block clipboard access.");
    }
  }

  function reset() {
    clearError();
    inEl.value = "";
    outEl.value = "";
    indentEl.value = "2";
    sortEl.value = "none";
    resEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    inEl.focus();
  }

  prettyBtn.addEventListener("click", prettyPrint);
  minifyBtn.addEventListener("click", minify);
  validateBtn.addEventListener("click", validateOnly);
  copyBtn.addEventListener("click", copyOutput);
  clearBtn.addEventListener("click", reset);

  // Ctrl/Cmd+Enter to pretty print
  inEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") prettyPrint();
  });

  // If input cleared manually, reset UI
  inEl.addEventListener("input", function () {
    if (!String(inEl.value || "").trim()) {
      clearError();
      resEl.textContent = "Result will appear here.";
      outEl.value = "";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
    }
  });
});
</script>