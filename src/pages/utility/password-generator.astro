---
import ToolLayout from "../../components/ToolLayout.astro";

export const tool = {
  title: "Password Generator",
  description: "Free secure password generator. Choose length and character types. Runs locally in your browser.",
  href: "/utility/password-generator/",
  order: 20,
};
---

<ToolLayout
  title="Password Generator — MinimalDev"
  description="Free secure password generator. Choose length and character types. Runs locally in your browser."
  canonicalPath="/utility/password-generator/"
  h1="Password Generator"
  intro="Generate strong passwords locally in your browser. Choose length and character types, with guaranteed inclusion."
>
  <div slot="tool" data-tool="password-generator">
    <div class="form">
      <div class="field">
        <label for="pw_len">Length (8–64)</label>
        <input id="pw_len" type="number" inputmode="numeric" value="16" min="8" max="64" />
      </div>

      <div class="field">
        <label>
          <input id="pw_upper" type="checkbox" checked />
          Uppercase (A–Z)
        </label>
      </div>

      <div class="field">
        <label>
          <input id="pw_lower" type="checkbox" checked />
          Lowercase (a–z)
        </label>
      </div>

      <div class="field">
        <label>
          <input id="pw_num" type="checkbox" checked />
          Numbers (0–9)
        </label>
      </div>

      <div class="field">
        <label>
          <input id="pw_sym" type="checkbox" />
          Symbols
        </label>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="pw_generate">Generate</button>
        <button class="btn secondary" type="button" id="pw_copy">Copy</button>
        <button class="btn secondary" type="button" id="pw_clear">Clear</button>
      </div>

      <div class="field">
        <label for="pw_result">Generated password</label>
        <input id="pw_result" type="text" readonly />
      </div>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This tool uses the browser’s cryptographic random generator and guarantees at least one character from each selected set.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>Length 16 + letters + numbers → strong general password</li>
      <li>Length 24 + symbols → high-entropy password</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>Is this generated on a server?</strong> No. It’s generated locally in your browser.</li>
      <li><strong>Should I reuse passwords?</strong> No. Use unique passwords for each account.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/utility/uuid-generator/">UUID Generator</a></li>
      <li><a href="/utility/random-number-generator/">Random Number Generator</a></li>
      <li><a href="/utility/">Utility Tools</a></li>
    </ul>
  </div>
</ToolLayout>