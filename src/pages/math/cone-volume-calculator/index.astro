---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Cone Volume Calculator",
  description:
    "Calculate cone volume from radius and height.",
  href: "/math/cone-volume-calculator/",
  order: 399,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/cone-volume-calculator/";

const faqs = [
  {
    q: "What does this cone volume calculator compute?",
    a: "It computes cone volume, slant height, lateral area, and total surface area from radius and height.",
  },
  {
    q: "What formula is used for cone volume?",
    a: "The formula is V = 1/3 × π × r² × h.",
  },
  {
    q: "How do you find slant height?",
    a: "For a right circular cone, slant height is l = sqrt(r² + h²).",
  },
  {
    q: "What is the total surface area?",
    a: "Total surface area = πr² + πrl, where l is the slant height.",
  },
  {
    q: "Are calculations stored?",
    a: "No. Everything runs locally in your browser.",
  },
];
---

<ToolLayout
  title={`Cone Volume Calculator — ${SITE_NAME}`}
  description="Calculate cone volume using radius and height for geometry, containers, design, and 3D measurement tasks."
  canonicalPath={CANONICAL_PATH}
  h1="Cone Volume Calculator"
  intro="Calculate cone volume, slant height, lateral area, and total surface area from radius and height."
  faq={faqs}
  categoryName="Math"
>
  <div slot="tool" data-tool="cone-volume-calculator">
    <style is:inline>
      .cone-wrap, .cone-wrap * { box-sizing: border-box; }
      .cone-grid {
        display:grid;
        grid-template-columns:repeat(2, minmax(0, 1fr));
        gap:10px;
      }
      .cone-grid input { width:100%; min-width:0; }
      .cone-code {
        font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        word-break:break-word;
      }
      @media (max-width: 760px) {
        .cone-grid { grid-template-columns:1fr; }
      }
    </style>

    <div class="form cone-wrap" role="form" aria-describedby="cone_help cone_privacy">
      <div class="cone-grid">
        <div class="field">
          <label for="cone_radius">Radius (r)</label>
          <input id="cone_radius" type="number" inputmode="decimal" step="any" min="0" placeholder="e.g., 3" />
        </div>

        <div class="field">
          <label for="cone_height">Height (h)</label>
          <input id="cone_height" type="number" inputmode="decimal" step="any" min="0" placeholder="e.g., 5" />
        </div>
      </div>

      <p class="note" id="cone_help" style="margin-top:6px;">
        Formulas:
        <br />
        <span class="cone-code">V = 1/3 × π × r² × h</span>
        <br />
        <span class="cone-code">l = √(r² + h²)</span>
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="cone_calc">Calculate</button>
        <button class="btn secondary" type="button" id="cone_fill_demo">Fill demo</button>
        <button class="btn secondary" type="button" id="cone_clear">Clear</button>
      </div>

      <div class="result" id="cone_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="cone_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="cone_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="cone_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="cone_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This page assumes a <strong>right circular cone</strong>.
    </p>
    <ul>
      <li><strong>Volume:</strong> 1/3 × π × r² × h</li>
      <li><strong>Slant height:</strong> √(r² + h²)</li>
      <li><strong>Lateral area:</strong> πrl</li>
      <li><strong>Total surface area:</strong> πr² + πrl</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>r = 3, h = 5</strong> → cone volume and slant height</li>
      <li><strong>r = 1, h = 1</strong> → small cone example</li>
      <li><strong>r = 10, h = 20</strong> → larger cone</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/sphere-volume-calculator/">Sphere Volume Calculator</a></li>
      <li><a href="/math/pyramid-volume-calculator/">Pyramid Volume Calculator</a></li>
      <li><a href="/math/circle-area-calculator/">Circle Area Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const rEl = document.getElementById("cone_radius");
  const hEl = document.getElementById("cone_height");
  const calcBtn = document.getElementById("cone_calc");
  const fillBtn = document.getElementById("cone_fill_demo");
  const clearBtn = document.getElementById("cone_clear");
  const errorEl = document.getElementById("cone_error");
  const resultEl = document.getElementById("cone_result");
  const cardsEl = document.getElementById("cone_cards");
  const tbodyEl = document.getElementById("cone_tbody");

  if (!rEl || !hEl || !calcBtn || !fillBtn || !clearBtn || !errorEl || !resultEl || !cardsEl || !tbodyEl) return;

  function num(v) {
    const n = parseFloat(String(v).trim());
    return Number.isFinite(n) ? n : NaN;
  }

  function fmt(n, d) {
    return Number.isFinite(n)
      ? n.toLocaleString(undefined, { maximumFractionDigits: Number.isFinite(d) ? d : 12 })
      : "—";
  }

  function badge(text) {
    return "<span style='display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,.2);font-size:12px;font-weight:900;'>" + text + "</span>";
  }

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function clearOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const a = document.createElement("td");
      const b = document.createElement("td");
      a.textContent = row[0];
      b.textContent = row[1];
      tr.appendChild(a);
      tr.appendChild(b);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearOutput();

    const r = num(rEl.value);
    const h = num(hEl.value);

    if (!Number.isFinite(r) || !Number.isFinite(h)) {
      showError("Please enter valid values for radius and height.");
      return;
    }
    if (r <= 0 || h <= 0) {
      showError("Radius and height must both be greater than 0.");
      return;
    }

    const slant = Math.sqrt(r * r + h * h);
    const volume = (Math.PI * r * r * h) / 3;
    const baseArea = Math.PI * r * r;
    const lateralArea = Math.PI * r * slant;
    const totalArea = baseArea + lateralArea;

    resultEl.innerHTML =
      "<strong>Cone result</strong><br/>" +
      "<span class='cone-code'>Volume = " + fmt(volume, 12) + "</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      "<div style='display:flex;gap:10px;flex-wrap:wrap;'>" +
      badge("Right circular cone") +
      badge("Slant height = " + fmt(slant, 8)) +
      badge(h > r ? "Taller than wide" : "Wider / balanced cone") +
      "</div>";

    fillTable([
      ["Radius", fmt(r, 12)],
      ["Height", fmt(h, 12)],
      ["Slant height", fmt(slant, 12)],
      ["Base area", fmt(baseArea, 12)],
      ["Lateral area", fmt(lateralArea, 12)],
      ["Total surface area", fmt(totalArea, 12)],
      ["Volume", fmt(volume, 12)],
    ]);
  }

  function fillDemo() {
    rEl.value = "3";
    hEl.value = "5";
    clearOutput();
  }

  function reset() {
    rEl.value = "";
    hEl.value = "";
    clearOutput();
    rEl.focus();
  }

  calcBtn.addEventListener("click", compute);
  fillBtn.addEventListener("click", fillDemo);
  clearBtn.addEventListener("click", reset);

  [rEl, hEl].forEach(function (el) {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") compute();
    });
  });

  clearOutput();
});
</script>