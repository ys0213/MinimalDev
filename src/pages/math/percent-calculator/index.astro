---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Percent Calculator",
  description:
    "Calculate percent of a number instantly. Useful for discounts, tax, tips, and quick math.",
  href: "/math/percent-calculator/",
  order: 10,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/percent-calculator/";

const faqs = [
  {
    q: "What does “percent of a number” mean?",
    a: "It means taking a portion of the number based on “per 100”. For example, 15% means 15 per 100.",
  },
  {
    q: "Can I use decimals?",
    a: "Yes. Both percent and number can be decimals, for example 2.5% of 19.99.",
  },
  {
    q: "How do I calculate percent off?",
    a: "First compute the percent amount, then subtract it from the original price: original − percent amount.",
  },
  {
    q: "Is this the same as percent increase?",
    a: "No. Percent increase or decrease compares an old value to a new value. This tool only computes percent of a number.",
  },
  {
    q: "When should I use this calculator?",
    a: "Use it when you need a portion of a value, such as discounts, taxes, commissions, or tips.",
  },
  {
    q: "Does this store my inputs?",
    a: "No. Calculations run locally in your browser. Inputs are not stored or sent to a server.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Percent Calculator — ${SITE_NAME}`}
  description="Free percent calculator to find the percentage of a number instantly. Useful for discounts, tax, tips, and everyday math."
  canonicalPath={CANONICAL_PATH}
  h1="Percent Calculator"
  intro="Calculate the percent (percentage) of a number instantly. Common uses include discounts, tax, tips, and quick mental-math checks."
  faq={faqs}
  categoryName="Math"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Percent Calculator",
    "description": "Calculate percentage of a number instantly. Easy tool for discounts, tax, and tips.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <div style="background: #f0fdf4; border: 1px solid #bbf7d0; padding: 10px; border-radius: 6px; margin-bottom: 20px;">
    <strong>🔒 Privacy First:</strong> Everything is processed locally in your browser. <strong>Your data is never sent to our servers.</strong>
  </div>

  <div slot="tool" data-tool="percent-calculator">
    <div class="form">
      <div class="field">
        <label for="pc_percent">Percent (%)</label>
        <input
          id="pc_percent"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 15"
          min="-1000000"
          max="1000000"
          step="0.01"
          aria-describedby="pc_help pc_error"
        />
      </div>

      <div class="field">
        <label for="pc_number">Number</label>
        <input
          id="pc_number"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 200"
          min="-1000000000000000"
          max="1000000000000000"
          step="0.01"
          aria-describedby="pc_help pc_error"
        />
        <div id="pc_error" class="note" style="margin-top:6px;" aria-live="polite"></div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="pc_calc">Calculate</button>
        <button class="btn secondary" type="button" id="pc_clear">Clear</button>
      </div>

      <div
        class="result"
        id="pc_result"
        role="status"
        aria-live="polite"
        style="margin-top:12px;"
      >
        Result will appear here.
      </div>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This calculator finds a percentage of a number using a standard formula. Percent means “per 100”, so the calculation converts the percent into a decimal before multiplying.
    </p>
    <ul>
      <li><strong>Step 1:</strong> Convert percent to decimal → percent ÷ 100</li>
      <li><strong>Step 2:</strong> Multiply by the number</li>
      <li><strong>Formula:</strong> result = (percent ÷ 100) × number</li>
    </ul>
  </div>
  
  <div class="prose" style="margin-top:24px;">
      <h2>Why Percentage Calculation Matters</h2>
      <p>Understanding percentages is a fundamental mathematical skill used in almost every aspect of daily life, from personal finance and business accounting to academic research and everyday shopping. Whether you are calculating the final price after a discount, determining the appropriate gratuity for service, or analyzing statistical data, percentages provide a standardized way to compare values and understand parts of a whole.</p>
      
      <h2>How to Calculate Percentages Manually</h2>
      <p>At its core, a percentage is a fraction of 100. To calculate the percentage of a number manually, you can follow these simple steps:</p>
      <ul>
        <li><strong>Step 1:</strong> Convert the percentage to a decimal by dividing it by 100. For instance, 15% becomes 0.15.</li>
        <li><strong>Step 2:</strong> Multiply this decimal by the total number. If you want 15% of 200, you multiply 0.15 by 200, which equals 30.</li>
      </ul>

      <h2>Practical Real-World Applications</h2>
      <p>Our Percent Calculator is designed to handle these common scenarios effortlessly:</p>
      <ul>
        <li><strong>Retail & Discounts:</strong> Quickly see how much you save during seasonal sales by applying percentage discounts to original prices.</li>
        <li><strong>Taxation:</strong> Easily add local sales tax to your subtotal to determine the final purchase price of items or services.</li>
        <li><strong>Personal Finance:</strong> Accurately calculate interest rates on savings accounts or commission earnings for sales roles.</li>
        <li><strong>Tipping:</strong> Determine service gratuity in restaurants or hotels without any mental strain or guesswork.</li>
      </ul>

      <h2>Limitations and Precision</h2>
      <p>While this tool is highly accurate for general use, it is important to note that very complex financial calculations or scientific research might require specialized software. For everyday math needs, this calculator ensures precision by handling decimals and large numbers with high accuracy, saving you time and preventing errors caused by manual calculations.</p>
    </div>

  <div slot="examples">
    <p><strong>Example breakdown:</strong></p>
    <ul>
      <li>20% of 45 → (20 ÷ 100) × 45 = 9</li>
      <li>7.5% of 80 → (7.5 ÷ 100) × 80 = 6</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/percent-increase-calculator/">Percent Increase Calculator</a></li>
      <li><a href="/math/percent-decrease-calculator/">Percent Decrease Calculator</a></li>
      <li><a href="/finance/compound-interest-calculator/">Compound Interest Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const percentEl = document.getElementById("pc_percent");
  const numberEl = document.getElementById("pc_number");
  const calcBtn = document.getElementById("pc_calc");
  const clearBtn = document.getElementById("pc_clear");
  const outEl = document.getElementById("pc_result");
  const errEl = document.getElementById("pc_error");

  if (!percentEl || !numberEl || !calcBtn || !clearBtn || !outEl || !errEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function fmt(n) {
    if (!Number.isFinite(n)) return "0";
    return n.toLocaleString(undefined, { maximumFractionDigits: 10 });
  }

  function compute() {
    errEl.textContent = "";
    const p = toNum(percentEl.value);
    const num = toNum(numberEl.value);

    if (isNaN(p) || isNaN(num)) {
      outEl.textContent = "Please enter valid numbers.";
      return;
    }

    const result = (p / 100) * num;
    outEl.innerHTML = `
      <div style='font-size:16px;'>
        <strong>${fmt(p)}% of ${fmt(num)} = ${fmt(result)}</strong>
      </div>
      <div class='note' style='margin-top:8px;'>
        Formula: (${fmt(p)} ÷ 100) × ${fmt(num)} = ${fmt(result)}
      </div>`;
  }

  calcBtn.addEventListener("click", compute);
  clearBtn.addEventListener("click", () => {
    percentEl.value = "";
    numberEl.value = "";
    outEl.textContent = "Result will appear here.";
  });
});
</script>