---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Z-Score Calculator",
  description:
    "Calculate a z-score from a value, mean, and standard deviation with validation, interpretation, and FAQ support.",
  href: "/math/z-score-calculator/",
  order: 364,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/z-score-calculator/";

const faqs = [
  {
    q: "What is a z-score?",
    a: "A z-score tells you how many standard deviations a value is above or below the mean.",
  },
  {
    q: "How is z-score calculated?",
    a: "Use the formula z = (x − mean) / standard deviation.",
  },
  {
    q: "Why can't standard deviation be 0?",
    a: "Because dividing by zero is undefined. If standard deviation is 0, there is no spread to standardize against.",
  },
  {
    q: "Are calculations stored?",
    a: "No. Everything runs locally in your browser.",
  },
];
---

<ToolLayout
  title={`Z-Score Calculator — ${SITE_NAME}`}
  description="Z-score calculator with validation, interpretation, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="Z-Score Calculator"
  intro="Calculate the z-score of a value using its mean and standard deviation, then interpret how far it sits from the average."
  faq={faqs}
  categoryName="Math"
>
  <div slot="tool" data-tool="z-score-calculator">
    <style is:inline>
      .zs-wrap, .zs-wrap * { box-sizing: border-box; }
      .zs-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
      }
      @media (max-width: 800px) {
        .zs-grid { grid-template-columns: 1fr; }
      }
    </style>

    <div class="form zs-wrap" role="form" aria-describedby="zs_help zs_privacy">
      <div class="zs-grid">
        <div class="field">
          <label for="zs_x">Value x</label>
          <input id="zs_x" type="number" step="any" inputmode="decimal" placeholder="e.g., 85" />
        </div>
        <div class="field">
          <label for="zs_mean">Mean</label>
          <input id="zs_mean" type="number" step="any" inputmode="decimal" placeholder="e.g., 70" />
        </div>
        <div class="field">
          <label for="zs_sd">Standard deviation</label>
          <input id="zs_sd" type="number" step="any" inputmode="decimal" placeholder="e.g., 10" />
        </div>
      </div>

      <p class="note" id="zs_help" style="margin-top:6px;">
        Formula: <strong>z = (x − mean) / standard deviation</strong>
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="zs_calc">Calculate</button>
        <button class="btn secondary" type="button" id="zs_fill_demo">Fill demo</button>
        <button class="btn secondary" type="button" id="zs_clear">Clear</button>
      </div>

      <div class="result" id="zs_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="zs_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="zs_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="zs_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="zs_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No values are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      A z-score standardizes a value relative to the dataset mean and spread.
      <br />
      <strong>Positive z</strong> means above the mean.
      <br />
      <strong>Negative z</strong> means below the mean.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>x = 85, mean = 70, sd = 10</strong> → <strong>z = 1.5</strong></li>
      <li><strong>x = 60, mean = 70, sd = 10</strong> → <strong>z = -1</strong></li>
      <li><strong>x = mean</strong> → <strong>z = 0</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/standard-deviation-calculator/">Standard Deviation Calculator</a></li>
      <li><a href="/math/normal-distribution-calculator/">Normal Distribution Calculator</a></li>
      <li><a href="/math/correlation-calculator/">Correlation Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const xEl = document.getElementById("zs_x");
  const meanEl = document.getElementById("zs_mean");
  const sdEl = document.getElementById("zs_sd");
  const calcBtn = document.getElementById("zs_calc");
  const demoBtn = document.getElementById("zs_fill_demo");
  const clearBtn = document.getElementById("zs_clear");
  const errorEl = document.getElementById("zs_error");
  const resultEl = document.getElementById("zs_result");
  const cardsEl = document.getElementById("zs_cards");
  const tbodyEl = document.getElementById("zs_tbody");

  if (!xEl || !meanEl || !sdEl || !calcBtn || !demoBtn || !clearBtn || !errorEl || !resultEl || !cardsEl || !tbodyEl) return;

  function badge(text) {
    return "<span style='display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;'>" + text + "</span>";
  }
  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }
  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }
  function clearOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }
  function getNum(el, label) {
    const raw = String(el.value || "").trim();
    if (!raw) throw new Error("Please fill value, mean, and standard deviation.");
    const n = Number(raw);
    if (!Number.isFinite(n)) throw new Error("Enter a valid number for " + label + ".");
    return n;
  }
  function fmt(n) {
    const rounded = Math.round(n * 1e12) / 1e12;
    return rounded.toLocaleString(undefined, { maximumFractionDigits: 12 });
  }
  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }
  function compute() {
    clearOutput();
    try {
      const x = getNum(xEl, "x");
      const mean = getNum(meanEl, "mean");
      const sd = getNum(sdEl, "standard deviation");

      if (sd === 0) {
        showError("Standard deviation cannot be 0.");
        return;
      }
      if (sd < 0) {
        showError("Standard deviation must be greater than 0.");
        return;
      }

      const z = (x - mean) / sd;
      let position = "At the mean";
      if (z > 0) position = "Above the mean";
      else if (z < 0) position = "Below the mean";

      let magnitude = "Typical";
      const az = Math.abs(z);
      if (az >= 3) magnitude = "Extreme";
      else if (az >= 2) magnitude = "Far from mean";
      else if (az >= 1) magnitude = "Moderately away";

      resultEl.innerHTML =
        "<strong>Z-score result</strong><br/>" +
        "<span style='font-size:1.15rem;font-weight:800;'>z = " + fmt(z) + "</span>";

      cardsEl.style.display = "block";
      cardsEl.innerHTML =
        "<div style='display:flex;gap:10px;flex-wrap:wrap;'>" +
        badge(position) +
        badge(magnitude) +
        badge("|z| = " + fmt(Math.abs(z))) +
        "</div>";

      fillTable([
        ["Value x", fmt(x)],
        ["Mean", fmt(mean)],
        ["Standard deviation", fmt(sd)],
        ["Z-score", fmt(z)],
        ["Interpretation", position + " / " + magnitude],
      ]);
    } catch (err) {
      showError(err instanceof Error ? err.message : "Could not calculate z-score.");
    }
  }
  function fillDemo() {
    xEl.value = "85";
    meanEl.value = "70";
    sdEl.value = "10";
    clearOutput();
  }
  function reset() {
    xEl.value = "";
    meanEl.value = "";
    sdEl.value = "";
    clearOutput();
    xEl.focus();
  }
  calcBtn.addEventListener("click", compute);
  demoBtn.addEventListener("click", fillDemo);
  clearBtn.addEventListener("click", reset);
  [xEl, meanEl, sdEl].forEach(function (el) {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") compute();
    });
  });
  clearOutput();
});
</script>