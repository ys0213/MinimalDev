---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Circle Circumference Calculator",
  description:
    "Calculate circle circumference using radius or diameter. Includes validation, unit UX, result cards, and FAQ schema.",
  href: "/math/circle-circumference-calculator/",
  order: 320,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/circle-circumference-calculator/";

const faqs = [
  {
    q: "What is the formula for circle circumference?",
    a: "Circumference = 2πr or πd.",
  },
  {
    q: "Can I enter diameter instead of radius?",
    a: "Yes. This calculator lets you choose radius or diameter as the input type.",
  },
  {
    q: "What is circumference?",
    a: "Circumference is the distance around the circle.",
  },
  {
    q: "Are my values stored?",
    a: "No. Calculations run locally in your browser and are not stored or transmitted.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Circle Circumference Calculator — ${SITE_NAME}`}
  description="Calculate circle circumference from radius or diameter with validation, result cards, unit labels, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Circle Circumference Calculator"
  intro="Enter a radius or diameter to calculate the circumference of a circle."
  faq={faqs}
  categoryName="Math"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="circle-circumference-calculator">
    <div class="form" role="form" aria-describedby="cc_help cc_privacy">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
        <div class="field">
          <label for="cc_input_type">Input type</label>
          <select id="cc_input_type">
            <option value="radius" selected>Radius</option>
            <option value="diameter">Diameter</option>
          </select>
        </div>

        <div class="field">
          <label for="cc_value">Value</label>
          <input id="cc_value" type="number" inputmode="decimal" placeholder="e.g., 5" aria-describedby="cc_help" />
        </div>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
        <div class="field">
          <label for="cc_unit">Unit label (optional)</label>
          <input id="cc_unit" type="text" placeholder="e.g., cm, m, in" />
        </div>

        <div class="field">
          <label for="cc_round">Rounding</label>
          <select id="cc_round">
            <option value="2" selected>2 decimals</option>
            <option value="4">4 decimals</option>
            <option value="6">6 decimals</option>
            <option value="auto">Smart</option>
          </select>
        </div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="cc_calc">Calculate</button>
        <button class="btn secondary" type="button" id="cc_clear">Clear</button>
      </div>

      <div class="result" id="cc_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="cc_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="cc_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="cc_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="cc_help" style="margin-top:6px;">
        Uses <strong>C = 2πr</strong> or <strong>C = πd</strong>.
      </p>
      <p class="note" id="cc_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No values are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Radius input: <strong>C = 2πr</strong><br />
      Diameter input: <strong>C = πd</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>radius = 5</strong> → circumference ≈ <strong>31.42</strong></li>
      <li><strong>diameter = 10</strong> → circumference ≈ <strong>31.42</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/circle-area-calculator/">Circle Area Calculator</a></li>
      <li><a href="/math/triangle-area-calculator/">Triangle Area Calculator</a></li>
      <li><a href="/math/square-root-calculator/">Square Root Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const typeEl = document.getElementById("cc_input_type");
  const valueEl = document.getElementById("cc_value");
  const unitEl = document.getElementById("cc_unit");
  const roundEl = document.getElementById("cc_round");
  const calcBtn = document.getElementById("cc_calc");
  const clearBtn = document.getElementById("cc_clear");
  const errEl = document.getElementById("cc_error");
  const outEl = document.getElementById("cc_result");
  const cardsEl = document.getElementById("cc_cards");
  const tbodyEl = document.getElementById("cc_tbody");

  if (!typeEl || !valueEl || !unitEl || !roundEl || !calcBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }
  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }
  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }
  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") {
      const ax = Math.abs(x);
      if (ax === 0) return "0";
      if (ax >= 1e12 || ax < 1e-10) return x.toExponential(8);
      return String(Number(x.toPrecision(12)));
    }
    const d = parseInt(r, 10);
    return x.toLocaleString(undefined, { maximumFractionDigits: d, minimumFractionDigits: 0 });
  }
  function badge(text) {
    return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`;
  }
  function lengthUnit() {
    const u = String(unitEl.value || "").trim();
    return u ? ` ${u}` : "";
  }
  function fillTable(radius, diameter, circumference) {
    tbodyEl.innerHTML = "";
    const rows = [
      ["Radius", fmt(radius) + lengthUnit()],
      ["Diameter", fmt(diameter) + lengthUnit()],
      ["2πr", fmt(2 * Math.PI * radius)],
      ["Circumference", fmt(circumference) + lengthUnit()],
    ];
    rows.forEach(([k, v]) => {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = String(k);
      td2.textContent = String(v);
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(valueEl.value);
    const type = String(typeEl.value);

    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid circle value.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Radius or diameter must be non-negative.";
      return;
    }

    const radius = type === "radius" ? raw : raw / 2;
    const diameter = radius * 2;
    const circumference = 2 * Math.PI * radius;

    outEl.innerHTML =
      `<strong>Circumference:</strong> ${fmt(circumference)}${lengthUnit()}<br/>` +
      `<span class="note">${type === "radius" ? `2π × ${fmt(radius)}` : `π × ${fmt(diameter)}`} = ${fmt(circumference)}</span>`;

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      `<div style="display:flex;gap:10px;flex-wrap:wrap;">` +
      badge(type === "radius" ? "Input: radius" : "Input: diameter") +
      badge(circumference === 0 ? "Zero circumference" : circumference < 50 ? "Smaller circle" : "Larger circle") +
      badge(unitEl.value ? `Unit: ${unitEl.value}` : "No unit label") +
      `</div>`;

    fillTable(radius, diameter, circumference);
  }

  function reset() {
    clearError();
    typeEl.value = "radius";
    valueEl.value = "";
    unitEl.value = "";
    roundEl.value = "2";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
    valueEl.focus();
  }

  calcBtn.addEventListener("click", compute);
  clearBtn.addEventListener("click", reset);

  [valueEl, unitEl].forEach((el) => {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") compute();
    });
  });
});
</script>