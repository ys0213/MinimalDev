---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Triangle Area Calculator",
  description:
    "Calculate the area of a triangle using base and height. Includes validation, result cards, unit labels, and FAQ schema.",
  href: "/math/triangle-area-calculator/",
  order: 290,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/triangle-area-calculator/";

const faqs = [
  {
    q: "What is the formula for the area of a triangle?",
    a: "Area = (base × height) / 2.",
  },
  {
    q: "Can base or height be decimal values?",
    a: "Yes. The calculator supports decimal values for both base and height.",
  },
  {
    q: "Can the values be negative?",
    a: "No. Triangle dimensions should be non-negative. The calculator will reject negative values.",
  },
  {
    q: "Are my values stored?",
    a: "No. Calculations run locally in your browser and are not stored or transmitted.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Triangle Area Calculator — ${SITE_NAME}`}
  description="Calculate triangle area using base and height. Includes validation, result cards, optional unit labels, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Triangle Area Calculator"
  intro="Enter the base and height of a triangle to calculate its area."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="triangle-area-calculator">
    <style is:inline>
      .ta-grid-2 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .ta-grid-2 > * {
        min-width: 0;
      }

      #ta_base,
      #ta_height,
      #ta_unit,
      #ta_round {
        width: 100%;
        min-width: 0;
      }

      @media (min-width: 700px) {
        .ta-grid-2 {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>

    <div class="form" role="form" aria-describedby="ta_help ta_privacy">
      <div class="ta-grid-2">
        <div class="field">
          <label for="ta_base">Base</label>
          <input id="ta_base" type="number" inputmode="decimal" placeholder="e.g., 10" aria-describedby="ta_help" />
        </div>

        <div class="field">
          <label for="ta_height">Height</label>
          <input id="ta_height" type="number" inputmode="decimal" placeholder="e.g., 6" />
        </div>
      </div>

      <div class="ta-grid-2">
        <div class="field">
          <label for="ta_unit">Unit label (optional)</label>
          <input id="ta_unit" type="text" placeholder="e.g., cm, m, in" />
        </div>

        <div class="field">
          <label for="ta_round">Rounding</label>
          <select id="ta_round">
            <option value="2" selected>2 decimals</option>
            <option value="4">4 decimals</option>
            <option value="6">6 decimals</option>
            <option value="auto">Smart</option>
          </select>
        </div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="ta_calc">Calculate</button>
        <button class="btn secondary" type="button" id="ta_clear">Clear</button>
      </div>

      <div class="result" id="ta_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="ta_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="ta_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="ta_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="ta_help" style="margin-top:6px;">
        Formula used: <strong>(base × height) / 2</strong>
      </p>
      <p class="note" id="ta_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No values are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Triangle area formula:
      <br />
      <strong>Area = (base × height) / 2</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>base = 10</strong>, <strong>height = 6</strong> → area = <strong>30</strong></li>
      <li><strong>base = 5.5</strong>, <strong>height = 8</strong> → area = <strong>22</strong></li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      {faqs.map((f) => (
        <li><strong>{f.q}</strong> {f.a}</li>
      ))}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/pythagorean-theorem-calculator/">Pythagorean Theorem Calculator</a></li>
      <li><a href="/math/circle-area-calculator/">Circle Area Calculator</a></li>
      <li><a href="/math/slope-calculator/">Slope Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const baseEl = document.getElementById("ta_base");
  const heightEl = document.getElementById("ta_height");
  const unitEl = document.getElementById("ta_unit");
  const roundEl = document.getElementById("ta_round");
  const calcBtn = document.getElementById("ta_calc");
  const clearBtn = document.getElementById("ta_clear");
  const errEl = document.getElementById("ta_error");
  const outEl = document.getElementById("ta_result");
  const cardsEl = document.getElementById("ta_cards");
  const tbodyEl = document.getElementById("ta_tbody");

  if (!baseEl || !heightEl || !unitEl || !roundEl || !calcBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  function toNum(v) {
    const s = String(v ?? "").trim();
    if (s === "") return NaN;
    const x = parseFloat(s);
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") {
      const ax = Math.abs(x);
      if (ax === 0) return "0";
      if (ax >= 1e12 || ax < 1e-10) return x.toExponential(8);
      return String(Number(x.toPrecision(12)));
    }
    const d = parseInt(r, 10);
    return x.toLocaleString(undefined, { maximumFractionDigits: d, minimumFractionDigits: 0 });
  }

  function badge(text) {
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">' + text + "</span>";
  }

  function unitValueLabel() {
    const u = String(unitEl.value || "").trim();
    return u ? " " + u : "";
  }

  function unitAreaLabel() {
    const u = String(unitEl.value || "").trim();
    return u ? " " + u + "²" : "";
  }

  function fillTable(base, height, area) {
    tbodyEl.innerHTML = "";
    const rows = [
      ["Base", fmt(base) + unitValueLabel()],
      ["Height", fmt(height) + unitValueLabel()],
      ["Base × Height", fmt(base * height) + unitAreaLabel()],
      ["Area", fmt(area) + unitAreaLabel()],
    ];

    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = String(row[0]);
      td2.textContent = String(row[1]);
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const base = toNum(baseEl.value);
    const height = toNum(heightEl.value);

    if (!Number.isFinite(base) || !Number.isFinite(height)) {
      outEl.textContent = "Please enter valid base and height values.";
      return;
    }

    if (base < 0 || height < 0) {
      outEl.textContent = "Base and height must be non-negative.";
      return;
    }

    const area = (base * height) / 2;

    outEl.innerHTML =
      "<strong>Area:</strong> " + fmt(area) + unitAreaLabel() +
      "<br/><span class='note'>(" + fmt(base) + " × " + fmt(height) + ") / 2 = " + fmt(area) + "</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      "<div style='display:flex;gap:10px;flex-wrap:wrap;'>" +
      badge(base === 0 || height === 0 ? "Zero area" : area < 10 ? "Small triangle" : area < 100 ? "Medium triangle" : "Large triangle") +
      badge(unitEl.value ? "Unit: " + unitEl.value : "No unit label") +
      badge("2D area") +
      "</div>";

    fillTable(base, height, area);
  }

  function reset() {
    clearError();
    baseEl.value = "";
    heightEl.value = "";
    unitEl.value = "";
    roundEl.value = "2";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
    baseEl.focus();
  }

  calcBtn.addEventListener("click", compute);
  clearBtn.addEventListener("click", reset);

  [baseEl, heightEl, unitEl].forEach(function (el) {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") compute();
    });
  });

  outEl.textContent = "Result will appear here.";
});
</script>