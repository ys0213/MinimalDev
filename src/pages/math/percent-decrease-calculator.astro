---
import ToolLayout from "../../components/ToolLayout.astro";

export const tool = {
  title: "Percent Decrease Calculator",
  description: "Free percent decrease calculator. Find the percentage decrease from an old value to a new value.",
  href: "/math/percent-decrease-calculator/",
  order: 30,
};
---

<ToolLayout
  title="Percent Decrease Calculator — MinimalDev"
  description="Free percent decrease calculator. Find the percentage decrease from an old value to a new value."
  canonicalPath="/math/percent-decrease-calculator/"
  h1="Percent Decrease Calculator"
  intro="Calculate percentage decrease between two values. Useful for discounts, drops, and reductions."
>
  <div slot="tool" data-tool="percent-decrease-calculator">
    <div class="form">
      <div class="field">
        <label for="pd_old">Old value</label>
        <input id="pd_old" type="number" inputmode="decimal" placeholder="e.g., 120" />
      </div>
      <div class="field">
        <label for="pd_new">New value</label>
        <input id="pd_new" type="number" inputmode="decimal" placeholder="e.g., 90" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="pd_calc">Calculate</button>
        <button class="btn secondary" type="button" id="pd_clear">Clear</button>
      </div>

      <div class="result" id="pd_result">Result will appear here.</div>
    </div>
  </div>

  <div slot="how">
    <p class="note"><strong>Formula:</strong> ((old − new) ÷ old) × 100</p>
  </div>

  <div slot="examples">
    <ul>
      <li>Old 120 → New 90: decrease = 25%</li>
      <li>Old 200 → New 150: decrease = 25%</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>What if old value is 0?</strong> Percent decrease is undefined when dividing by 0.</li>
      <li><strong>What if new is larger than old?</strong> Use the percent increase tool instead.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/percent-increase-calculator/">Percent Increase Calculator</a></li>
      <li><a href="/math/percentage-change-calculator/">Percentage Change Calculator</a></li>
      <li><a href="/math/percent-calculator/">Percent Calculator</a></li>
      <li><a href="/math/">Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>