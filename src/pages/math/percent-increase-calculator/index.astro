---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Percentage Increase Calculator",
  description: "Free percentage increase calculator. Calculate percent increase between two values instantly.",
  href: "/math/percent-increase-calculator/",
  order: 20, // ✅ keep as-is
};
---

<ToolLayout
  title="Percentage Increase Calculator — MinimalDev"
  description="Free percentage increase calculator. Find the percent increase from an old value to a new value instantly."
  canonicalPath="/math/percent-increase-calculator/"
  h1="Percentage Increase Calculator"
  intro="Calculate percentage increase between two numbers. Useful for price increases, growth rates, salary raises, and comparisons."
>
  <div slot="tool" data-tool="percent-increase-calculator">
    <div class="form">
      <div class="field">
        <label for="pi_old">Old value</label>
        <input
          id="pi_old"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 80"
          step="0.01"
          min="-1e15"
          max="1e15"
          aria-describedby="pi_help pi_error"
        />
      </div>

      <div class="field">
        <label for="pi_new">New value</label>
        <input
          id="pi_new"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 100"
          step="0.01"
          min="-1e15"
          max="1e15"
          aria-describedby="pi_help pi_error"
        />
        <div id="pi_error" class="note" style="margin-top:6px;" aria-live="polite"></div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="pi_calc">Calculate</button>
        <button class="btn secondary" type="button" id="pi_clear">Clear</button>
      </div>

      <div
        class="result"
        id="pi_result"
        role="status"
        aria-live="polite"
        style="margin-top:12px;"
      >
        Result will appear here.
      </div>

      <!-- Screen-reader summary -->
      <div
        class="note"
        id="pi_sr_summary"
        style="position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;"
      ></div>

      <p class="note" id="pi_help" style="margin-top:8px;">
        All calculations run locally in your browser. No data is stored.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      <strong>Percentage increase formula:</strong>
      ((new − old) ÷ old) × 100
    </p>

    <ul>
      <li><strong>Step 1:</strong> Subtract the old value from the new value.</li>
      <li><strong>Step 2:</strong> Divide the difference by the old value.</li>
      <li><strong>Step 3:</strong> Multiply by 100 to get the percentage.</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Old 80 → New 100</strong> → Increase = 25%</li>
      <li><strong>Old 50 → New 60</strong> → Increase = 20%</li>
      <li><strong>Salary 40,000 → 44,000</strong> → Increase = 10%</li>
      <li><strong>Price 120 → 150</strong> → Increase = 25%</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>What if the old value is 0?</strong> Percentage increase is undefined because division by zero is not possible.</li>
      <li><strong>Can the result be negative?</strong> If the new value is smaller than the old value, the result represents a decrease.</li>
      <li><strong>Is this the same as percentage change?</strong> Percentage change can represent either increase or decrease.</li>
      <li><strong>Why is my result very large?</strong> When the old value is small, even small differences can create large percentage increases.</li>
      <li><strong>Is this accurate?</strong> Yes. It uses the standard mathematical formula.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/percent-decrease-calculator/">Percent Decrease Calculator</a></li>
      <li><a href="/math/percentage-change-calculator/">Percentage Change Calculator</a></li>
      <li><a href="/math/percent-calculator/">Percent Calculator</a></li>
      <li><a href="/math/">Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<!-- FAQ schema (auto-generated from a single source of truth in this file) -->
<script is:inline type="application/ld+json" id="pi_faq_schema"></script>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const oldEl = document.getElementById("pi_old");
  const newEl = document.getElementById("pi_new");
  const calcBtn = document.getElementById("pi_calc");
  const clearBtn = document.getElementById("pi_clear");
  const outEl = document.getElementById("pi_result");
  const errEl = document.getElementById("pi_error");
  const srEl = document.getElementById("pi_sr_summary");
  const faqSchemaEl = document.getElementById("pi_faq_schema");

  if (!oldEl || !newEl || !calcBtn || !clearBtn || !outEl || !errEl || !srEl || !faqSchemaEl) return;

  // Single source of truth for FAQ content (schema uses this)
  const FAQ = [
    {
      q: "What if the old value is 0?",
      a: "Percentage increase is undefined because it would require division by zero.",
    },
    {
      q: "Can the result be negative?",
      a: "Yes. If the new value is smaller than the old value, the result represents a decrease (negative increase).",
    },
    {
      q: "Is this the same as percentage change?",
      a: "Percentage change can represent either an increase or a decrease. This tool focuses on the increase formula but will show a negative result if the new value is smaller.",
    },
    {
      q: "Why is my result very large?",
      a: "When the old value is small (near zero), even small absolute differences can create very large percentage increases.",
    },
    {
      q: "Is this accurate?",
      a: "Yes. It uses the standard mathematical formula for percentage increase.",
    },
  ];

  function renderFaqSchema() {
    const json = {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: FAQ.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    };
    faqSchemaEl.textContent = JSON.stringify(json);
  }

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    oldEl.removeAttribute("aria-invalid");
    newEl.removeAttribute("aria-invalid");
    errEl.textContent = "";
  }

  function setError(msg, which) {
    errEl.textContent = msg;
    if (which === "old") oldEl.setAttribute("aria-invalid", "true");
    if (which === "new") newEl.setAttribute("aria-invalid", "true");
    if (which === "both") {
      oldEl.setAttribute("aria-invalid", "true");
      newEl.setAttribute("aria-invalid", "true");
    }
  }

  function fmt(n) {
    if (!Number.isFinite(n)) return "0";
    return n.toLocaleString(undefined, { maximumFractionDigits: 10 });
  }

  function fmtPct(n) {
    if (!Number.isFinite(n)) return "0%";
    return n.toLocaleString(undefined, { maximumFractionDigits: 4 }) + "%";
  }

  function compute(showEmptyAsPlaceholder) {
    clearError();

    const oRaw = String(oldEl.value || "").trim();
    const nRaw = String(newEl.value || "").trim();

    if (!oRaw || !nRaw) {
      if (showEmptyAsPlaceholder) outEl.textContent = "Result will appear here.";
      srEl.textContent = "";
      return null;
    }

    const oldV = toNum(oRaw);
    const newV = toNum(nRaw);

    if (!Number.isFinite(oldV)) {
      setError("Please enter a valid old value.", "old");
      return null;
    }
    if (!Number.isFinite(newV)) {
      setError("Please enter a valid new value.", "new");
      return null;
    }

    if (Math.abs(oldV) > 1e15) {
      setError("Old value is too large. Please enter a smaller value.", "old");
      return null;
    }
    if (Math.abs(newV) > 1e15) {
      setError("New value is too large. Please enter a smaller value.", "new");
      return null;
    }

    if (oldV === 0) {
      setError("Old value cannot be 0 (division by zero).", "old");
      outEl.textContent = "Please enter a non-zero old value.";
      srEl.textContent = "";
      return null;
    }

    const diff = newV - oldV;
    const pct = (diff / oldV) * 100;

    // Category label for UX
    let tag = "Increase";
    if (pct === 0) tag = "No change";
    else if (pct < 0) tag = "Decrease";
    else if (pct >= 50) tag = "Large increase";

    outEl.innerHTML =
      "<div style='display:flex; justify-content:space-between; gap:10px; align-items:baseline; flex-wrap:wrap;'>" +
        "<strong>Percentage change (increase)</strong>" +
        "<span class='note' style='margin:0;'>" + tag + "</span>" +
      "</div>" +
      "<div style='margin-top:6px; font-size:18px; font-weight:700;'>" +
        (pct >= 0 ? "Increase: " : "Change: ") + fmtPct(pct) +
      "</div>" +
      "<div class='note' style='margin-top:6px;'>" +
        "Old: " + fmt(oldV) + " · New: " + fmt(newV) + " · Difference: " + fmt(diff) +
      "</div>" +
      "<div class='note' style='margin-top:4px;'>" +
        "Computed as ((" + fmt(newV) + " − " + fmt(oldV) + ") ÷ " + fmt(oldV) + ") × 100" +
      "</div>" +
      (pct < 0
        ? "<div class='note' style='margin-top:6px;'><strong>Note:</strong> New is smaller than old, so this is a decrease (negative “increase”).</div>"
        : "");

    srEl.textContent =
      "Old value " + fmt(oldV) + ", new value " + fmt(newV) + ". " +
      (pct >= 0 ? "Percentage increase " : "Percentage change ") + fmtPct(pct) + "." +
      " Difference " + fmt(diff) + ".";

    return { oldV, newV, diff, pct };
  }

  calcBtn.addEventListener("click", function () {
    const r = compute(false);
    if (!r) {
      if (oldEl.getAttribute("aria-invalid") === "true") oldEl.focus();
      else if (newEl.getAttribute("aria-invalid") === "true") newEl.focus();
      else outEl.textContent = "Please enter values to calculate.";
    }
  });

  clearBtn.addEventListener("click", function () {
    oldEl.value = "";
    newEl.value = "";
    clearError();
    outEl.textContent = "Result will appear here.";
    srEl.textContent = "";
    oldEl.focus();
  });

  // Live update on input (keeps Calculate for explicit action)
  oldEl.addEventListener("input", function () { compute(true); });
  newEl.addEventListener("input", function () { compute(true); });

  renderFaqSchema();
  clearError();
});
</script>