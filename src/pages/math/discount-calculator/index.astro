---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Discount Calculator",
  description:
    "Calculate discount amount, final price, and savings from an original price and discount rate.",
  href: "/math/discount-calculator/",
  order: 70,
};

const faqs = [
  {
    q: "Can discount be over 100%?",
    a: "No. A discount above 100% would result in a negative price, which is not valid in real transactions.",
  },
  {
    q: "How do multiple discounts work?",
    a: "Apply discounts sequentially. For example, 20% then 10% becomes price × (1−0.20) × (1−0.10), not 30%.",
  },
  {
    q: "Does this include sales tax?",
    a: "No. This tool calculates the discount first. Sales tax should be applied afterward if needed.",
  },
  {
    q: "What does 'You save' mean?",
    a: "It shows the absolute amount reduced from the original price.",
  },
  {
    q: "Why is the final price sometimes not exactly intuitive?",
    a: "Because percentages apply proportionally, not linearly. Multiple discounts compound rather than add.",
  },
];
---

<ToolLayout
  title="Discount Calculator — MinimalDev"
  description="Calculate discounts, sale prices, and savings for shopping, pricing checks, promotions, and quick cost comparisons."
  canonicalPath="/math/discount-calculator/"
  h1="Discount Calculator"
  intro="Calculate discounted price and understand how much you actually save in real situations like shopping, pricing, and budgeting."
  faq={faqs}
  categoryName="Math"
>
  <div slot="tool" data-tool="discount-calculator">
    <div class="form">
      <div class="field">
        <label for="dc_currency">Currency</label>
        <select id="dc_currency" aria-describedby="dc_help" autocomplete="off">
          <option value="auto" selected>Auto (browser locale)</option>
          <option value="USD">USD</option>
          <option value="EUR">EUR</option>
          <option value="GBP">GBP</option>
          <option value="KRW">KRW</option>
          <option value="JPY">JPY</option>
          <option value="CAD">CAD</option>
          <option value="AUD">AUD</option>
        </select>
      </div>

      <div class="field">
        <label for="dc_price">Original price</label>
        <input
          id="dc_price"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 120"
          min="0"
          step="0.01"
          aria-describedby="dc_help dc_error"
        />
      </div>

      <div class="field">
        <label for="dc_discount">Discount (%)</label>
        <input
          id="dc_discount"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 25"
          min="0"
          max="100"
          step="0.01"
          aria-describedby="dc_help dc_error"
        />
        <div id="dc_error" class="note" style="margin-top:6px;" aria-live="polite"></div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="dc_calc">Calculate</button>
        <button class="btn secondary" type="button" id="dc_clear">Clear</button>
      </div>

      <div
        class="result"
        id="dc_result"
        role="status"
        aria-live="polite"
        style="margin-top:12px;"
      >
        Result will appear here.
      </div>

      <div
        class="note"
        id="dc_sr_summary"
        style="position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;"
      ></div>

      <p class="note" id="dc_help" style="margin-top:10px;">
        Enter a price and discount rate from 0 to 100. This tool runs locally in your browser and does not store your inputs.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This calculator determines how much you save and what you actually pay after a discount.
    </p>

    <p class="note">
      <strong>Calculation method:</strong><br/>
      Discount amount = price × (discount ÷ 100)<br/>
      Final price = price − discount amount
    </p>

    <p class="note">
      <strong>How to interpret results:</strong><br/>
      - Final price: the actual amount you will pay<br/>
      - You save: the exact money reduced from original price<br/>
      - Discount %: helps compare deals across products
    </p>

    <p class="note">
      Use this to evaluate whether a discount is meaningful or just marketing.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Shopping:</strong> Check if a sale is actually worth buying.</li>
      <li><strong>Price comparison:</strong> Compare discounts across multiple stores.</li>
      <li><strong>Budget planning:</strong> Estimate spending during sales events.</li>
    </ul>

    <p class="note"><strong>Examples:</strong></p>
    <ul>
      <li>$120 with 25% off → save $30 → pay $90</li>
      <li>$200 with 50% off → save $100 → pay $100</li>
      <li>$80 with 10% then 20% → pay $57.6 (not $56)</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/sales-tax-calculator/">Sales Tax Calculator</a></li>
      <li><a href="/math/percent-calculator/">Percent Calculator</a></li>
      <li><a href="/math/percent-increase-calculator/">Percent Increase Calculator</a></li>
      <li><a href="/math/percent-decrease-calculator/">Percent Decrease Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const currencyEl = document.getElementById("dc_currency");
  const priceEl = document.getElementById("dc_price");
  const discEl = document.getElementById("dc_discount");
  const calcBtn = document.getElementById("dc_calc");
  const clearBtn = document.getElementById("dc_clear");
  const outEl = document.getElementById("dc_result");
  const errEl = document.getElementById("dc_error");
  const srEl = document.getElementById("dc_sr_summary");

  if (!currencyEl || !priceEl || !discEl || !calcBtn || !clearBtn || !outEl || !errEl || !srEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    priceEl.removeAttribute("aria-invalid");
    discEl.removeAttribute("aria-invalid");
    errEl.textContent = "";
  }

  function setError(msg, which) {
    errEl.textContent = msg;
    if (which === "price") priceEl.setAttribute("aria-invalid", "true");
    if (which === "discount") discEl.setAttribute("aria-invalid", "true");
    if (which === "both") {
      priceEl.setAttribute("aria-invalid", "true");
      discEl.setAttribute("aria-invalid", "true");
    }
  }

  function getCurrency() {
    return String(currencyEl.value || "auto");
  }

  function formatMoney(amount) {
    const c = getCurrency();
    if (!Number.isFinite(amount)) return "0";

    if (c === "auto") {
      return amount.toLocaleString(undefined, {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      });
    }

    try {
      return amount.toLocaleString(undefined, {
        style: "currency",
        currency: c,
      });
    } catch (_) {
      return (
        amount.toLocaleString(undefined, {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        }) +
        " " +
        c
      );
    }
  }

  function currencySuffix() {
    return getCurrency() === "auto"
      ? "<span class='note'> (set currency for symbol)</span>"
      : "";
  }

  function compute() {
    clearError();

    const priceRaw = String(priceEl.value || "").trim();
    const discRaw = String(discEl.value || "").trim();

    const price = toNum(priceRaw);
    const disc = toNum(discRaw);

    if (!priceRaw || !discRaw) {
      outEl.textContent = "Result will appear here.";
      srEl.textContent = "";
      return;
    }

    if (!Number.isFinite(price) || price < 0) {
      setError("Please enter a valid original price (0 or more).", "price");
      outEl.textContent = "Please fix the input above.";
      srEl.textContent = "";
      return;
    }

    if (!Number.isFinite(disc) || disc < 0 || disc > 100) {
      setError("Please enter a valid discount between 0 and 100.", "discount");
      outEl.textContent = "Please fix the input above.";
      srEl.textContent = "";
      return;
    }

    const save = price * (disc / 100);
    const final = price - save;

    let tag = "Small discount";
    if (disc >= 10) tag = "Good discount";
    if (disc >= 30) tag = "Big discount";
    if (disc >= 60) tag = "Huge discount";

    const discLabel = disc.toFixed(2).replace(/\.00$/, "");

    outEl.innerHTML =
      "<div style='display:flex; justify-content:space-between; gap:10px; align-items:baseline; flex-wrap:wrap;'>" +
        "<strong>Discount result</strong>" +
        "<span class='note' style='margin:0;'>" + tag + "</span>" +
      "</div>" +
      "<div style='margin-top:6px; font-size:18px; font-weight:700;'>" +
        "Final price: " + formatMoney(final) + currencySuffix() +
      "</div>" +
      "<div style='margin-top:6px;'>" +
        "<strong>You save:</strong> " + formatMoney(save) + currencySuffix() +
        " <span class='note'>(" + discLabel + "%)</span>" +
      "</div>" +
      "<div class='note' style='margin-top:6px;'>" +
        "Formula: final = price × (1 − discount/100)" +
      "</div>";

    srEl.textContent =
      "Final price " + formatMoney(final) + ", you save " + formatMoney(save) + ", discount " + discLabel + " percent.";
  }

  calcBtn.addEventListener("click", function () {
    compute();
    if (priceEl.getAttribute("aria-invalid") === "true") {
      priceEl.focus();
    } else if (discEl.getAttribute("aria-invalid") === "true") {
      discEl.focus();
    }
  });

  clearBtn.addEventListener("click", function () {
    currencyEl.value = "auto";
    priceEl.value = "";
    discEl.value = "";
    clearError();
    outEl.textContent = "Result will appear here.";
    srEl.textContent = "";
    priceEl.focus();
  });

  priceEl.addEventListener("input", compute);
  discEl.addEventListener("input", compute);
  currencyEl.addEventListener("change", compute);

  clearError();
});
</script>