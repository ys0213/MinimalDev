---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Percentile Calculator",
  description:
    "Calculate a percentile value from numeric data using linear interpolation on the sorted dataset.",
  href: "/math/percentile-calculator/",
  order: 382,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/percentile-calculator/";

const faqs = [
  {
    q: "What is a percentile?",
    a: "A percentile shows the value below which a given percentage of observations fall in a sorted dataset.",
  },
  {
    q: "What percentile range is allowed?",
    a: "This calculator accepts percentiles from 0 to 100 inclusive.",
  },
  {
    q: "How does this calculator estimate percentile values?",
    a: "It uses linear interpolation on the sorted dataset between adjacent ranks.",
  },
  {
    q: "How should I enter the data?",
    a: "Enter values separated by commas, spaces, or line breaks.",
  },
  {
    q: "Are calculations stored?",
    a: "No. Everything runs locally in your browser.",
  },
];
---

<ToolLayout
  title={`Percentile Calculator — ${SITE_NAME}`}
  description="Calculate percentile values from numeric data using a sorted dataset and interpolation."
  canonicalPath={CANONICAL_PATH}
  h1="Percentile Calculator"
  intro="Calculate a percentile value from a dataset. Enter numeric values and choose a percentile from 0 to 100."
  faq={faqs}
  categoryName="Math"
>
  <div slot="tool" data-tool="percentile-calculator">
    <style is:inline>
      .pc-wrap, .pc-wrap * { box-sizing: border-box; }
      .pc-grid {
        display:grid;
        grid-template-columns:minmax(0, 1fr) minmax(0, 220px);
        gap:10px;
      }
      .pc-grid textarea,
      .pc-grid input {
        width:100%;
        min-width:0;
      }
      .pc-grid textarea {
        resize:vertical;
      }
      .pc-code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        word-break: break-word;
      }
      .pc-list {
        white-space: normal;
        word-break: break-word;
        overflow-wrap: anywhere;
      }
      @media (max-width: 860px) {
        .pc-grid { grid-template-columns:1fr; }
      }
    </style>

    <div class="form pc-wrap" role="form" aria-describedby="pc_help pc_privacy">
      <div class="pc-grid">
        <div class="field">
          <label for="pc_data">Data values</label>
          <textarea
            id="pc_data"
            rows="7"
            placeholder="e.g.
5, 7, 8, 11, 13, 16, 20"
            spellcheck="false"
          ></textarea>
        </div>
        <div class="field">
          <label for="pc_percentile">Percentile (0–100)</label>
          <input id="pc_percentile" type="number" inputmode="decimal" min="0" max="100" step="any" placeholder="e.g., 75" />
        </div>
      </div>

      <p class="note" id="pc_help" style="margin-top:6px;">
        Enter values separated by commas, spaces, or line breaks.
        <br />
        This page uses a sorted dataset and interpolates between ranks when needed.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="pc_calc">Calculate</button>
        <button class="btn secondary" type="button" id="pc_fill_demo">Fill demo</button>
        <button class="btn secondary" type="button" id="pc_clear">Clear</button>
      </div>

      <div class="result" id="pc_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="pc_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="pc_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="pc_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="pc_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      The data is sorted first. The percentile is then located using a fractional position within the sorted values.
      If the target position falls between two values, the result is linearly interpolated.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Data:</strong> 5, 7, 8, 11, 13, 16, 20</li>
      <li><strong>75th percentile</strong> returns a value near the upper quartile of the dataset.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/quartile-calculator/">Quartile Calculator</a></li>
      <li><a href="/math/median-absolute-deviation/">Median Absolute Deviation Calculator</a></li>
      <li><a href="/math/iqr-calculator/">IQR Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const dataEl = document.getElementById("pc_data");
  const percentileEl = document.getElementById("pc_percentile");
  const calcBtn = document.getElementById("pc_calc");
  const fillBtn = document.getElementById("pc_fill_demo");
  const clearBtn = document.getElementById("pc_clear");
  const errorEl = document.getElementById("pc_error");
  const resultEl = document.getElementById("pc_result");
  const cardsEl = document.getElementById("pc_cards");
  const tbodyEl = document.getElementById("pc_tbody");

  if (!dataEl || !percentileEl || !calcBtn || !fillBtn || !clearBtn || !errorEl || !resultEl || !cardsEl || !tbodyEl) return;

  function fmt(n, digits) {
    return n.toLocaleString(undefined, { maximumFractionDigits: Number.isFinite(digits) ? digits : 8 });
  }

  function badge(text) {
    return "<span style='display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;'>" + text + "</span>";
  }

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function clearOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  function parseData(raw) {
    const text = String(raw || "").trim();
    if (!text) throw new Error("Please enter at least 1 numeric value.");

    const nums = text.split(/[\s,]+/).filter(Boolean).map(function (part) {
      const n = Number(part);
      if (!Number.isFinite(n)) throw new Error("All entries must be valid numbers.");
      return n;
    });

    if (!nums.length) throw new Error("Please enter at least 1 numeric value.");
    return nums;
  }

  function percentileValue(sorted, p) {
    if (sorted.length === 1) return sorted[0];
    const pos = (p / 100) * (sorted.length - 1);
    const lower = Math.floor(pos);
    const upper = Math.ceil(pos);
    if (lower === upper) return sorted[lower];
    const weight = pos - lower;
    return sorted[lower] + weight * (sorted[upper] - sorted[lower]);
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      if (row[2] === "html") td2.innerHTML = row[1];
      else td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearOutput();

    try {
      const arr = parseData(dataEl.value);
      const sorted = arr.slice().sort(function (a, b) { return a - b; });

      const pRaw = String(percentileEl.value || "").trim();
      if (!pRaw) {
        showError("Please enter a percentile between 0 and 100.");
        return;
      }

      const p = Number(pRaw);
      if (!Number.isFinite(p) || p < 0 || p > 100) {
        showError("Percentile must be a valid number between 0 and 100.");
        return;
      }

      const value = percentileValue(sorted, p);
      const pos = (p / 100) * (sorted.length - 1);

      let label = "Middle percentile";
      if (p === 0) label = "Minimum percentile";
      else if (p === 100) label = "Maximum percentile";
      else if (p < 25) label = "Lower percentile";
      else if (p > 75) label = "Upper percentile";

      resultEl.innerHTML =
        "<strong>Percentile result</strong><br/>" +
        "<span class='pc-code'>P" + fmt(p, 4) + " = " + fmt(value, 8) + "</span>";

      cardsEl.style.display = "block";
      cardsEl.innerHTML =
        "<div style='display:flex;gap:10px;flex-wrap:wrap;'>" +
        badge(label) +
        badge("Count = " + sorted.length) +
        badge("Position = " + fmt(pos, 6)) +
        "</div>";

      fillTable([
        ["Count", String(sorted.length)],
        ["Percentile requested", fmt(p, 6)],
        ["Percentile value", fmt(value, 8)],
        ["Position in sorted data", fmt(pos, 8)],
        ["Minimum", fmt(sorted[0], 8)],
        ["Maximum", fmt(sorted[sorted.length - 1], 8)],
        ["Sorted data", "<span class='pc-list'>" + sorted.map(function (x) { return fmt(x, 8); }).join(", ") + "</span>", "html"],
      ]);
    } catch (err) {
      showError(err instanceof Error ? err.message : "Calculation failed.");
    }
  }

  function fillDemo() {
    dataEl.value = "5, 7, 8, 11, 13, 16, 20";
    percentileEl.value = "75";
    clearOutput();
  }

  function reset() {
    dataEl.value = "";
    percentileEl.value = "";
    clearOutput();
    dataEl.focus();
  }

  calcBtn.addEventListener("click", compute);
  fillBtn.addEventListener("click", fillDemo);
  clearBtn.addEventListener("click", reset);

  dataEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  });

  percentileEl.addEventListener("keydown", function (e) {
    if (e.key === "Enter") compute();
  });

  clearOutput();
});
</script>