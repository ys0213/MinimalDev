---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Cumulative Distribution Calculator",
  description:
    "Calculate the normal cumulative distribution value P(X ≤ x) from x, mean, and standard deviation.",
  href: "/math/cumulative-distribution-calculator/",
  order: 387,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/cumulative-distribution-calculator/";

const faqs = [
  {
    q: "What does this cumulative distribution calculator compute?",
    a: "It computes the normal cumulative probability P(X ≤ x) for a chosen x, mean, and standard deviation.",
  },
  {
    q: "What is a cumulative distribution value?",
    a: "A cumulative distribution value is the probability that a random variable is less than or equal to a specified value.",
  },
  {
    q: "What formula is used?",
    a: "This page uses the normal CDF based on the error function: Φ(z) = 0.5 × (1 + erf(z / √2)).",
  },
  {
    q: "Why must standard deviation be positive?",
    a: "Because the z score and normal CDF require division by the standard deviation.",
  },
  {
    q: "Are calculations stored?",
    a: "No. Everything runs locally in your browser.",
  },
];
---

<ToolLayout
  title={`Cumulative Distribution Calculator — ${SITE_NAME}`}
  description="Calculate normal cumulative probability P(X ≤ x) from x, mean, and standard deviation."
  canonicalPath={CANONICAL_PATH}
  h1="Cumulative Distribution Calculator"
  intro="Calculate the cumulative probability of a normal distribution at a chosen x value, using a mean and standard deviation."
  faq={faqs}
  categoryName="Math"
>
  <div slot="tool" data-tool="cumulative-distribution-calculator">
    <style is:inline>
      .cdf-wrap, .cdf-wrap * { box-sizing: border-box; }
      .cdf-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
      }
      .cdf-grid input {
        width: 100%;
        min-width: 0;
      }
      .cdf-code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        word-break: break-word;
      }
      @media (max-width: 860px) {
        .cdf-grid { grid-template-columns: 1fr; }
      }
    </style>

    <div class="form cdf-wrap" role="form" aria-describedby="cdf_help cdf_privacy">
      <div class="cdf-grid">
        <div class="field">
          <label for="cdf_x">x value</label>
          <input id="cdf_x" type="number" inputmode="decimal" step="any" placeholder="e.g., 70" />
        </div>

        <div class="field">
          <label for="cdf_mean">Mean (μ)</label>
          <input id="cdf_mean" type="number" inputmode="decimal" step="any" placeholder="e.g., 65" />
        </div>

        <div class="field">
          <label for="cdf_sd">Standard deviation (σ)</label>
          <input id="cdf_sd" type="number" inputmode="decimal" step="any" min="0" placeholder="e.g., 10" />
        </div>
      </div>

      <p class="note" id="cdf_help" style="margin-top:6px;">
        Formula:
        <br />
        <span class="cdf-code">P(X ≤ x) = Φ(z), where z = (x − μ) / σ</span>
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="cdf_calc">Calculate</button>
        <button class="btn secondary" type="button" id="cdf_fill_demo">Fill demo</button>
        <button class="btn secondary" type="button" id="cdf_clear">Clear</button>
      </div>

      <div class="result" id="cdf_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="cdf_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="cdf_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="cdf_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="cdf_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This page computes the <strong>normal cumulative distribution function</strong>, which gives the probability that
      a normally distributed variable is less than or equal to x.
    </p>
    <p class="note">
      Example interpretation: if the result is 0.6915, then about 69.15% of values are expected to be at or below x.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>x = 70</strong>, <strong>μ = 65</strong>, <strong>σ = 10</strong></li>
      <li>The result is the probability mass to the left of x on the normal curve.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/normal-distribution-calculator/">Normal Distribution Calculator</a></li>
      <li><a href="/math/probability-density-calculator/">Probability Density Calculator</a></li>
      <li><a href="/math/z-score-calculator/">Z Score Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const xEl = document.getElementById("cdf_x");
  const meanEl = document.getElementById("cdf_mean");
  const sdEl = document.getElementById("cdf_sd");
  const calcBtn = document.getElementById("cdf_calc");
  const fillBtn = document.getElementById("cdf_fill_demo");
  const clearBtn = document.getElementById("cdf_clear");
  const errorEl = document.getElementById("cdf_error");
  const resultEl = document.getElementById("cdf_result");
  const cardsEl = document.getElementById("cdf_cards");
  const tbodyEl = document.getElementById("cdf_tbody");

  if (!xEl || !meanEl || !sdEl || !calcBtn || !fillBtn || !clearBtn || !errorEl || !resultEl || !cardsEl || !tbodyEl) return;

  function fmt(n, digits) {
    return n.toLocaleString(undefined, { maximumFractionDigits: Number.isFinite(digits) ? digits : 12 });
  }

  function fmtPct(n, digits) {
    return fmt(n * 100, Number.isFinite(digits) ? digits : 8) + "%";
  }

  function badge(text) {
    return "<span style='display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;'>" + text + "</span>";
  }

  function erf(x) {
    const sign = x < 0 ? -1 : 1;
    const ax = Math.abs(x);
    const a1 = 0.254829592;
    const a2 = -0.284496736;
    const a3 = 1.421413741;
    const a4 = -1.453152027;
    const a5 = 1.061405429;
    const p = 0.3275911;

    const t = 1 / (1 + p * ax);
    const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-ax * ax);
    return sign * y;
  }

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function clearOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearOutput();

    const x = Number(String(xEl.value || "").trim());
    const mean = Number(String(meanEl.value || "").trim());
    const sd = Number(String(sdEl.value || "").trim());

    if (![x, mean, sd].every(Number.isFinite)) {
      showError("Please enter valid numeric values for x, mean, and standard deviation.");
      return;
    }

    if (sd <= 0) {
      showError("Standard deviation must be greater than 0.");
      return;
    }

    const z = (x - mean) / sd;
    const cdf = 0.5 * (1 + erf(z / Math.SQRT2));
    const rightTail = 1 - cdf;

    let label = "Central region";
    if (cdf < 0.1) label = "Lower tail";
    else if (cdf > 0.9) label = "Upper tail";

    resultEl.innerHTML =
      "<strong>Cumulative distribution result</strong><br/>" +
      "<span class='cdf-code'>P(X ≤ x) = " + fmt(cdf, 12) + "</span>" +
      "<br/><span class='note'>Equivalent percentage = " + fmtPct(cdf, 8) + "</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      "<div style='display:flex;gap:10px;flex-wrap:wrap;'>" +
      badge(label) +
      badge("z = " + fmt(z, 4)) +
      badge("Right tail = " + fmtPct(rightTail, 4)) +
      "</div>";

    fillTable([
      ["x", fmt(x, 8)],
      ["Mean (μ)", fmt(mean, 8)],
      ["Standard deviation (σ)", fmt(sd, 8)],
      ["z score", fmt(z, 8)],
      ["P(X ≤ x)", fmt(cdf, 12)],
      ["P(X > x)", fmt(rightTail, 12)],
      ["Percentage at or below x", fmtPct(cdf, 8)],
    ]);
  }

  function fillDemo() {
    xEl.value = "70";
    meanEl.value = "65";
    sdEl.value = "10";
    clearOutput();
  }

  function reset() {
    xEl.value = "";
    meanEl.value = "";
    sdEl.value = "";
    clearOutput();
    xEl.focus();
  }

  calcBtn.addEventListener("click", compute);
  fillBtn.addEventListener("click", fillDemo);
  clearBtn.addEventListener("click", reset);

  [xEl, meanEl, sdEl].forEach(function (el) {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") compute();
    });
  });

  clearOutput();
});
</script>