---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Reverse Percentage Calculator",
  description: "Free reverse percentage calculator. Find what percent Y is of X instantly.",
  href: "/math/reverse-percentage-calculator/",
  order: 130,
};

const faqs = [
  {
    q: "What if X is 0?",
    a: "Division by zero is undefined, so the result cannot be computed when X is 0.",
  },
  {
    q: "Can the result exceed 100%?",
    a: "Yes. If Y is larger than X, then Y divided by X is greater than 1, producing a percentage above 100%.",
  },
  {
    q: "Is this the same as percent of a number?",
    a: "It is the reverse operation. Instead of finding a value from a percent, it solves for the percent given Y and X.",
  },
];
---

<ToolLayout
  title="Reverse Percentage Calculator — MinimalDev"
  description="Free reverse percentage calculator. Find what percent Y is of X (Y ÷ X × 100)."
  canonicalPath="/math/reverse-percentage-calculator/"
  h1="Reverse Percentage Calculator"
  intro="Find what percent Y is of X. Useful for grading, progress, conversion rates, and comparisons."
  faq={faqs}
  categoryName="Math"
>
  <div slot="tool" data-tool="reverse-percentage-calculator">
    <div class="form">
      <div class="field">
        <label for="rp_y">Y (part)</label>
        <input
          id="rp_y"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 45"
          step="0.01"
          min="-1000000000000000"
          max="1000000000000000"
          aria-describedby="rp_help rp_error"
        />
      </div>

      <div class="field">
        <label for="rp_x">X (whole)</label>
        <input
          id="rp_x"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 60"
          step="0.01"
          min="-1000000000000000"
          max="1000000000000000"
          aria-describedby="rp_help rp_error"
        />
        <div id="rp_error" class="note" style="margin-top:6px;" aria-live="polite"></div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="rp_calc">Calculate</button>
        <button class="btn secondary" type="button" id="rp_clear">Clear</button>
      </div>

      <div
        class="result"
        id="rp_result"
        role="status"
        aria-live="polite"
        style="margin-top:12px;"
      >
        Result will appear here.
      </div>

      <div
        class="note"
        id="rp_sr_summary"
        style="position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;"
      ></div>

      <p class="note" id="rp_help" style="margin-top:8px;">
        Privacy: calculations run locally in your browser. No inputs are stored or sent to a server.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      <strong>Formula:</strong> percent = (Y ÷ X) × 100<br />
      Example: 45 out of 60 → (45 ÷ 60) × 100 = 75%
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>45 is what percent of 60? → 75%</li>
      <li>18 is what percent of 200? → 9%</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/percent-calculator/">Percent Calculator</a></li>
      <li><a href="/math/percent-increase-calculator/">Percent Increase Calculator</a></li>
      <li><a href="/math/percent-decrease-calculator/">Percent Decrease Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const yEl = document.getElementById("rp_y");
  const xEl = document.getElementById("rp_x");
  const calcBtn = document.getElementById("rp_calc");
  const clearBtn = document.getElementById("rp_clear");
  const outEl = document.getElementById("rp_result");
  const errEl = document.getElementById("rp_error");
  const srEl = document.getElementById("rp_sr_summary");

  if (!yEl || !xEl || !calcBtn || !clearBtn || !outEl || !errEl || !srEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    yEl.removeAttribute("aria-invalid");
    xEl.removeAttribute("aria-invalid");
    errEl.textContent = "";
  }

  function setError(msg, which) {
    errEl.textContent = msg;
    if (which === "y") yEl.setAttribute("aria-invalid", "true");
    if (which === "x") xEl.setAttribute("aria-invalid", "true");
    if (which === "both") {
      yEl.setAttribute("aria-invalid", "true");
      xEl.setAttribute("aria-invalid", "true");
    }
  }

  function fmtNumber(n) {
    if (!Number.isFinite(n)) return "0";
    return n.toLocaleString(undefined, { maximumFractionDigits: 10 });
  }

  function fmtPct(p) {
    if (!Number.isFinite(p)) return "0%";
    const abs = Math.abs(p);
    const s = abs.toLocaleString(undefined, { maximumFractionDigits: 4 });
    return s + "%";
  }

  function compute(showEmptyAsPlaceholder) {
    clearError();

    const yRaw = String(yEl.value || "").trim();
    const xRaw = String(xEl.value || "").trim();

    if (!yRaw || !xRaw) {
      if (showEmptyAsPlaceholder) outEl.textContent = "Result will appear here.";
      srEl.textContent = "";
      return null;
    }

    const y = toNum(yRaw);
    const x = toNum(xRaw);

    if (!Number.isFinite(y)) {
      setError("Please enter a valid Y (part).", "y");
      outEl.textContent = "Please fix the input above.";
      srEl.textContent = "";
      return null;
    }
    if (!Number.isFinite(x)) {
      setError("Please enter a valid X (whole).", "x");
      outEl.textContent = "Please fix the input above.";
      srEl.textContent = "";
      return null;
    }

    if (Math.abs(y) > 1e15) {
      setError("Y is too large. Please enter a smaller value.", "y");
      outEl.textContent = "Please fix the input above.";
      srEl.textContent = "";
      return null;
    }
    if (Math.abs(x) > 1e15) {
      setError("X is too large. Please enter a smaller value.", "x");
      outEl.textContent = "Please fix the input above.";
      srEl.textContent = "";
      return null;
    }

    if (x === 0) {
      setError("X cannot be 0 (division by zero).", "x");
      outEl.textContent = "Please enter a non-zero X value.";
      srEl.textContent = "";
      return null;
    }

    const pct = (y / x) * 100;

    let tag = "Standard";
    if (pct < 0) tag = "Negative percent";
    if (pct > 100) tag = "Over 100%";

    outEl.innerHTML =
      "<div style='display:flex; justify-content:space-between; gap:10px; align-items:baseline; flex-wrap:wrap;'>" +
        "<strong>Result</strong>" +
        "<span class='note' style='margin:0;'>" + tag + "</span>" +
      "</div>" +
      "<div style='margin-top:6px; font-size:18px; font-weight:700;'>" +
        fmtPct(pct) +
      "</div>" +
      "<div class='note' style='margin-top:6px;'>" +
        fmtNumber(y) + " is " + fmtPct(pct) + " of " + fmtNumber(x) + "." +
      "</div>" +
      "<div class='note' style='margin-top:4px;'>" +
        "Computed as (" + fmtNumber(y) + " ÷ " + fmtNumber(x) + ") × 100" +
      "</div>";

    srEl.textContent =
      "Y " + fmtNumber(y) + ", X " + fmtNumber(x) + ". Result " + fmtPct(pct) + ".";

    return { y, x, pct };
  }

  calcBtn.addEventListener("click", function () {
    const r = compute(false);
    if (!r) {
      if (yEl.getAttribute("aria-invalid") === "true") yEl.focus();
      else if (xEl.getAttribute("aria-invalid") === "true") xEl.focus();
      else outEl.textContent = "Please enter values to calculate.";
    }
  });

  clearBtn.addEventListener("click", function () {
    yEl.value = "";
    xEl.value = "";
    clearError();
    outEl.textContent = "Result will appear here.";
    srEl.textContent = "";
    yEl.focus();
  });

  yEl.addEventListener("input", function () { compute(true); });
  xEl.addEventListener("input", function () { compute(true); });

  clearError();
});
</script>