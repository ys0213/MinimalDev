---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Nth Root Calculator",
  description:
    "Calculate nth roots using a selected root degree.",
  href: "/math/nth-root-calculator/",
  order: 352,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/nth-root-calculator/";

const faqs = [
  {
    q: "What is an nth root?",
    a: "The nth root of x is a value y such that y^n = x.",
  },
  {
    q: "Can I use a negative x?",
    a: "Yes, but only when n is an odd integer if you want a real-number result.",
  },
  {
    q: "Why can’t n be 0?",
    a: "A zeroth root is undefined, because it would require solving y^0 = x.",
  },
  {
    q: "Are calculations stored?",
    a: "No. Everything runs locally in your browser.",
  },
];
---

<ToolLayout
  title={`Nth Root Calculator — ${SITE_NAME}`}
  description="Calculate nth roots of numbers for algebra, powers, radicals, scientific calculations, and equation solving."
  canonicalPath={CANONICAL_PATH}
  h1="Nth Root Calculator"
  intro="Calculate nth roots with real-number domain checks and view the equivalent power relationship."
  faq={faqs}
  categoryName="Math"
>
  <div slot="tool" data-tool="nth-root-calculator">
    <style is:inline>
      .nrc-wrap, .nrc-wrap * { box-sizing: border-box; }
      .nrc-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }
      @media (max-width: 720px) {
        .nrc-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <div class="form nrc-wrap" role="form" aria-describedby="nrc_help nrc_privacy">
      <div class="nrc-grid">
        <div class="field">
          <label for="nrc_x">Value x</label>
          <input id="nrc_x" type="number" step="any" inputmode="decimal" placeholder="e.g., 16" />
        </div>
        <div class="field">
          <label for="nrc_n">Root n</label>
          <input id="nrc_n" type="number" step="1" inputmode="numeric" placeholder="e.g., 4" />
        </div>
      </div>

      <p class="note" id="nrc_help" style="margin-top:8px;">
        Real-number rule: if <strong>x &lt; 0</strong>, then <strong>n</strong> must be an odd integer.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="nrc_calc">Calculate</button>
        <button class="btn secondary" type="button" id="nrc_fill_demo">Fill demo</button>
        <button class="btn secondary" type="button" id="nrc_clear">Clear</button>
      </div>

      <div class="result" id="nrc_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="nrc_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="nrc_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="nrc_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="nrc_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No values are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      The nth root solves:
      <br />
      <strong>y^n = x</strong>
      <br />
      For positive x, this is computed as:
      <br />
      <strong>x^(1/n)</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>4th root of 16</strong> = <strong>2</strong></li>
      <li><strong>5th root of 32</strong> = <strong>2</strong></li>
      <li><strong>3rd root of -27</strong> = <strong>-3</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/cube-root-calculator/">Cube Root Calculator</a></li>
      <li><a href="/math/square-root-calculator/">Square Root Calculator</a></li>
      <li><a href="/math/exponent-calculator/">Exponent Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const xEl = document.getElementById("nrc_x");
  const nEl = document.getElementById("nrc_n");
  const calcBtn = document.getElementById("nrc_calc");
  const demoBtn = document.getElementById("nrc_fill_demo");
  const clearBtn = document.getElementById("nrc_clear");
  const errorEl = document.getElementById("nrc_error");
  const resultEl = document.getElementById("nrc_result");
  const cardsEl = document.getElementById("nrc_cards");
  const tbodyEl = document.getElementById("nrc_tbody");

  if (!xEl || !nEl || !calcBtn || !demoBtn || !clearBtn || !errorEl || !resultEl || !cardsEl || !tbodyEl) return;

  function badge(text) {
    return "<span style='display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;'>" + text + "</span>";
  }

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function clearOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  function getNum(el, label) {
    const raw = String(el.value || "").trim();
    if (!raw) throw new Error("Please enter both x and n.");
    const n = Number(raw);
    if (!Number.isFinite(n)) throw new Error("Enter a valid number for " + label + ".");
    return n;
  }

  function fmt(n) {
    const rounded = Math.round(n * 1e12) / 1e12;
    return rounded.toLocaleString(undefined, { maximumFractionDigits: 12 });
  }

  function isInteger(n) {
    return Math.abs(n - Math.round(n)) < 1e-12;
  }

  function nthRoot(x, n) {
    if (x < 0) {
      return -Math.pow(-x, 1 / n);
    }
    return Math.pow(x, 1 / n);
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearOutput();

    try {
      const x = getNum(xEl, "x");
      const n = getNum(nEl, "n");

      if (Math.abs(n) < 1e-12) {
        showError("n cannot be 0.");
        return;
      }

      if (!isInteger(n)) {
        showError("This real-number nth root tool requires n to be an integer.");
        return;
      }

      const nInt = Math.trunc(n);

      if (nInt < 0) {
        showError("Please enter a positive integer for n.");
        return;
      }

      if (x < 0 && nInt % 2 === 0) {
        showError("A negative x with an even n does not have a real nth root.");
        return;
      }

      const y = nthRoot(x, nInt);
      const check = Math.pow(y, nInt);

      resultEl.innerHTML =
        "<strong>Nth root result</strong><br/>" +
        "<span style='font-size:1.15rem;font-weight:800;'>" + fmt(nInt) + "th root of " + fmt(x) + " = " + fmt(y) + "</span>";

      cardsEl.style.display = "block";
      cardsEl.innerHTML =
        "<div style='display:flex;gap:10px;flex-wrap:wrap;'>" +
        badge("n = " + nInt) +
        badge(x < 0 ? "Negative input" : "Non-negative input") +
        badge(fmt(y) + "^" + nInt + " ≈ " + fmt(check)) +
        "</div>";

      fillTable([
        ["Input x", fmt(x)],
        ["Root n", String(nInt)],
        ["Nth root", fmt(y)],
        ["Verification", fmt(y) + "^" + nInt + " ≈ " + fmt(check)],
      ]);
    } catch (err) {
      showError(err instanceof Error ? err.message : "Could not calculate the nth root.");
    }
  }

  function fillDemo() {
    xEl.value = "16";
    nEl.value = "4";
    clearOutput();
  }

  function reset() {
    xEl.value = "";
    nEl.value = "";
    clearOutput();
    xEl.focus();
  }

  calcBtn.addEventListener("click", compute);
  demoBtn.addEventListener("click", fillDemo);
  clearBtn.addEventListener("click", reset);

  [xEl, nEl].forEach(function (el) {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") compute();
    });
  });

  clearOutput();
});
</script>