---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
 title:"Binary Calculator",
 description:"Add, subtract, multiply and divide binary numbers.",
 href:"/math/binary-calculator/",
 order:230
};

const SITE_NAME="MinimalDev";
const CANONICAL_PATH="/math/binary-calculator/";

const faqs=[
{q:"What is binary?",a:"Binary is a base-2 number system using only 0 and 1."},
{q:"What operations are supported?",a:"Addition, subtraction, multiplication and division."},
{q:"Why convert binary?",a:"Binary is used by computers to represent data."},
{q:"Are inputs stored?",a:"No. Calculations run locally in your browser."}
];

const faqJsonLd={
"@context":"https://schema.org",
"@type":"FAQPage",
mainEntity:faqs.map(f=>({
"@type":"Question",
name:f.q,
acceptedAnswer:{ "@type":"Answer", text:f.a }
}))
};
---

<ToolLayout
title={`Binary Calculator — ${SITE_NAME}`}
description="Binary arithmetic calculator with result cards and validation."
canonicalPath={CANONICAL_PATH}
h1="Binary Calculator"
intro="Perform arithmetic with binary numbers."
>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<div slot="tool">

<div class="form">

<div class="field">
<label>Binary A</label>
<input id="bin_a" placeholder="e.g., 1011"/>
</div>

<div class="field">
<label>Binary B</label>
<input id="bin_b" placeholder="e.g., 0101"/>
</div>

<div class="field">
<label>Operation</label>
<select id="bin_op">
<option value="+">Add</option>
<option value="-">Subtract</option>
<option value="*">Multiply</option>
<option value="/">Divide</option>
</select>
</div>

<button class="btn" id="bin_calc">Calculate</button>

<div class="result" id="bin_result">Result will appear here.</div>
<div class="result" id="bin_cards" style="display:none;"></div>

</div>
</div>

<div slot="faq">
<ul>{faqs.map(f=>(<li><strong>{f.q}</strong> {f.a}</li>))}</ul>
</div>

<div slot="related">
<ul>
<li><a href="/math/hex-calculator/">Hex Calculator</a></li>
<li><a href="/math/number-base-converter/">Number Base Converter</a></li>
<li><a href="/math/">All Math Tools</a></li>
</ul>
</div>

</ToolLayout>

<script is:inline>

function validBinary(v){return /^[01]+$/.test(v)}

document.getElementById("bin_calc").onclick=()=>{

const a=document.getElementById("bin_a").value.trim()
const b=document.getElementById("bin_b").value.trim()
const op=document.getElementById("bin_op").value

if(!validBinary(a)||!validBinary(b)){
document.getElementById("bin_result").textContent="Binary numbers must contain only 0 and 1."
return
}

const A=parseInt(a,2)
const B=parseInt(b,2)

let r
if(op==="+") r=A+B
if(op==="-") r=A-B
if(op==="*") r=A*B
if(op==="/") r=Math.floor(A/B)

const out=r.toString(2)

document.getElementById("bin_result").innerHTML=
"<strong>"+out+"</strong>"

document.getElementById("bin_cards").style.display="block"
document.getElementById("bin_cards").innerHTML=
`<span class="badge">Decimal result: ${r}</span>`
}

</script>