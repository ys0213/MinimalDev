---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/math/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort(
    (a, b) =>
      (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title)
  );
---

<BaseLayout
  title="Math Tools — MinimalDev"
  description="Free math calculators for percentages, ratios, averages, algebra, geometry, statistics, and everyday calculations. Solve math problems quickly in your browser."
  canonicalPath="/math/"
>
  <div class="container">
    <h1 class="page-title">Math Tools</h1>
    <p class="lead">
      Free math tools for percentages, ratios, algebra, statistics, geometry, and everyday calculations.
      Use these calculators to solve common problems such as discounts, averages, square roots, factorials, and formulas.
      All math tools run instantly in your browser.
    </p>

    <div class="tool-search" style="margin-bottom:16px;">
      <input
          id="toolSearch"
          type="search"
          placeholder="Search tools..."
          style="
          width:100%;
          padding:10px 12px;
          border-radius:10px;
          border:1px solid rgba(0,0,0,0.15);
          font-size:14px;
          "
      />
    </div>

    {tools.length ? (
      <div class="grid">
        {tools.map((t) => (
          <section class="card">
            <h2>{t.title}</h2>
            <p>{t.description}</p>
            <a class="btn" href={t.href}>Open</a>
          </section>
        ))}
      </div>
    ) : (
      <p class="note">No tools found in this category yet.</p>
    )}

    <section class="section">
      <h2>FAQ</h2>
      <ul>
        <li><strong>Do I need an account?</strong> No. Tools run locally in your browser.</li>
        <li><strong>Are results exact?</strong> Standard formulas are used.</li>
      </ul>
    </section>
  </div>
</BaseLayout>