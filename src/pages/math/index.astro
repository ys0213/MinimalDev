---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/math/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort(
    (a, b) =>
      (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title)
  );

const getTool = (href: string) => tools.find((tool) => tool.href === href);
const pickTools = (hrefs: string[]) => hrefs.map(getTool).filter((tool): tool is ToolMeta => !!tool);

const popularTools = pickTools([
  "/math/percent-calculator/",
  "/math/percentage-change-calculator/",
  "/math/average-calculator/",
  "/math/fraction-calculator/",
  "/math/pythagorean-theorem-calculator/",
  "/math/standard-deviation-calculator/",
  "/math/quadratic-equation-calculator/",
  "/math/scientific-calculator/",
]);

const toolGroups = [
  {
    title: "Percentages and ratios",
    description: "Use these tools for percent changes, discounts, comparisons, ratios, proportions, and everyday number relationships.",
    tools: pickTools([
      "/math/percent-calculator/",
      "/math/percentage-change-calculator/",
      "/math/percent-increase-calculator/",
      "/math/percent-decrease-calculator/",
      "/math/ratio-calculator/",
      "/math/proportion-calculator/",
    ]),
  },
  {
    title: "Averages and statistics",
    description: "Calculate summaries, spread, sample statistics, and common values used in school, reporting, and analysis.",
    tools: pickTools([
      "/math/average-calculator/",
      "/math/mean-median-mode-calculator/",
      "/math/standard-deviation-calculator/",
      "/math/variance-population-calculator/",
      "/math/variance-sample-calculator/",
      "/math/z-score-calculator/",
    ]),
  },
  {
    title: "Algebra and equations",
    description: "Solve equations, work with roots, exponents, logarithms, and common algebra-style problems.",
    tools: pickTools([
      "/math/equation-solver/",
      "/math/linear-equation-solver/",
      "/math/quadratic-equation-calculator/",
      "/math/square-root-calculator/",
      "/math/exponent-calculator/",
      "/math/log-calculator/",
    ]),
  },
  {
    title: "Geometry and measurement",
    description: "Use these calculators for shapes, distances, areas, volumes, and formula-based geometry checks.",
    tools: pickTools([
      "/math/pythagorean-theorem-calculator/",
      "/math/triangle-area-calculator/",
      "/math/circle-area-calculator/",
      "/math/sphere-volume-calculator/",
      "/math/distance-formula-calculator/",
      "/math/slope-calculator/",
    ]),
  },
].filter((group) => group.tools.length);
---

<BaseLayout
  title="Math Tools — MinimalDev"
  description="Free math calculators for percentages, ratios, averages, algebra, geometry, statistics, roots, equations, and everyday calculations."
  canonicalPath="/math/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <h1 class="page-title" style="margin:0 0 8px;">Math Tools</h1>
      <p class="lead" style="margin:0 0 10px;">
        Solve common math tasks with focused calculators for percentages, ratios, averages,
        algebra, geometry, statistics, roots, and formula-based problems.
      </p>
      <p class="lead" style="margin:0;">
        Start with a task group if you are not sure which calculator fits your problem,
        or use the full list when you already know the exact calculation you need.
      </p>
    </section>

    {popularTools.length ? (
      <section class="section">
        <h2>Start with common math tools</h2>
        <div class="grid">
          {popularTools.map((t) => (
            <section class="card">
              <span class="badge">Popular math tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    {toolGroups.length ? (
      <section class="section">
        <h2>Math tools by task</h2>
        <div class="grid">
          {toolGroups.map((group) => (
            <section class="card">
              <h2>{group.title}</h2>
              <p>{group.description}</p>
              <ul>
                {group.tools.map((t) => (
                  <li><a href={t.href}>{t.title}</a></li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    <section class="section">
      <h2>What these tools are useful for</h2>
      <div class="grid">
        <section class="card">
          <h2>Everyday calculations</h2>
          <p>
            Use math tools for discounts, markups, percentages, averages, ratios,
            simple comparisons, and other quick calculations that come up in daily life.
          </p>
        </section>

        <section class="card">
          <h2>Study and practice</h2>
          <p>
            Check formulas, review intermediate results, and solve structured math problems
            more quickly while studying or practicing.
          </p>
        </section>

        <section class="card">
          <h2>Work and planning</h2>
          <p>
            Use calculators for estimates, numeric checks, measurement-based planning,
            summaries, and repeated business or project calculations.
          </p>
        </section>
      </div>
    </section>

    <section class="section">
      <h2>Browse all math tools</h2>
      <p class="lead" style="margin-top:0;">
        Search all available math calculators below if you already know the type of calculation you need.
      </p>

      <div class="tool-search" style="margin-bottom:16px;">
        <input
          id="toolSearch"
          type="search"
          placeholder="Search tools..."
          aria-label="Search math tools"
          style="
            width:100%;
            padding:10px 12px;
            border-radius:10px;
            border:1px solid rgba(0,0,0,0.15);
            font-size:14px;
            box-sizing:border-box;
          "
        />
      </div>

      {tools.length ? (
        <div class="grid" data-search-grid>
          {tools.map((t) => (
            <section class="card">
              <span class="badge">Math</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      ) : (
        <p class="note">No tools found in this category yet.</p>
      )}
    </section>

    <section class="section">
      <h2>How to choose the right calculator</h2>
      <div class="card" style="padding:18px;">
        <p style="margin-top:0;">
          If your problem is about comparing parts of a number, start with percentage or ratio tools.
          If it is about repeated values or summaries, use averages or statistics-related pages.
          If the problem involves shapes or measurements, choose a geometry-oriented calculator.
        </p>
        <p style="margin-bottom:0;">
          Focused calculators make results easier to check because each page is built around one main
          calculation instead of mixing unrelated inputs into one large form.
        </p>
      </div>
    </section>
  </div>

  <script>
    const searchInput = document.getElementById("toolSearch") as HTMLInputElement | null;
    const grid = document.querySelector("[data-search-grid]");

    if (searchInput && grid) {
      const cards = Array.from(grid.querySelectorAll(".card")) as HTMLElement[];

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();

        cards.forEach((card) => {
          const text = card.textContent?.toLowerCase() || "";
          card.style.display = text.includes(query) ? "" : "none";
        });
      });
    }
  </script>
</BaseLayout>