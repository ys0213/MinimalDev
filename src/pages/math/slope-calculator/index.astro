---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Slope Calculator",
  description:
    "Calculate slope between two points. Includes validation, undefined-slope handling, result cards, and FAQ schema.",
  href: "/math/slope-calculator/",
  order: 280,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/slope-calculator/";

const faqs = [
  {
    q: "What is slope?",
    a: "Slope measures the steepness of a line and is calculated as rise over run: (y2−y1)/(x2−x1).",
  },
  {
    q: "What if x1 equals x2?",
    a: "Then the slope is undefined because the line is vertical and division by zero would occur.",
  },
  {
    q: "Can slope be negative?",
    a: "Yes. A negative slope means the line goes down as x increases.",
  },
  {
    q: "Are my coordinates stored?",
    a: "No. Calculations run locally in your browser and are not stored or transmitted.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Slope Calculator — ${SITE_NAME}`}
  description="Calculate the slope between two points with validation, undefined-slope handling, result cards, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Slope Calculator"
  intro="Enter two points (x1, y1) and (x2, y2) to calculate the slope of the line through them."
>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<div slot="tool" data-tool="slope-calculator">

<style is:inline>

.sl-grid{
display:grid;
grid-template-columns:1fr;
gap:10px;
}

.sl-grid > *{
min-width:0;
}

#sl_x1,#sl_y1,#sl_x2,#sl_y2,#sl_round{
width:100%;
min-width:0;
}

@media(min-width:700px){
.sl-grid{
grid-template-columns:1fr 1fr;
}
}

</style>

<div class="form" role="form" aria-describedby="sl_help sl_privacy">

<div class="sl-grid">

<div class="field">
<label for="sl_x1">x1</label>
<input id="sl_x1" type="number" inputmode="decimal" placeholder="e.g., 1"/>
</div>

<div class="field">
<label for="sl_y1">y1</label>
<input id="sl_y1" type="number" inputmode="decimal" placeholder="e.g., 2"/>
</div>

<div class="field">
<label for="sl_x2">x2</label>
<input id="sl_x2" type="number" inputmode="decimal" placeholder="e.g., 4"/>
</div>

<div class="field">
<label for="sl_y2">y2</label>
<input id="sl_y2" type="number" inputmode="decimal" placeholder="e.g., 8"/>
</div>

</div>

<div class="field">
<label for="sl_round">Rounding</label>
<select id="sl_round">
<option value="4" selected>4 decimals</option>
<option value="6">6 decimals</option>
<option value="10">10 decimals</option>
<option value="auto">Smart</option>
</select>
</div>

<div style="display:flex;gap:10px;flex-wrap:wrap;">
<button class="btn" type="button" id="sl_calc">Calculate</button>
<button class="btn secondary" type="button" id="sl_clear">Clear</button>
</div>

<div class="result" id="sl_error" role="alert" style="display:none;margin-top:12px;"></div>

<div class="result" id="sl_result" role="status" style="margin-top:12px;">
Result will appear here.
</div>

<div class="result" id="sl_cards" style="display:none;margin-top:12px;"></div>

<div style="margin-top:16px;overflow:auto;">
<table style="width:100%;border-collapse:collapse;">
<thead>
<tr>
<th scope="col">Metric</th>
<th scope="col">Value</th>
</tr>
</thead>
<tbody id="sl_tbody"></tbody>
</table>
</div>

<p class="note" id="sl_help" style="margin-top:6px;">
Uses the slope formula: <strong>(y2−y1)/(x2−x1)</strong>.
</p>

<p class="note" id="sl_privacy" style="margin-top:10px;">
Privacy: calculations run locally in your browser. No coordinates are stored or transmitted.
</p>

</div>
</div>

<div slot="how">
<p class="note">
Slope formula:<br>
<strong>m = (y2−y1) / (x2−x1)</strong>
</p>
</div>

<div slot="examples">
<ul>
<li><strong>(1, 2)</strong> to <strong>(4, 8)</strong> → slope = <strong>2</strong></li>
<li><strong>(0, 0)</strong> to <strong>(3, 3)</strong> → slope = <strong>1</strong></li>
<li><strong>(2, 1)</strong> to <strong>(2, 5)</strong> → slope = <strong>undefined</strong></li>
</ul>
</div>

<div slot="faq">
<ul>
{faqs.map((f)=>(
<li><strong>{f.q}</strong> {f.a}</li>
))}
</ul>
</div>

<div slot="related">
<ul>
<li><a href="/math/distance-formula-calculator/">Distance Formula Calculator</a></li>
<li><a href="/math/triangle-area-calculator/">Triangle Area Calculator</a></li>
<li><a href="/math/quadratic-equation-calculator/">Quadratic Equation Calculator</a></li>
<li><a href="/math/">All Math Tools</a></li>
</ul>
</div>

</ToolLayout>

<script is:inline>

document.addEventListener("DOMContentLoaded",function(){

const x1=document.getElementById("sl_x1")
const y1=document.getElementById("sl_y1")
const x2=document.getElementById("sl_x2")
const y2=document.getElementById("sl_y2")

const round=document.getElementById("sl_round")

const calc=document.getElementById("sl_calc")
const clear=document.getElementById("sl_clear")

const error=document.getElementById("sl_error")
const result=document.getElementById("sl_result")
const cards=document.getElementById("sl_cards")
const tbody=document.getElementById("sl_tbody")

function toNum(v){
const x=parseFloat(String(v))
return Number.isFinite(x)?x:NaN
}

function fmt(x){
if(!Number.isFinite(x))return "—"

const r=String(round.value)

if(r==="auto"){
const ax=Math.abs(x)
if(ax===0)return "0"
if(ax>=1e12||ax<1e-10)return x.toExponential(8)
return String(Number(x.toPrecision(12)))
}

const d=parseInt(r,10)

return x.toLocaleString(undefined,{
maximumFractionDigits:d,
minimumFractionDigits:0
})
}

function badge(t){
return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${t}</span>`
}

function fill(dx,dy,slopeText){

tbody.innerHTML=""

const rows=[
["Δx",fmt(dx)],
["Δy",fmt(dy)],
["Slope",slopeText]
]

rows.forEach(r=>{

const tr=document.createElement("tr")
const td1=document.createElement("td")
const td2=document.createElement("td")

td1.textContent=r[0]
td2.textContent=r[1]

tr.appendChild(td1)
tr.appendChild(td2)

tbody.appendChild(tr)

})

}

function compute(){

cards.style.display="none"
tbody.innerHTML=""

const X1=toNum(x1.value)
const Y1=toNum(y1.value)
const X2=toNum(x2.value)
const Y2=toNum(y2.value)

if(![X1,Y1,X2,Y2].every(Number.isFinite)){
result.textContent="Please enter valid numbers."
return
}

const dx=X2-X1
const dy=Y2-Y1

if(dx===0){

result.innerHTML=`<strong>Slope:</strong> undefined<br>
<span class="note">Vertical line (division by zero).</span>`

cards.style.display="block"

cards.innerHTML=
`<div style="display:flex;gap:10px;flex-wrap:wrap;">
${badge("Vertical line")}
${badge("Undefined slope")}
</div>`

fill(dx,dy,"undefined")

return
}

const slope=dy/dx

result.innerHTML=
`<strong>Slope:</strong> ${fmt(slope)}<br>
<span class="note">(${fmt(Y2)}−${fmt(Y1)}) / (${fmt(X2)}−${fmt(X1)})</span>`

cards.style.display="block"

cards.innerHTML=
`<div style="display:flex;gap:10px;flex-wrap:wrap;">
${badge(slope>0?"Positive slope":slope<0?"Negative slope":"Horizontal line")}
${badge(Math.abs(slope)<1?"Gentle slope":"Steeper slope")}
</div>`

fill(dx,dy,fmt(slope))

}

function reset(){

x1.value=""
y1.value=""
x2.value=""
y2.value=""

round.value="4"

result.textContent="Result will appear here."

cards.style.display="none"
cards.innerHTML=""
tbody.innerHTML=""

x1.focus()

}

calc.addEventListener("click",compute)
clear.addEventListener("click",reset)

[x1,y1,x2,y2].forEach(el=>{
el.addEventListener("keydown",e=>{
if(e.key==="Enter")compute()
})
})

})

</script>