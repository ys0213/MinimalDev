---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Triangle Perimeter Calculator",
  description:
    "Calculate triangle perimeter from three side lengths and validate the triangle inequality.",
  href: "/math/triangle-perimeter-calculator/",
  order: 388,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/math/triangle-perimeter-calculator/";

const faqs = [
  {
    q: "What is triangle perimeter?",
    a: "Triangle perimeter is the total length around the triangle, equal to the sum of all three side lengths.",
  },
  {
    q: "What formula is used?",
    a: "This page uses perimeter = a + b + c.",
  },
  {
    q: "Why does the calculator validate side lengths?",
    a: "A valid triangle must satisfy the triangle inequality: each side must be less than the sum of the other two sides.",
  },
  {
    q: "Can this calculator classify the triangle?",
    a: "Yes. It labels the triangle as equilateral, isosceles, or scalene based on the side lengths.",
  },
  {
    q: "Are calculations stored?",
    a: "No. Everything runs locally in your browser.",
  },
];
---

<ToolLayout
  title={`Triangle Perimeter Calculator — ${SITE_NAME}`}
  description="Calculate triangle perimeter from side lengths and validate the triangle inequality."
  canonicalPath={CANONICAL_PATH}
  h1="Triangle Perimeter Calculator"
  intro="Calculate the perimeter of a triangle from three side lengths. This page also validates whether the side lengths form a valid triangle and classifies the triangle by side type."
  faq={faqs}
  categoryName="Math"
>
  <div slot="tool" data-tool="triangle-perimeter-calculator">
    <style is:inline>
      .tp-wrap, .tp-wrap * { box-sizing: border-box; }
      .tp-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
      }
      .tp-grid input {
        width: 100%;
        min-width: 0;
      }
      .tp-code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        word-break: break-word;
      }
      @media (max-width: 860px) {
        .tp-grid { grid-template-columns: 1fr; }
      }
    </style>

    <div class="form tp-wrap" role="form" aria-describedby="tp_help tp_privacy">
      <div class="tp-grid">
        <div class="field">
          <label for="tp_a">Side a</label>
          <input id="tp_a" type="number" inputmode="decimal" step="any" min="0" placeholder="e.g., 3" />
        </div>

        <div class="field">
          <label for="tp_b">Side b</label>
          <input id="tp_b" type="number" inputmode="decimal" step="any" min="0" placeholder="e.g., 4" />
        </div>

        <div class="field">
          <label for="tp_c">Side c</label>
          <input id="tp_c" type="number" inputmode="decimal" step="any" min="0" placeholder="e.g., 5" />
        </div>
      </div>

      <p class="note" id="tp_help" style="margin-top:6px;">
        Formula:
        <br />
        <span class="tp-code">Perimeter = a + b + c</span>
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="tp_calc">Calculate</button>
        <button class="btn secondary" type="button" id="tp_fill_demo">Fill demo</button>
        <button class="btn secondary" type="button" id="tp_clear">Clear</button>
      </div>

      <div class="result" id="tp_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="tp_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="tp_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="tp_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="tp_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This calculator adds the three sides to get the perimeter. It also checks whether the side lengths satisfy the triangle inequality.
    </p>
    <p class="note">
      A valid triangle must satisfy:
      <br />
      <strong>a + b &gt; c</strong>,
      <strong>a + c &gt; b</strong>,
      <strong>b + c &gt; a</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>3, 4, 5</strong> → perimeter = <strong>12</strong></li>
      <li><strong>5, 5, 5</strong> → equilateral triangle</li>
      <li><strong>5, 5, 8</strong> → isosceles triangle</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/math/triangle-angle-calculator/">Triangle Angle Calculator</a></li>
      <li><a href="/math/triangle-area-calculator/">Triangle Area Calculator</a></li>
      <li><a href="/math/pythagorean-theorem-calculator/">Pythagorean Theorem Calculator</a></li>
      <li><a href="/math/">All Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const aEl = document.getElementById("tp_a");
  const bEl = document.getElementById("tp_b");
  const cEl = document.getElementById("tp_c");
  const calcBtn = document.getElementById("tp_calc");
  const fillBtn = document.getElementById("tp_fill_demo");
  const clearBtn = document.getElementById("tp_clear");
  const errorEl = document.getElementById("tp_error");
  const resultEl = document.getElementById("tp_result");
  const cardsEl = document.getElementById("tp_cards");
  const tbodyEl = document.getElementById("tp_tbody");

  if (!aEl || !bEl || !cEl || !calcBtn || !fillBtn || !clearBtn || !errorEl || !resultEl || !cardsEl || !tbodyEl) return;

  function fmt(n, digits) {
    return n.toLocaleString(undefined, { maximumFractionDigits: Number.isFinite(digits) ? digits : 8 });
  }

  function badge(text) {
    return "<span style='display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;'>" + text + "</span>";
  }

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function clearOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classify(a, b, c) {
    if (a === b && b === c) return "Equilateral";
    if (a === b || a === c || b === c) return "Isosceles";
    return "Scalene";
  }

  function compute() {
    clearOutput();

    const a = Number(String(aEl.value || "").trim());
    const b = Number(String(bEl.value || "").trim());
    const c = Number(String(cEl.value || "").trim());

    if (![a, b, c].every(Number.isFinite)) {
      showError("Please enter valid numeric side lengths.");
      return;
    }

    if (a <= 0 || b <= 0 || c <= 0) {
      showError("All side lengths must be greater than 0.");
      return;
    }

    const valid = a + b > c && a + c > b && b + c > a;
    if (!valid) {
      showError("These side lengths do not form a valid triangle because they fail the triangle inequality.");
      return;
    }

    const perimeter = a + b + c;
    const type = classify(a, b, c);

    let label = "Valid triangle";
    if (type === "Equilateral") label = "Equilateral";
    else if (type === "Isosceles") label = "Isosceles";
    else label = "Scalene";

    resultEl.innerHTML =
      "<strong>Triangle perimeter result</strong><br/>" +
      "<span class='tp-code'>Perimeter = " + fmt(perimeter, 8) + "</span>" +
      "<br/><span class='note'>Triangle type = " + type + "</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      "<div style='display:flex;gap:10px;flex-wrap:wrap;'>" +
      badge(label) +
      badge("Perimeter = " + fmt(perimeter, 4)) +
      badge("Valid triangle") +
      "</div>";

    fillTable([
      ["Side a", fmt(a, 8)],
      ["Side b", fmt(b, 8)],
      ["Side c", fmt(c, 8)],
      ["Perimeter", fmt(perimeter, 8)],
      ["Triangle type", type],
      ["Triangle inequality", "Satisfied"],
    ]);
  }

  function fillDemo() {
    aEl.value = "3";
    bEl.value = "4";
    cEl.value = "5";
    clearOutput();
  }

  function reset() {
    aEl.value = "";
    bEl.value = "";
    cEl.value = "";
    clearOutput();
    aEl.focus();
  }

  calcBtn.addEventListener("click", compute);
  fillBtn.addEventListener("click", fillDemo);
  clearBtn.addEventListener("click", reset);

  [aEl, bEl, cEl].forEach(function (el) {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") compute();
    });
  });

  clearOutput();
});
</script>