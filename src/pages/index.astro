---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="MinimalDev — Free Online Utility Tools"
  description="Free online calculators, converters, and utility tools for everyday tasks. Simple, fast, and mobile-friendly."
  canonicalPath="/"
>
  <div class="container">

    <!-- HERO -->
    <section class="card" style="padding:18px;">
      <div style="display:flex; gap:14px; align-items:center; flex-wrap:wrap;">
        <div style="min-width:240px; max-width:720px;">
          <h1 class="page-title" style="margin:0 0 8px;">
            Free Online Tools & Practical Guides
          </h1>

          <p class="lead" style="margin:0 0 8px;">
            MinimalDev provides simple online calculators, converters, and clear guides for everyday tasks.
          </p>

          <p class="lead" style="margin:0;">
            Understand when to use each tool and get accurate results quickly.
          </p>
        </div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:14px;">
        <a class="btn" href="/math/">Start with Math</a>
        <a class="btn secondary" href="/converter/">Browse Converters</a>
        <a class="btn secondary" href="/categories/">All Categories</a>
        <a class="btn secondary" href="/guides/">Guides</a>
      </div>
    </section>

    <!-- 🔥 Guides 추가 (핵심) -->
    <section class="section">
      <h2>Guides & Practical Tips</h2>
      <p class="lead" style="margin-top:0;">
        Learn how to use tools correctly and understand results with real examples.
      </p>

      <div class="grid">
        <section class="card">
          <h2>Image Format Comparison</h2>
          <p>Compare JPG, PNG, and WebP formats and when to use each.</p>
          <a class="btn" href="/image-format-comparison/">Read Guide</a>
        </section>

        <section class="card">
          <h2>Reduce Image Size</h2>
          <p>Learn compression trade-offs between quality and file size.</p>
          <a class="btn" href="/reduce-image-size/">Read Guide</a>
        </section>

        <section class="card">
          <h2>Why Use WebP</h2>
          <p>Understand how WebP improves performance and reduces size.</p>
          <a class="btn" href="/why-use-webp/">Read Guide</a>
        </section>

        <section class="card">
          <h2>JPG vs PNG</h2>
          <p>Choose the right format for photos vs graphics.</p>
          <a class="btn" href="/jpg-vs-png/">Read Guide</a>
        </section>
        <section class="card">
          <h2>Image Resize Guide</h2>
          <p>Resize images properly while maintaining aspect ratio and clarity.</p>
          <a class="btn" href="/image-resize-guide/">Read Guide</a>
        </section>

        <section class="card">
          <h2>Image Optimization for Web</h2>
          <p>Optimize images to improve website speed and performance.</p>
          <a class="btn" href="/image-optimization-for-web/">Read Guide</a>
        </section>
      </div>
    </section>

    <!-- POPULAR TOOLS (기존 6개 유지) -->
    <section class="section">
      <h2>Popular tools</h2>
      <p class="lead" style="margin-top:0;">
        Start with commonly used tools for calculations, conversions, and quick checks.
      </p>

      <div class="grid">

        <section class="card">
          <span class="badge">Math</span>
          <h2>Percent Calculator</h2>
          <p>Calculate percentages and changes.</p>
          <a class="btn" href="/math/percent-calculator/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Finance</span>
          <h2>Compound Interest Calculator</h2>
          <p>Calculate long-term investment growth with compounding.</p>
          <a class="btn" href="/finance/compound-interest-calculator/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Finance</span>
          <h2>Loan Calculator</h2>
          <p>Estimate loan payments and total interest.</p>
          <a class="btn" href="/finance/loan-calculator/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Utility</span>
          <h2>JSON Formatter</h2>
          <p>Format, validate, and debug JSON data easily.</p>
          <a class="btn" href="/utility/json-formatter/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Utility</span>
          <h2>Base64 Encoder & Decoder</h2>
          <p>Encode and decode Base64 securely in your browser.</p>
          <a class="btn" href="/utility/base64/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Utility</span>
          <h2>Random String Generator</h2>
          <p>Generate secure random strings for tokens and IDs.</p>
          <a class="btn" href="/utility/random-string-generator/">Open</a>
        </section>

      </div>
    </section>

    <!-- CATEGORY (기존 6개 유지) -->
    <section class="section">
      <h2>Browse by category</h2>
      <p class="lead" style="margin-top:0;">
        Explore tools by category to quickly find what you need.
      </p>

      <div class="grid">
        <section class="card">
          <h2>Converters</h2>
          <p>Unit conversion tools.</p>
          <a class="btn" href="/converter/">Open</a>
        </section>

        <section class="card">
          <h2>Math</h2>
          <p>Calculation tools.</p>
          <a class="btn" href="/math/">Open</a>
        </section>

        <section class="card">
          <h2>Finance</h2>
          <p>Financial calculators.</p>
          <a class="btn" href="/finance/">Open</a>
        </section>

        <section class="card">
          <h2>Date-Time</h2>
          <p>Date and time tools.</p>
          <a class="btn" href="/date-time/">Open</a>
        </section>

        <section class="card">
          <h2>Health</h2>
          <p>Health-related calculators.</p>
          <a class="btn" href="/health/">Open</a>
        </section>

        <section class="card">
          <h2>All Categories</h2>
          <p>Browse all tools.</p>
          <a class="btn" href="/categories/">Open</a>
        </section>
      </div>
    </section>

    <!-- About -->
    <section class="section">
      <h2>About MinimalDev</h2>
      <div class="card" style="padding:18px;">
        <p style="margin-top:0;">
          MinimalDev focuses on simple tools with clear explanations.
        </p>
        <p style="margin-bottom:0;">
          Each tool solves one problem clearly and efficiently.
        </p>
      </div>
    </section>

  </div>
</BaseLayout>