---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="MinimalDev — Free Online Utility Tools"
  description="Fast, free online calculators and utility tools. Mobile-first and easy to use."
  canonicalPath="/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <div style="display:flex; gap:14px; align-items:center; flex-wrap:wrap;">
        <div style="min-width:220px;">
          <h1 class="page-title" style="margin:0 0 6px;">Free Online Utility Tools</h1>
          <p class="lead" style="margin:0;">
            Fast calculators and converters. One tool per page, mobile-first, easy to bookmark.
          </p>
        </div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:14px;">
        <a class="btn" href="/math/">Start with Math</a>
        <a class="btn secondary" href="/converter/">Browse Converters</a>
        <a class="btn secondary" href="/categories/">All Categories</a>
        <a class="btn secondary" href="/legal/privacy-policy/">Privacy</a>
      </div>
    </section>

    <section class="section">
      <h2>Start here</h2>

      <div class="grid">
        <section class="card">
          <span class="badge">Math</span>
          <h2>Percent Calculator</h2>
          <p>Percent of a number, increase/decrease, and percentage change.</p>
          <a class="btn" href="/math/percent-calculator/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Date-Time</span>
          <h2>Days Between Dates</h2>
          <p>Calculate the number of days between two dates.</p>
          <a class="btn" href="/date-time/days-between-dates/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Converter</span>
          <h2>Length Converter</h2>
          <p>Convert mm, cm, m, km, inches, feet, yards, miles.</p>
          <a class="btn" href="/converter/length/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Finance</span>
          <h2>Loan Calculator</h2>
          <p>Estimate monthly payments, total interest, and payoff timeline.</p>
          <a class="btn" href="/finance/loan-calculator/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Health</span>
          <h2>BMI Calculator</h2>
          <p>Calculate BMI quickly and see the category range.</p>
          <a class="btn" href="/health/bmi-calculator/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Utility</span>
          <h2>Password Generator</h2>
          <p>Create strong passwords instantly with offline-friendly generation.</p>
          <a class="btn" href="/utility/password-generator/">Open</a>
        </section>
      </div>
    </section>

    <section class="section">
      <h2>Browse by category</h2>
      <div class="grid">
        <section class="card">
          <span class="badge">Category</span>
          <h2>Converters</h2>
          <p>Unit converters for length, weight, temperature, time, data, and more.</p>
          <a class="btn" href="/converter/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Category</span>
          <h2>Math</h2>
          <p>Calculators for percentages, algebra, geometry, roots, ratios, and more.</p>
          <a class="btn" href="/math/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Category</span>
          <h2>Finance</h2>
          <p>Loan, interest, savings, salary, budget, tax, and investment calculators.</p>
          <a class="btn" href="/finance/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Category</span>
          <h2>Date-Time</h2>
          <p>Date difference, working days, age, timestamps, countdowns, and more.</p>
          <a class="btn" href="/date-time/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Category</span>
          <h2>Health</h2>
          <p>BMI, BMR, calories, hydration, sleep, pace, and body calculators.</p>
          <a class="btn" href="/health/">Open</a>
        </section>

        <section class="card">
          <span class="badge">Category</span>
          <h2>All Categories</h2>
          <p>See every category including Utility, Developer Tools, Generators, Text Tools, and Design Tools.</p>
          <a class="btn" href="/categories/">Open</a>
        </section>
      </div>
    </section>
  </div>
</BaseLayout>