---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "robots.txt Generator",
  description:
    "Generate robots.txt rules for crawler access settings.",
  href: "/developer-tools/robots-txt-generator/",
  order: 182,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/developer-tools/robots-txt-generator/";

const faqs = [
  {
    q: "What does this robots.txt generator create?",
    a: "It generates robots.txt directives such as User-agent, Allow, Disallow, Crawl-delay, and Sitemap.",
  },
  {
    q: "Can I include multiple allow or disallow rules?",
    a: "Yes. Enter one path per line and the generator will output each directive separately.",
  },
  {
    q: "Does this validate sitemap URLs?",
    a: "Yes. If a sitemap URL is provided, the tool checks for a valid http or https URL format.",
  },
  {
    q: "Does robots.txt guarantee blocking from search results?",
    a: "No. robots.txt is mainly for crawl control, not guaranteed de-indexing.",
  },
  {
    q: "Are my rules stored?",
    a: "No. Everything runs locally in your browser.",
  },
];
---

<ToolLayout
  title={`robots.txt Generator — ${SITE_NAME}`}
  description="Generate robots.txt content for allowing or blocking crawlers, defining sitemap locations, and controlling site crawling behavior."
  canonicalPath={CANONICAL_PATH}
  h1="robots.txt Generator"
  intro="Generate a robots.txt file for your site using common directives such as User-agent, Allow, Disallow, Crawl-delay, and Sitemap."
  faq={faqs}
  categoryName="Developer Tools"
>
  <div slot="tool" data-tool="robots-txt-generator">
    <style is:inline>
      .rtg-wrap, .rtg-wrap * { box-sizing: border-box; }
      .rtg-grid {
        display:grid;
        grid-template-columns:repeat(2, minmax(0, 1fr));
        gap:10px;
      }
      .rtg-grid input,
      .rtg-grid select,
      .rtg-grid textarea,
      #rtg_output {
        width:100%;
        min-width:0;
      }
      .rtg-output {
        white-space:pre-wrap;
        word-break:break-word;
        font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size:14px;
      }
      @media (max-width: 760px) {
        .rtg-grid { grid-template-columns:1fr; }
      }
    </style>

    <div class="form rtg-wrap" role="form" aria-describedby="rtg_help rtg_privacy">
      <div class="rtg-grid">
        <div class="field">
          <label for="rtg_user_agent">User-agent</label>
          <input id="rtg_user_agent" type="text" placeholder="e.g. *" value="*" />
        </div>

        <div class="field">
          <label for="rtg_crawl_delay">Crawl-delay (optional)</label>
          <input id="rtg_crawl_delay" type="number" inputmode="numeric" min="0" step="1" placeholder="e.g. 10" />
        </div>

        <div class="field" style="grid-column:1 / -1;">
          <label for="rtg_allow">Allow paths (one per line)</label>
          <textarea id="rtg_allow" rows="4" spellcheck="false" placeholder="/&#10;/public/&#10;/assets/"></textarea>
        </div>

        <div class="field" style="grid-column:1 / -1;">
          <label for="rtg_disallow">Disallow paths (one per line)</label>
          <textarea id="rtg_disallow" rows="4" spellcheck="false" placeholder="/admin/&#10;/private/"></textarea>
        </div>

        <div class="field" style="grid-column:1 / -1;">
          <label for="rtg_sitemap">Sitemap URL (optional)</label>
          <input id="rtg_sitemap" type="url" placeholder="https://example.com/sitemap.xml" />
        </div>
      </div>

      <p class="note" id="rtg_help" style="margin-top:6px;">
        Use one path per line. Paths should usually begin with <code>/</code>.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="rtg_generate">Generate</button>
        <button class="btn secondary" type="button" id="rtg_copy">Copy Output</button>
        <button class="btn secondary" type="button" id="rtg_fill_demo">Fill Demo</button>
        <button class="btn secondary" type="button" id="rtg_clear">Clear</button>
      </div>

      <div class="result" id="rtg_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result rtg-output" id="rtg_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="rtg_cards" style="display:none; margin-top:12px;"></div>

      <div class="field" style="margin-top:16px;">
        <label for="rtg_output">Generated robots.txt</label>
        <textarea id="rtg_output" rows="14" readonly spellcheck="false" placeholder="Generated robots.txt content will appear here."></textarea>
      </div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="rtg_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="rtg_privacy" style="margin-top:10px;">
        Privacy: generation runs locally in your browser. No rules are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Enter a user-agent and optional allow/disallow rules, then generate a robots.txt file that can be placed at your site root.
    </p>
    <ul>
      <li><strong>User-agent:</strong> which crawler the rules apply to</li>
      <li><strong>Allow / Disallow:</strong> crawl path rules</li>
      <li><strong>Sitemap:</strong> helps crawlers discover your sitemap</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Public site:</strong> allow all, include sitemap</li>
      <li><strong>Block admin:</strong> disallow <code>/admin/</code></li>
      <li><strong>Selective crawl:</strong> combine allow and disallow directives</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/developer-tools/sitemap-generator/">Sitemap Generator</a></li>
      <li><a href="/developer-tools/meta-tag-generator/">Meta Tag Generator</a></li>
      <li><a href="/developer-tools/redirect-checker/">Redirect Checker</a></li>
      <li><a href="/developer-tools/">All Developer Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const userAgentEl = document.getElementById("rtg_user_agent");
  const crawlDelayEl = document.getElementById("rtg_crawl_delay");
  const allowEl = document.getElementById("rtg_allow");
  const disallowEl = document.getElementById("rtg_disallow");
  const sitemapEl = document.getElementById("rtg_sitemap");
  const generateBtn = document.getElementById("rtg_generate");
  const copyBtn = document.getElementById("rtg_copy");
  const fillBtn = document.getElementById("rtg_fill_demo");
  const clearBtn = document.getElementById("rtg_clear");
  const errorEl = document.getElementById("rtg_error");
  const resultEl = document.getElementById("rtg_result");
  const cardsEl = document.getElementById("rtg_cards");
  const outputEl = document.getElementById("rtg_output");
  const tbodyEl = document.getElementById("rtg_tbody");

  if (
    !userAgentEl || !crawlDelayEl || !allowEl || !disallowEl || !sitemapEl ||
    !generateBtn || !copyBtn || !fillBtn || !clearBtn || !errorEl ||
    !resultEl || !cardsEl || !outputEl || !tbodyEl
  ) return;

  let lastOutput = "";

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function resetOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    outputEl.value = "";
    tbodyEl.innerHTML = "";
    lastOutput = "";
  }

  function badge(text) {
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">' + text + "</span>";
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function isValidUrl(v) {
    if (!v) return true;
    try {
      const u = new URL(v);
      return u.protocol === "http:" || u.protocol === "https:";
    } catch (_) {
      return false;
    }
  }

  function listFromTextarea(el) {
    return String(el.value || "")
      .split(/\r?\n/)
      .map(function (s) { return s.trim(); })
      .filter(Boolean);
  }

  function generateRobots() {
    resetOutput();

    const userAgent = String(userAgentEl.value || "").trim();
    const crawlDelay = String(crawlDelayEl.value || "").trim();
    const allowList = listFromTextarea(allowEl);
    const disallowList = listFromTextarea(disallowEl);
    const sitemap = String(sitemapEl.value || "").trim();

    if (!userAgent) {
      showError("Please enter a user-agent.");
      return;
    }

    if (crawlDelay && (!/^\d+$/.test(crawlDelay) || parseInt(crawlDelay, 10) < 0)) {
      showError("Crawl-delay must be a non-negative whole number.");
      return;
    }

    if (!isValidUrl(sitemap)) {
      showError("Please enter a valid sitemap URL (http or https).");
      return;
    }

    const lines = [];
    lines.push("User-agent: " + userAgent);

    allowList.forEach(function (p) { lines.push("Allow: " + p); });
    disallowList.forEach(function (p) { lines.push("Disallow: " + p); });

    if (crawlDelay) lines.push("Crawl-delay: " + crawlDelay);
    if (sitemap) {
      lines.push("");
      lines.push("Sitemap: " + sitemap);
    }

    const output = lines.join("\n");
    lastOutput = output;
    outputEl.value = output;

    resultEl.innerHTML = "<strong>robots.txt generated.</strong>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      '<div style="display:flex;gap:10px;flex-wrap:wrap;">' +
      badge("Allow rules: " + allowList.length) +
      badge("Disallow rules: " + disallowList.length) +
      badge(crawlDelay ? "Crawl-delay included" : "No crawl-delay") +
      badge(sitemap ? "Sitemap included" : "No sitemap") +
      "</div>";

    fillTable([
      ["User-agent", userAgent],
      ["Allow rule count", String(allowList.length)],
      ["Disallow rule count", String(disallowList.length)],
      ["Crawl-delay", crawlDelay || "Not set"],
      ["Sitemap", sitemap || "Not set"],
      ["Total output lines", String(lines.length)],
    ]);
  }

  async function copyOutput() {
    clearError();
    if (!lastOutput) {
      showError("No generated robots.txt output to copy yet.");
      return;
    }
    try {
      await navigator.clipboard.writeText(lastOutput);
      resultEl.innerHTML = "<strong>Copied robots.txt output.</strong>";
    } catch (_) {
      showError("Clipboard copy failed in this browser.");
    }
  }

  function fillDemo() {
    userAgentEl.value = "*";
    crawlDelayEl.value = "";
    allowEl.value = "/\n/assets/";
    disallowEl.value = "/admin/\n/private/";
    sitemapEl.value = "https://example.com/sitemap.xml";
    resetOutput();
  }

  function clearAll() {
    userAgentEl.value = "*";
    crawlDelayEl.value = "";
    allowEl.value = "";
    disallowEl.value = "";
    sitemapEl.value = "";
    resetOutput();
    userAgentEl.focus();
  }

  generateBtn.addEventListener("click", generateRobots);
  copyBtn.addEventListener("click", copyOutput);
  fillBtn.addEventListener("click", fillDemo);
  clearBtn.addEventListener("click", clearAll);

  [userAgentEl, crawlDelayEl, sitemapEl].forEach(function (el) {
    el.addEventListener("keydown", function (e) {
      if ((e.ctrlKey || e.metaKey) && e.key === "Enter") generateRobots();
    });
  });
});
</script>