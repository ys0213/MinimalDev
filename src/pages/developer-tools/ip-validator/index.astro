---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "IP Validator",
  description:
    "Validate IPv4 addresses with format checks, private/public range hints, result cards, and FAQ schema.",
  href: "/developer-tools/ip-validator/",
  order: 410,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/developer-tools/ip-validator/";

const faqs = [
  {
    q: "What does this IP validator check?",
    a: "It validates IPv4 format, checks that each octet is within 0-255, and flags common reserved or private ranges.",
  },
  {
    q: "Does it support IPv6?",
    a: "No. This page validates IPv4 addresses only.",
  },
  {
    q: "Can it tell whether an IP is private or public?",
    a: "Yes. It highlights common private, loopback, link-local, multicast, and other special IPv4 ranges.",
  },
  {
    q: "Is my IP stored?",
    a: "No. Validation runs locally in your browser and is not stored or transmitted.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.a,
    },
  })),
};
---

<ToolLayout
  title={`IP Validator — ${SITE_NAME}`}
  description="Validate IPv4 addresses, inspect octets, and classify private/public and reserved ranges."
  canonicalPath={CANONICAL_PATH}
  h1="IP Validator"
  intro="Validate an IPv4 address and check whether it belongs to common private, loopback, link-local, multicast, or public ranges."
  faq={faqs}
  categoryName="Developer Tools"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="ip-validator">
    <style is:inline>
      #ipv_input {
        width: 100%;
        min-width: 0;
      }
      .ipv-mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        word-break: break-word;
      }
      .ipv-grid {
        display: grid;
        gap: 10px;
      }
      @media (min-width: 720px) {
        .ipv-grid {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>

    <div class="form" role="form" aria-describedby="ipv_help ipv_privacy">
      <div class="field">
        <label for="ipv_input">IPv4 address</label>
        <input
          id="ipv_input"
          type="text"
          inputmode="decimal"
          spellcheck="false"
          placeholder="e.g. 192.168.1.10"
          autocomplete="off"
        />
      </div>

      <p class="note" id="ipv_help" style="margin-top:6px;">
        Enter a dotted IPv4 address with 4 octets. Example: <span class="ipv-mono">8.8.8.8</span>
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="ipv_validate">Validate</button>
        <button class="btn secondary" type="button" id="ipv_fill_private">Example Private IP</button>
        <button class="btn secondary" type="button" id="ipv_clear">Clear</button>
      </div>

      <div class="result" id="ipv_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="ipv_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="ipv_cards" style="display:none; margin-top:12px;"></div>

      <div class="ipv-grid" style="margin-top:16px;">
        <div style="overflow:auto;">
          <table style="width:100%; border-collapse:collapse;">
            <thead>
              <tr>
                <th scope="col">Metric</th>
                <th scope="col">Value</th>
              </tr>
            </thead>
            <tbody id="ipv_tbody"></tbody>
          </table>
        </div>

        <div style="overflow:auto;">
          <table style="width:100%; border-collapse:collapse;">
            <thead>
              <tr>
                <th scope="col">Octet</th>
                <th scope="col">Value</th>
              </tr>
            </thead>
            <tbody id="ipv_octets"></tbody>
          </table>
        </div>
      </div>

      <p class="note" id="ipv_privacy" style="margin-top:10px;">
        Privacy: validation runs locally in your browser. No IP addresses are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This validator checks:
    </p>
    <ul>
      <li>Whether the address has exactly 4 octets</li>
      <li>Whether each octet is numeric and within <strong>0-255</strong></li>
      <li>Whether the address falls into common private or reserved IPv4 ranges</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>192.168.1.10</strong> → valid private IPv4</li>
      <li><strong>8.8.8.8</strong> → valid public IPv4</li>
      <li><strong>127.0.0.1</strong> → valid loopback IPv4</li>
      <li><strong>256.1.1.1</strong> → invalid because 256 is out of range</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/developer-tools/ipv4-to-decimal/">IPv4 to Decimal</a></li>
      <li><a href="/developer-tools/decimal-to-ipv4/">Decimal to IPv4</a></li>
      <li><a href="/developer-tools/cidr-calculator/">CIDR Calculator</a></li>
      <li><a href="/developer-tools/subnet-calculator/">Subnet Calculator</a></li>
      <li><a href="/developer-tools/">All Developer Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inputEl = document.getElementById("ipv_input");
  const validateBtn = document.getElementById("ipv_validate");
  const fillBtn = document.getElementById("ipv_fill_private");
  const clearBtn = document.getElementById("ipv_clear");
  const errEl = document.getElementById("ipv_error");
  const resultEl = document.getElementById("ipv_result");
  const cardsEl = document.getElementById("ipv_cards");
  const tbodyEl = document.getElementById("ipv_tbody");
  const octetsEl = document.getElementById("ipv_octets");

  if (!inputEl || !validateBtn || !fillBtn || !clearBtn || !errEl || !resultEl || !cardsEl || !tbodyEl || !octetsEl) return;

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function resetOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
    octetsEl.innerHTML = "";
  }

  function badge(text) {
    return '<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">' + text + "</span>";
  }

  function fillTable(target, rows) {
    target.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      target.appendChild(tr);
    });
  }

  function classifyIPv4(parts) {
    const a = parts[0];
    const b = parts[1];

    if (a === 10) return "Private (10.0.0.0/8)";
    if (a === 172 && b >= 16 && b <= 31) return "Private (172.16.0.0/12)";
    if (a === 192 && b === 168) return "Private (192.168.0.0/16)";
    if (a === 127) return "Loopback (127.0.0.0/8)";
    if (a === 169 && b === 254) return "Link-local (169.254.0.0/16)";
    if (a >= 224 && a <= 239) return "Multicast (224.0.0.0/4)";
    if (a >= 240) return "Reserved / Experimental";
    if (a === 0) return "Current network / reserved";
    if (a === 255 && parts[1] === 255 && parts[2] === 255 && parts[3] === 255) return "Limited broadcast";
    return "Public / General use";
  }

  function isValidIPv4(raw) {
    if (!raw) return { ok: false, msg: "Please enter an IPv4 address." };

    const trimmed = raw.trim();
    if (!/^\d+\.\d+\.\d+\.\d+$/.test(trimmed)) {
      return { ok: false, msg: "IPv4 format must be four dot-separated numeric octets." };
    }

    const parts = trimmed.split(".");
    if (parts.length !== 4) {
      return { ok: false, msg: "IPv4 address must contain exactly 4 octets." };
    }

    const nums = [];
    for (let i = 0; i < parts.length; i++) {
      const p = parts[i];

      if (p.length > 1 && p.startsWith("0")) {
        return { ok: false, msg: "Leading zeros are not allowed in octet " + (i + 1) + "." };
      }

      const n = Number(p);
      if (!Number.isInteger(n)) {
        return { ok: false, msg: "Octet " + (i + 1) + " is not a valid integer." };
      }
      if (n < 0 || n > 255) {
        return { ok: false, msg: "Octet " + (i + 1) + " must be between 0 and 255." };
      }
      nums.push(n);
    }

    return { ok: true, parts: nums, normalized: nums.join(".") };
  }

  function render() {
    resetOutput();

    const raw = String(inputEl.value || "");
    const parsed = isValidIPv4(raw);

    if (!parsed.ok) {
      showError(parsed.msg);
      return;
    }

    const parts = parsed.parts;
    const classification = classifyIPv4(parts);
    const normalized = parsed.normalized;
    const isPrivate = classification.indexOf("Private") === 0;
    const isPublic = classification === "Public / General use";

    resultEl.innerHTML =
      "<strong>Valid IPv4 address.</strong><br/><span class='note'>Normalized form: " + normalized + "</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      '<div style="display:flex; gap:10px; flex-wrap:wrap;">' +
      badge("Valid IPv4") +
      badge(classification) +
      badge(isPrivate ? "Private" : (isPublic ? "Public" : "Special range")) +
      "</div>";

    fillTable(tbodyEl, [
      ["Input", raw.trim()],
      ["Normalized", normalized],
      ["Classification", classification],
      ["Address family", "IPv4"],
      ["Octet count", "4"],
    ]);

    fillTable(octetsEl, [
      ["Octet 1", String(parts[0])],
      ["Octet 2", String(parts[1])],
      ["Octet 3", String(parts[2])],
      ["Octet 4", String(parts[3])],
    ]);
  }

  function clearAll() {
    inputEl.value = "";
    resetOutput();
    inputEl.focus();
  }

  validateBtn.addEventListener("click", render);
  fillBtn.addEventListener("click", function () {
    inputEl.value = "192.168.1.10";
    render();
  });
  clearBtn.addEventListener("click", clearAll);

  inputEl.addEventListener("keydown", function (e) {
    if (e.key === "Enter") render();
  });
});
</script>