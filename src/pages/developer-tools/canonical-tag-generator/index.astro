---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Canonical Tag Generator",
  description:
    "Generate rel=canonical link tags from a URL with validation, result cards, and FAQ schema.",
  href: "/developer-tools/canonical-tag-generator/",
  order: 188,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/developer-tools/canonical-tag-generator/";

const faqs = [
  {
    q: "What does a canonical tag do?",
    a: "A canonical tag tells search engines which URL should be treated as the preferred version of a page.",
  },
  {
    q: "What does this generator create?",
    a: "It creates a standard HTML canonical link tag you can paste into the head section of your page.",
  },
  {
    q: "Should the canonical URL be absolute?",
    a: "Yes. Canonical tags are generally best written with full absolute URLs.",
  },
  {
    q: "Can I include a trailing slash or query parameters?",
    a: "Yes, but you should use the exact preferred URL version you want search engines to treat as canonical.",
  },
  {
    q: "Is my URL stored?",
    a: "No. Everything runs locally in your browser.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Canonical Tag Generator — ${SITE_NAME}`}
  description="Generate rel=canonical link tags from a preferred URL."
  canonicalPath={CANONICAL_PATH}
  h1="Canonical Tag Generator"
  intro="Generate a canonical link tag for your preferred page URL. Useful for SEO templates, duplicate-page handling, and page head markup."
  faq={faqs}
  categoryName="Developer Tools"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="canonical-tag-generator">
    <style is:inline>
      .ctg-wrap, .ctg-wrap * { box-sizing: border-box; }
      #ctg_url,
      #ctg_output {
        width:100%;
        min-width:0;
      }
      .ctg-output {
        white-space:pre-wrap;
        word-break:break-word;
        font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size:14px;
      }
    </style>

    <div class="form ctg-wrap" role="form" aria-describedby="ctg_help ctg_privacy">
      <div class="field">
        <label for="ctg_url">Canonical URL</label>
        <input id="ctg_url" type="url" placeholder="https://example.com/page/" />
      </div>

      <p class="note" id="ctg_help" style="margin-top:6px;">
        Use the exact preferred absolute URL you want search engines to treat as canonical.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="ctg_generate">Generate</button>
        <button class="btn secondary" type="button" id="ctg_copy">Copy Output</button>
        <button class="btn secondary" type="button" id="ctg_fill_demo">Fill Demo</button>
        <button class="btn secondary" type="button" id="ctg_clear">Clear</button>
      </div>

      <div class="result" id="ctg_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result ctg-output" id="ctg_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="ctg_cards" style="display:none; margin-top:12px;"></div>

      <div class="field" style="margin-top:16px;">
        <label for="ctg_output">Generated canonical tag</label>
        <textarea id="ctg_output" rows="4" readonly spellcheck="false" placeholder="Generated canonical tag will appear here."></textarea>
      </div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="ctg_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="ctg_privacy" style="margin-top:10px;">
        Privacy: generation runs locally in your browser. No URLs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Enter the preferred page URL, generate the canonical tag, then paste it inside your HTML head section.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Preferred page:</strong> <code>https://example.com/tools/slug-generator/</code></li>
      <li><strong>Generated tag:</strong> <code>&lt;link rel="canonical" href="..." /&gt;</code></li>
      <li><strong>Typical use:</strong> duplicate URLs, filtered pages, or consistent template output</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/developer-tools/meta-tag-generator/">Meta Tag Generator</a></li>
      <li><a href="/developer-tools/meta-tag-analyzer/">Meta Tag Analyzer</a></li>
      <li><a href="/developer-tools/sitemap-generator/">Sitemap Generator</a></li>
      <li><a href="/developer-tools/">All Developer Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const urlEl = document.getElementById("ctg_url");
  const generateBtn = document.getElementById("ctg_generate");
  const copyBtn = document.getElementById("ctg_copy");
  const fillBtn = document.getElementById("ctg_fill_demo");
  const clearBtn = document.getElementById("ctg_clear");
  const errorEl = document.getElementById("ctg_error");
  const resultEl = document.getElementById("ctg_result");
  const cardsEl = document.getElementById("ctg_cards");
  const outputEl = document.getElementById("ctg_output");
  const tbodyEl = document.getElementById("ctg_tbody");

  if (!urlEl || !generateBtn || !copyBtn || !fillBtn || !clearBtn || !errorEl || !resultEl || !cardsEl || !outputEl || !tbodyEl) return;

  let lastOutput = "";

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function resetOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    outputEl.value = "";
    tbodyEl.innerHTML = "";
    lastOutput = "";
  }

  function badge(text) {
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">' + text + "</span>";
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function isValidHttpUrl(v) {
    try {
      const u = new URL(v);
      return u.protocol === "http:" || u.protocol === "https:";
    } catch (_) {
      return false;
    }
  }

  function generateCanonical() {
    resetOutput();

    const raw = String(urlEl.value || "").trim();
    if (!raw) {
      showError("Please enter a canonical URL.");
      return;
    }

    if (!isValidHttpUrl(raw)) {
      showError("Please enter a valid http or https URL.");
      return;
    }

    const normalized = new URL(raw).href;
    const tag = '<link rel="canonical" href="' + normalized.replace(/"/g, "&quot;") + '" />';

    lastOutput = tag;
    outputEl.value = tag;

    resultEl.innerHTML = "<strong>Canonical tag generated.</strong>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      '<div style="display:flex;gap:10px;flex-wrap:wrap;">' +
      badge("Absolute URL") +
      badge(normalized.endsWith("/") ? "Trailing slash" : "No trailing slash") +
      badge("Length: " + normalized.length) +
      "</div>";

    fillTable([
      ["Canonical URL", normalized],
      ["URL length", String(normalized.length)],
      ["Protocol", new URL(normalized).protocol.replace(":", "")],
      ["Generated tag", tag],
    ]);
  }

  async function copyOutput() {
    clearError();
    if (!lastOutput) {
      showError("No generated canonical tag to copy yet.");
      return;
    }
    try {
      await navigator.clipboard.writeText(lastOutput);
      resultEl.innerHTML = "<strong>Copied canonical tag.</strong>";
    } catch (_) {
      showError("Clipboard copy failed in this browser.");
    }
  }

  function fillDemo() {
    urlEl.value = "https://example.com/tools/meta-tag-generator/";
    resetOutput();
  }

  function clearAll() {
    urlEl.value = "";
    resetOutput();
    urlEl.focus();
  }

  generateBtn.addEventListener("click", generateCanonical);
  copyBtn.addEventListener("click", copyOutput);
  fillBtn.addEventListener("click", fillDemo);
  clearBtn.addEventListener("click", clearAll);

  urlEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") generateCanonical();
  });
});
</script>