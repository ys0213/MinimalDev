---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "JSON Validator",
  description:
    "Validate JSON syntax, find parsing errors, and format JSON for API and configuration debugging.",
  href: "/developer-tools/json-validator/",
  order: 20,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/developer-tools/json-validator/";

const faqs = [
  {
    q: "What does this JSON validator do?",
    a: "It checks whether your JSON is valid, shows parsing errors for invalid input, and can pretty-print or minify valid JSON.",
  },
  {
    q: "Does it support arrays and nested objects?",
    a: "Yes. It validates standard JSON including arrays, nested objects, strings, numbers, booleans, and null values.",
  },
  {
    q: "Why is my JSON invalid?",
    a: "Common causes include trailing commas, comments, single quotes around keys, missing quotes, unescaped characters, or invalid values such as NaN and undefined.",
  },
  {
    q: "Is JSON with comments valid?",
    a: "No. Standard JSON does not allow comments. Some configuration formats look similar to JSON but are not valid JSON.",
  },
  {
    q: "Is my JSON uploaded or stored?",
    a: "No. Validation runs locally in your browser and your JSON is not sent to a server.",
  },
];

---

<ToolLayout
  title={`JSON Validator — ${SITE_NAME}`}
  description="Validate JSON syntax, identify parse errors, and format JSON for API responses, config files, logs, and debugging workflows."
  canonicalPath={CANONICAL_PATH}
  h1="JSON Validator"
  intro="Validate JSON input, find syntax errors, pretty-print readable JSON, or minify JSON for compact output. Useful for API debugging, configuration files, and developer workflows."
  faq={faqs}
  categoryName="Developer Tools"
>
  <div slot="tool" data-tool="json-validator">
    <style is:inline>
      #jv_input,
      #jv_output,
      #jv_format {
        width: 100%;
        min-width: 0;
      }

      .jv-output {
        white-space: pre-wrap;
        word-break: break-word;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 14px;
      }
    </style>

    <div class="privacy-note">
      <strong>Privacy First:</strong> This tool runs locally in your browser.
      <strong>Your input values are never sent to any server.</strong>
    </div>

    <div class="form" role="form" aria-describedby="jv_help">
      <div class="field">
        <label for="jv_input">JSON input</label>
        <textarea id="jv_input" rows="12" spellcheck="false" placeholder='e.g. {"name":"Alex","age":30}'></textarea>
      </div>

      <div class="field">
        <label for="jv_format">Output format</label>
        <select id="jv_format">
          <option value="pretty" selected>Pretty print</option>
          <option value="minify">Minify</option>
        </select>
      </div>

      <p class="note" id="jv_help" style="margin-top:6px;">
        Standard JSON only. Trailing commas, comments, single-quoted keys, NaN, and undefined are not valid JSON.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="jv_validate">Validate</button>
        <button class="btn secondary" type="button" id="jv_copy">Copy Output</button>
        <button class="btn secondary" type="button" id="jv_clear">Clear</button>
      </div>

      <div class="result" id="jv_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result jv-output" id="jv_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="jv_cards" style="display:none; margin-top:12px;"></div>

      <div class="field" style="margin-top:16px;">
        <label for="jv_output">Formatted output</label>
        <textarea id="jv_output" rows="12" spellcheck="false" readonly placeholder="Validated JSON output will appear here."></textarea>
      </div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="jv_tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div slot="how">
    <h2>How JSON validation works</h2>

    <p class="note">
      JSON validation checks whether the input follows the official JSON syntax rules. This tool parses your input as JSON, then returns either a valid formatted result or a parsing error.
    </p>

    <ul>
      <li><strong>Validate:</strong> checks whether the JSON can be parsed</li>
      <li><strong>Pretty print:</strong> adds indentation for easier reading</li>
      <li><strong>Minify:</strong> removes unnecessary whitespace for compact output</li>
      <li><strong>Common mistakes:</strong> trailing commas, comments, missing quotes, and JavaScript-only values</li>
    </ul>

    <p class="note">
      JSON is often used in API responses, configuration files, package metadata, logs, and data exchange. Validating before saving or sending JSON helps catch small syntax errors early.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>{'{"name":"Alex","age":30}'}</strong> → valid JSON object</li>
      <li><strong>{'[1,2,3]'}</strong> → valid JSON array</li>
      <li><strong>{'{"enabled":true,"items":null}'}</strong> → valid boolean and null values</li>
      <li><strong>{'{"a":1,}'}</strong> → invalid because of a trailing comma</li>
      <li><strong>{'{name:"Alex"}'}</strong> → invalid because the key is not in double quotes</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/utility/json-formatter/">JSON Formatter</a></li>
      <li><a href="/developer-tools/json-to-csv/">JSON to CSV</a></li>
      <li><a href="/developer-tools/csv-to-json/">CSV to JSON</a></li>
      <li><a href="/developer-tools/jwt-decoder/">JWT Decoder</a></li>
      <li><a href="/developer-tools/">All Developer Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inputEl = document.getElementById("jv_input");
  const formatEl = document.getElementById("jv_format");
  const validateBtn = document.getElementById("jv_validate");
  const copyBtn = document.getElementById("jv_copy");
  const clearBtn = document.getElementById("jv_clear");
  const errEl = document.getElementById("jv_error");
  const resultEl = document.getElementById("jv_result");
  const cardsEl = document.getElementById("jv_cards");
  const outputEl = document.getElementById("jv_output");
  const tbodyEl = document.getElementById("jv_tbody");

  if (!inputEl || !formatEl || !validateBtn || !copyBtn || !clearBtn || !errEl || !resultEl || !cardsEl || !outputEl || !tbodyEl) return;

  let lastOutput = "";

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function resetOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    outputEl.value = "";
    tbodyEl.innerHTML = "";
    lastOutput = "";
  }

  function badge(text) {
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">' + text + '</span>';
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function getTopType(value) {
    if (Array.isArray(value)) return "array";
    if (value === null) return "null";
    return typeof value;
  }

  function validateJson() {
    resetOutput();

    const raw = String(inputEl.value || "").trim();
    const format = String(formatEl.value || "pretty");

    if (!raw) {
      showError("Please paste JSON input.");
      return;
    }

    let parsed;
    try {
      parsed = JSON.parse(raw);
    } catch (e) {
      showError("Invalid JSON: " + (e && e.message ? e.message : "parse error"));
      return;
    }

    const output = format === "minify"
      ? JSON.stringify(parsed)
      : JSON.stringify(parsed, null, 2);

    lastOutput = output;
    outputEl.value = output;

    const topType = getTopType(parsed);
    const rootCount =
      Array.isArray(parsed) ? parsed.length :
      (parsed && typeof parsed === "object" ? Object.keys(parsed).length : 0);

    resultEl.innerHTML = "<strong>Valid JSON.</strong>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      '<div style="display:flex;gap:10px;flex-wrap:wrap;">' +
      badge("Valid") +
      badge("Root type: " + topType) +
      badge(format === "minify" ? "Minified" : "Pretty printed") +
      "</div>";

    fillTable([
      ["Root type", topType],
      ["Root item/key count", String(rootCount)],
      ["Input length", String(raw.length)],
      ["Output length", String(output.length)],
    ]);
  }

  async function copyOutput() {
    clearError();
    if (!lastOutput) {
      showError("No validated output to copy yet.");
      return;
    }
    try {
      await navigator.clipboard.writeText(lastOutput);
      resultEl.innerHTML = "<strong>Copied formatted output.</strong>";
    } catch (_) {
      showError("Clipboard copy failed in this browser.");
    }
  }

  function clearAll() {
    inputEl.value = "";
    formatEl.value = "pretty";
    resetOutput();
    inputEl.focus();
  }

  validateBtn.addEventListener("click", validateJson);
  copyBtn.addEventListener("click", copyOutput);
  clearBtn.addEventListener("click", clearAll);

  inputEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") validateJson();
  });
});
</script>