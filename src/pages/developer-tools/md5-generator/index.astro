---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "MD5 Generator",
  description:
    "Generate MD5 hashes for text input with validation, result cards, copy support, and FAQ schema.",
  href: "/developer-tools/md5-generator/",
  order: 80,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/developer-tools/md5-generator/";

const faqs = [
  {
    q: "What does this MD5 generator do?",
    a: "It generates an MD5 hash for the text you enter and shows the hexadecimal output.",
  },
  {
    q: "Is MD5 secure for passwords?",
    a: "No. MD5 is not recommended for password storage or modern security use cases. It is mainly useful for legacy workflows, quick checksums, or compatibility tasks.",
  },
  {
    q: "Can I hash Unicode text?",
    a: "Yes. This tool hashes UTF-8 encoded text input.",
  },
  {
    q: "Is my input stored?",
    a: "No. Hash generation runs locally in your browser and is not stored or transmitted.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`MD5 Generator — ${SITE_NAME}`}
  description="Generate MD5 hashes for text input with copy support, result cards, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="MD5 Generator"
  intro="Generate an MD5 hash for text input directly in your browser."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="md5-generator">
    <style is:inline>
      #md5_input, #md5_output {
        width: 100%;
        min-width: 0;
      }
      .md5-mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        white-space: pre-wrap;
        word-break: break-all;
      }
    </style>

    <div class="form" role="form" aria-describedby="md5_help md5_privacy">
      <div class="field">
        <label for="md5_input">Input text</label>
        <textarea id="md5_input" rows="8" spellcheck="false" placeholder="Enter text to hash."></textarea>
      </div>

      <div class="field">
        <label>
          <input id="md5_upper" type="checkbox" />
          Uppercase output
        </label>
      </div>

      <p class="note" id="md5_help" style="margin-top:6px;">
        MD5 is included for compatibility and checksum-style use cases. It is not recommended for secure password storage.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="md5_generate">Generate</button>
        <button class="btn secondary" type="button" id="md5_copy">Copy Hash</button>
        <button class="btn secondary" type="button" id="md5_clear">Clear</button>
      </div>

      <div class="result" id="md5_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="md5_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="md5_cards" style="display:none; margin-top:12px;"></div>

      <div class="field" style="margin-top:16px;">
        <label for="md5_output">MD5 output</label>
        <textarea id="md5_output" class="md5-mono" rows="5" readonly spellcheck="false"></textarea>
      </div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="md5_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="md5_privacy" style="margin-top:10px;">
        Privacy: hashing runs locally in your browser. No input text or output hash is stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Enter text, generate the MD5 digest, and copy the hexadecimal result if needed for legacy compatibility or quick checksum tasks.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>Hash a short text string for testing or comparison</li>
      <li>Generate lowercase or uppercase hexadecimal output</li>
      <li>Use SHA-256 instead if you need a stronger modern hash</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      {faqs.map((f) => <li><strong>{f.q}</strong> {f.a}</li>)}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/developer-tools/hash-generator/">Hash Generator</a></li>
      <li><a href="/developer-tools/sha256-generator/">SHA256 Generator</a></li>
      <li><a href="/developer-tools/bcrypt-generator/">Bcrypt Generator</a></li>
      <li><a href="/developer-tools/">All Developer Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inputEl = document.getElementById("md5_input");
  const upperEl = document.getElementById("md5_upper");
  const generateBtn = document.getElementById("md5_generate");
  const copyBtn = document.getElementById("md5_copy");
  const clearBtn = document.getElementById("md5_clear");
  const errEl = document.getElementById("md5_error");
  const resultEl = document.getElementById("md5_result");
  const cardsEl = document.getElementById("md5_cards");
  const outputEl = document.getElementById("md5_output");
  const tbodyEl = document.getElementById("md5_tbody");

  if (!inputEl || !upperEl || !generateBtn || !copyBtn || !clearBtn || !errEl || !resultEl || !cardsEl || !outputEl || !tbodyEl) return;

  let lastHash = "";

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function resetOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    outputEl.value = "";
    tbodyEl.innerHTML = "";
    lastHash = "";
  }

  function badge(text) {
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">' + text + '</span>';
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function safeAdd(x, y) {
    const lsw = (x & 0xffff) + (y & 0xffff);
    const msw = (x >>> 16) + (y >>> 16) + (lsw >>> 16);
    return (msw << 16) | (lsw & 0xffff);
  }

  function bitRotateLeft(num, cnt) {
    return (num << cnt) | (num >>> (32 - cnt));
  }

  function md5cmn(q, a, b, x, s, t) {
    return safeAdd(bitRotateLeft(safeAdd(safeAdd(a, q), safeAdd(x, t)), s), b);
  }
  function md5ff(a, b, c, d, x, s, t) {
    return md5cmn((b & c) | (~b & d), a, b, x, s, t);
  }
  function md5gg(a, b, c, d, x, s, t) {
    return md5cmn((b & d) | (c & ~d), a, b, x, s, t);
  }
  function md5hh(a, b, c, d, x, s, t) {
    return md5cmn(b ^ c ^ d, a, b, x, s, t);
  }
  function md5ii(a, b, c, d, x, s, t) {
    return md5cmn(c ^ (b | ~d), a, b, x, s, t);
  }

  function binlMD5(x, len) {
    x[len >> 5] |= 0x80 << (len % 32);
    x[(((len + 64) >>> 9) << 4) + 14] = len;

    let i;
    let olda, oldb, oldc, oldd;
    let a = 1732584193;
    let b = -271733879;
    let c = -1732584194;
    let d = 271733878;

    for (i = 0; i < x.length; i += 16) {
      olda = a;
      oldb = b;
      oldc = c;
      oldd = d;

      a = md5ff(a, b, c, d, x[i], 7, -680876936);
      d = md5ff(d, a, b, c, x[i + 1], 12, -389564586);
      c = md5ff(c, d, a, b, x[i + 2], 17, 606105819);
      b = md5ff(b, c, d, a, x[i + 3], 22, -1044525330);
      a = md5ff(a, b, c, d, x[i + 4], 7, -176418897);
      d = md5ff(d, a, b, c, x[i + 5], 12, 1200080426);
      c = md5ff(c, d, a, b, x[i + 6], 17, -1473231341);
      b = md5ff(b, c, d, a, x[i + 7], 22, -45705983);
      a = md5ff(a, b, c, d, x[i + 8], 7, 1770035416);
      d = md5ff(d, a, b, c, x[i + 9], 12, -1958414417);
      c = md5ff(c, d, a, b, x[i + 10], 17, -42063);
      b = md5ff(b, c, d, a, x[i + 11], 22, -1990404162);
      a = md5ff(a, b, c, d, x[i + 12], 7, 1804603682);
      d = md5ff(d, a, b, c, x[i + 13], 12, -40341101);
      c = md5ff(c, d, a, b, x[i + 14], 17, -1502002290);
      b = md5ff(b, c, d, a, x[i + 15], 22, 1236535329);

      a = md5gg(a, b, c, d, x[i + 1], 5, -165796510);
      d = md5gg(d, a, b, c, x[i + 6], 9, -1069501632);
      c = md5gg(c, d, a, b, x[i + 11], 14, 643717713);
      b = md5gg(b, c, d, a, x[i], 20, -373897302);
      a = md5gg(a, b, c, d, x[i + 5], 5, -701558691);
      d = md5gg(d, a, b, c, x[i + 10], 9, 38016083);
      c = md5gg(c, d, a, b, x[i + 15], 14, -660478335);
      b = md5gg(b, c, d, a, x[i + 4], 20, -405537848);
      a = md5gg(a, b, c, d, x[i + 9], 5, 568446438);
      d = md5gg(d, a, b, c, x[i + 14], 9, -1019803690);
      c = md5gg(c, d, a, b, x[i + 3], 14, -187363961);
      b = md5gg(b, c, d, a, x[i + 8], 20, 1163531501);
      a = md5gg(a, b, c, d, x[i + 13], 5, -1444681467);
      d = md5gg(d, a, b, c, x[i + 2], 9, -51403784);
      c = md5gg(c, d, a, b, x[i + 7], 14, 1735328473);
      b = md5gg(b, c, d, a, x[i + 12], 20, -1926607734);

      a = md5hh(a, b, c, d, x[i + 5], 4, -378558);
      d = md5hh(d, a, b, c, x[i + 8], 11, -2022574463);
      c = md5hh(c, d, a, b, x[i + 11], 16, 1839030562);
      b = md5hh(b, c, d, a, x[i + 14], 23, -35309556);
      a = md5hh(a, b, c, d, x[i + 1], 4, -1530992060);
      d = md5hh(d, a, b, c, x[i + 4], 11, 1272893353);
      c = md5hh(c, d, a, b, x[i + 7], 16, -155497632);
      b = md5hh(b, c, d, a, x[i + 10], 23, -1094730640);
      a = md5hh(a, b, c, d, x[i + 13], 4, 681279174);
      d = md5hh(d, a, b, c, x[i], 11, -358537222);
      c = md5hh(c, d, a, b, x[i + 3], 16, -722521979);
      b = md5hh(b, c, d, a, x[i + 6], 23, 76029189);
      a = md5hh(a, b, c, d, x[i + 9], 4, -640364487);
      d = md5hh(d, a, b, c, x[i + 12], 11, -421815835);
      c = md5hh(c, d, a, b, x[i + 15], 16, 530742520);
      b = md5hh(b, c, d, a, x[i + 2], 23, -995338651);

      a = md5ii(a, b, c, d, x[i], 6, -198630844);
      d = md5ii(d, a, b, c, x[i + 7], 10, 1126891415);
      c = md5ii(c, d, a, b, x[i + 14], 15, -1416354905);
      b = md5ii(b, c, d, a, x[i + 5], 21, -57434055);
      a = md5ii(a, b, c, d, x[i + 12], 6, 1700485571);
      d = md5ii(d, a, b, c, x[i + 3], 10, -1894986606);
      c = md5ii(c, d, a, b, x[i + 10], 15, -1051523);
      b = md5ii(b, c, d, a, x[i + 1], 21, -2054922799);
      a = md5ii(a, b, c, d, x[i + 8], 6, 1873313359);
      d = md5ii(d, a, b, c, x[i + 15], 10, -30611744);
      c = md5ii(c, d, a, b, x[i + 6], 15, -1560198380);
      b = md5ii(b, c, d, a, x[i + 13], 21, 1309151649);
      a = md5ii(a, b, c, d, x[i + 4], 6, -145523070);
      d = md5ii(d, a, b, c, x[i + 11], 10, -1120210379);
      c = md5ii(c, d, a, b, x[i + 2], 15, 718787259);
      b = md5ii(b, c, d, a, x[i + 9], 21, -343485551);

      a = safeAdd(a, olda);
      b = safeAdd(b, oldb);
      c = safeAdd(c, oldc);
      d = safeAdd(d, oldd);
    }
    return [a, b, c, d];
  }

  function binl2hex(binarray) {
    const hexTab = "0123456789abcdef";
    let str = "";
    for (let i = 0; i < binarray.length * 4; i++) {
      str += hexTab.charAt((binarray[i >> 2] >> ((i % 4) * 8 + 4)) & 0x0f) +
             hexTab.charAt((binarray[i >> 2] >> ((i % 4) * 8)) & 0x0f);
    }
    return str;
  }

  function str2binlUtf8(str) {
    const bytes = new TextEncoder().encode(str);
    const out = [];
    for (let i = 0; i < bytes.length * 8; i += 8) {
      out[i >> 5] |= bytes[i / 8] << (i % 32);
    }
    return { words: out, bitLength: bytes.length * 8 };
  }

  function md5(str) {
    const data = str2binlUtf8(str);
    return binl2hex(binlMD5(data.words, data.bitLength));
  }

  function generateHash() {
    resetOutput();
    const text = String(inputEl.value || "");
    const upper = !!upperEl.checked;

    if (!text) {
      showError("Please enter input text to hash.");
      return;
    }

    let hash = md5(text);
    if (upper) hash = hash.toUpperCase();

    lastHash = hash;
    outputEl.value = hash;

    resultEl.innerHTML = "<strong>MD5 hash generated.</strong>";
    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      '<div style="display:flex;gap:10px;flex-wrap:wrap;">' +
      badge("MD5") +
      badge("Input length: " + text.length) +
      badge("Hex output") +
      "</div>";

    fillTable([
      ["Algorithm", "MD5"],
      ["Input length", String(text.length)],
      ["Hash length", String(hash.length)],
      ["Case", upper ? "Uppercase" : "Lowercase"],
    ]);
  }

  async function copyHash() {
    clearError();
    if (!lastHash) {
      showError("No hash output to copy yet.");
      return;
    }
    try {
      await navigator.clipboard.writeText(lastHash);
      resultEl.innerHTML = "<strong>Copied hash output.</strong>";
    } catch (_) {
      showError("Clipboard copy failed in this browser.");
    }
  }

  function clearAll() {
    inputEl.value = "";
    upperEl.checked = false;
    resetOutput();
    inputEl.focus();
  }

  generateBtn.addEventListener("click", generateHash);
  copyBtn.addEventListener("click", copyHash);
  clearBtn.addEventListener("click", clearAll);
});
</script>