---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/developer-tools/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort((a, b) => (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title));

const getTool = (href: string) => tools.find((tool) => tool.href === href);
const pickTools = (hrefs: string[]) => hrefs.map(getTool).filter((tool): tool is ToolMeta => !!tool);

const popularTools = pickTools([
  "/developer-tools/json-validator/",
  "/developer-tools/json-minifier/",
  "/developer-tools/jwt-decoder/",
  "/developer-tools/sha256-generator/",
  "/developer-tools/meta-tag-generator/",
  "/developer-tools/heading-structure-checker/",
  "/developer-tools/regex-tester/",
  "/developer-tools/cron-expression-parser/",
]);

const toolGroups = [
  {
    title: "JSON and structured data",
    description: "Validate, format, minify, or convert structured data used in APIs, configuration, and development workflows.",
    tools: pickTools([
      "/developer-tools/json-validator/",
      "/developer-tools/json-minifier/",
      "/developer-tools/json-to-csv/",
      "/developer-tools/json-to-yaml/",
      "/developer-tools/csv-to-json/",
      "/developer-tools/xml-formatter/",
    ]),
  },
  {
    title: "Tokens, hashes, and identifiers",
    description: "Inspect tokens, generate hashes, validate identifiers, or work with values commonly used in authentication and debugging.",
    tools: pickTools([
      "/developer-tools/jwt-decoder/",
      "/developer-tools/jwt-encoder/",
      "/developer-tools/sha256-generator/",
      "/developer-tools/md5-generator/",
      "/developer-tools/uuid-validator/",
      "/developer-tools/hash-generator/",
    ]),
  },
  {
    title: "SEO and web page checks",
    description: "Create or inspect page metadata, headings, canonical tags, schema, redirects, and other web implementation details.",
    tools: pickTools([
      "/developer-tools/meta-tag-generator/",
      "/developer-tools/meta-tag-analyzer/",
      "/developer-tools/heading-structure-checker/",
      "/developer-tools/canonical-tag-generator/",
      "/developer-tools/schema-validator/",
      "/developer-tools/redirect-checker/",
    ]),
  },
  {
    title: "Encoding and parsing",
    description: "Encode, decode, parse, or inspect strings and technical values used in web development and data handling.",
    tools: pickTools([
      "/developer-tools/url-parser/",
      "/developer-tools/html-entity-decoder/",
      "/developer-tools/html-entity-encoder/",
      "/developer-tools/string-escape/",
      "/developer-tools/string-unescape/",
      "/developer-tools/user-agent-parser/",
    ]),
  },
].filter((group) => group.tools.length);
---

<BaseLayout
  title="Developer Tools — MinimalDev"
  description="Free developer tools for JSON validation, JWT decoding, hashing, regex testing, cron expressions, metadata checks, parsers, and data utilities."
  canonicalPath="/developer-tools/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <h1 class="page-title" style="margin:0 0 8px;">Developer Tools</h1>
      <p class="lead" style="margin:0 0 10px;">
        Use focused browser-based tools for common development tasks such as validating JSON,
        decoding JWTs, checking hashes, testing regular expressions, parsing headers, and preparing
        structured data.
      </p>
      <p class="lead" style="margin:0;">
        This category is organized by workflow so you can start with a common task group instead of scanning
        one long list of unrelated utilities.
      </p>
    </section>

    {popularTools.length ? (
      <section class="section">
        <h2>Start with common developer tools</h2>
        <div class="grid">
          {popularTools.map((t) => (
            <section class="card">
              <span class="badge">Popular developer tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    {toolGroups.length ? (
      <section class="section">
        <h2>Developer tools by workflow</h2>
        <div class="grid">
          {toolGroups.map((group) => (
            <section class="card">
              <h2>{group.title}</h2>
              <p>{group.description}</p>
              <ul>
                {group.tools.map((t) => (
                  <li><a href={t.href}>{t.title}</a></li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    <section class="section">
      <h2>What these tools are useful for</h2>
      <div class="grid">
        <section class="card">
          <h2>Validation and debugging</h2>
          <p>
            Check whether input is valid, inspect encoded data, test patterns,
            or confirm that structured content is in the expected format.
          </p>
        </section>

        <section class="card">
          <h2>Formatting and transformation</h2>
          <p>
            Convert data between formats, clean structured content, or generate output that is easier
            to read, copy, compare, or reuse.
          </p>
        </section>

        <section class="card">
          <h2>Quick workflow helpers</h2>
          <p>
            Use focused tools for small repeat tasks such as decoding tokens, checking hashes,
            parsing URLs, inspecting headers, or validating web metadata.
          </p>
        </section>
      </div>
    </section>

    <section class="section">
      <h2>Browse all developer tools</h2>
      <p class="lead" style="margin-top:0;">
        Search all available developer tools below if you already know the exact task or format you need.
      </p>

      <div class="tool-search" style="margin-bottom:16px;">
        <input
          id="toolSearch"
          type="search"
          placeholder="Search tools..."
          aria-label="Search developer tools"
          style="
            width:100%;
            padding:10px 12px;
            border-radius:10px;
            border:1px solid rgba(0,0,0,0.15);
            font-size:14px;
            box-sizing:border-box;
          "
        />
      </div>

      {tools.length ? (
        <div class="grid" data-search-grid>
          {tools.map((t) => (
            <section class="card">
              <span class="badge">Developer Tool</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      ) : (
        <p class="note">No tools found in this category yet.</p>
      )}
    </section>

    <section class="section">
      <h2>How to choose the right tool</h2>
      <div class="card" style="padding:18px;">
        <p style="margin-top:0;">
          If your task is about checking whether data is correct, start with a validator or parser.
          If your task is about changing one representation into another, choose an encoder, decoder,
          formatter, or converter. For page-level SEO checks, use metadata, heading, canonical, or schema tools.
        </p>
        <p style="margin-bottom:0;">
          Keeping each page focused on one technical job makes results easier to understand and reduces the noise
          that often appears in large all-in-one dashboards.
        </p>
      </div>
    </section>
  </div>

  <script>
    const searchInput = document.getElementById("toolSearch") as HTMLInputElement | null;
    const grid = document.querySelector("[data-search-grid]");

    if (searchInput && grid) {
      const cards = Array.from(grid.querySelectorAll(".card")) as HTMLElement[];

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();

        cards.forEach((card) => {
          const text = card.textContent?.toLowerCase() || "";
          card.style.display = text.includes(query) ? "" : "none";
        });
      });
    }
  </script>
</BaseLayout>