---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/developer-tools/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort((a, b) => (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title));
---

<BaseLayout
  title="Developer Tools — MinimalDev"
  description="Free developer tools for regex testing, JSON validation, hashing, JWT decoding, cron expressions, parsers, and development utilities."
  canonicalPath="/developer-tools/"
>
  <div class="container">
    <h1 class="page-title">Developer Tools</h1>
    <p class="lead">
      Free developer tools for regex testing, JSON validation, hashing, JWT handling, parsing, and conversion tasks.
      Use these tools to speed up debugging, formatting, validation, and common development workflows.
      All developer tools run directly in your browser with no installation required.
    </p>

    <div class="tool-search" style="margin-bottom:16px;">
      <input
          id="toolSearch"
          type="search"
          placeholder="Search tools..."
          style="
          width:100%;
          padding:10px 12px;
          border-radius:10px;
          border:1px solid rgba(0,0,0,0.15);
          font-size:14px;
          "
      />
    </div>

    {tools.length ? (
      <div class="grid">
        {tools.map((t) => (
          <section class="card">
            <h2>{t.title}</h2>
            <p>{t.description}</p>
            <a class="btn" href={t.href}>Open</a>
          </section>
        ))}
      </div>
    ) : (
      <p class="note">No tools found in this category yet.</p>
    )}
  </div>
</BaseLayout>