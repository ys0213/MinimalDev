---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Gradient Generator",
  description:
    "Generate linear gradients with two colors, direction controls, live preview, CSS output, and FAQ schema.",
  href: "/design-tools/gradient-generator/",
  order: 20,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/design-tools/gradient-generator/";

const faqs = [
  {
    q: "What does this gradient generator do?",
    a: "It creates a two-color linear gradient and shows a live preview plus the corresponding CSS output.",
  },
  {
    q: "Can I change the gradient angle?",
    a: "Yes. You can choose the angle in degrees to control the gradient direction.",
  },
  {
    q: "Can I copy the CSS code?",
    a: "Yes. The tool provides a copy-ready CSS linear-gradient value.",
  },
  {
    q: "Is any design data stored?",
    a: "No. Everything runs locally in your browser and no values are stored or transmitted.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Gradient Generator — ${SITE_NAME}`}
  description="Generate two-color linear gradients with preview and copyable CSS."
  canonicalPath={CANONICAL_PATH}
  h1="Gradient Generator"
  intro="Build a simple two-color linear gradient and copy the CSS for UI and web design work."
  faq={faqs}
  categoryName="Design Tools"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="gradient-generator">
    <style is:inline>
      .gg-grid-2 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
      }
      .gg-grid-2 > * {
        min-width: 0;
      }
      #gg_color1,
      #gg_color2,
      #gg_angle,
      #gg_css {
        width: 100%;
        min-width: 0;
      }
      .gg-preview {
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 14px;
        min-height: 180px;
        padding: 16px;
      }
      .gg-code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        white-space: pre-wrap;
        word-break: break-word;
      }
      @media (min-width: 760px) {
        .gg-grid-2 {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>

    <div class="form" role="form" aria-describedby="gg_help gg_privacy">
      <div class="gg-grid-2">
        <div class="field">
          <label for="gg_color1">Color 1</label>
          <input id="gg_color1" type="color" value="#4f46e5" />
        </div>
        <div class="field">
          <label for="gg_color2">Color 2</label>
          <input id="gg_color2" type="color" value="#06b6d4" />
        </div>
      </div>

      <div class="field">
        <label for="gg_angle">Angle (degrees)</label>
        <input id="gg_angle" type="number" inputmode="decimal" min="0" max="360" value="90" />
      </div>

      <p class="note" id="gg_help" style="margin-top:6px;">
        This tool creates a linear gradient using two colors and a single angle value.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="gg_generate">Generate Gradient</button>
        <button class="btn secondary" type="button" id="gg_copy">Copy CSS</button>
        <button class="btn secondary" type="button" id="gg_reset">Reset</button>
      </div>

      <div class="result" id="gg_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="gg_result" role="status" style="margin-top:12px;">Result will appear here.</div>

      <div class="gg-preview" id="gg_preview" style="margin-top:16px;"></div>

      <div class="field" style="margin-top:16px;">
        <label for="gg_css">CSS output</label>
        <textarea id="gg_css" class="gg-code" rows="4" readonly spellcheck="false"></textarea>
      </div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr><th scope="col">Setting</th><th scope="col">Value</th></tr>
          </thead>
          <tbody id="gg_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="gg_privacy" style="margin-top:10px;">
        Privacy: gradient generation runs locally in your browser. No values are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Choose two colors, set the angle, preview the result, and copy the CSS linear-gradient value for direct use in stylesheets.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>Create a hero background gradient for a landing page</li>
      <li>Test different gradient angles quickly</li>
      <li>Copy the CSS value directly into your stylesheet</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/design-tools/css-gradient-generator/">CSS Gradient Generator</a></li>
      <li><a href="/design-tools/color-picker/">Color Picker</a></li>
      <li><a href="/design-tools/color-palette-generator/">Color Palette Generator</a></li>
      <li><a href="/design-tools/">All Design Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const color1El = document.getElementById("gg_color1");
  const color2El = document.getElementById("gg_color2");
  const angleEl = document.getElementById("gg_angle");
  const generateBtn = document.getElementById("gg_generate");
  const copyBtn = document.getElementById("gg_copy");
  const resetBtn = document.getElementById("gg_reset");
  const errEl = document.getElementById("gg_error");
  const resultEl = document.getElementById("gg_result");
  const previewEl = document.getElementById("gg_preview");
  const cssEl = document.getElementById("gg_css");
  const tbodyEl = document.getElementById("gg_tbody");

  if (!color1El || !color2El || !angleEl || !generateBtn || !copyBtn || !resetBtn || !errEl || !resultEl || !previewEl || !cssEl || !tbodyEl) return;

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }
  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }
  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function update() {
    clearError();

    const angle = Number(String(angleEl.value || ""));
    if (!Number.isFinite(angle) || angle < 0 || angle > 360) {
      showError("Please enter a valid angle from 0 to 360.");
      return;
    }

    const color1 = String(color1El.value || "#4f46e5");
    const color2 = String(color2El.value || "#06b6d4");
    const css = "linear-gradient(" + angle + "deg, " + color1 + ", " + color2 + ")";

    previewEl.style.background = css;
    cssEl.value = "background: " + css + ";";
    resultEl.innerHTML = "<strong>Gradient generated.</strong>";

    fillTable([
      ["Color 1", color1.toUpperCase()],
      ["Color 2", color2.toUpperCase()],
      ["Angle", angle + "deg"],
      ["Gradient type", "Linear"],
    ]);
  }

  async function copyCss() {
    clearError();
    if (!cssEl.value) {
      showError("No CSS value available to copy.");
      return;
    }
    try {
      await navigator.clipboard.writeText(cssEl.value);
      resultEl.innerHTML = "<strong>Copied CSS gradient value.</strong>";
    } catch (_) {
      showError("Clipboard copy failed in this browser.");
    }
  }

  function resetAll() {
    color1El.value = "#4f46e5";
    color2El.value = "#06b6d4";
    angleEl.value = "90";
    update();
  }

  generateBtn.addEventListener("click", update);
  copyBtn.addEventListener("click", copyCss);
  resetBtn.addEventListener("click", resetAll);
  color1El.addEventListener("input", update);
  color2El.addEventListener("input", update);
  angleEl.addEventListener("input", update);

  update();
});
</script>