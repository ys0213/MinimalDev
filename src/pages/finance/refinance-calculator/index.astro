---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Refinance Calculator",
  description:
    "Compare your current loan vs refinance scenario. Estimate monthly payment, total interest savings, and break-even time including closing costs.",
  href: "/finance/refinance-calculator/",
  order: 140,
};

const faq = [
  {
    q: "What is refinance break-even?",
    a: "Break-even is the number of months required for monthly payment savings to recover refinance closing costs.",
  },
  {
    q: "Does this include taxes and insurance?",
    a: "No. This calculator compares principal and interest only. Taxes and insurance are typically unaffected by rate changes.",
  },
  {
    q: "What about discount points?",
    a: "Treat discount points as part of closing costs for a simplified break-even estimate.",
  },
  {
    q: "Should I refinance if monthly payment increases?",
    a: "Not necessarily. Some refinances shorten the term and reduce total interest even if the monthly payment increases.",
  },
  {
    q: "Why can lender results differ?",
    a: "Lenders may include fees, escrow adjustments, daily interest calculations, rounding rules, and other contractual terms.",
  },
];
---

<ToolLayout
  title="Refinance Calculator — MinimalDev"
  description="Compare your current loan vs refinance scenario. Estimate monthly savings, total interest difference, and break-even months."
  canonicalPath="/finance/refinance-calculator/"
  h1="Refinance Calculator"
  intro="Compare your current loan with a refinance option to estimate payment changes, interest savings, and break-even time."
  faq={faq}
>
  <div slot="tool" data-tool="refinance-calculator">
    <div class="form">

      <div class="field">
        <label for="rf_currency">Currency (display only)</label>
        <select id="rf_currency">
          <option value="USD" selected>USD ($)</option>
          <option value="EUR">EUR (€)</option>
          <option value="GBP">GBP (£)</option>
          <option value="KRW">KRW (₩)</option>
          <option value="JPY">JPY (¥)</option>
        </select>
      </div>

      <h2 style="margin:16px 0 10px;">Current loan</h2>

      <div class="field">
        <label for="rf_balance">Remaining balance</label>
        <input id="rf_balance" type="number" inputmode="decimal" placeholder="e.g., 240000" />
      </div>

      <div class="field">
        <label for="rf_rate_old">Interest rate (%)</label>
        <input id="rf_rate_old" type="number" inputmode="decimal" placeholder="e.g., 6.5" />
      </div>

      <div class="field">
        <label for="rf_years_left">Years remaining</label>
        <input id="rf_years_left" type="number" inputmode="decimal" placeholder="e.g., 25" />
      </div>

      <h2 style="margin:20px 0 10px;">New loan</h2>

      <div class="field">
        <label for="rf_rate_new">New interest rate (%)</label>
        <input id="rf_rate_new" type="number" inputmode="decimal" placeholder="e.g., 5.25" />
      </div>

      <div class="field">
        <label for="rf_years_new">New term (years)</label>
        <input id="rf_years_new" type="number" inputmode="decimal" placeholder="e.g., 25" />
      </div>

      <div class="field">
        <label for="rf_closing">Closing costs (optional)</label>
        <input id="rf_closing" type="number" inputmode="decimal" placeholder="e.g., 3000" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="rf_calc">Calculate</button>
        <button class="btn secondary" type="button" id="rf_clear">Clear</button>
      </div>

      <div class="result" id="rf_result" style="margin-top:12px;">
        Result will appear here.
      </div>

      <p class="note" style="margin-top:10px;">
        Informational estimate only. Actual refinance terms depend on fees, points, escrow, and lender structure.
      </p>

    </div>
  </div>

  <div slot="how">
    <p class="note">
      This calculator compares principal & interest (P&I) payments for your current loan versus a refinance option.
      Both scenarios use standard monthly amortization.
    </p>

    <p class="note">
      Monthly payment formula:
      <br />
      <strong>M = P × (r(1+r)<sup>n</sup>) ÷ ((1+r)<sup>n</sup> − 1)</strong>
    </p>

    <p class="note">
      Break-even months = closing costs ÷ monthly savings.
      If monthly savings are negative, refinance may not produce immediate payment savings.
    </p>
  </div>

  <div slot="faq">
    <ul>
      {faq.map((item) => (
        <li>
          <strong>{item.q}</strong> {item.a}
        </li>
      ))}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/mortgage-calculator/">Mortgage Calculator</a></li>
      <li><a href="/finance/loan-calculator/">Loan Calculator</a></li>
      <li><a href="/finance/apr-calculator/">APR Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {

  const ccyEl = document.getElementById("rf_currency");
  const balEl = document.getElementById("rf_balance");
  const roEl = document.getElementById("rf_rate_old");
  const ylEl = document.getElementById("rf_years_left");
  const rnEl = document.getElementById("rf_rate_new");
  const ynEl = document.getElementById("rf_years_new");
  const ccEl = document.getElementById("rf_closing");
  const calcBtn = document.getElementById("rf_calc");
  const clearBtn = document.getElementById("rf_clear");
  const outEl = document.getElementById("rf_result");

  if (!ccyEl || !balEl || !roEl || !ylEl || !rnEl || !ynEl || !ccEl || !calcBtn || !clearBtn || !outEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return isFinite(x) ? x : NaN;
  }

  function money(v, ccy) {
    if (!isFinite(v)) return "0";
    try {
      return v.toLocaleString(undefined, { style: "currency", currency: ccy });
    } catch {
      return v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " " + ccy;
    }
  }

  function payment(P, rate, years) {
    const n = Math.round(years * 12);
    const r = (rate / 100) / 12;
    if (n <= 0) return NaN;
    if (r === 0) return P / n;
    const pow = Math.pow(1 + r, n);
    return P * (r * pow) / (pow - 1);
  }

  function totalInterest(P, rate, years) {
    const n = Math.round(years * 12);
    const r = (rate / 100) / 12;
    const M = payment(P, rate, years);
    if (!isFinite(M)) return NaN;

    let bal = P;
    let ti = 0;

    for (let i = 1; i <= n; i++) {
      const interest = r === 0 ? 0 : bal * r;
      const principal = M - interest;
      ti += interest;
      bal -= principal;
      if (bal <= 0.0000001) break;
    }

    return ti;
  }

  function reset() {
    outEl.textContent = "Result will appear here.";
  }

  calcBtn.addEventListener("click", function () {

    const ccy = String(ccyEl.value || "USD");
    const P = toNum(balEl.value);
    const oldRate = toNum(roEl.value);
    const yearsLeft = toNum(ylEl.value);
    const newRate = toNum(rnEl.value);
    const yearsNew = toNum(ynEl.value);
    const closing = toNum(ccEl.value) || 0;

    if (!isFinite(P) || P <= 0 ||
        !isFinite(oldRate) || oldRate < 0 ||
        !isFinite(yearsLeft) || yearsLeft <= 0 ||
        !isFinite(newRate) || newRate < 0 ||
        !isFinite(yearsNew) || yearsNew <= 0 ||
        closing < 0) {
      outEl.textContent = "Please enter valid values.";
      return;
    }

    const M_old = payment(P, oldRate, yearsLeft);
    const M_new = payment(P, newRate, yearsNew);
    const I_old = totalInterest(P, oldRate, yearsLeft);
    const I_new = totalInterest(P, newRate, yearsNew);

    if (!isFinite(M_old) || !isFinite(M_new) || !isFinite(I_old) || !isFinite(I_new)) {
      outEl.textContent = "Could not compute with these values.";
      return;
    }

    const monthlyDiff = M_old - M_new;
    const interestDiff = I_old - I_new;
    const breakeven = monthlyDiff > 0 && closing > 0
      ? Math.ceil(closing / monthlyDiff)
      : null;

    outEl.innerHTML =
      "<strong>Current monthly payment:</strong> " + money(M_old, ccy) + "<br/>" +
      "<strong>New monthly payment:</strong> " + money(M_new, ccy) + "<br/>" +
      "<strong>Monthly difference:</strong> " + money(monthlyDiff, ccy) + "<br/>" +
      "<strong>Total interest difference:</strong> " + money(interestDiff, ccy) + "<br/>" +
      (closing > 0 ? "<strong>Closing costs:</strong> " + money(closing, ccy) + "<br/>" : "") +
      (breakeven !== null
        ? "<strong>Break-even:</strong> " + breakeven.toLocaleString() + " months"
        : "<span class='note'>Break-even requires positive monthly savings and closing costs.</span>");
  });

  clearBtn.addEventListener("click", function () {
    ccyEl.value = "USD";
    balEl.value = "";
    roEl.value = "";
    ylEl.value = "";
    rnEl.value = "";
    ynEl.value = "";
    ccEl.value = "";
    reset();
  });

  reset();
});
</script>