---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Refinance Calculator",
  description: "Compare current vs new loan to estimate monthly savings, total interest, and break-even time with closing costs.",
  href: "/finance/refinance-calculator/",
  order: 30,
};
---

<ToolLayout
  title="Refinance Calculator — MinimalDev"
  description="Compare current loan vs refinance scenario. Estimate monthly payment, interest savings, and break-even months."
  canonicalPath="/finance/refinance-calculator/"
  h1="Refinance Calculator"
  intro="Compare your current loan vs a new loan to estimate payment difference, interest savings, and break-even time."
>
  <div slot="tool" data-tool="refinance-calculator">
    <div class="form">
      <h2 style="margin:0 0 10px;">Current loan</h2>

      <div class="field">
        <label for="rf_balance">Remaining balance</label>
        <input id="rf_balance" type="number" inputmode="decimal" placeholder="e.g., 240000" />
      </div>
      <div class="field">
        <label for="rf_rate_old">Interest rate (%)</label>
        <input id="rf_rate_old" type="number" inputmode="decimal" placeholder="e.g., 6.5" />
      </div>
      <div class="field">
        <label for="rf_years_left">Years remaining</label>
        <input id="rf_years_left" type="number" inputmode="decimal" placeholder="e.g., 25" />
      </div>

      <h2 style="margin:16px 0 10px;">New loan</h2>

      <div class="field">
        <label for="rf_rate_new">New interest rate (%)</label>
        <input id="rf_rate_new" type="number" inputmode="decimal" placeholder="e.g., 5.25" />
      </div>
      <div class="field">
        <label for="rf_years_new">New term (years)</label>
        <input id="rf_years_new" type="number" inputmode="decimal" placeholder="e.g., 25" />
      </div>
      <div class="field">
        <label for="rf_closing">Closing costs (optional)</label>
        <input id="rf_closing" type="number" inputmode="decimal" placeholder="e.g., 3000" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="rf_calc">Calculate</button>
        <button class="btn secondary" type="button" id="rf_clear">Clear</button>
      </div>

      <div class="result" id="rf_result">Result will appear here.</div>

      <p class="note" style="margin-top:10px;">
        Informational only. Real refinance outcomes depend on fees, escrow, points, and lender terms.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses standard monthly payment formula (principal + interest only) for both scenarios, then compares totals.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>$240,000 balance, 6.5% vs 5.25%, 25 years → compare savings</li>
      <li>Add closing costs to estimate break-even months</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>What is break-even?</strong> Months needed for monthly savings to cover closing costs.</li>
      <li><strong>Does this include taxes/insurance?</strong> No, principal & interest only.</li>
      <li><strong>What about points?</strong> Treat points as part of closing costs for a rough estimate.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/mortgage-calculator/">Mortgage Calculator</a></li>
      <li><a href="/finance/loan-calculator/">Loan Calculator</a></li>
      <li><a href="/finance/apr-calculator/">APR Calculator</a></li>
      <li><a href="/finance/break-even-calculator/">Break-even Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const balEl = document.getElementById("rf_balance");
  const roEl = document.getElementById("rf_rate_old");
  const ylEl = document.getElementById("rf_years_left");
  const rnEl = document.getElementById("rf_rate_new");
  const ynEl = document.getElementById("rf_years_new");
  const ccEl = document.getElementById("rf_closing");
  const calcBtn = document.getElementById("rf_calc");
  const clearBtn = document.getElementById("rf_clear");
  const outEl = document.getElementById("rf_result");
  if (!balEl || !roEl || !ylEl || !rnEl || !ynEl || !ccEl || !calcBtn || !clearBtn || !outEl) return;

  function money(v) {
    if (!isFinite(v)) return "$0.00";
    return v.toLocaleString(undefined, { style: "currency", currency: "USD" });
  }

  function payment(P, annual, years) {
    const n = Math.round(years * 12);
    const r = (annual / 100) / 12;
    if (n <= 0) return NaN;
    if (r === 0) return P / n;
    return P * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
  }

  function totalInterest(P, annual, years) {
    const n = Math.round(years * 12);
    const r = (annual / 100) / 12;
    const M = payment(P, annual, years);
    if (!isFinite(M)) return NaN;

    let bal = P;
    let ti = 0;
    for (let i = 1; i <= n; i++) {
      const interest = r === 0 ? 0 : bal * r;
      const principal = M - interest;
      ti += interest;
      bal -= principal;
      if (bal <= 0) break;
    }
    return ti;
  }

  calcBtn.addEventListener("click", function () {
    const P = parseFloat(balEl.value);
    const oldRate = parseFloat(roEl.value);
    const yearsLeft = parseFloat(ylEl.value);
    const newRate = parseFloat(rnEl.value);
    const yearsNew = parseFloat(ynEl.value);
    const closing = parseFloat(ccEl.value) || 0;

    if (!isFinite(P) || P <= 0 || !isFinite(oldRate) || oldRate < 0 || !isFinite(yearsLeft) || yearsLeft <= 0 ||
        !isFinite(newRate) || newRate < 0 || !isFinite(yearsNew) || yearsNew <= 0 || closing < 0) {
      outEl.textContent = "Please enter valid values.";
      return;
    }

    const M_old = payment(P, oldRate, yearsLeft);
    const M_new = payment(P, newRate, yearsNew);

    const I_old = totalInterest(P, oldRate, yearsLeft);
    const I_new = totalInterest(P, newRate, yearsNew);

    if (!isFinite(M_old) || !isFinite(M_new) || !isFinite(I_old) || !isFinite(I_new)) {
      outEl.textContent = "Could not compute with these values.";
      return;
    }

    const monthlyDiff = M_old - M_new;
    const interestDiff = I_old - I_new;
    const breakeven = monthlyDiff > 0 && closing > 0 ? (closing / monthlyDiff) : null;

    outEl.innerHTML =
      "<strong>Current payment:</strong> " + money(M_old) + "<br/>" +
      "<strong>New payment:</strong> " + money(M_new) + "<br/>" +
      "<strong>Monthly difference:</strong> " + money(monthlyDiff) + "<br/>" +
      "<strong>Interest difference (approx):</strong> " + money(interestDiff) + "<br/>" +
      (closing > 0
        ? "<strong>Closing costs:</strong> " + money(closing) + "<br/>"
        : "") +
      (breakeven !== null
        ? "<strong>Break-even:</strong> " + (Math.ceil(breakeven)).toLocaleString() + " months"
        : "<span class='note'>Break-even needs positive monthly savings and closing costs.</span>");
  });

  clearBtn.addEventListener("click", function () {
    balEl.value = "";
    roEl.value = "";
    ylEl.value = "";
    rnEl.value = "";
    ynEl.value = "";
    ccEl.value = "";
    outEl.textContent = "Result will appear here.";
  });
});
</script>