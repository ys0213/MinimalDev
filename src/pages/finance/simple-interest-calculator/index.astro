---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Simple Interest Calculator",
  description:
    "Calculate simple interest and total amount from principal, annual rate, and time. No compounding applied.",
  href: "/finance/simple-interest-calculator/",
  order: 20,
};

const faq = [
  {
    q: "What is simple interest?",
    a: "Simple interest is calculated only on the original principal. It does not compound over time.",
  },
  {
    q: "How is it different from compound interest?",
    a: "Compound interest earns interest on both principal and accumulated interest. Simple interest applies only to the original principal.",
  },
  {
    q: "Can I enter fractional years?",
    a: "Yes. For example, 2.5 years represents two years and six months.",
  },
  {
    q: "Does this include fees or taxes?",
    a: "No. This tool provides a mathematical estimate only.",
  },
  {
    q: "When is simple interest used?",
    a: "It is commonly used for short-term loans, certain bonds, and basic financial calculations.",
  },
];
---

<ToolLayout
  title="Simple Interest Calculator — MinimalDev"
  description="Calculate simple interest and final amount. Useful for short-term loans and basic interest calculations."
  canonicalPath="/finance/simple-interest-calculator/"
  h1="Simple Interest Calculator"
  intro="Calculate simple interest using principal, annual rate, and time in years."
  faq={faq}
>
  <div slot="tool" data-tool="simple-interest-calculator">
    <div class="form">

      <div class="field">
        <label for="si_currency">Currency (display only)</label>
        <select id="si_currency">
          <option value="USD" selected>USD ($)</option>
          <option value="EUR">EUR (€)</option>
          <option value="GBP">GBP (£)</option>
          <option value="KRW">KRW (₩)</option>
          <option value="JPY">JPY (¥)</option>
        </select>
      </div>

      <div class="field">
        <label for="si_principal">Principal</label>
        <input id="si_principal" type="number" inputmode="decimal" placeholder="e.g., 5000" />
      </div>

      <div class="field">
        <label for="si_rate">Annual interest rate (%)</label>
        <input id="si_rate" type="number" inputmode="decimal" placeholder="e.g., 6" />
      </div>

      <div class="field">
        <label for="si_years">Time (years)</label>
        <input id="si_years" type="number" inputmode="decimal" placeholder="e.g., 2.5" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="si_calc">Calculate</button>
        <button class="btn secondary" type="button" id="si_clear">Clear</button>
      </div>

      <div class="result" id="si_result" style="margin-top:12px;">
        Result will appear here.
      </div>

      <p class="note" style="margin-top:10px;">
        Simple interest does not compound. For compounding calculations, use the Compound Interest Calculator.
      </p>

    </div>
  </div>

  <div slot="how">
    <p class="note">
      Simple interest is calculated using the formula:
      <strong>Interest = Principal × Rate × Time</strong>.
      The rate must be expressed as a decimal (6% → 0.06).
    </p>

    <p class="note">
      Unlike compound interest, simple interest does not accumulate interest on previously earned interest.
      The total grows linearly over time.
    </p>

    <p class="note">
      This formula is often used for short-term financial calculations and certain loan agreements.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>$5,000 at 6% for 2 years → Interest = $600</li>
      <li>$10,000 at 4% for 1.5 years → linear interest calculation</li>
      <li>Set rate to 0% → total equals principal</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      {faq.map((item) => (
        <li>
          <strong>{item.q}</strong> {item.a}
        </li>
      ))}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/compound-interest-calculator/">Compound Interest Calculator</a></li>
      <li><a href="/finance/savings-calculator/">Savings Calculator</a></li>
      <li><a href="/finance/future-value-calculator/">Future Value Calculator</a></li>
      <li><a href="/finance/loan-calculator/">Loan Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {

  const ccyEl = document.getElementById("si_currency");
  const pEl = document.getElementById("si_principal");
  const rEl = document.getElementById("si_rate");
  const tEl = document.getElementById("si_years");
  const calcBtn = document.getElementById("si_calc");
  const clearBtn = document.getElementById("si_clear");
  const resultEl = document.getElementById("si_result");

  if (!ccyEl || !pEl || !rEl || !tEl || !calcBtn || !clearBtn || !resultEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return isFinite(x) ? x : NaN;
  }

  function money(v, ccy) {
    if (!isFinite(v)) return "0";
    try {
      return v.toLocaleString(undefined, { style: "currency", currency: ccy });
    } catch {
      return v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " " + ccy;
    }
  }

  function reset() {
    resultEl.textContent = "Result will appear here.";
  }

  calcBtn.addEventListener("click", function () {

    const ccy = String(ccyEl.value || "USD");

    const P = toNum(pEl.value);
    const rate = (toNum(rEl.value) || 0) / 100;
    const years = toNum(tEl.value);

    if (!isFinite(P) || P <= 0 ||
        !isFinite(rate) || rate < 0 ||
        !isFinite(years) || years <= 0) {
      resultEl.textContent = "Please enter valid values.";
      return;
    }

    const interest = P * rate * years;
    const total = P + interest;

    resultEl.innerHTML =
      "<strong>Interest:</strong> " + money(interest, ccy) + "<br/>" +
      "<strong>Total amount:</strong> " + money(total, ccy) + "<br/>" +
      "<span class='note'>Linear growth (no compounding applied).</span>";
  });

  clearBtn.addEventListener("click", function () {
    ccyEl.value = "USD";
    pEl.value = "";
    rEl.value = "";
    tEl.value = "";
    reset();
  });

  reset();
});
</script>