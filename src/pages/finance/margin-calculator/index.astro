---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Margin Calculator",
  description:
    "Free margin calculator. Compute gross margin %, markup %, profit, and selling price from cost and price/markup.",
  href: "/finance/margin-calculator/",
  order: 180,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/finance/margin-calculator/";

const faqs = [
  {
    q: "What is profit margin?",
    a: "Profit margin (gross margin) is profit divided by selling price: margin% = (price − cost) ÷ price × 100.",
  },
  {
    q: "What is markup?",
    a: "Markup is profit divided by cost: markup% = (price − cost) ÷ cost × 100. Markup and margin are different.",
  },
  {
    q: "How do I get price from cost and margin?",
    a: "price = cost ÷ (1 − marginRate). Example: cost 60, margin 25% → price = 60 ÷ 0.75 = 80.",
  },
  {
    q: "How do I get price from cost and markup?",
    a: "price = cost × (1 + markupRate). Example: cost 60, markup 25% → price = 60 × 1.25 = 75.",
  },
  {
    q: "Can margin be 100%?",
    a: "A 100% margin would require cost to be 0. If cost is positive, margin will be below 100%.",
  },
  {
    q: "Does this include taxes, shipping, or fees?",
    a: "No. Enter your full effective cost (including any fees) if you want them reflected in the result.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Margin Calculator — ${SITE_NAME}`}
  description="Margin calculator to compute gross margin, markup, profit, and price. Includes margin-to-price and markup-to-price modes with clear breakdown."
  canonicalPath={CANONICAL_PATH}
  h1="Margin Calculator"
  intro="Calculate gross margin, markup, and profit. You can also solve for the selling price using a target margin or markup."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="margin-calculator">
    <div class="form" role="form" aria-describedby="mg_note">
      <div class="field">
        <label for="mg_mode">Mode</label>
        <select id="mg_mode">
          <option value="from_price" selected>Cost + Price → Margin / Markup</option>
          <option value="target_margin">Cost + Target Margin → Price</option>
          <option value="target_markup">Cost + Target Markup → Price</option>
        </select>
      </div>

      <div class="field">
        <label for="mg_cost">Cost</label>
        <input id="mg_cost" type="number" inputmode="decimal" placeholder="e.g., 60" />
        <p class="note" id="mg_cost_help" style="margin-top:6px;">
          Enter your total effective cost (e.g., item cost + fees) if needed.
        </p>
      </div>

      <div class="field" id="mg_price_field">
        <label for="mg_price">Selling price</label>
        <input id="mg_price" type="number" inputmode="decimal" placeholder="e.g., 80" />
      </div>

      <div class="field" id="mg_target_field" style="display:none;">
        <label for="mg_target">Target (%)</label>
        <input id="mg_target" type="number" inputmode="decimal" placeholder="e.g., 25" />
        <p class="note" id="mg_target_help" style="margin-top:6px;">
          Target means <strong>margin%</strong> in “Target Margin” mode, or <strong>markup%</strong> in “Target Markup” mode.
        </p>
      </div>

      <div class="field">
        <label for="mg_currency">Currency (display only)</label>
        <select id="mg_currency">
          <option value="USD" selected>USD</option>
          <option value="EUR">EUR</option>
          <option value="GBP">GBP</option>
          <option value="CAD">CAD</option>
          <option value="AUD">AUD</option>
          <option value="JPY">JPY</option>
          <option value="KRW">KRW</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="mg_calc">Calculate</button>
        <button class="btn secondary" type="button" id="mg_clear">Clear</button>
      </div>

      <div class="result" id="mg_error" role="alert" style="display:none;"></div>

      <div class="result" id="mg_result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <p class="note" id="mg_note" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      <strong>Profit:</strong> price − cost<br/>
      <strong>Margin % (gross margin):</strong> (price − cost) ÷ price × 100<br/>
      <strong>Markup %:</strong> (price − cost) ÷ cost × 100
    </p>
    <p class="note">
      <strong>Price from target margin:</strong> price = cost ÷ (1 − marginRate)<br/>
      <strong>Price from target markup:</strong> price = cost × (1 + markupRate)
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>Cost 60, price 80 → profit 20 → margin 25% → markup 33.33%</li>
      <li>Cost 60, target margin 25% → price 80</li>
      <li>Cost 60, target markup 25% → price 75</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      {faqs.map((f) => (
        <li><strong>{f.q}</strong> {f.a}</li>
      ))}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/markup-calculator/">Markup Calculator</a></li>
      <li><a href="/finance/break-even-calculator/">Break Even Calculator</a></li>
      <li><a href="/finance/vat-calculator/">VAT Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const modeEl = document.getElementById("mg_mode");
  const costEl = document.getElementById("mg_cost");
  const priceField = document.getElementById("mg_price_field");
  const priceEl = document.getElementById("mg_price");
  const targetField = document.getElementById("mg_target_field");
  const targetEl = document.getElementById("mg_target");
  const curEl = document.getElementById("mg_currency");
  const calcBtn = document.getElementById("mg_calc");
  const clearBtn = document.getElementById("mg_clear");
  const errEl = document.getElementById("mg_error");
  const outEl = document.getElementById("mg_result");

  if (!modeEl || !costEl || !priceField || !priceEl || !targetField || !targetEl || !curEl || !calcBtn || !clearBtn || !errEl || !outEl) return;

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }
  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function num(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function decimalsForCurrency(code) {
    if (code === "JPY" || code === "KRW") return 0;
    return 2;
  }

  function money(v, code) {
    if (!Number.isFinite(v)) v = 0;
    const d = decimalsForCurrency(code);
    const p = Math.pow(10, d);
    const rounded = Math.round(v * p) / p;
    const safe = Object.is(rounded, -0) ? 0 : rounded;
    return safe.toLocaleString(undefined, { style: "currency", currency: code, minimumFractionDigits: d, maximumFractionDigits: d });
  }

  function fmtPct(v) {
    if (!Number.isFinite(v)) return "0%";
    const rounded = Math.round(v * 100) / 100;
    const safe = Object.is(rounded, -0) ? 0 : rounded;
    return safe.toLocaleString() + "%";
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 8px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:700;">${text}</span>`;
  }

  function card(title, value, subtitle) {
    return `
      <div style="border:1px solid rgba(255,255,255,0.15); border-radius:12px; padding:12px; flex:1; min-width:220px;">
        <strong>${title}</strong>
        <div style="font-size:26px; font-weight:900; margin-top:6px;">${value}</div>
        <div class="note" style="margin-top:4px;">${subtitle}</div>
      </div>
    `;
  }

  function bucketMargin(marginPct) {
    if (!Number.isFinite(marginPct)) return "—";
    if (marginPct < 0) return "Negative margin";
    if (marginPct < 10) return "Low margin";
    if (marginPct < 30) return "Typical margin";
    if (marginPct < 60) return "High margin";
    return "Very high margin";
  }

  function bucketMarkup(markupPct) {
    if (!Number.isFinite(markupPct)) return "—";
    if (markupPct < 0) return "Negative markup";
    if (markupPct < 20) return "Low markup";
    if (markupPct < 50) return "Typical markup";
    if (markupPct < 100) return "High markup";
    return "Very high markup";
  }

  function syncModeUI() {
    const mode = String(modeEl.value);

    if (mode === "from_price") {
      priceField.style.display = "";
      targetField.style.display = "none";
      priceEl.disabled = false;
      targetEl.disabled = true;
      outEl.textContent = "Result will appear here.";
    } else if (mode === "target_margin") {
      priceField.style.display = "none";
      targetField.style.display = "";
      priceEl.disabled = true;
      targetEl.disabled = false;
      targetEl.placeholder = "e.g., 25";
      outEl.textContent = "Result will appear here.";
    } else {
      priceField.style.display = "none";
      targetField.style.display = "";
      priceEl.disabled = true;
      targetEl.disabled = false;
      targetEl.placeholder = "e.g., 25";
      outEl.textContent = "Result will appear here.";
    }

    clearError();
  }

  function compute() {
    clearError();

    const mode = String(modeEl.value);
    const cost = num(costEl.value);
    const code = String(curEl.value || "USD");

    if (!Number.isFinite(cost) || cost < 0) {
      showError("Please enter a valid cost (0 or higher).");
      return;
    }

    let price = NaN;
    let profit = NaN;
    let marginPct = NaN;
    let markupPct = NaN;

    if (mode === "from_price") {
      price = num(priceEl.value);
      if (!Number.isFinite(price) || price < 0) {
        showError("Please enter a valid selling price (0 or higher).");
        return;
      }
      if (price === 0 && cost > 0) {
        showError("Price is 0 while cost is greater than 0. Margin cannot be computed.");
        return;
      }

      profit = price - cost;
      marginPct = price === 0 ? 0 : (profit / price) * 100;
      markupPct = cost === 0 ? (profit === 0 ? 0 : Infinity) : (profit / cost) * 100;

      const marginLabel = bucketMargin(marginPct);
      const markupLabel = (markupPct === Infinity) ? "Infinite markup (cost 0)" : bucketMarkup(markupPct);

      outEl.innerHTML = `
        <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:stretch;">
          ${card("Profit", money(profit, code), `profit = price − cost`)}
          ${card("Margin (gross margin)", fmtPct(marginPct), `${badge(marginLabel)} · margin = profit ÷ price`)}
          ${card("Markup", (markupPct === Infinity ? "∞" : fmtPct(markupPct)), `${badge(markupLabel)} · markup = profit ÷ cost`)}
        </div>
        <div class="note" style="margin-top:10px;">
          <strong>Inputs:</strong> cost ${money(cost, code)}, price ${money(price, code)}
        </div>
      `;
      return;
    }

    // Target-based modes
    const targetPct = num(targetEl.value);
    if (!Number.isFinite(targetPct)) {
      showError("Please enter a valid target percentage.");
      return;
    }

    if (mode === "target_margin") {
      // marginRate must be < 1 to avoid division by zero/negative denominator
      if (targetPct >= 100) {
        showError("Target margin must be less than 100% (unless cost is 0).");
        return;
      }
      const m = targetPct / 100;
      const denom = 1 - m;
      if (denom <= 0) {
        showError("Target margin results in an invalid price. Use a margin below 100%.");
        return;
      }
      price = denom === 0 ? NaN : (cost / denom);
      profit = price - cost;
      marginPct = price === 0 ? 0 : (profit / price) * 100;
      markupPct = cost === 0 ? (profit === 0 ? 0 : Infinity) : (profit / cost) * 100;

      outEl.innerHTML = `
        <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:stretch;">
          ${card("Selling price", money(price, code), `price = cost ÷ (1 − marginRate)`)}
          ${card("Profit", money(profit, code), `profit = price − cost`)}
          ${card("Resulting markup", (markupPct === Infinity ? "∞" : fmtPct(markupPct)), `${badge(bucketMarkup(markupPct))}`)}
        </div>
        <div class="note" style="margin-top:10px;">
          <strong>Target:</strong> margin ${fmtPct(targetPct)} · <strong>Inputs:</strong> cost ${money(cost, code)}
        </div>
      `;
      return;
    }

    if (mode === "target_markup") {
      if (targetPct < -100) {
        showError("Target markup is too low. Enter a markup of -100% or higher.");
        return;
      }
      const k = targetPct / 100;
      price = cost * (1 + k);
      if (!Number.isFinite(price) || price < 0) {
        showError("Computed price is invalid. Please check inputs.");
        return;
      }
      profit = price - cost;
      marginPct = price === 0 ? 0 : (profit / price) * 100;
      markupPct = cost === 0 ? (profit === 0 ? 0 : Infinity) : (profit / cost) * 100;

      outEl.innerHTML = `
        <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:stretch;">
          ${card("Selling price", money(price, code), `price = cost × (1 + markupRate)`)}
          ${card("Profit", money(profit, code), `profit = price − cost`)}
          ${card("Resulting margin", fmtPct(marginPct), `${badge(bucketMargin(marginPct))}`)}
        </div>
        <div class="note" style="margin-top:10px;">
          <strong>Target:</strong> markup ${fmtPct(targetPct)} · <strong>Inputs:</strong> cost ${money(cost, code)}
        </div>
      `;
      return;
    }
  }

  calcBtn.addEventListener("click", compute);

  // Enter-to-calc
  [costEl, priceEl, targetEl].forEach((el) => {
    el.addEventListener("keydown", function (e) {
      if (e.key === "Enter") compute();
    });
  });

  modeEl.addEventListener("change", syncModeUI);

  clearBtn.addEventListener("click", function () {
    modeEl.value = "from_price";
    curEl.value = "USD";
    costEl.value = "";
    priceEl.value = "";
    targetEl.value = "";
    syncModeUI();
    outEl.textContent = "Result will appear here.";
    clearError();
    costEl.focus();
  });

  syncModeUI();
});
</script>