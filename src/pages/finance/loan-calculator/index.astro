---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Loan Calculator",
  description:
    "Free loan calculator with amortization schedule. Estimate monthly payment, total interest, and view the full payoff table.",
  href: "/finance/loan-calculator/",
  order: 20,
};

const faqs = [
  {
    q: "What does this loan calculator include?",
    a: "It calculates principal-and-interest (P&I) only: monthly payment, total interest, total paid, and an amortization schedule. It does not include taxes, insurance, or lender-specific fees.",
  },
  {
    q: "What is an amortization schedule?",
    a: "An amortization schedule is a detailed month-by-month breakdown showing how each payment is divided between interest and principal, and how your remaining balance decreases over time.",
  },
  {
    q: "What happens if the interest rate is 0%?",
    a: "If the interest rate is 0%, the monthly payment is simply the loan amount divided by the total number of months, and no interest is paid.",
  },
  {
    q: "Why might my lender’s numbers differ?",
    a: "Lenders may include fees, use different rounding rules, or apply daily interest calculations. This calculator provides a simplified estimate for planning purposes.",
  },
  {
    q: "How should I interpret total interest?",
    a: "Total interest represents the cost of borrowing money. A higher interest rate or longer term increases total interest paid over time.",
  },
  {
    q: "Is my data stored?",
    a: "No. All calculations are performed locally in your browser. No data is stored or transmitted.",
  },
];

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/finance/loan-calculator/";

---

<ToolLayout
  title={`Loan Calculator with Amortization Schedule — ${SITE_NAME}`}
  description="Free loan calculator with amortization schedule. Estimate monthly payment, total interest, and total loan cost."
  canonicalPath={CANONICAL_PATH}
  h1="Loan Calculator"
  intro="Calculate monthly loan payments, total interest, and understand how your balance decreases over time."
  faq={faqs}
  categoryName="Finance"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Loan Calculator",
    "description": "Estimate fixed-rate loan payments, total interest, total paid, and amortization schedule.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />
  <div slot="tool" data-tool="loan-calculator">
    <div
      style="background:#f0fdf4; border:1px solid #bbf7d0; padding:10px; border-radius:8px; margin-bottom:16px;"
      class="note"
    >
      <strong>Privacy First:</strong> All calculations run locally in your browser.
      <strong>Your financial inputs are never sent to any server.</strong>
    </div>
    <div class="form">
      <div class="field">
        <label for="loan_amount">Loan amount</label>
        <input id="loan_amount" type="number" inputmode="decimal" placeholder="e.g., 10000" />
      </div>

      <div class="field">
        <label for="loan_rate">Annual interest rate (APR %)</label>
        <input id="loan_rate" type="number" inputmode="decimal" placeholder="e.g., 5" />
      </div>

      <div class="field">
        <label for="loan_years">Loan term (years)</label>
        <input id="loan_years" type="number" inputmode="decimal" placeholder="e.g., 5" />
      </div>

      <div class="field">
        <label for="loan_currency">Currency (display only)</label>
        <select id="loan_currency">
          <option value="USD" selected>USD ($)</option>
          <option value="EUR">EUR (€)</option>
          <option value="GBP">GBP (£)</option>
          <option value="KRW">KRW (₩)</option>
          <option value="JPY">JPY (¥)</option>
        </select>
      </div>

      <div class="field">
        <label for="loan_max_months">Max months (safety cap)</label>
        <input id="loan_max_months" type="number" inputmode="numeric" value="600" min="12" max="1200" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="loan_calc">Calculate</button>
        <button class="btn secondary" type="button" id="loan_clear">Clear</button>
      </div>

      <div id="loan_summary" class="result" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div style="margin-top:18px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:14px;">
          <thead>
            <tr>
              <th>Month</th>
              <th>Payment</th>
              <th>Principal</th>
              <th>Interest</th>
              <th>Balance</th>
            </tr>
          </thead>
          <tbody id="loan_tbody"></tbody>
        </table>
      </div>

      <p class="note" style="margin-top:10px;">
        Informational estimate only. Taxes, insurance, escrow, and lender fees are not included.
      </p>
    </div>
  </div>

  <div slot="how">
    <h2>How Loan Calculation Works</h2>

    <p class="note">
      This loan calculator estimates payments using a standard fixed-rate amortization model. Each monthly payment includes both principal and interest, gradually reducing the loan balance over time.
    </p>

    <p class="note">
      <strong>Formula:</strong><br/>
      M = P × (r(1+r)^n) ÷ ((1+r)^n − 1)
    </p>

    <p class="note">
      Where:<br/>
      - P = loan amount<br/>
      - r = monthly interest rate<br/>
      - n = total number of payments
    </p>

    <div class="prose" style="margin-top:20px;">
      <h2>How Loan Payments Work</h2>
      <p>
        A fixed-rate loan uses the same monthly payment throughout the entire term. However, the composition of that payment changes over time. In the early stages of a loan, a larger portion of each payment goes toward interest. As the balance decreases, more of each payment goes toward principal.
      </p>

      <p>
        This process is called amortization. The amortization schedule shows exactly how much interest and principal you pay each month, along with the remaining balance after each payment.
      </p>

      <h2>Why Total Interest Matters</h2>
      <p>
        The total interest represents the real cost of borrowing. Even a small increase in interest rate or loan term can significantly increase the total amount paid over time. Longer loans reduce monthly payments but increase total interest.
      </p>

      <p>
        For example, extending a loan from 5 years to 7 years may lower your monthly payment, but you will pay more in total interest. This trade-off is important when comparing loan options.
      </p>

      <h2>Common Use Cases</h2>
      <ul>
        <li><strong>Car loans:</strong> Estimate monthly payments before purchasing a vehicle</li>
        <li><strong>Personal loans:</strong> Compare loan terms and interest rates</li>
        <li><strong>Debt planning:</strong> Understand repayment structure and long-term cost</li>
        <li><strong>Financial decisions:</strong> Evaluate affordability before committing to a loan</li>
      </ul>

      <h2>How to Interpret Results</h2>
      <p>
        The monthly payment shows your required fixed payment. The total interest shows the cost of borrowing. The amortization table provides a detailed breakdown for each payment, helping you understand how your balance decreases over time.
      </p>
    </div>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Car loan:</strong> Estimate monthly payment before buying a vehicle</li>
      <li><strong>Personal loan planning:</strong> Compare loan terms to reduce interest</li>
      <li><strong>Debt management:</strong> Understand long-term repayment structure</li>
    </ul>

    <p class="note"><strong>Example:</strong></p>
    <ul>
      <li>$10,000 at 5% for 5 years</li>
      <li>Monthly payment ≈ $188.71 per month</li>
      <li>Total paid ≈ $11,322</li>
      <li>Total interest ≈ $1,322</li>
    </ul>

    <p class="note">
      These values are estimates and may vary depending on lender terms, fees, or compounding methods.
    </p>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/mortgage-calculator/">Mortgage Calculator</a></li>
      <li><a href="/finance/personal-loan-calculator/">Personal Loan Calculator</a></li>
      <li><a href="/finance/car-loan-calculator/">Car Loan Calculator</a></li>
      <li><a href="/math/percent-calculator/">Percent Calculator</a></li>
      <li><a href="/date-time/age-calculator/">Age Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const amountEl = document.getElementById("loan_amount");
  const rateEl = document.getElementById("loan_rate");
  const yearsEl = document.getElementById("loan_years");
  const ccyEl = document.getElementById("loan_currency");
  const maxEl = document.getElementById("loan_max_months");
  const calcBtn = document.getElementById("loan_calc");
  const clearBtn = document.getElementById("loan_clear");
  const summaryEl = document.getElementById("loan_summary");
  const tbodyEl = document.getElementById("loan_tbody");

  if (!amountEl || !rateEl || !yearsEl || !ccyEl || !maxEl || !calcBtn || !clearBtn || !summaryEl || !tbodyEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return isFinite(x) ? x : NaN;
  }

  function clampInt(v, lo, hi, fallback) {
    const n = parseInt(String(v), 10);
    if (!isFinite(n)) return fallback;
    return Math.max(lo, Math.min(hi, n));
  }

  function money(v, ccy) {
    if (!isFinite(v)) return "0";
    try {
      return v.toLocaleString(undefined, { style: "currency", currency: ccy });
    } catch {
      return v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " " + ccy;
    }
  }

  function payment(P, r, n) {
    if (n <= 0) return NaN;
    if (r === 0) return P / n;
    return P * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
  }

  function reset() {
    summaryEl.textContent = "Result will appear here.";
    tbodyEl.innerHTML = "";
  }

  calcBtn.addEventListener("click", function () {
    const P = toNum(amountEl.value);
    const annual = toNum(rateEl.value) / 100;
    const years = toNum(yearsEl.value);
    const ccy = String(ccyEl.value || "USD");
    const maxMonths = clampInt(maxEl.value, 12, 1200, 600);

    if (!isFinite(P) || P <= 0) { summaryEl.textContent = "Please enter a valid loan amount."; tbodyEl.innerHTML = ""; return; }
    if (!isFinite(annual) || annual < 0) { summaryEl.textContent = "Please enter a valid APR (0 or more)."; tbodyEl.innerHTML = ""; return; }
    if (!isFinite(years) || years <= 0) { summaryEl.textContent = "Please enter a valid term in years (> 0)."; tbodyEl.innerHTML = ""; return; }

    const n = Math.round(years * 12);
    if (n <= 0) { summaryEl.textContent = "Term is too small."; tbodyEl.innerHTML = ""; return; }
    if (n > maxMonths) {
      summaryEl.innerHTML =
        "Term exceeds the safety cap.<br/>" +
        "<span class='note'>Reduce years or increase Max months.</span>";
      tbodyEl.innerHTML = "";
      return;
    }

    const r = annual / 12;
    const M = payment(P, r, n);
    if (!isFinite(M)) { summaryEl.textContent = "Could not compute payment with the provided inputs."; tbodyEl.innerHTML = ""; return; }

    const totalPay = M * n;
    const totalInterest = totalPay - P;

    summaryEl.innerHTML =
      "<strong>Monthly payment:</strong> " + money(M, ccy) + "<br/>" +
      "<strong>Total interest:</strong> " + money(totalInterest, ccy) + "<br/>" +
      "<strong>Total paid:</strong> " + money(totalPay, ccy);

    let balance = P;
    tbodyEl.innerHTML = "";

    for (let i = 1; i <= n; i++) {
      const interest = r === 0 ? 0 : balance * r;
      let principal = M - interest;

      if (principal > balance) principal = balance;

      balance = balance - principal;
      if (balance < 0) balance = 0;

      const row =
        "<tr>" +
          "<td>" + i + "</td>" +
          "<td>" + money(M, ccy) + "</td>" +
          "<td>" + money(principal, ccy) + "</td>" +
          "<td>" + money(interest, ccy) + "</td>" +
          "<td>" + money(balance, ccy) + "</td>" +
        "</tr>";

      tbodyEl.insertAdjacentHTML("beforeend", row);
    }
  });

  clearBtn.addEventListener("click", function () {
    amountEl.value = "";
    rateEl.value = "";
    yearsEl.value = "";
    ccyEl.value = "USD";
    maxEl.value = "600";
    reset();
  });

  reset();
});
</script>