---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Net Present Value (NPV) Calculator",
  description: "Calculate NPV from an initial investment, discount rate, and a series of cash flows.",
  href: "/finance/net-present-value-calculator/",
  order: 50,
};
---

<ToolLayout
  title="NPV Calculator — MinimalDev"
  description="Calculate Net Present Value (NPV) from an initial investment and annual cash flows."
  canonicalPath="/finance/net-present-value-calculator/"
  h1="NPV Calculator"
  intro="Compute NPV using a discount rate and yearly cash flows. Useful for simple investment comparisons."
>
  <div slot="tool" data-tool="npv-calculator">
    <div class="form">
      <div class="field">
        <label for="npv_initial">Initial investment (negative)</label>
        <input id="npv_initial" type="number" inputmode="decimal" placeholder="e.g., -10000" />
      </div>

      <div class="field">
        <label for="npv_rate">Discount rate (%)</label>
        <input id="npv_rate" type="number" inputmode="decimal" placeholder="e.g., 8" />
      </div>

      <div class="field">
        <label for="npv_flows">Annual cash flows (comma-separated)</label>
        <input id="npv_flows" type="text" placeholder="e.g., 3000,3000,3000,3000" />
        <p class="note" style="margin-top:6px;">Year 1, Year 2, ... (use negative values if needed)</p>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="npv_calc">Calculate</button>
        <button class="btn secondary" type="button" id="npv_clear">Clear</button>
      </div>

      <div class="result" id="npv_result">Result will appear here.</div>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      NPV = Σ( CF_t / (1+r)^t ) + initialInvestment
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>-10,000 initial, 8% rate, cash flows 3,000×4 → compute NPV</li>
      <li>Positive NPV generally indicates value above the discount rate</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>What is discount rate?</strong> A required return used to convert future cash flows into present value.</li>
      <li><strong>Do cash flows have to be yearly?</strong> This page assumes yearly spacing for simplicity.</li>
      <li><strong>Does this include taxes?</strong> No. Use after-tax cash flows if needed.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/future-value-calculator/">Future Value Calculator</a></li>
      <li><a href="/finance/investment-calculator/">Investment Calculator</a></li>
      <li><a href="/finance/annuity-calculator/">Annuity Calculator</a></li>
      <li><a href="/finance/compound-interest-calculator/">Compound Interest Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const initEl = document.getElementById("npv_initial");
  const rateEl = document.getElementById("npv_rate");
  const flowsEl = document.getElementById("npv_flows");
  const calcBtn = document.getElementById("npv_calc");
  const clearBtn = document.getElementById("npv_clear");
  const outEl = document.getElementById("npv_result");
  if (!initEl || !rateEl || !flowsEl || !calcBtn || !clearBtn || !outEl) return;

  function money(v) {
    if (!isFinite(v)) return "$0.00";
    return v.toLocaleString(undefined, { style: "currency", currency: "USD" });
  }

  calcBtn.addEventListener("click", function () {
    const initial = parseFloat(initEl.value);
    const r = (parseFloat(rateEl.value) || 0) / 100;
    const raw = String(flowsEl.value || "").trim();

    if (!isFinite(initial) || !isFinite(r) || r < 0 || !raw) {
      outEl.textContent = "Please enter valid values and cash flows.";
      return;
    }

    const flows = raw.split(",").map(s => parseFloat(s.trim())).filter(v => isFinite(v));
    if (!flows.length) {
      outEl.textContent = "Please enter cash flows like: 3000,3000,3000";
      return;
    }

    let pv = 0;
    for (let i = 0; i < flows.length; i++) {
      const t = i + 1;
      pv += flows[i] / Math.pow(1 + r, t);
    }
    const npv = initial + pv;

    outEl.innerHTML =
      "<strong>NPV:</strong> " + money(npv) + "<br/>" +
      "<span class='note'>Present value of cash flows: " + money(pv) + "</span>";
  });

  clearBtn.addEventListener("click", function () {
    initEl.value = "";
    rateEl.value = "";
    flowsEl.value = "";
    outEl.textContent = "Result will appear here.";
  });
});
</script>