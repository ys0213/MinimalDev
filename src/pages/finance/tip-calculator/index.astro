---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Tip Calculator",
  description:
    "Free tip calculator. Calculate tip amount, total bill, and split per person with custom tip percentage and rounding options.",
  href: "/finance/tip-calculator/",
  order: 70,
};

const faqs = [
  {
    q: "What does this tip calculator do?",
    a: "It calculates the tip amount, total bill including tip, and optional split amount per person based on your bill and chosen tip percentage.",
  },
  {
    q: "Can I split the bill between multiple people?",
    a: "Yes. Enter the number of people to see how much each person would pay.",
  },
  {
    q: "Does this calculator include tax automatically?",
    a: "No. Enter the bill amount you want to tip on. If you want to include tax, add it to the bill before calculating.",
  },
  {
    q: "Can I round the total?",
    a: "Yes. You can optionally round the total up to the nearest whole currency unit.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser and are not stored or transmitted.",
  },
];
---

<ToolLayout
  title="Tip Calculator — MinimalDev"
  description="Calculate tip, total bill, and split amount per person with custom tip percentage and optional rounding."
  canonicalPath="/finance/tip-calculator/"
  h1="Tip Calculator"
  intro="Calculate tip amount, final total, and per-person split. Useful for restaurants, delivery, taxis, and shared bills."
  faq={faqs}
  categoryName="Finance"
>
  <div slot="tool" data-tool="tip-calculator">
    <div class="form" role="form" aria-describedby="tip_note tip_privacy">
      <div class="field">
        <label for="tip_bill">Bill amount</label>
        <input id="tip_bill" type="number" inputmode="decimal" placeholder="e.g., 48.50" />
      </div>

      <div class="field">
        <label for="tip_percent">Tip percentage (%)</label>
        <input id="tip_percent" type="number" inputmode="decimal" placeholder="e.g., 15" />
        <p class="note" style="margin-top:6px;">
          Common presets: 10%, 15%, 18%, 20%.
        </p>
      </div>

      <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <button type="button" class="btn secondary" data-tip-preset="10">10%</button>
        <button type="button" class="btn secondary" data-tip-preset="15">15%</button>
        <button type="button" class="btn secondary" data-tip-preset="18">18%</button>
        <button type="button" class="btn secondary" data-tip-preset="20">20%</button>
      </div>

      <div class="field">
        <label for="tip_people">Number of people (optional)</label>
        <input id="tip_people" type="number" inputmode="numeric" placeholder="e.g., 2" />
      </div>

      <div class="field">
        <label for="tip_round">Rounding</label>
        <select id="tip_round">
          <option value="none" selected>No rounding</option>
          <option value="up-total">Round total up</option>
          <option value="up-tip">Round tip up</option>
        </select>
      </div>

      <div class="field">
        <label for="tip_currency">Currency (display only)</label>
        <select id="tip_currency">
          <option value="USD" selected>USD ($)</option>
          <option value="EUR">EUR (€)</option>
          <option value="GBP">GBP (£)</option>
          <option value="KRW">KRW (₩)</option>
          <option value="JPY">JPY (¥)</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button id="tip_calc" class="btn" type="button">Calculate</button>
        <button id="tip_clear" class="btn secondary" type="button">Clear</button>
      </div>

      <div id="tip_error" class="result" role="alert" style="display:none;"></div>

      <div id="tip_summary" class="result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div id="tip_cards" class="result" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:14px;">
          <thead>
            <tr>
              <th>Metric</th>
              <th>Value</th>
            </tr>
          </thead>
          <tbody id="tip_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="tip_note" style="margin-top:10px;">
        Tip amount = bill × tip rate. Total = bill + tip. Split = total ÷ people.
      </p>

      <p class="note" id="tip_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This calculator multiplies the bill by your chosen tip percentage to find the tip amount,
      then adds it back to the bill to get the total. If you enter a number of people, it also
      divides the final total evenly to estimate each person's share.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>$48.50 bill with 15% tip → $7.28 tip, $55.78 total</li>
      <li>$80 bill with 20% tip split 4 ways → $24 per person</li>
      <li>Use “Round total up” if you want a cleaner final payment amount</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/tax-calculator/">Tax Calculator</a></li>
      <li><a href="/math/percent-calculator/">Percent Calculator</a></li>
      <li><a href="/finance/budget-calculator/">Budget Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const billEl = document.getElementById("tip_bill");
  const percentEl = document.getElementById("tip_percent");
  const peopleEl = document.getElementById("tip_people");
  const roundEl = document.getElementById("tip_round");
  const currencyEl = document.getElementById("tip_currency");
  const calcBtn = document.getElementById("tip_calc");
  const clearBtn = document.getElementById("tip_clear");
  const errorEl = document.getElementById("tip_error");
  const summaryEl = document.getElementById("tip_summary");
  const cardsEl = document.getElementById("tip_cards");
  const tbodyEl = document.getElementById("tip_tbody");

  if (!billEl || !percentEl || !peopleEl || !roundEl || !currencyEl || !calcBtn || !clearBtn || !errorEl || !summaryEl || !cardsEl || !tbodyEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return isFinite(x) ? x : NaN;
  }

  function money(v, ccy) {
    if (!isFinite(v)) return "0";
    try {
      return v.toLocaleString(undefined, { style: "currency", currency: ccy });
    } catch {
      return v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " " + ccy;
    }
  }

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function badge(text) {
    return "<span style='display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;'>" + text + "</span>";
  }

  function clearOut() {
    clearError();
    summaryEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  document.querySelectorAll("[data-tip-preset]").forEach(function (btn) {
    btn.addEventListener("click", function () {
      percentEl.value = String(btn.getAttribute("data-tip-preset") || "");
    });
  });

  calcBtn.addEventListener("click", function () {
    clearOut();

    const bill = toNum(billEl.value);
    const percent = toNum(percentEl.value);
    const peopleRaw = String(peopleEl.value || "").trim();
    const people = peopleRaw ? parseInt(peopleRaw, 10) : 1;
    const roundMode = String(roundEl.value || "none");
    const ccy = String(currencyEl.value || "USD");

    if (!isFinite(bill) || bill < 0) {
      showError("Please enter a valid bill amount (0 or more).");
      return;
    }
    if (!isFinite(percent) || percent < 0) {
      showError("Please enter a valid tip percentage (0 or more).");
      return;
    }
    if (!isFinite(people) || people <= 0) {
      showError("Please enter a valid number of people (1 or more).");
      return;
    }

    let tip = bill * (percent / 100);
    let total = bill + tip;

    if (roundMode === "up-total") {
      total = Math.ceil(total);
      tip = total - bill;
    } else if (roundMode === "up-tip") {
      tip = Math.ceil(tip);
      total = bill + tip;
    }

    const split = total / people;

    summaryEl.innerHTML =
      "<strong>Tip:</strong> " + money(tip, ccy) + "<br/>" +
      "<strong>Total:</strong> " + money(total, ccy) + "<br/>" +
      "<strong>Per person:</strong> " + money(split, ccy);

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      badge(percent + "% tip") + " " +
      badge(people === 1 ? "No split" : "Split " + people + " ways") + " " +
      badge(roundMode === "none" ? "No rounding" : roundMode === "up-total" ? "Rounded total up" : "Rounded tip up");

    const rows = [
      ["Bill amount", money(bill, ccy)],
      ["Tip rate", percent.toLocaleString() + "%"],
      ["Tip amount", money(tip, ccy)],
      ["Final total", money(total, ccy)],
      ["People", String(people)],
      ["Per person", money(split, ccy)],
    ];

    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  });

  clearBtn.addEventListener("click", function () {
    billEl.value = "";
    percentEl.value = "";
    peopleEl.value = "";
    roundEl.value = "none";
    currencyEl.value = "USD";
    clearOut();
  });
});
</script>