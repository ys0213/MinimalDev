---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Savings Calculator",
  description:
    "Estimate savings growth over time with monthly deposits and optional interest. See year-by-year balances, deposits, and interest earned.",
  href: "/finance/savings-calculator/",
  order: 40,
};

const faq = [
  {
    q: "Is the interest compounded monthly?",
    a: "Yes. This tool applies the annual rate as a monthly rate (annual ÷ 12) and compounds month by month for a simple estimate.",
  },
  {
    q: "Does it model APY exactly like banks do?",
    a: "Not exactly. Banks may use daily compounding, different posting schedules, and fees. Use this as an estimate.",
  },
  {
    q: "What if the interest rate is 0%?",
    a: "Then the balance grows only from deposits. The interest earned will be 0.",
  },
  {
    q: "Are taxes and fees included?",
    a: "No. Taxes, account fees, and tiered rates are not included.",
  },
  {
    q: "How should I treat irregular deposits?",
    a: "Convert your average deposit into a monthly amount for a rough projection.",
  },
];
---

<ToolLayout
  title="Savings Calculator — MinimalDev"
  description="Estimate savings growth with monthly deposits and optional interest. View balances by year with total deposits and interest earned."
  canonicalPath="/finance/savings-calculator/"
  h1="Savings Calculator"
  intro="Estimate how your savings balance could grow with monthly deposits and an optional annual interest rate."
  faq={faq}
>
  <div slot="tool" data-tool="savings-calculator">
    <div class="form">
      <div class="field">
        <label for="sv_currency">Currency (display only)</label>
        <select id="sv_currency">
          <option value="USD" selected>USD ($)</option>
          <option value="EUR">EUR (€)</option>
          <option value="GBP">GBP (£)</option>
          <option value="KRW">KRW (₩)</option>
          <option value="JPY">JPY (¥)</option>
        </select>
      </div>

      <div class="field">
        <label for="sv_start">Starting balance</label>
        <input id="sv_start" type="number" inputmode="decimal" placeholder="e.g., 1000" />
      </div>

      <div class="field">
        <label for="sv_monthly">Monthly deposit</label>
        <input id="sv_monthly" type="number" inputmode="decimal" placeholder="e.g., 200" />
      </div>

      <div class="field">
        <label for="sv_rate">Annual interest rate (%) (optional)</label>
        <input id="sv_rate" type="number" inputmode="decimal" placeholder="e.g., 3" />
        <p class="note" style="margin-top:6px;">
          Use your expected average annual rate. This is a simplified projection.
        </p>
      </div>

      <div class="field">
        <label for="sv_years">Years</label>
        <input id="sv_years" type="number" inputmode="decimal" placeholder="e.g., 10" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button id="sv_calc" class="btn" type="button">Calculate</button>
        <button id="sv_clear" class="btn secondary" type="button">Clear</button>
      </div>

      <div id="sv_summary" class="result" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div style="margin-top:20px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th>Year</th>
              <th>Balance</th>
              <th>Total Deposits</th>
              <th>Interest Earned</th>
            </tr>
          </thead>
          <tbody id="sv_tbody"></tbody>
        </table>
      </div>

      <p class="note" style="margin-top:10px;">
        Estimates only. Actual yields vary by account, compounding method, and fees.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This calculator applies a simple monthly compounding model. Each month:
      (1) interest is applied to the current balance, then (2) your monthly deposit is added.
    </p>

    <p class="note">
      The annual interest rate is converted to a monthly rate by dividing by 12.
      This is common for quick projections, but real accounts may compound daily or use APY rules.
    </p>

    <p class="note">
      Use the year-by-year table to sanity-check your plan and to compare different deposit amounts or rates.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>$1,000 start, $200/mo, 3% for 10 years → estimate final balance and total interest</li>
      <li>Set interest to 0% → deposit-only savings projection</li>
      <li>Increase monthly deposit to compare how much faster you reach a target balance</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      {faq.map((item) => (
        <li>
          <strong>{item.q}</strong> {item.a}
        </li>
      ))}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/compound-interest-calculator/">Compound Interest Calculator</a></li>
      <li><a href="/finance/future-value-calculator/">Future Value Calculator</a></li>
      <li><a href="/finance/investment-calculator/">Investment Calculator</a></li>
      <li><a href="/finance/retirement-calculator/">Retirement Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const ccyEl = document.getElementById("sv_currency");
  const startEl = document.getElementById("sv_start");
  const monthlyEl = document.getElementById("sv_monthly");
  const rateEl = document.getElementById("sv_rate");
  const yearsEl = document.getElementById("sv_years");
  const calcBtn = document.getElementById("sv_calc");
  const clearBtn = document.getElementById("sv_clear");
  const summaryEl = document.getElementById("sv_summary");
  const tbodyEl = document.getElementById("sv_tbody");

  if (!ccyEl || !startEl || !monthlyEl || !rateEl || !yearsEl || !calcBtn || !clearBtn || !summaryEl || !tbodyEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return isFinite(x) ? x : NaN;
  }

  function money(v, ccy) {
    if (!isFinite(v)) return "0";
    try {
      return v.toLocaleString(undefined, { style: "currency", currency: ccy });
    } catch {
      return v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " " + ccy;
    }
  }

  function reset() {
    summaryEl.textContent = "Result will appear here.";
    tbodyEl.innerHTML = "";
  }

  calcBtn.addEventListener("click", function () {
    const ccy = String(ccyEl.value || "USD");

    let balance = toNum(startEl.value);
    const monthly = toNum(monthlyEl.value);
    const annual = (toNum(rateEl.value) || 0) / 100;
    const yearsRaw = toNum(yearsEl.value);

    if (!isFinite(balance) || balance < 0 ||
        !isFinite(monthly) || monthly < 0 ||
        !isFinite(annual) || annual < 0 ||
        !isFinite(yearsRaw) || yearsRaw <= 0) {
      summaryEl.textContent = "Please enter valid values.";
      tbodyEl.innerHTML = "";
      return;
    }

    // allow decimals, but show a sensible table by years (rounded down for full years)
    const fullYears = Math.floor(yearsRaw);
    const remainingMonths = Math.round((yearsRaw - fullYears) * 12);

    const r = annual / 12;

    let deposits = balance;
    let interestEarned = 0;

    tbodyEl.innerHTML = "";

    function stepMonths(monthCount) {
      for (let m = 1; m <= monthCount; m++) {
        const interest = r === 0 ? 0 : balance * r;
        balance += interest;
        interestEarned += interest;

        balance += monthly;
        deposits += monthly;
      }
    }

    for (let y = 1; y <= fullYears; y++) {
      stepMonths(12);

      const row =
        "<tr>" +
          "<td>" + y + "</td>" +
          "<td>" + money(balance, ccy) + "</td>" +
          "<td>" + money(deposits, ccy) + "</td>" +
          "<td>" + money(interestEarned, ccy) + "</td>" +
        "</tr>";

      tbodyEl.insertAdjacentHTML("beforeend", row);
    }

    if (remainingMonths > 0) {
      stepMonths(remainingMonths);

      const label = (fullYears + remainingMonths / 12).toFixed(2);
      const row =
        "<tr>" +
          "<td>" + label + "</td>" +
          "<td>" + money(balance, ccy) + "</td>" +
          "<td>" + money(deposits, ccy) + "</td>" +
          "<td>" + money(interestEarned, ccy) + "</td>" +
        "</tr>";

      tbodyEl.insertAdjacentHTML("beforeend", row);
    }

    summaryEl.innerHTML =
      "<strong>Final balance:</strong> " + money(balance, ccy) + "<br/>" +
      "<strong>Total deposits:</strong> " + money(deposits, ccy) + "<br/>" +
      "<strong>Interest earned:</strong> " + money(interestEarned, ccy);
  });

  clearBtn.addEventListener("click", function () {
    ccyEl.value = "USD";
    startEl.value = "";
    monthlyEl.value = "";
    rateEl.value = "";
    yearsEl.value = "";
    reset();
  });

  reset();
});
</script>