---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Compound Interest Calculator",
  description:
    "Calculate compound interest growth from principal, rate, time, and compounding frequency.",
  href: "/finance/compound-interest-calculator/",
  order: 30,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/finance/compound-interest-calculator/";

const faqs = [
  {
    q: "How does this calculator work?",
    a: "It uses the compound interest formula, applying interest monthly on your balance and adding monthly contributions at the end of each period.",
  },
  {
    q: "Is my investment data secure?",
    a: "Yes. All calculations are performed locally within your browser. No financial data is ever transmitted or stored on our servers.",
  },
  {
    q: "Why does compound interest matter?",
    a: "It allows your money to grow exponentially. Over time, the interest you earn begins to earn its own interest, accelerating your wealth accumulation.",
  },
  {
    q: "Does this account for taxes and inflation?",
    a: "No. This tool provides a mathematical projection. Actual results will vary based on market conditions, tax laws, and inflation.",
  }
];

---

<ToolLayout
  title={`Compound Interest Calculator — ${SITE_NAME}`}
  description="Calculate compound interest and estimate how money may grow over time with different rates, periods, and compounding schedules."
  canonicalPath={CANONICAL_PATH}
  h1="Compound Interest Calculator"
  intro="Estimate how your money grows over time using compound interest, with optional monthly contributions for a clearer financial projection."
  faq={faqs}
  categoryName="Finance"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Compound Interest Calculator",
    "description": "Financial tool to calculate compound interest growth and future value of investments.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

    <div slot="tool" data-tool="compound-interest-calculator">
     <div style="background: #f0fdf4; border: 1px solid #bbf7d0; padding: 15px; border-radius: 6px; margin-bottom: 24px;">
       <strong>Privacy First:</strong> This calculator runs entirely locally in your browser.
       <strong>Your financial inputs are never stored or sent to our servers.</strong>
     </div>

    <div class="form">
      <div class="field">
        <label for="ci_principal">Initial Investment ($)</label>
        <input id="ci_principal" type="number" inputmode="decimal" placeholder="e.g., 10000" />
      </div>
      <div class="field">
        <label for="ci_rate">Annual Interest Rate (%)</label>
        <input id="ci_rate" type="number" inputmode="decimal" placeholder="e.g., 7" />
      </div>
      <div class="field">
        <label for="ci_years">Investment Period (Years)</label>
        <input id="ci_years" type="number" inputmode="numeric" placeholder="e.g., 10" />
      </div>
      <div class="field">
        <label for="ci_monthly">Monthly Contribution ($)</label>
        <input id="ci_monthly" type="number" inputmode="decimal" placeholder="e.g., 200" />
      </div>

      <div style="display:flex; gap:10px; margin-top:10px;">
        <button id="ci_calc" class="btn" type="button">Calculate</button>
        <button id="ci_clear" class="btn secondary" type="button">Clear</button>
      </div>

      <div id="ci_summary" class="result" style="margin-top:20px; padding:15px; background:#f9fafb;">Result will appear here.</div>

      <div style="margin-top:20px; overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:14px; text-align:right;">
          <thead style="border-bottom: 2px solid #e5e7eb;">
            <tr>
              <th style="padding: 8px;">Year</th>
              <th style="padding: 8px;">Total Value</th>
              <th style="padding: 8px;">Contributions</th>
              <th style="padding: 8px;">Interest</th>
            </tr>
          </thead>
          <tbody id="ci_tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div slot="how">
    <h2>How Compound Interest Works</h2>

    <p class="note">
      Compound interest means earning interest on both your initial investment and the interest accumulated over time.
      This calculator applies interest monthly and includes optional monthly contributions.
    </p>

    <ul>
      <li><strong>Step 1:</strong> Convert annual rate to monthly → rate ÷ 12</li>
      <li><strong>Step 2:</strong> Apply interest to current balance</li>
      <li><strong>Step 3:</strong> Add monthly contribution</li>
      <li><strong>Formula:</strong> balance = previous balance × (1 + monthly rate) + monthly contribution</li>
    </ul>

    <div class="prose" style="margin-top:40px;">
      <h2>Understanding the Power of Compound Interest</h2>
      <p>
        Compound interest is different from simple interest because interest is calculated on both the original principal and previously accumulated interest. Over long time periods, this can create a compounding effect where growth accelerates as the balance becomes larger.
      </p>
      
      <h2>How We Calculate Your Projections</h2>
      <p>
        This calculator uses monthly compounding as a practical default. Some accounts or investments may compound daily, monthly, quarterly, annually, or by another schedule, so actual results can differ.
      </p>
      <ul>
        <li><strong>Monthly Interest:</strong> Dividing your annual rate by 12 and applying it to your current balance each month.</li>
        <li><strong>Periodic Contributions:</strong> If you add monthly contributions, they are added to your balance at the end of each month, immediately beginning to compound in the following cycle.</li>
      </ul>

      <h2>Strategic Tips for Long-Term Wealth</h2>
      <ul>
        <li><strong>Start Early:</strong> Time is your greatest asset. Even small amounts compounded over decades can grow significantly compared to larger amounts invested for a shorter period.</li>
        <li><strong>Consistency Matters:</strong> Regular monthly contributions significantly alter the growth curve by increasing the principal base upon which interest is earned.</li>
        <li><strong>Manage Expectations:</strong> While our calculator provides an optimistic mathematical projection, real-world investing involves volatility, fees, and taxes that are not included here. Always consult a financial advisor for personalized planning.</li>
      </ul>

      <p>
      To calculate simple percentages, you can use our 
      <a href="/math/percent-calculator/">Percent Calculator</a>.
      </p>

      <p>
      For loan-related projections, try our 
      <a href="/finance/loan-calculator/">Loan Calculator</a>.
      </p>
    </div>

  </div>

  <div slot="examples">
    <p><strong>Example:</strong></p>
    <ul>
      <li><strong>Initial:</strong> $10,000</li>
      <li><strong>Rate:</strong> 7% annually</li>
      <li><strong>Years:</strong> 10</li>
      <li><strong>Monthly contribution:</strong> $200</li>
      <li><strong>Estimated result:</strong> about $54,700 after 10 years, before taxes, fees, and inflation</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/savings-calculator/">Savings Calculator</a></li>
      <li><a href="/finance/investment-calculator/">Investment Calculator</a></li>
      <li><a href="/finance/simple-interest-calculator/">Simple Interest Calculator</a></li>
      <li><a href="/math/percent-calculator/">Percent Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const principalEl = document.getElementById("ci_principal");
  const rateEl = document.getElementById("ci_rate");
  const yearsEl = document.getElementById("ci_years");
  const monthlyEl = document.getElementById("ci_monthly");
  const calcBtn = document.getElementById("ci_calc");
  const clearBtn = document.getElementById("ci_clear");
  const summaryEl = document.getElementById("ci_summary");
  const tbodyEl = document.getElementById("ci_tbody");

  if (!principalEl || !rateEl || !yearsEl || !monthlyEl || !calcBtn) return;

  function money(v) {
    return v.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
  }

  calcBtn.addEventListener("click", function () {
    const P = parseFloat(principalEl.value);
    const annualRateInput = parseFloat(rateEl.value);
    const years = parseFloat(yearsEl.value);
    const monthlyContribInput = parseFloat(monthlyEl.value);

    if (
      !Number.isFinite(P) || P < 0 ||
      !Number.isFinite(annualRateInput) || annualRateInput < 0 ||
      !Number.isFinite(years) || years <= 0 ||
      !Number.isFinite(monthlyContribInput) || monthlyContribInput < 0
    ) {
      summaryEl.textContent = "Please enter valid non-negative values. Investment period must be greater than 0.";
      tbodyEl.innerHTML = "";
      return;
    }

    const annualRate = annualRateInput / 100;
    const monthlyContrib = monthlyContribInput;

    let balance = P;
    let totalContrib = P;
    let totalInterest = 0;
    let rows = "";

    tbodyEl.innerHTML = "";
    
    for (let m = 1; m <= years * 12; m++) {
      balance = balance * (1 + annualRate / 12) + monthlyContrib;
      totalContrib += monthlyContrib;
      
      if (m % 12 === 0) {
        totalInterest = balance - totalContrib;
        rows += `<tr>
          <td style="padding: 8px;">${m / 12}</td>
          <td style="padding: 8px;">${money(balance)}</td>
          <td style="padding: 8px;">${money(totalContrib)}</td>
          <td style="padding: 8px;">${money(totalInterest)}</td>
        </tr>`;
      }
    }
    
    tbodyEl.innerHTML = rows;
    summaryEl.innerHTML = `
      <div style="font-size:1.1em;">
        <strong>Final Balance:</strong> ${money(balance)}<br/>
        <strong>Total Interest Earned:</strong> ${money(balance - totalContrib)}
      </div>`;
  });

  clearBtn.addEventListener("click", () => {
    [principalEl, rateEl, yearsEl, monthlyEl].forEach(el => el.value = "");
    summaryEl.textContent = "Result will appear here.";
    tbodyEl.innerHTML = "";
  });
});
</script>