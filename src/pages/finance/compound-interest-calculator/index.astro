---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Compound Interest Calculator",
  description:
    "Calculate compound interest with optional monthly contributions. Estimate future value, total contributions, and total interest over time.",
  href: "/finance/compound-interest-calculator/",
  order: 30,
};

const faqs = [
  {
    q: "Does this assume monthly compounding?",
    a: "Yes. This calculator compounds monthly and optionally adds a contribution at the end of each month.",
  },
  {
    q: "When are contributions added?",
    a: "Monthly contributions are added at the end of each month, after interest is applied.",
  },
  {
    q: "What does the final value represent?",
    a: "Final value is the total investment amount after compounding, including both your contributions and earned interest.",
  },
  {
    q: "Why is long-term growth so large?",
    a: "Because compound interest grows exponentially over time. The longer the period, the more interest earns additional interest.",
  },
  {
    q: "Does this include inflation or taxes?",
    a: "No. This is a simplified projection. Real-world returns may differ due to inflation, taxes, and fees.",
  },
  {
    q: "Is my data stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title="Compound Interest Calculator — MinimalDev"
  description="Estimate compound interest growth with optional monthly contributions. See future value, total contributions, and interest breakdown."
  canonicalPath="/finance/compound-interest-calculator/"
  h1="Compound Interest Calculator"
  intro="Estimate how your money grows over time using compound interest, with optional monthly contributions."
  faq={faqs}
  categoryName="Finance"
>
  <div slot="tool" data-tool="compound-interest-calculator">
    <div class="form">
      <div class="field">
        <label for="ci_principal">Initial investment</label>
        <input id="ci_principal" type="number" inputmode="decimal" placeholder="e.g., 10000" />
      </div>

      <div class="field">
        <label for="ci_rate">Annual interest rate (%)</label>
        <input id="ci_rate" type="number" inputmode="decimal" placeholder="e.g., 7" />
        <p class="note" style="margin-top:6px;">
          Expected annual return. Compounded monthly.
        </p>
      </div>

      <div class="field">
        <label for="ci_years">Investment period (years)</label>
        <input id="ci_years" type="number" inputmode="numeric" placeholder="e.g., 10" />
      </div>

      <div class="field">
        <label for="ci_monthly">Monthly contribution (optional)</label>
        <input id="ci_monthly" type="number" inputmode="decimal" placeholder="e.g., 200" />
        <p class="note" style="margin-top:6px;">
          Added at the end of each month.
        </p>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button id="ci_calc" class="btn" type="button">Calculate</button>
        <button id="ci_clear" class="btn secondary" type="button">Clear</button>
      </div>

      <div id="ci_summary" class="result" style="margin-top:12px;">Result will appear here.</div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:14px;">
          <thead>
            <tr>
              <th>Year</th>
              <th>Total value</th>
              <th>Total contributions</th>
              <th>Total interest</th>
            </tr>
          </thead>
          <tbody id="ci_tbody"></tbody>
        </table>
      </div>

      <p class="note" style="margin-top:10px;">
        Informational only. Estimates do not include inflation, taxes, or fees.
      </p>
    </div>
  </div>

  <!-- 강화된 How -->
  <div slot="how">
    <p class="note">
      Compound interest means your investment earns interest not only on the original amount but also on previously earned interest.
    </p>

    <p class="note">
      This tool simulates growth month by month using a monthly rate (annual rate ÷ 12) and optionally adds contributions at the end of each month.
    </p>

    <p class="note">
      <strong>How to interpret results:</strong><br/>
      - Final value: total accumulated amount<br/>
      - Total contributions: how much you invested<br/>
      - Total interest: growth generated by compounding
    </p>

    <p class="note">
      Over time, interest becomes a larger portion of total growth. This is why long-term investing significantly increases returns.
    </p>
  </div>

  <!-- 강화된 Examples -->
  <div slot="examples">
    <ul>
      <li><strong>Long-term investing:</strong> Compare 10 vs 30 years to see exponential growth.</li>
      <li><strong>Monthly savings plan:</strong> Add a fixed monthly contribution to simulate regular investing.</li>
      <li><strong>Goal planning:</strong> Estimate how much you need to invest to reach a target amount.</li>
    </ul>

    <p class="note"><strong>Example:</strong></p>
    <ul>
      <li>$10,000 at 7% for 10 years → grows to about $19,671</li>
      <li>$10,000 + $200/month → significantly higher due to contributions</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/savings-calculator/">Savings Calculator</a></li>
      <li><a href="/finance/investment-calculator/">Investment Calculator</a></li>
      <li><a href="/finance/simple-interest-calculator/">Simple Interest Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const principalEl = document.getElementById("ci_principal");
  const rateEl = document.getElementById("ci_rate");
  const yearsEl = document.getElementById("ci_years");
  const monthlyEl = document.getElementById("ci_monthly");
  const calcBtn = document.getElementById("ci_calc");
  const clearBtn = document.getElementById("ci_clear");
  const summaryEl = document.getElementById("ci_summary");
  const tbodyEl = document.getElementById("ci_tbody");

  if (!principalEl || !rateEl || !yearsEl || !monthlyEl || !calcBtn || !clearBtn || !summaryEl || !tbodyEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return isFinite(x) ? x : NaN;
  }

  function money(v) {
    if (!isFinite(v)) return "$0.00";
    return v.toLocaleString(undefined, { style: "currency", currency: "USD" });
  }

  calcBtn.addEventListener("click", function () {
    const P0 = toNum(principalEl.value);
    const annualPct = toNum(rateEl.value);
    const years = toNum(yearsEl.value);
    const monthly = String(monthlyEl.value).trim() === "" ? 0 : toNum(monthlyEl.value);

    if (!isFinite(P0) || P0 < 0) {
      summaryEl.textContent = "Please enter a valid initial investment (>= 0).";
      tbodyEl.innerHTML = "";
      return;
    }
    if (!isFinite(annualPct) || annualPct < 0) {
      summaryEl.textContent = "Please enter a valid annual rate (>= 0).";
      tbodyEl.innerHTML = "";
      return;
    }
    if (!isFinite(years) || years <= 0) {
      summaryEl.textContent = "Please enter a valid investment period in years (> 0).";
      tbodyEl.innerHTML = "";
      return;
    }
    if (!isFinite(monthly) || monthly < 0) {
      summaryEl.textContent = "Please enter a valid monthly contribution (>= 0).";
      tbodyEl.innerHTML = "";
      return;
    }

    const totalMonths = Math.round(years * 12);
    const r = (annualPct / 100) / 12;

    let balance = P0;
    let totalContrib = P0;
    let totalInterest = 0;

    tbodyEl.innerHTML = "";

    for (let month = 1; month <= totalMonths; month++) {
      if (r !== 0) balance = balance * (1 + r);

      if (monthly > 0) {
        balance += monthly;
        totalContrib += monthly;
      }

      if (month % 12 === 0 || month === totalMonths) {
        const year = Math.ceil(month / 12);
        totalInterest = balance - totalContrib;

        const row =
          "<tr>" +
            "<td>" + year + "</td>" +
            "<td>" + money(balance) + "</td>" +
            "<td>" + money(totalContrib) + "</td>" +
            "<td>" + money(totalInterest) + "</td>" +
          "</tr>";
        tbodyEl.insertAdjacentHTML("beforeend", row);
      }
    }

    totalInterest = balance - totalContrib;

    summaryEl.innerHTML =
      "<strong>Final value:</strong> " + money(balance) + "<br/>" +
      "<strong>Total contributions:</strong> " + money(totalContrib) + "<br/>" +
      "<strong>Total interest earned:</strong> " + money(totalInterest);
  });

  clearBtn.addEventListener("click", function () {
    principalEl.value = "";
    rateEl.value = "";
    yearsEl.value = "";
    monthlyEl.value = "";
    summaryEl.textContent = "Result will appear here.";
    tbodyEl.innerHTML = "";
  });
});
</script>