---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Salary Calculator",
  description:
    "Free salary calculator. Convert annual salary into monthly, biweekly, weekly, daily, and hourly pay estimates.",
  href: "/finance/salary-calculator/",
  order: 80,
};

const faqs = [
  {
    q: "What does this salary calculator estimate?",
    a: "It converts an annual salary into monthly, biweekly, weekly, daily, and hourly pay estimates based on your selected work schedule.",
  },
  {
    q: "Does this calculator account for taxes?",
    a: "No. This tool estimates gross pay only. Use the Tax Calculator or Paycheck Calculator for after-tax estimates.",
  },
  {
    q: "How is hourly pay calculated?",
    a: "Hourly pay is estimated from annual salary divided by total hours worked per year, based on your hours per week and weeks per year inputs.",
  },
  {
    q: "Can I adjust work weeks and hours?",
    a: "Yes. You can customize hours per week, days per week, and weeks worked per year.",
  },
  {
    q: "Are my salary inputs stored?",
    a: "No. All calculations run locally in your browser and are not stored or transmitted.",
  },
];
---

<ToolLayout
  title="Salary Calculator — MinimalDev"
  description="Convert annual salary into monthly, biweekly, weekly, daily, and hourly pay estimates with a customizable work schedule."
  canonicalPath="/finance/salary-calculator/"
  h1="Salary Calculator"
  intro="Enter an annual salary and your work schedule to estimate monthly, biweekly, weekly, daily, and hourly gross pay."
  faq={faqs}
  categoryName="Finance"
>
  <div slot="tool" data-tool="salary-calculator">
    <style is:inline>
      .sal-grid-3 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .sal-grid-3 > * {
        min-width: 0;
      }

      #sal_annual,
      #sal_hours_week,
      #sal_days_week,
      #sal_weeks_year,
      #sal_currency {
        width: 100%;
        min-width: 0;
      }

      @media (min-width: 700px) {
        .sal-grid-3 {
          grid-template-columns: 1fr 1fr 1fr;
        }
      }
    </style>

    <div class="form" role="form" aria-describedby="sal_note sal_privacy">
      <div class="field">
        <label for="sal_annual">Annual salary</label>
        <input id="sal_annual" type="number" inputmode="decimal" placeholder="e.g., 60000" />
      </div>

      <div class="sal-grid-3">
        <div class="field">
          <label for="sal_hours_week">Hours per week</label>
          <input id="sal_hours_week" type="number" inputmode="decimal" placeholder="e.g., 40" value="40" />
        </div>

        <div class="field">
          <label for="sal_days_week">Days per week</label>
          <input id="sal_days_week" type="number" inputmode="decimal" placeholder="e.g., 5" value="5" />
        </div>

        <div class="field">
          <label for="sal_weeks_year">Weeks per year</label>
          <input id="sal_weeks_year" type="number" inputmode="decimal" placeholder="e.g., 52" value="52" />
        </div>
      </div>

      <div class="field">
        <label for="sal_currency">Currency (display only)</label>
        <select id="sal_currency">
          <option value="USD" selected>USD ($)</option>
          <option value="EUR">EUR (€)</option>
          <option value="GBP">GBP (£)</option>
          <option value="KRW">KRW (₩)</option>
          <option value="JPY">JPY (¥)</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button id="sal_calc" class="btn" type="button">Calculate</button>
        <button id="sal_clear" class="btn secondary" type="button">Clear</button>
      </div>

      <div id="sal_error" class="result" role="alert" style="display:none;"></div>

      <div id="sal_summary" class="result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div id="sal_cards" class="result" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:14px;">
          <thead>
            <tr>
              <th>Pay period</th>
              <th>Estimate</th>
            </tr>
          </thead>
          <tbody id="sal_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="sal_note" style="margin-top:10px;">
        Gross pay only. No taxes, deductions, or benefits are included.
      </p>

      <p class="note" id="sal_privacy" style="margin-top:10px;">
        Privacy: calculations run locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This calculator starts with annual gross salary, then divides it across common pay periods:
      monthly, biweekly, weekly, daily, and hourly. Hourly pay depends on the total hours you
      work per year based on your schedule.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>$60,000/year → about $5,000/month gross</li>
      <li>$52,000/year with 40 hours/week → about $25/hour gross</li>
      <li>Adjust weeks per year if you want unpaid leave or seasonal work reflected</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/hourly-to-salary-calculator/">Hourly to Salary Calculator</a></li>
      <li><a href="/finance/salary-to-hourly-calculator/">Salary to Hourly Calculator</a></li>
      <li><a href="/finance/paycheck-calculator/">Paycheck Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const annualEl = document.getElementById("sal_annual");
  const hoursWeekEl = document.getElementById("sal_hours_week");
  const daysWeekEl = document.getElementById("sal_days_week");
  const weeksYearEl = document.getElementById("sal_weeks_year");
  const currencyEl = document.getElementById("sal_currency");
  const calcBtn = document.getElementById("sal_calc");
  const clearBtn = document.getElementById("sal_clear");
  const errorEl = document.getElementById("sal_error");
  const summaryEl = document.getElementById("sal_summary");
  const cardsEl = document.getElementById("sal_cards");
  const tbodyEl = document.getElementById("sal_tbody");

  if (!annualEl || !hoursWeekEl || !daysWeekEl || !weeksYearEl || !currencyEl || !calcBtn || !clearBtn || !errorEl || !summaryEl || !cardsEl || !tbodyEl) return;

  function toNum(v) {
    const s = String(v ?? "").trim();
    if (s === "") return NaN;
    const x = parseFloat(s);
    return Number.isFinite(x) ? x : NaN;
  }

  function money(v, ccy) {
    if (!Number.isFinite(v)) return "0";
    try {
      return v.toLocaleString(undefined, { style: "currency", currency: ccy });
    } catch {
      return v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " " + ccy;
    }
  }

  function clearError() {
    errorEl.style.display = "none";
    errorEl.textContent = "";
  }

  function showError(msg) {
    errorEl.style.display = "block";
    errorEl.textContent = msg;
  }

  function badge(text) {
    return "<span style='display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;'>" + text + "</span>";
  }

  function clearOut() {
    clearError();
    summaryEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  calcBtn.addEventListener("click", function () {
    clearOut();

    const annual = toNum(annualEl.value);
    const hoursWeek = toNum(hoursWeekEl.value);
    const daysWeek = toNum(daysWeekEl.value);
    const weeksYear = toNum(weeksYearEl.value);
    const ccy = String(currencyEl.value || "USD");

    if (!Number.isFinite(annual) || annual < 0 || annual > 1000000000) {
      showError("Please enter a valid annual salary (0 or more).");
      return;
    }
    if (!Number.isFinite(hoursWeek) || hoursWeek <= 0 || hoursWeek > 168) {
      showError("Please enter valid hours per week (> 0 and up to 168).");
      return;
    }
    if (!Number.isFinite(daysWeek) || daysWeek <= 0 || daysWeek > 7) {
      showError("Please enter valid days per week (> 0 and up to 7).");
      return;
    }
    if (!Number.isFinite(weeksYear) || weeksYear <= 0 || weeksYear > 366) {
      showError("Please enter valid weeks per year (> 0 and within a realistic range).");
      return;
    }
    if (hoursWeek < daysWeek) {
      showError("Hours per week should not be less than days per week for a typical work schedule.");
      return;
    }

    const monthly = annual / 12;
    const biweekly = annual / 26;
    const weekly = annual / weeksYear;
    const daily = weekly / daysWeek;
    const hourly = annual / (hoursWeek * weeksYear);

    summaryEl.innerHTML =
      "<strong>Annual salary:</strong> " + money(annual, ccy) + "<br/>" +
      "<strong>Estimated hourly pay:</strong> " + money(hourly, ccy);

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      badge(hoursWeek.toLocaleString(undefined, { maximumFractionDigits: 2 }) + " hrs/week") + " " +
      badge(daysWeek.toLocaleString(undefined, { maximumFractionDigits: 2 }) + " days/week") + " " +
      badge(weeksYear.toLocaleString(undefined, { maximumFractionDigits: 2 }) + " weeks/year");

    const rows = [
      ["Annual", money(annual, ccy)],
      ["Monthly", money(monthly, ccy)],
      ["Biweekly", money(biweekly, ccy)],
      ["Weekly", money(weekly, ccy)],
      ["Daily", money(daily, ccy)],
      ["Hourly", money(hourly, ccy)],
    ];

    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  });

  clearBtn.addEventListener("click", function () {
    annualEl.value = "";
    hoursWeekEl.value = "40";
    daysWeekEl.value = "5";
    weeksYearEl.value = "52";
    currencyEl.value = "USD";
    clearOut();
    annualEl.focus();
  });

  clearOut();
});
</script>