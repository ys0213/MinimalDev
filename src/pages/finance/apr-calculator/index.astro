---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "APR Calculator",
  description:
    "Estimate APR including fees. Compare the true annual cost of borrowing using amount, rate, term, and upfront fees.",
  href: "/finance/apr-calculator/",
  order: 70,
};

const faqs = [
  {
    q: "What is APR (Annual Percentage Rate)?",
    a: "APR is the effective annual cost of borrowing that includes interest plus certain fees. It helps compare loans more fairly than the nominal interest rate alone.",
  },
  {
    q: "Is this the same APR a lender shows?",
    a: "This is a close estimate using a simplified cash-flow method. Real lender APR may include additional costs or different timing/rounding rules.",
  },
  {
    q: "How are fees treated in this calculator?",
    a: "Upfront fees are treated as reducing the net amount you receive (loan amount minus fees). You still repay based on the full loan amount.",
  },
  {
    q: "What if fees are rolled into the loan balance?",
    a: "If fees are financed (added to the balance), the true cost can differ. This calculator assumes fees are paid upfront (net proceeds are lower).",
  },
  {
    q: "Does APR include insurance, taxes, or penalties?",
    a: "No. This tool focuses on principal, interest, and an upfront fee amount. Other charges can change the effective cost.",
  },
];
---

<ToolLayout
  title="APR Calculator (Including Fees) — MinimalDev"
  description="Estimate APR (effective annual cost) including upfront loan fees. Compare loans using amount, nominal rate, term, and fees."
  canonicalPath="/finance/apr-calculator/"
  h1="APR Calculator"
  intro="Estimate APR by including upfront fees in the effective cost of borrowing. Useful for comparing loan offers beyond the nominal interest rate."
  faq={faqs}
  categoryName="Finance"
>
  <div slot="tool" data-tool="apr-calculator">
    <div class="form">
      <div class="field">
        <label for="apr_amount">Loan amount</label>
        <input id="apr_amount" type="number" inputmode="decimal" placeholder="e.g., 10000" />
      </div>

      <div class="field">
        <label for="apr_rate">Nominal annual interest rate (%)</label>
        <input id="apr_rate" type="number" inputmode="decimal" placeholder="e.g., 8" />
      </div>

      <div class="field">
        <label for="apr_years">Term (years)</label>
        <input id="apr_years" type="number" inputmode="numeric" placeholder="e.g., 3" />
      </div>

      <div class="field">
        <label for="apr_fees">Upfront fees</label>
        <input id="apr_fees" type="number" inputmode="decimal" placeholder="e.g., 200" />
        <p class="note" style="margin-top:6px;">
          Example: origination fee, processing fee, points (entered as a dollar amount).
        </p>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="apr_calc">Calculate</button>
        <button class="btn secondary" type="button" id="apr_clear">Clear</button>
      </div>

      <div class="result" id="apr_result" style="margin-top:12px;">Result will appear here.</div>

      <p class="note" style="margin-top:10px;">
        Informational only. This APR is estimated from a simplified cash-flow approach.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      APR helps you compare loans by incorporating certain fees into the borrowing cost.
      In this calculator, we first compute the <strong>monthly payment</strong> using the nominal interest rate.
      Then we estimate the <strong>effective rate</strong> that makes the present value of those payments equal to the
      <strong>net proceeds</strong> you actually receive.
    </p>

    <p class="note">
      <strong>Step 1 — Monthly payment (nominal):</strong><br />
      M = P × (r(1+r)<sup>n</sup>) ÷ ((1+r)<sup>n</sup> − 1)<br />
      where P = loan amount, r = nominal monthly rate, n = number of payments.
    </p>

    <p class="note">
      <strong>Step 2 — APR estimate with fees:</strong><br />
      Net proceeds = P − fees. We solve for the monthly rate i such that:<br />
      Net proceeds = M × (1 − (1+i)<sup>−n</sup>) ÷ i<br />
      Then convert to effective annual APR: (1+i)<sup>12</sup> − 1.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>$10,000 at 8% for 3 years with $200 fees → APR higher than 8%</li>
      <li>Compare two loans: lower nominal rate may still have higher APR if fees are larger</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/loan-calculator/">Loan Calculator</a></li>
      <li><a href="/finance/credit-card-interest-calculator/">Credit Card Interest Calculator</a></li>
      <li><a href="/finance/car-loan-calculator/">Car Loan Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const amountEl = document.getElementById("apr_amount");
  const rateEl = document.getElementById("apr_rate");
  const yearsEl = document.getElementById("apr_years");
  const feesEl = document.getElementById("apr_fees");
  const calcBtn = document.getElementById("apr_calc");
  const clearBtn = document.getElementById("apr_clear");
  const resultEl = document.getElementById("apr_result");
  if (!amountEl || !rateEl || !yearsEl || !feesEl || !calcBtn || !clearBtn || !resultEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return isFinite(x) ? x : NaN;
  }

  function money(v) {
    if (!isFinite(v)) return "$0.00";
    return v.toLocaleString(undefined, { style: "currency", currency: "USD" });
  }

  function payment(P, r, n) {
    if (n <= 0) return NaN;
    if (r === 0) return P / n;
    const a = Math.pow(1 + r, n);
    return P * (r * a) / (a - 1);
  }

  // Solve for monthly rate i such that PV(payments, i) = netProceeds
  // PV = M * (1 - (1+i)^-n) / i
  function pvOfAnnuity(M, i, n) {
    if (n <= 0) return NaN;
    if (i === 0) return M * n;
    return M * (1 - Math.pow(1 + i, -n)) / i;
  }

  // Robust bisection: expand hi until PV(hi) <= net (PV decreases as i increases)
  function solveMonthlyRate(M, n, net) {
    if (!(M > 0 && n > 0 && net > 0)) return NaN;

    let lo = 0;
    let hi = 1; // 100% monthly initial guess
    let pvHi = pvOfAnnuity(M, hi, n);

    // Expand upper bound if needed (cap to avoid infinite loop)
    let guard = 0;
    while (isFinite(pvHi) && pvHi > net && hi < 10 && guard < 60) {
      hi *= 2;
      pvHi = pvOfAnnuity(M, hi, n);
      guard++;
    }

    // If even extremely high rates still produce PV > net, something is off
    if (!isFinite(pvHi)) return NaN;

    // Bisection
    for (let k = 0; k < 120; k++) {
      const mid = (lo + hi) / 2;
      const pv = pvOfAnnuity(M, mid, n);

      if (!isFinite(pv)) return NaN;

      // If PV is still too high, rate is too low -> increase lo
      if (pv > net) lo = mid;
      else hi = mid;
    }
    return (lo + hi) / 2;
  }

  calcBtn.addEventListener("click", function () {
    const amount = toNum(amountEl.value);
    const nominalAnnual = toNum(rateEl.value) / 100;
    const years = toNum(yearsEl.value);
    const fees = feesEl.value === "" ? 0 : toNum(feesEl.value);

    if (!isFinite(amount) || amount <= 0) {
      resultEl.textContent = "Please enter a valid loan amount.";
      return;
    }
    if (!isFinite(nominalAnnual) || nominalAnnual < 0) {
      resultEl.textContent = "Please enter a valid nominal interest rate (>= 0).";
      return;
    }
    if (!isFinite(years) || years <= 0) {
      resultEl.textContent = "Please enter a valid term in years.";
      return;
    }
    if (!isFinite(fees) || fees < 0) {
      resultEl.textContent = "Please enter valid fees (>= 0).";
      return;
    }

    const n = Math.max(1, Math.round(years * 12));
    const rNominalMonthly = nominalAnnual / 12;

    const M = payment(amount, rNominalMonthly, n);
    const net = amount - fees;

    if (!(net > 0)) {
      resultEl.textContent = "Fees cannot be equal to or greater than the loan amount.";
      return;
    }
    if (!isFinite(M) || M <= 0) {
      resultEl.textContent = "Unable to compute payment. Please check inputs.";
      return;
    }

    const i = solveMonthlyRate(M, n, net);
    if (!isFinite(i) || i < 0) {
      resultEl.textContent = "Unable to estimate APR with these inputs.";
      return;
    }

    const aprEffective = Math.pow(1 + i, 12) - 1;

    const totalPay = M * n;
    const totalInterestNominal = totalPay - amount;

    resultEl.innerHTML =
      "<strong>Monthly payment (nominal):</strong> " + money(M) + "<br/>" +
      "<strong>Total interest (nominal):</strong> " + money(totalInterestNominal) + "<br/>" +
      "<strong>Net proceeds (amount − fees):</strong> " + money(net) + "<br/>" +
      "<strong>Estimated APR (effective):</strong> " + (aprEffective * 100).toFixed(2) + "%";
  });

  clearBtn.addEventListener("click", function () {
    amountEl.value = "";
    rateEl.value = "";
    yearsEl.value = "";
    feesEl.value = "";
    resultEl.textContent = "Result will appear here.";
  });
});
</script>