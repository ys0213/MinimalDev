---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Annuity Calculator",
  description:
    "Calculate present value (PV) or future value (FV) of an annuity. Supports ordinary annuity and annuity due.",
  href: "/finance/annuity-calculator/",
  order: 160,
};

const faqs = [
  {
    q: "What is an annuity in this calculator?",
    a: "An annuity here means a series of equal payments made at a regular interval (monthly, yearly, etc.) with a constant interest rate per period.",
  },
  {
    q: "What’s the difference between ordinary annuity and annuity due?",
    a: "Ordinary annuity assumes payments at the end of each period. Annuity due assumes payments at the beginning of each period, which increases PV/FV because payments happen one period earlier.",
  },
  {
    q: "Do I enter an annual rate or a rate per period?",
    a: "Enter the annual rate (APR-style) and choose payments per year. The calculator converts it to a periodic rate automatically.",
  },
  {
    q: "Does this include taxes, inflation, or fees?",
    a: "No. Results are informational and assume a constant rate with equal payments. Taxes, inflation, and fees can change real outcomes.",
  },
  {
    q: "What if the interest rate is 0%?",
    a: "With a 0% rate, PV and FV reduce to payment × number of periods (with a small adjustment for annuity due).",
  },
];
---

<ToolLayout
  title="Annuity Calculator (PV & FV) — MinimalDev"
  description="Calculate present value (PV) or future value (FV) of an annuity. Supports ordinary annuity and annuity due with annual rate + payment frequency."
  canonicalPath="/finance/annuity-calculator/"
  h1="Annuity Calculator"
  intro="Compute present value (PV) or future value (FV) of an annuity using payment amount, annual interest rate, and number of periods."
  faq={faqs}
  categoryName="Finance"
>
  <div slot="tool" data-tool="annuity-calculator">
    <div class="form">
      <div class="field">
        <label for="an_mode">What do you want to calculate?</label>
        <select id="an_mode">
          <option value="pv" selected>Present Value (PV)</option>
          <option value="fv">Future Value (FV)</option>
        </select>
      </div>

      <div class="field">
        <label for="an_type">Payment timing</label>
        <select id="an_type">
          <option value="ordinary" selected>Ordinary annuity (end of period)</option>
          <option value="due">Annuity due (beginning of period)</option>
        </select>
      </div>

      <div class="field">
        <label for="an_pmt">Payment per period</label>
        <input id="an_pmt" type="number" inputmode="decimal" placeholder="e.g., 200" />
        <p class="note" style="margin-top:6px;">Example: monthly contribution/payment amount.</p>
      </div>

      <div class="field">
        <label for="an_apr">Annual interest rate (%)</label>
        <input id="an_apr" type="number" inputmode="decimal" placeholder="e.g., 6.5" />
      </div>

      <div class="field">
        <label for="an_ppy">Payments per year</label>
        <select id="an_ppy">
          <option value="12" selected>12 (monthly)</option>
          <option value="52">52 (weekly)</option>
          <option value="26">26 (biweekly)</option>
          <option value="4">4 (quarterly)</option>
          <option value="2">2 (semiannual)</option>
          <option value="1">1 (annual)</option>
        </select>
        <p class="note" style="margin-top:6px;">
          Used to convert annual rate into a periodic rate.
        </p>
      </div>

      <div class="field">
        <label for="an_n">Number of periods</label>
        <input id="an_n" type="number" inputmode="numeric" placeholder="e.g., 60" />
        <p class="note" style="margin-top:6px;">
          Example: 60 monthly payments = 5 years.
        </p>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="an_calc">Calculate</button>
        <button class="btn secondary" type="button" id="an_clear">Clear</button>
      </div>

      <div class="result" id="an_result">Result will appear here.</div>

      <p class="note" style="margin-top:10px;">
        Informational only. Assumes equal payments and a constant interest rate.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This annuity calculator computes <strong>present value (PV)</strong> or <strong>future value (FV)</strong>
      for a stream of equal payments (PMT) made at a fixed interval. It’s commonly used for retirement contributions,
      savings plans, structured payouts, and investment growth estimates.
    </p>

    <p class="note">
      The calculator converts your <strong>annual interest rate</strong> into a <strong>periodic rate</strong> using payments per year,
      then applies the standard annuity formulas. Choose <strong>annuity due</strong> if payments happen at the beginning of each period.
    </p>

    <p class="note">
      <strong>Ordinary annuity:</strong><br />
      PV = PMT × (1 − (1+r)<sup>−n</sup>) ÷ r<br />
      FV = PMT × ((1+r)<sup>n</sup> − 1) ÷ r<br />
      <br />
      <strong>Annuity due:</strong> multiply the ordinary result by (1+r)
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>Monthly PMT 200, APR 6%, n 60 → PV/FV estimate depending on mode</li>
      <li>Switch to “Annuity due” for payments at beginning of period (often higher PV/FV)</li>
      <li>APR 0% → PV/FV becomes roughly PMT × n</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/retirement-calculator/">Retirement Calculator</a></li>
      <li><a href="/finance/future-value-calculator/">Future Value Calculator</a></li>
      <li><a href="/finance/investment-calculator/">Investment Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const modeEl = document.getElementById("an_mode");
  const typeEl = document.getElementById("an_type");
  const pmtEl = document.getElementById("an_pmt");
  const aprEl = document.getElementById("an_apr");
  const ppyEl = document.getElementById("an_ppy");
  const nEl = document.getElementById("an_n");
  const calcBtn = document.getElementById("an_calc");
  const clearBtn = document.getElementById("an_clear");
  const outEl = document.getElementById("an_result");
  if (!modeEl || !typeEl || !pmtEl || !aprEl || !ppyEl || !nEl || !calcBtn || !clearBtn || !outEl) return;

  function money(v) {
    if (!isFinite(v)) return "$0.00";
    return v.toLocaleString(undefined, { style: "currency", currency: "USD" });
  }

  function pvOrdinary(pmt, r, n) {
    if (r === 0) return pmt * n;
    return pmt * (1 - Math.pow(1 + r, -n)) / r;
  }

  function fvOrdinary(pmt, r, n) {
    if (r === 0) return pmt * n;
    return pmt * (Math.pow(1 + r, n) - 1) / r;
  }

  function pct(v) {
    if (!isFinite(v)) return "0%";
    return (v * 100).toLocaleString(undefined, { maximumFractionDigits: 6 }) + "%";
  }

  calcBtn.addEventListener("click", function () {
    const mode = String(modeEl.value || "pv");
    const timing = String(typeEl.value || "ordinary");

    const pmt = parseFloat(pmtEl.value);
    const apr = (parseFloat(aprEl.value) || 0) / 100;
    const ppy = parseInt(ppyEl.value, 10);
    const n = parseInt(nEl.value, 10);

    if (!isFinite(pmt) || pmt <= 0 || !isFinite(apr) || apr < 0 || !isFinite(ppy) || ppy <= 0 || !isFinite(n) || n <= 0) {
      outEl.textContent = "Please enter valid values.";
      return;
    }

    const r = apr / ppy; // periodic rate
    let base = mode === "fv" ? fvOrdinary(pmt, r, n) : pvOrdinary(pmt, r, n);
    if (timing === "due") base = base * (1 + r);

    const label = mode === "fv" ? "Future Value (FV)" : "Present Value (PV)";
    const timingLabel = timing === "due" ? "Annuity due (beginning of period)" : "Ordinary annuity (end of period)";

    outEl.innerHTML =
      "<div><strong>" + label + ":</strong> " + money(base) + "</div>" +
      "<div class='note' style='margin-top:6px;'><strong>Payment timing:</strong> " + timingLabel + "</div>" +
      "<div class='note' style='margin-top:6px;'><strong>Periodic rate:</strong> " + pct(r) + " per period (" + ppy.toLocaleString() + " payments/year)</div>" +
      "<div class='note' style='margin-top:6px;'>Assumes equal payments, constant rate, and no taxes/fees.</div>";
  });

  clearBtn.addEventListener("click", function () {
    pmtEl.value = "";
    aprEl.value = "";
    nEl.value = "";
    outEl.textContent = "Result will appear here.";
  });
});
</script>