---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Lease vs Buy Calculator",
  description: "Compare total cost of leasing vs buying a car over a term. Informational estimate for decision-making.",
  href: "/finance/lease-vs-buy-calculator/",
  order: 70,
};
---

<ToolLayout
  title="Lease vs Buy Calculator — MinimalDev"
  description="Compare estimated total cost of leasing vs buying over a chosen term. Simplified principal & interest model."
  canonicalPath="/finance/lease-vs-buy-calculator/"
  h1="Lease vs Buy Calculator"
  intro="Compare estimated total cost of leasing vs buying over the same term. Simplified model for quick decisions."
>
  <div slot="tool" data-tool="lease-vs-buy-calculator">
    <div class="form">
      <h2 style="margin:0 0 10px;">Buy</h2>

      <div class="field">
        <label for="lvb_price">Car price</label>
        <input id="lvb_price" type="number" inputmode="decimal" placeholder="e.g., 30000" />
      </div>
      <div class="field">
        <label for="lvb_down">Down payment (optional)</label>
        <input id="lvb_down" type="number" inputmode="decimal" placeholder="e.g., 3000" />
      </div>
      <div class="field">
        <label for="lvb_apr">Loan APR (%)</label>
        <input id="lvb_apr" type="number" inputmode="decimal" placeholder="e.g., 6.5" />
      </div>
      <div class="field">
        <label for="lvb_term">Term (months)</label>
        <input id="lvb_term" type="number" inputmode="numeric" placeholder="e.g., 36" />
      </div>
      <div class="field">
        <label for="lvb_resale">Estimated resale value after term</label>
        <input id="lvb_resale" type="number" inputmode="decimal" placeholder="e.g., 21000" />
      </div>

      <h2 style="margin:16px 0 10px;">Lease</h2>
      <div class="field">
        <label for="lvb_lease_monthly">Lease monthly payment</label>
        <input id="lvb_lease_monthly" type="number" inputmode="decimal" placeholder="e.g., 350" />
      </div>
      <div class="field">
        <label for="lvb_lease_due">Due at signing (optional)</label>
        <input id="lvb_lease_due" type="number" inputmode="decimal" placeholder="e.g., 2000" />
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="lvb_calc">Calculate</button>
        <button class="btn secondary" type="button" id="lvb_clear">Clear</button>
      </div>

      <div class="result" id="lvb_result">Result will appear here.</div>

      <p class="note" style="margin-top:10px;">
        Simplified estimate. Does not include maintenance, insurance, taxes, mileage fees, or opportunity cost.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Buy total cost ≈ down + (monthly payment × term) − resale value<br/>
      Lease total cost ≈ due at signing + (lease monthly × term)
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>Compare a 36-month lease vs a 36-month loan plus estimated resale value</li>
      <li>Adjust resale value to test sensitivity</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      <li><strong>Is resale value guaranteed?</strong> No, it’s an estimate and can change with market conditions.</li>
      <li><strong>Does buy include remaining balance?</strong> This simplified model assumes you pay monthly for the term.</li>
      <li><strong>What about taxes/fees?</strong> Not included. Add them into price or due-at-signing for a rough estimate.</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/car-loan-calculator/">Car Loan Calculator</a></li>
      <li><a href="/finance/loan-calculator/">Loan Calculator</a></li>
      <li><a href="/finance/apr-calculator/">APR Calculator</a></li>
      <li><a href="/finance/break-even-calculator/">Break-even Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const priceEl = document.getElementById("lvb_price");
  const downEl = document.getElementById("lvb_down");
  const aprEl = document.getElementById("lvb_apr");
  const termEl = document.getElementById("lvb_term");
  const resaleEl = document.getElementById("lvb_resale");
  const leaseMoEl = document.getElementById("lvb_lease_monthly");
  const leaseDueEl = document.getElementById("lvb_lease_due");
  const calcBtn = document.getElementById("lvb_calc");
  const clearBtn = document.getElementById("lvb_clear");
  const outEl = document.getElementById("lvb_result");
  if (!priceEl || !downEl || !aprEl || !termEl || !resaleEl || !leaseMoEl || !leaseDueEl || !calcBtn || !clearBtn || !outEl) return;

  function money(v) {
    if (!isFinite(v)) return "$0.00";
    return v.toLocaleString(undefined, { style: "currency", currency: "USD" });
  }

  function payment(P, annualPct, months) {
    const r = (annualPct / 100) / 12;
    const n = months;
    if (n <= 0) return NaN;
    if (r === 0) return P / n;
    return P * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
  }

  calcBtn.addEventListener("click", function () {
    const price = parseFloat(priceEl.value);
    const down = parseFloat(downEl.value) || 0;
    const apr = parseFloat(aprEl.value);
    const term = parseInt(termEl.value, 10);
    const resale = parseFloat(resaleEl.value);
    const leaseMo = parseFloat(leaseMoEl.value);
    const leaseDue = parseFloat(leaseDueEl.value) || 0;

    if (!isFinite(price) || price <= 0 || down < 0 || down > price || !isFinite(apr) || apr < 0 || !isFinite(term) || term <= 0 ||
        !isFinite(resale) || resale < 0 || !isFinite(leaseMo) || leaseMo < 0 || leaseDue < 0) {
      outEl.textContent = "Please enter valid values.";
      return;
    }

    const loanPrincipal = price - down;
    const buyMonthly = payment(loanPrincipal, apr, term);
    if (!isFinite(buyMonthly)) { outEl.textContent = "Could not compute loan payment."; return; }

    const buyPaid = down + (buyMonthly * term);
    const buyNet = buyPaid - resale;

    const leaseNet = leaseDue + (leaseMo * term);
    const diff = leaseNet - buyNet;

    outEl.innerHTML =
      "<strong>Buy monthly (est):</strong> " + money(buyMonthly) + "<br/>" +
      "<strong>Buy total cost (est):</strong> " + money(buyNet) + "<br/>" +
      "<strong>Lease total cost (est):</strong> " + money(leaseNet) + "<br/>" +
      "<strong>Lease − Buy:</strong> " + money(diff) + "<br/>" +
      "<span class='note'>" + (diff > 0 ? "Leasing is estimated to cost more." : "Leasing is estimated to cost less.") + "</span>";
  });

  clearBtn.addEventListener("click", function () {
    priceEl.value = "";
    downEl.value = "";
    aprEl.value = "";
    termEl.value = "";
    resaleEl.value = "";
    leaseMoEl.value = "";
    leaseDueEl.value = "";
    outEl.textContent = "Result will appear here.";
  });
});
</script>