---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Future Value Calculator",
  description:
    "Free future value calculator with monthly compounding and optional contributions. Estimate ending balance, contributions, and growth.",
  href: "/finance/future-value-calculator/",
  order: 120,
};

const faq = [
  {
    q: "What is future value (FV)?",
    a: "Future value is the projected value of a starting amount after a period of time, given a growth rate and optional ongoing contributions.",
  },
  {
    q: "Does this compound monthly?",
    a: "Yes. This tool uses monthly compounding for simplicity: monthlyRate = annualRate ÷ 12, repeated for months = years × 12.",
  },
  {
    q: "Are returns guaranteed?",
    a: "No. This is a projection. Real investment returns can vary and may be negative in some periods.",
  },
  {
    q: "Does this include taxes, inflation, or fees?",
    a: "No. This tool estimates gross growth only. Taxes, fees, and inflation can reduce real-world results.",
  },
  {
    q: "How are contributions handled?",
    a: "Monthly contributions are added at the end of each month in this model. Different timing (beginning-of-month) can slightly change results.",
  },
];
---

<ToolLayout
  title="Future Value Calculator — MinimalDev"
  description="Calculate future value from a starting amount, monthly contributions, annual rate, and years (monthly compounding). View yearly breakdown."
  canonicalPath="/finance/future-value-calculator/"
  h1="Future Value Calculator"
  intro="Estimate future value using a starting balance, monthly contributions, and an annual return rate. Includes a yearly breakdown table."
  faq={faq}
>
  <div slot="tool" data-tool="future-value-calculator">
    <div class="form">
      <div class="field">
        <label for="fv_pv">Starting amount (present value)</label>
        <input id="fv_pv" type="number" inputmode="decimal" placeholder="e.g., 10000" />
      </div>

      <div class="field">
        <label for="fv_pmt">Monthly contribution (optional)</label>
        <input id="fv_pmt" type="number" inputmode="decimal" placeholder="e.g., 200" />
        <p class="note" style="margin-top:6px;">
          Enter 0 to estimate growth from the starting amount only.
        </p>
      </div>

      <div class="field">
        <label for="fv_rate">Annual rate (%)</label>
        <input id="fv_rate" type="number" inputmode="decimal" placeholder="e.g., 6" />
      </div>

      <div class="field">
        <label for="fv_years">Years</label>
        <input id="fv_years" type="number" inputmode="decimal" placeholder="e.g., 10" />
      </div>

      <div class="field">
        <label for="fv_max_years">Max years (safety cap)</label>
        <input id="fv_max_years" type="number" inputmode="numeric" value="50" min="1" max="100" />
        <p class="note" style="margin-top:6px;">
          Prevents huge simulations/tables. Typical use is 1–50 years.
        </p>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="fv_calc">Calculate</button>
        <button class="btn secondary" type="button" id="fv_clear">Clear</button>
      </div>

      <div class="result" id="fv_result" style="margin-top:12px;">Result will appear here.</div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:14px;">
          <thead>
            <tr>
              <th>Year</th>
              <th>End Balance</th>
              <th>Total Contributions</th>
              <th>Estimated Growth</th>
            </tr>
          </thead>
          <tbody id="fv_tbody"></tbody>
        </table>
      </div>

      <p class="note" style="margin-top:10px;">
        Informational only. Assumes constant rate and monthly compounding; real returns vary.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This calculator models a simple monthly compounding process. Each month the current balance grows by
      <strong>(annualRate ÷ 12)</strong>, then your monthly contribution (if any) is added.
      Over many months, compounding can significantly increase the ending balance compared to simple interest.
    </p>

    <p class="note">
      The “Estimated Growth” shown here is <strong>ending balance − (starting amount + total contributions)</strong>.
      It’s a useful way to see how much of the result comes from market growth versus deposits.
    </p>

    <p class="note">
      If you need a tool that focuses on “interest only” behavior, use a compound interest calculator.
      If you need to discount future cash flows back to today, use net present value (NPV).
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>$10,000 + $200/mo at 6% for 10 years → future value estimate</li>
      <li>$10,000 + $0/mo at 6% for 10 years → growth-only scenario</li>
      <li>Try a shorter horizon (e.g., 3 years) to see the impact of time on compounding</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/finance/investment-calculator/">Investment Calculator</a></li>
      <li><a href="/finance/compound-interest-calculator/">Compound Interest Calculator</a></li>
      <li><a href="/finance/retirement-calculator/">Retirement Calculator</a></li>
      <li><a href="/finance/">All Finance Calculators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const pvEl = document.getElementById("fv_pv");
  const pmtEl = document.getElementById("fv_pmt");
  const rEl = document.getElementById("fv_rate");
  const yEl = document.getElementById("fv_years");
  const maxYEl = document.getElementById("fv_max_years");
  const calcBtn = document.getElementById("fv_calc");
  const clearBtn = document.getElementById("fv_clear");
  const outEl = document.getElementById("fv_result");
  const tbodyEl = document.getElementById("fv_tbody");
  if (!pvEl || !pmtEl || !rEl || !yEl || !maxYEl || !calcBtn || !clearBtn || !outEl || !tbodyEl) return;

  function toNum(v) {
    const x = parseFloat(String(v));
    return isFinite(x) ? x : NaN;
  }

  function clampInt(x, lo, hi, fallback) {
    const n = parseInt(String(x), 10);
    if (!isFinite(n)) return fallback;
    return Math.max(lo, Math.min(hi, n));
  }

  function money(v) {
    if (!isFinite(v)) return "$0.00";
    return v.toLocaleString(undefined, { style: "currency", currency: "USD" });
  }

  calcBtn.addEventListener("click", function () {
    const pv = toNum(pvEl.value);
    const pmt = toNum(pmtEl.value || 0);
    const annualPct = toNum(rEl.value);
    const years = toNum(yEl.value);
    const maxYears = clampInt(maxYEl.value, 1, 100, 50);

    if (!isFinite(pv) || pv < 0) {
      outEl.textContent = "Please enter a valid starting amount (>= 0).";
      tbodyEl.innerHTML = "";
      return;
    }
    if (!isFinite(pmt) || pmt < 0) {
      outEl.textContent = "Please enter a valid monthly contribution (>= 0).";
      tbodyEl.innerHTML = "";
      return;
    }
    if (!isFinite(annualPct) || annualPct < 0) {
      outEl.textContent = "Please enter a valid annual rate (>= 0).";
      tbodyEl.innerHTML = "";
      return;
    }
    if (!isFinite(years) || years <= 0) {
      outEl.textContent = "Please enter a valid number of years (> 0).";
      tbodyEl.innerHTML = "";
      return;
    }
    if (years > maxYears) {
      outEl.innerHTML =
        "Years is larger than the safety cap.<br/>" +
        "<span class='note'>Increase Max years or reduce Years.</span>";
      tbodyEl.innerHTML = "";
      return;
    }

    const annual = annualPct / 100;
    const months = Math.max(1, Math.round(years * 12));
    const r = annual / 12;

    let bal = pv;
    let contrib = 0;

    tbodyEl.innerHTML = "";

    // yearly checkpoints for readability
    const yearsInt = Math.max(1, Math.round(years));
    for (let yr = 1; yr <= yearsInt; yr++) {
      const monthsThisYear = (yr === yearsInt) ? (months - (12 * (yr - 1))) : 12;
      for (let m = 1; m <= monthsThisYear; m++) {
        bal = bal * (1 + r) + pmt; // end-of-month contribution model
        contrib += pmt;
      }

      const growth = bal - (pv + contrib);

      const row =
        "<tr>" +
          "<td>" + yr + "</td>" +
          "<td>" + money(bal) + "</td>" +
          "<td>" + money(contrib) + "</td>" +
          "<td>" + money(growth) + "</td>" +
        "</tr>";
      tbodyEl.insertAdjacentHTML("beforeend", row);
    }

    const finalGrowth = bal - (pv + contrib);
    outEl.innerHTML =
      "<strong>Future value:</strong> " + money(bal) + "<br/>" +
      "<strong>Total contributions:</strong> " + money(contrib) + "<br/>" +
      "<strong>Estimated growth:</strong> " + money(finalGrowth);
  });

  clearBtn.addEventListener("click", function () {
    pvEl.value = "";
    pmtEl.value = "";
    rEl.value = "";
    yEl.value = "";
    maxYEl.value = "50";
    outEl.textContent = "Result will appear here.";
    tbodyEl.innerHTML = "";
  });
});
</script>