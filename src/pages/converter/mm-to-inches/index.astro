---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "mm to Inches",
  description:
    "Convert millimeters to inches instantly. Includes validation, reverse mode, result cards, and FAQ support.",
  href: "/converter/mm-to-inches/",
  order: 308,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/mm-to-inches/";

const faqs = [
  {
    q: "How do you convert millimeters to inches?",
    a: "Divide millimeters by 25.4, or multiply millimeters by 0.0393700787.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between millimeters to inches and inches to millimeters.",
  },
  {
    q: "What is this useful for?",
    a: "It is useful for engineering, manufacturing, crafts, screen sizes, and everyday measurements.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`mm to Inches Converter — ${SITE_NAME}`}
  description="Convert millimeters to inches instantly with validation, reverse mode, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="mm to Inches Converter"
  intro="Convert length from millimeters to inches instantly. Useful for manufacturing, crafts, hardware, and everyday measurement comparisons."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="mm-to-inches">
    <div class="form" role="form" aria-describedby="mm2in_hint mm2in_privacy">
      <div class="field">
        <label for="mm2in_input">Millimeters</label>
        <input id="mm2in_input" type="number" inputmode="decimal" placeholder="e.g., 25.4" />
        <p class="note" id="mm2in_hint" style="margin-top:6px;">
          Enter a non-negative value. 25.4 mm equals exactly 1 inch.
        </p>
      </div>

      <div class="field">
        <label for="mm2in_round">Rounding</label>
        <select id="mm2in_round">
          <option value="2">2 decimals</option>
          <option value="4" selected>4 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="mm2in_convert">Convert</button>
        <button class="btn secondary" type="button" id="mm2in_swap">Reverse (in → mm)</button>
        <button class="btn secondary" type="button" id="mm2in_clear">Clear</button>
      </div>

      <div class="result" id="mm2in_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="mm2in_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="mm2in_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="mm2in_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="mm2in_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard conversion: <strong>1 inch = 25.4 mm</strong>.<br />
      Formula: <strong>in = mm ÷ 25.4</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>25.4 mm</strong> = <strong>1 in</strong></li>
      <li><strong>50 mm</strong> ≈ <strong>1.9685 in</strong></li>
      <li><strong>100 mm</strong> ≈ <strong>3.9370 in</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/length/">Length Converter</a></li>
      <li><a href="/converter/inches-to-mm/">Inches to mm</a></li>
      <li><a href="/converter/cm-to-inches/">cm to Inches</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("mm2in_input");
  const roundEl = document.getElementById("mm2in_round");
  const convertBtn = document.getElementById("mm2in_convert");
  const swapBtn = document.getElementById("mm2in_swap");
  const clearBtn = document.getElementById("mm2in_clear");
  const errEl = document.getElementById("mm2in_error");
  const outEl = document.getElementById("mm2in_result");
  const cardsEl = document.getElementById("mm2in_cards");
  const tbodyEl = document.getElementById("mm2in_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const MM_TO_IN = 1 / 25.4;
  const IN_TO_MM = 25.4;
  let mode = "mm-to-in";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="mm2in_input"]');
    if (!label) return;

    if (mode === "mm-to-in") {
      label.textContent = "Millimeters";
      inEl.placeholder = "e.g., 25.4";
      swapBtn.textContent = "Reverse (in → mm)";
    } else {
      label.textContent = "Inches";
      inEl.placeholder = "e.g., 1";
      swapBtn.textContent = "Reverse (mm → in)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "mm-to-in"
      ? [
          ["Conversion factor", "1 in = 25.4 mm"],
          ["Reverse factor", "1 mm ≈ " + fmtSmart(MM_TO_IN) + " in"],
          ["Input", fmt(input) + " mm"],
          ["Output", fmt(output) + " in"],
        ]
      : [
          ["Conversion factor", "1 mm ≈ " + fmtSmart(MM_TO_IN) + " in"],
          ["Reverse factor", "1 in = 25.4 mm"],
          ["Input", fmt(input) + " in"],
          ["Output", fmt(output) + " mm"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const output = mode === "mm-to-in" ? raw * MM_TO_IN : raw * IN_TO_MM;

    if (mode === "mm-to-in") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} in<br/><span class="note">${fmt(raw)} mm = ${fmt(output)} in</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} mm<br/><span class="note">${fmt(raw)} in = ${fmt(output)} mm</span>`;
    }

    const mm = mode === "mm-to-in" ? raw : output;
    let scale = "Typical";
    if (mm < 10) scale = "Very small length";
    else if (mm >= 1000) scale = "Large length";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `<div style="display:flex;gap:10px;flex-wrap:wrap;">
      ${badge(mode === "mm-to-in" ? "mm → in" : "in → mm")}
      ${badge("Base ≈ " + fmtSmart(mm) + " mm")}
      ${badge(scale)}
    </div>`;

    fillTable(raw, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "4";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "mm-to-in" ? "in-to-mm" : "mm-to-in";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>