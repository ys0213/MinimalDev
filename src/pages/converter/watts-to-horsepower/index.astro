---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Watts to Horsepower",
  description:
    "Convert watts (W) to horsepower (hp) instantly with validation, accessible UX, result cards, reference table, and FAQ schema.",
  href: "/converter/watts-to-horsepower/",
  order: 370,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/watts-to-horsepower/";

const faqs = [
  { q: "How do you convert watts to horsepower?", a: "Divide watts by 745.699872 to get horsepower." },
  { q: "What is 1000 watts in horsepower?", a: "1000 watts equals about 1.341 horsepower." },
  { q: "What horsepower standard is used here?", a: "This converter uses mechanical horsepower." },
  { q: "Are my inputs stored?", a: "No. All calculations run locally in your browser." },
];

const faqJsonLd = {
  "@context":"https://schema.org",
  "@type":"FAQPage",
  mainEntity: faqs.map((f)=>({
    "@type":"Question",
    name:f.q,
    acceptedAnswer:{ "@type":"Answer", text:f.a }
  }))
};
---

<ToolLayout
  title={`Watts to Horsepower Converter — ${SITE_NAME}`}
  description="Convert watts to horsepower with validation, accessible UX, result cards, a reference table, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Watts to Horsepower Converter"
  intro="Convert power from watts (W) to horsepower (hp)."
  faq={faqs}
  categoryName="Converters"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <div slot="tool" data-tool="watts-to-horsepower">
    <div class="form" role="form" aria-describedby="w2h_help w2h_privacy">
      <div class="field">
        <label for="w2h_w">Power (watts)</label>
        <input id="w2h_w" type="number" inputmode="decimal" placeholder="e.g., 1000" aria-describedby="w2h_help" />
        <p class="note" id="w2h_help" style="margin-top:6px;">
          Enter watts and convert. Press <kbd>Ctrl</kbd>/<kbd>Cmd</kbd> + <kbd>Enter</kbd>.
        </p>
      </div>
      <div class="field">
        <label for="w2h_round">Rounding</label>
        <select id="w2h_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="w2h_convert">Convert</button>
        <button class="btn secondary" type="button" id="w2h_swap">Swap (hp → W)</button>
        <button class="btn secondary" type="button" id="w2h_clear">Clear</button>
      </div>
      <div class="result" id="w2h_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="w2h_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="w2h_cards" style="display:none; margin-top:12px;"></div>
      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead><tr><th scope="col">Reference</th><th scope="col">W</th><th scope="col">hp</th></tr></thead>
          <tbody id="w2h_tbody"></tbody>
        </table>
      </div>
      <p class="note" id="w2h_privacy" style="margin-top:10px;">Privacy: runs locally in your browser. No inputs are stored or transmitted.</p>
    </div>
  </div>
  <div slot="how"><p class="note"><strong>hp = W ÷ 745.699872</strong><br />Reverse: <strong>W = hp × 745.699872</strong></p></div>
  <div slot="examples">
    <ul>
      <li><strong>746 W</strong> ≈ <strong>1 hp</strong></li>
      <li><strong>1000 W</strong> ≈ <strong>1.341 hp</strong></li>
      <li><strong>2000 W</strong> ≈ <strong>2.682 hp</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/horsepower-to-watts/">Horsepower to Watts</a></li>
      <li><a href="/converter/power-converter/">Power Converter</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded",function(){
  const inEl=document.getElementById("w2h_w");
  const roundEl=document.getElementById("w2h_round");
  const convertBtn=document.getElementById("w2h_convert");
  const swapBtn=document.getElementById("w2h_swap");
  const clearBtn=document.getElementById("w2h_clear");
  const errEl=document.getElementById("w2h_error");
  const outEl=document.getElementById("w2h_result");
  const cardsEl=document.getElementById("w2h_cards");
  const tbodyEl=document.getElementById("w2h_tbody");
  if(!inEl||!roundEl||!convertBtn||!swapBtn||!clearBtn||!errEl||!outEl||!cardsEl||!tbodyEl) return;

  let modeWtoHp=true;
  const W_PER_HP=745.699872;

  function toNum(v){ const x=parseFloat(String(v)); return Number.isFinite(x)?x:NaN; }
  function clearError(){ errEl.style.display="none"; errEl.textContent=""; }
  function showError(msg){ errEl.style.display="block"; errEl.textContent=msg; }
  function fmtSmart(x){ if(!Number.isFinite(x)) return "—"; const ax=Math.abs(x); if(ax===0) return "0"; if(ax>=1e9||ax<1e-8) return x.toExponential(6); return String(Number(x.toPrecision(10))); }
  function fmt(x){ if(!Number.isFinite(x)) return "—"; const r=String(roundEl.value); if(r==="auto") return fmtSmart(x); const d=parseInt(r,10); return Number(x).toLocaleString(undefined,{minimumFractionDigits:d,maximumFractionDigits:d}); }
  function badge(text){ return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`; }
  function wToHp(v){ return v/W_PER_HP; }
  function hpToW(v){ return v*W_PER_HP; }

  function setUi(){
    const label=document.querySelector('label[for="w2h_w"]');
    if(!label) return;
    if(modeWtoHp){ label.textContent="Power (watts)"; inEl.placeholder="e.g., 1000"; swapBtn.textContent="Swap (hp → W)"; }
    else { label.textContent="Power (horsepower)"; inEl.placeholder="e.g., 2"; swapBtn.textContent="Swap (W → hp)"; }
  }

  function fillTable(inputValue){
    tbodyEl.innerHTML="";
    const refs=[{name:"1 horsepower",w:745.699872},{name:"1000 watts",w:1000},{name:"2000 watts",w:2000}];
    if(Number.isFinite(inputValue)){
      const wVal=modeWtoHp?inputValue:hpToW(inputValue);
      refs.push({name:"Your input",w:wVal,highlight:true});
    }
    refs.forEach((r)=>{
      const tr=document.createElement("tr");
      if(r.highlight) tr.style.fontWeight="900";
      const td1=document.createElement("td");
      const td2=document.createElement("td");
      const td3=document.createElement("td");
      td1.textContent=r.name; td2.textContent=fmtSmart(r.w); td3.textContent=fmt(wToHp(r.w));
      tr.appendChild(td1); tr.appendChild(td2); tr.appendChild(td3);
      tbodyEl.appendChild(tr);
    });
  }

  function compute(){
    clearError(); cardsEl.style.display="none"; tbodyEl.innerHTML="";
    const raw=toNum(inEl.value);
    if(!Number.isFinite(raw)){ outEl.textContent="Please enter a valid power value."; return; }
    if(Math.abs(raw)>1e18){ showError("Value is too large for reliable display."); outEl.textContent="Result will appear here."; return; }

    let w,hp;
    if(modeWtoHp){ w=raw; hp=wToHp(w); }
    else { hp=raw; w=hpToW(hp); }

    outEl.innerHTML=modeWtoHp
      ? `<strong>Result:</strong> ${fmt(hp)} hp<br/><span class="note">${fmtSmart(w)} W = ${fmt(hp)} hp</span>`
      : `<strong>Result:</strong> ${fmt(w)} W<br/><span class="note">${fmtSmart(hp)} hp = ${fmt(w)} W</span>`;

    cardsEl.style.display="block";
    cardsEl.innerHTML=`<div style="display:flex;gap:10px;flex-wrap:wrap;">
      ${badge(modeWtoHp?"W → hp":"hp → W")}
      ${badge("Reference: 1 hp = 745.699872 W")}
      ${badge(Math.abs(w)<1000 ? "Small power" : Math.abs(w)<100000 ? "Moderate power" : "High power")}
    </div>`;
    fillTable(raw);
  }

  function reset(){
    clearError(); inEl.value=""; roundEl.value="3"; outEl.textContent="Result will appear here.";
    cardsEl.style.display="none"; cardsEl.innerHTML=""; tbodyEl.innerHTML="";
  }

  convertBtn.addEventListener("click",compute);
  swapBtn.addEventListener("click",function(){ modeWtoHp=!modeWtoHp; setUi(); if(String(inEl.value||"").trim()) compute(); else reset(); });
  clearBtn.addEventListener("click",function(){ modeWtoHp=true; setUi(); reset(); });
  roundEl.addEventListener("change",function(){ if(String(inEl.value||"").trim()) compute(); });
  inEl.addEventListener("keydown",function(e){ if((e.ctrlKey||e.metaKey)&&e.key==="Enter") compute(); });

  setUi();
});
</script>