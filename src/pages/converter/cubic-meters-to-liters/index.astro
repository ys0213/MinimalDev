---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Cubic Meters to Liters",
  description:
    "Convert cubic meters to liters for volume, tanks, and container measurements.",
  href: "/converter/cubic-meters-to-liters/",
  order: 312,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/cubic-meters-to-liters/";

const faqs = [
  {
    q: "How do you convert cubic meters to liters?",
    a: "Multiply cubic meters by 1,000 to get liters.",
  },
  {
    q: "Why is the factor 1,000?",
    a: "One cubic meter contains exactly 1,000 liters.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between cubic meters to liters and liters to cubic meters.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Cubic Meters to Liters Converter — ${SITE_NAME}`}
  description="Convert cubic meters to liters with clear results for storage tanks, water volume, containers, and capacity planning."
  canonicalPath={CANONICAL_PATH}
  h1="Cubic Meters to Liters Converter"
  intro="Convert volume from cubic meters to liters instantly. Useful for tanks, water storage, industrial volume, and large liquid capacity comparisons."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="cubic-meters-to-liters">
    <div class="form" role="form" aria-describedby="m3l_hint m3l_privacy">
      <div class="field">
        <label for="m3l_input">Cubic meters (m³)</label>
        <input id="m3l_input" type="number" inputmode="decimal" placeholder="e.g., 1.5" />
        <p class="note" id="m3l_hint" style="margin-top:6px;">
          Enter a non-negative value. One cubic meter equals exactly 1,000 liters.
        </p>
      </div>

      <div class="field">
        <label for="m3l_round">Rounding</label>
        <select id="m3l_round">
          <option value="0">0 decimals</option>
          <option value="2" selected>2 decimals</option>
          <option value="4">4 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="m3l_convert">Convert</button>
        <button class="btn secondary" type="button" id="m3l_swap">Reverse (L → m³)</button>
        <button class="btn secondary" type="button" id="m3l_clear">Clear</button>
      </div>

      <div class="result" id="m3l_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="m3l_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="m3l_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="m3l_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="m3l_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard conversion: <strong>1 m³ = 1,000 L</strong>.<br />
      Formula: <strong>L = m³ × 1,000</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1 m³</strong> = <strong>1,000 L</strong></li>
      <li><strong>1.5 m³</strong> = <strong>1,500 L</strong></li>
      <li><strong>10 m³</strong> = <strong>10,000 L</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/volume-converter/">Volume Converter</a></li>
      <li><a href="/converter/liters-to-cubic-meters/">Liters to Cubic Meters</a></li>
      <li><a href="/converter/liters-to-gallons/">Liters to Gallons</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("m3l_input");
  const roundEl = document.getElementById("m3l_round");
  const convertBtn = document.getElementById("m3l_convert");
  const swapBtn = document.getElementById("m3l_swap");
  const clearBtn = document.getElementById("m3l_clear");
  const errEl = document.getElementById("m3l_error");
  const outEl = document.getElementById("m3l_result");
  const cardsEl = document.getElementById("m3l_cards");
  const tbodyEl = document.getElementById("m3l_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const M3_TO_L = 1000;
  const L_TO_M3 = 1 / M3_TO_L;
  let mode = "m3-to-l";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="m3l_input"]');
    if (!label) return;
    if (mode === "m3-to-l") {
      label.textContent = "Cubic meters (m³)";
      inEl.placeholder = "e.g., 1.5";
      swapBtn.textContent = "Reverse (L → m³)";
    } else {
      label.textContent = "Liters";
      inEl.placeholder = "e.g., 1500";
      swapBtn.textContent = "Reverse (m³ → L)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "m3-to-l"
      ? [
          ["Conversion factor", "1 m³ = 1,000 L"],
          ["Reverse factor", "1 L = " + fmtSmart(L_TO_M3) + " m³"],
          ["Input", fmt(input) + " m³"],
          ["Output", fmt(output) + " L"],
        ]
      : [
          ["Conversion factor", "1 L = " + fmtSmart(L_TO_M3) + " m³"],
          ["Reverse factor", "1 m³ = 1,000 L"],
          ["Input", fmt(input) + " L"],
          ["Output", fmt(output) + " m³"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "m3-to-l" ? input * M3_TO_L : input * L_TO_M3;

    if (mode === "m3-to-l") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} L<br/><span class="note">${fmt(input)} m³ = ${fmt(output)} L</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} m³<br/><span class="note">${fmt(input)} L = ${fmt(output)} m³</span>`;
    }

    const liters = mode === "m3-to-l" ? output : input;
    let scale = "Typical";
    if (liters < 1000) scale = "Small tank";
    else if (liters >= 10000) scale = "Large storage";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `<div style="display:flex;gap:10px;flex-wrap:wrap;">
      ${badge(mode === "m3-to-l" ? "m³ → L" : "L → m³")}
      ${badge("Base ≈ " + fmtSmart(liters) + " L")}
      ${badge(scale)}
    </div>`;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "2";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "m3-to-l" ? "l-to-m3" : "m3-to-l";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>