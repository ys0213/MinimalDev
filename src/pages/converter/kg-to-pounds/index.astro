---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "kg to Pounds",
  description:
    "Convert kilograms to pounds instantly. Includes validation, reverse mode, result cards, and FAQ support.",
  href: "/converter/kg-to-pounds/",
  order: 304,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/kg-to-pounds/";

const faqs = [
  {
    q: "How do you convert kilograms to pounds?",
    a: "Multiply kilograms by 2.2046226218 to get pounds.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between kilograms to pounds and pounds to kilograms.",
  },
  {
    q: "Is this for body weight or general weight?",
    a: "It works for any mass or weight value commonly expressed in kilograms and pounds.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`kg to Pounds Converter — ${SITE_NAME}`}
  description="Convert kilograms to pounds instantly with validation, reverse mode, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="kg to Pounds Converter"
  intro="Convert weight from kilograms to pounds instantly. Useful for body weight, luggage, shipping, and product measurements."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="kg-to-pounds">
    <div class="form" role="form" aria-describedby="k2p_hint k2p_privacy">
      <div class="field">
        <label for="k2p_input">Kilograms</label>
        <input id="k2p_input" type="number" inputmode="decimal" placeholder="e.g., 70" />
        <p class="note" id="k2p_hint" style="margin-top:6px;">
          Enter a non-negative value. Useful for body weight, packages, and shipping.
        </p>
      </div>

      <div class="field">
        <label for="k2p_round">Rounding</label>
        <select id="k2p_round">
          <option value="2">2 decimals</option>
          <option value="4" selected>4 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="k2p_convert">Convert</button>
        <button class="btn secondary" type="button" id="k2p_swap">Reverse (lb → kg)</button>
        <button class="btn secondary" type="button" id="k2p_clear">Clear</button>
      </div>

      <div class="result" id="k2p_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="k2p_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="k2p_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="k2p_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="k2p_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard conversion: <strong>1 kg = 2.2046226218 lb</strong>.<br />
      Formula: <strong>lb = kg × 2.2046226218</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1 kg</strong> ≈ <strong>2.2046 lb</strong></li>
      <li><strong>50 kg</strong> ≈ <strong>110.2311 lb</strong></li>
      <li><strong>70 kg</strong> ≈ <strong>154.3236 lb</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/weight-converter/">Weight Converter</a></li>
      <li><a href="/converter/pounds-to-kg/">Pounds to kg</a></li>
      <li><a href="/converter/grams-to-ounces/">Grams to Ounces</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("k2p_input");
  const roundEl = document.getElementById("k2p_round");
  const convertBtn = document.getElementById("k2p_convert");
  const swapBtn = document.getElementById("k2p_swap");
  const clearBtn = document.getElementById("k2p_clear");
  const errEl = document.getElementById("k2p_error");
  const outEl = document.getElementById("k2p_result");
  const cardsEl = document.getElementById("k2p_cards");
  const tbodyEl = document.getElementById("k2p_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const KG_TO_LB = 2.2046226218;
  const LB_TO_KG = 1 / KG_TO_LB;
  let mode = "kg-to-lb";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="k2p_input"]');
    if (!label) return;

    if (mode === "kg-to-lb") {
      label.textContent = "Kilograms";
      inEl.placeholder = "e.g., 70";
      swapBtn.textContent = "Reverse (lb → kg)";
    } else {
      label.textContent = "Pounds";
      inEl.placeholder = "e.g., 154";
      swapBtn.textContent = "Reverse (kg → lb)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "kg-to-lb"
      ? [
          ["Conversion factor", "1 kg = 2.2046226218 lb"],
          ["Reverse factor", "1 lb ≈ " + fmtSmart(LB_TO_KG) + " kg"],
          ["Input", fmt(input) + " kg"],
          ["Output", fmt(output) + " lb"],
        ]
      : [
          ["Conversion factor", "1 lb ≈ " + fmtSmart(LB_TO_KG) + " kg"],
          ["Reverse factor", "1 kg = 2.2046226218 lb"],
          ["Input", fmt(input) + " lb"],
          ["Output", fmt(output) + " kg"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const output = mode === "kg-to-lb" ? raw * KG_TO_LB : raw * LB_TO_KG;

    if (mode === "kg-to-lb") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} lb<br/><span class="note">${fmt(raw)} kg = ${fmt(output)} lb</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} kg<br/><span class="note">${fmt(raw)} lb = ${fmt(output)} kg</span>`;
    }

    const kg = mode === "kg-to-lb" ? raw : output;
    let scale = "Typical";
    if (kg < 1) scale = "Very light";
    else if (kg >= 100) scale = "Heavy weight";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `<div style="display:flex;gap:10px;flex-wrap:wrap;">
      ${badge(mode === "kg-to-lb" ? "kg → lb" : "lb → kg")}
      ${badge("Base ≈ " + fmtSmart(kg) + " kg")}
      ${badge(scale)}
    </div>`;

    fillTable(raw, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "4";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "kg-to-lb" ? "lb-to-kg" : "kg-to-lb";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>