---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "kg to Tons",
  description:
    "Convert kilograms to tons for large weight and mass reference.",
  href: "/converter/kg-to-tons/",
  order: 311,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/kg-to-tons/";

const faqs = [
  {
    q: "How do you convert kilograms to tons?",
    a: "Divide kilograms by 1,000, or multiply kilograms by 0.001 to get metric tons.",
  },
  {
    q: "Does this use metric tons?",
    a: "Yes. This tool uses metric tons, where 1 ton equals 1,000 kilograms.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between kilograms to tons and tons to kilograms.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`kg to Tons Converter — ${SITE_NAME}`}
  description="Convert kilograms to tons with clear results for freight, materials, bulk weight, and industrial measurements."
  canonicalPath={CANONICAL_PATH}
  h1="kg to Tons Converter"
  intro="Convert weight from kilograms to metric tons instantly. Useful for industrial loads, freight, and large weight comparisons."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="kg-to-tons">
    <div class="form" role="form" aria-describedby="k2t_hint k2t_privacy">
      <div class="field">
        <label for="k2t_input">Kilograms</label>
        <input id="k2t_input" type="number" inputmode="decimal" placeholder="e.g., 2500" />
        <p class="note" id="k2t_hint" style="margin-top:6px;">
          Enter a non-negative value. This tool uses metric tons.
        </p>
      </div>

      <div class="field">
        <label for="k2t_round">Rounding</label>
        <select id="k2t_round">
          <option value="2">2 decimals</option>
          <option value="4" selected>4 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="k2t_convert">Convert</button>
        <button class="btn secondary" type="button" id="k2t_swap">Reverse (t → kg)</button>
        <button class="btn secondary" type="button" id="k2t_clear">Clear</button>
      </div>

      <div class="result" id="k2t_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="k2t_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="k2t_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="k2t_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="k2t_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard metric conversion: <strong>1,000 kg = 1 metric ton</strong>.<br />
      Formula: <strong>t = kg ÷ 1,000</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1,000 kg</strong> = <strong>1 t</strong></li>
      <li><strong>2,500 kg</strong> = <strong>2.5 t</strong></li>
      <li><strong>10,000 kg</strong> = <strong>10 t</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/weight-converter/">Weight Converter</a></li>
      <li><a href="/converter/tons-to-kg/">Tons to kg</a></li>
      <li><a href="/converter/kg-to-pounds/">kg to Pounds</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("k2t_input");
  const roundEl = document.getElementById("k2t_round");
  const convertBtn = document.getElementById("k2t_convert");
  const swapBtn = document.getElementById("k2t_swap");
  const clearBtn = document.getElementById("k2t_clear");
  const errEl = document.getElementById("k2t_error");
  const outEl = document.getElementById("k2t_result");
  const cardsEl = document.getElementById("k2t_cards");
  const tbodyEl = document.getElementById("k2t_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const KG_TO_TON = 0.001;
  const TON_TO_KG = 1000;
  let mode = "kg-to-t";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="k2t_input"]');
    if (!label) return;
    if (mode === "kg-to-t") {
      label.textContent = "Kilograms";
      inEl.placeholder = "e.g., 2500";
      swapBtn.textContent = "Reverse (t → kg)";
    } else {
      label.textContent = "Metric tons";
      inEl.placeholder = "e.g., 2.5";
      swapBtn.textContent = "Reverse (kg → t)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "kg-to-t"
      ? [
          ["Conversion factor", "1,000 kg = 1 t"],
          ["Reverse factor", "1 t = 1,000 kg"],
          ["Input", fmt(input) + " kg"],
          ["Output", fmt(output) + " t"],
        ]
      : [
          ["Conversion factor", "1 t = 1,000 kg"],
          ["Reverse factor", "1,000 kg = 1 t"],
          ["Input", fmt(input) + " t"],
          ["Output", fmt(output) + " kg"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "kg-to-t" ? input * KG_TO_TON : input * TON_TO_KG;

    if (mode === "kg-to-t") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} t<br/><span class="note">${fmt(input)} kg = ${fmt(output)} t</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} kg<br/><span class="note">${fmt(input)} t = ${fmt(output)} kg</span>`;
    }

    const kg = mode === "kg-to-t" ? input : output;
    let scale = "Typical";
    if (kg < 1000) scale = "Sub-ton weight";
    else if (kg >= 10000) scale = "Heavy load";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `<div style="display:flex;gap:10px;flex-wrap:wrap;">
      ${badge(mode === "kg-to-t" ? "kg → t" : "t → kg")}
      ${badge("Base ≈ " + fmtSmart(kg) + " kg")}
      ${badge(scale)}
    </div>`;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "4";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "kg-to-t" ? "t-to-kg" : "kg-to-t";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>