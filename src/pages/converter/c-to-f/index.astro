---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "C to F",
  description:
    "Convert Celsius (°C) to Fahrenheit (°F) instantly with validation, accessible UX, result cards, reference table, and FAQ schema.",
  href: "/converter/c-to-f/",
  order: 240,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/c-to-f/";

const faqs = [
  {
    q: "What is the formula for converting °C to °F?",
    a: "°F = (°C × 9/5) + 32.",
  },
  {
    q: "Can Celsius values be negative?",
    a: "Yes. Celsius can be below 0 (e.g., −10°C). The converter supports negative values.",
  },
  {
    q: "Is there a minimum possible temperature?",
    a: "Yes. Absolute zero is −273.15°C. Values below that are not physically meaningful; this tool flags them as invalid.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`C to F Converter — ${SITE_NAME}`}
  description="Convert Celsius (°C) to Fahrenheit (°F) with validation, accessible UX, result cards, a reference table, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="C to F Converter"
  intro="Convert Celsius (°C) to Fahrenheit (°F). Includes rounding controls, common temperature references, and input validation."
  faq={faqs}
  categoryName="Converters"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="c-to-f">
    <div class="form" role="form" aria-describedby="c2f_help c2f_privacy">
      <div class="field">
        <label for="c2f_c">Temperature (°C)</label>
        <input
          id="c2f_c"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 25"
          aria-describedby="c2f_help"
        />
        <p class="note" id="c2f_help" style="margin-top:6px;">
          Enter °C then convert. Press <kbd>Ctrl</kbd>/<kbd>Cmd</kbd> + <kbd>Enter</kbd>.
        </p>
      </div>

      <div class="field">
        <label for="c2f_round">Rounding</label>
        <select id="c2f_round">
          <option value="0">0 decimals</option>
          <option value="1" selected>1 decimal</option>
          <option value="2">2 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <button class="btn" type="button" id="c2f_convert">Convert</button>
        <button class="btn secondary" type="button" id="c2f_swap">Swap (°F → °C)</button>
        <button class="btn secondary" type="button" id="c2f_clear">Clear</button>
      </div>

      <div class="result" id="c2f_error" role="alert" style="display:none; margin-top:12px;"></div>

      <div class="result" id="c2f_result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div class="result" id="c2f_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">°C</th>
              <th scope="col">°F</th>
            </tr>
          </thead>
          <tbody id="c2f_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="c2f_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      <strong>°F = (°C × 9/5) + 32</strong><br/>
      Reverse: <strong>°C = (°F − 32) × 5/9</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>0°C</strong> = <strong>32°F</strong></li>
      <li><strong>25°C</strong> = <strong>77°F</strong></li>
      <li><strong>100°C</strong> = <strong>212°F</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/f-to-c/">F to C</a></li>
      <li><a href="/converter/temperature-converter/">Temperature Converter</a></li>
      <li><a href="/converter/weight-converter/">Weight Converter</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("c2f_c");
  const roundEl = document.getElementById("c2f_round");
  const convertBtn = document.getElementById("c2f_convert");
  const swapBtn = document.getElementById("c2f_swap");
  const clearBtn = document.getElementById("c2f_clear");
  const errEl = document.getElementById("c2f_error");
  const outEl = document.getElementById("c2f_result");
  const cardsEl = document.getElementById("c2f_cards");
  const tbodyEl = document.getElementById("c2f_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  // Physical limit (Celsius)
  const ABS_ZERO_C = -273.15;

  // Mode true: C -> F, false: F -> C
  let modeCtoF = true;

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax >= 100) return x.toLocaleString(undefined, { maximumFractionDigits: 1 });
    if (ax >= 1) return x.toLocaleString(undefined, { maximumFractionDigits: 2 });
    const rounded = Math.round(x * 1e6) / 1e6;
    return rounded.toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    const d = parseInt(r, 10);
    if (!Number.isFinite(d) || d < 0) return x.toString();
    return x.toFixed(d);
  }

  function classifyByC(c) {
    // Simple, non-medical, non-claimy labels
    if (!Number.isFinite(c)) return "—";
    if (c < -10) return "Very cold";
    if (c < 5) return "Cold";
    if (c < 20) return "Cool";
    if (c < 28) return "Warm";
    if (c < 35) return "Hot";
    return "Very hot";
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function cToF(c) {
    return (c * 9) / 5 + 32;
  }

  function fToC(f) {
    return ((f - 32) * 5) / 9;
  }

  function setUiForMode() {
    const label = modeCtoF ? "Temperature (°C)" : "Temperature (°F)";
    const ph = modeCtoF ? "e.g., 25" : "e.g., 77";

    const lbl = document.querySelector('label[for="c2f_c"]');
    if (lbl) lbl.textContent = label;

    inEl.setAttribute("aria-label", label);
    inEl.placeholder = ph;

    swapBtn.textContent = modeCtoF ? "Swap (°F → °C)" : "Swap (°C → °F)";
  }

  function fillTable(inputValue) {
    tbodyEl.innerHTML = "";

    const refs = [
      { name: "Freezing point of water", c: 0 },
      { name: "Room temperature (approx.)", c: 20 },
      { name: "Body temperature (approx.)", c: 37 },
      { name: "Boiling point of water", c: 100 },
    ];

    // Add current input as a row if valid
    if (Number.isFinite(inputValue)) {
      const cVal = modeCtoF ? inputValue : fToC(inputValue);
      if (Number.isFinite(cVal)) refs.push({ name: "Your input", c: cVal, highlight: true });
    }

    for (const r of refs) {
      const tr = document.createElement("tr");
      if (r.highlight) tr.style.fontWeight = "900";

      const tdName = document.createElement("td");
      const tdC = document.createElement("td");
      const tdF = document.createElement("td");

      tdName.textContent = r.name;
      tdC.textContent = fmtSmart(r.c);
      tdF.textContent = fmt(cToF(r.c));

      tr.appendChild(tdName);
      tr.appendChild(tdC);
      tr.appendChild(tdF);
      tbodyEl.appendChild(tr);
    }
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid temperature.";
      return;
    }

    // Clamp extremely large values (avoid UI nonsense / float quirks)
    const value = Math.max(Math.min(raw, 1e9), -1e9);
    if (value !== raw) showError("Value is extremely large; output may be rounded due to floating-point limits.");

    let c, f;
    if (modeCtoF) {
      c = value;
      if (c < ABS_ZERO_C) {
        showError("Below absolute zero (−273.15°C). Please enter a physically valid temperature.");
        outEl.textContent = "Please enter a valid temperature.";
        return;
      }
      f = cToF(c);
    } else {
      f = value;
      c = fToC(f);
      if (c < ABS_ZERO_C) {
        showError("Below absolute zero (−273.15°C). Please enter a physically valid temperature.");
        outEl.textContent = "Please enter a valid temperature.";
        return;
      }
    }

    const category = classifyByC(c);

    outEl.innerHTML =
      (modeCtoF
        ? `<strong>Result:</strong> ${fmt(f)} °F<br/><span class="note">${fmt(c)} °C = ${fmt(f)} °F</span>`
        : `<strong>Result:</strong> ${fmt(c)} °C<br/><span class="note">${fmt(f)} °F = ${fmt(c)} °C</span>`
      );

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(modeCtoF ? "°C → °F" : "°F → °C")}
        ${badge("Category: " + category)}
        ${badge("Absolute zero: −273.15°C")}
      </div>
    `;

    fillTable(value);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "1";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);

  swapBtn.addEventListener("click", function () {
    modeCtoF = !modeCtoF;
    setUiForMode();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });

  clearBtn.addEventListener("click", function () {
    modeCtoF = true;
    setUiForMode();
    reset();
  });

  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  inEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  });

  inEl.addEventListener("input", function () {
    if (!String(inEl.value || "").trim()) {
      clearError();
      outEl.textContent = "Result will appear here.";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      tbodyEl.innerHTML = "";
    }
  });

  setUiForMode();
});
</script>