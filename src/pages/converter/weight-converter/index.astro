---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Weight Converter",
  description: "Convert weight units with explanations and real-world use cases (kg, lb, g, oz).",
  href: "/converter/weight-converter/",
  order: 30,
};

const faqs = [
  {
    q: "Is this converter accurate?",
    a: "Yes. It uses standard constants such as 1 lb = 0.45359237 kg (exact).",
  },
  {
    q: "Does it support decimals?",
    a: "Yes. Both input and output support decimal values.",
  },
  {
    q: "Why do results sometimes look rounded?",
    a: "Some conversions produce long decimals, so results are formatted for readability.",
  },
  {
    q: "What is the base unit used?",
    a: "All conversions are calculated using kilograms as the base reference.",
  },
  {
    q: "When should I use kg vs lb?",
    a: "Kilograms are used in most countries, while pounds are mainly used in the United States.",
  },
  {
    q: "Is my data stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title="Weight Converter — MinimalDev"
  description="Free weight converter for mg, g, kg, oz, and lb. Convert kg to lb, lb to kg, g to oz and more with instant results."
  canonicalPath="/converter/weight-converter/"
  h1="Weight Converter"
  intro="Convert weight units instantly between metric and imperial measurements. Supports common conversions like kg to lb and lb to kg."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="weight-converter">
    <div class="form">
      <div class="field">
        <label for="wc_value">Value</label>
        <input id="wc_value" type="number" inputmode="decimal" placeholder="e.g., 2.5" />
      </div>

      <div class="field">
        <label for="wc_from_unit">From</label>
        <select id="wc_from_unit">
          <option value="mg">Milligram (mg)</option>
          <option value="g">Gram (g)</option>
          <option value="kg" selected>Kilogram (kg)</option>
          <option value="oz">Ounce (oz)</option>
          <option value="lb">Pound (lb)</option>
        </select>
      </div>

      <div class="field">
        <label for="wc_to_unit">To</label>
        <select id="wc_to_unit">
          <option value="mg">Milligram (mg)</option>
          <option value="g" selected>Gram (g)</option>
          <option value="kg">Kilogram (kg)</option>
          <option value="oz">Ounce (oz)</option>
          <option value="lb">Pound (lb)</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn secondary" type="button" id="wc_swap">Swap</button>
        <button class="btn secondary" type="button" id="wc_clear">Clear</button>
      </div>

      <div class="result" id="wc_result">Result will appear here.</div>

      <p class="note" style="margin-top:8px;">
        Privacy: calculations run locally in your browser. No inputs are stored or sent to a server.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This converter uses kilograms (kg) as the base unit.
    </p>

    <p class="note">
      <strong>Calculation process:</strong><br/>
      Step 1: Convert input value to kilograms<br/>
      Step 2: Convert kilograms to the target unit
    </p>

    <p class="note">
      <strong>How to interpret results:</strong><br/>
      - kg: standard metric unit used worldwide<br/>
      - lb: commonly used in the US for body weight<br/>
      - g/mg: used for smaller measurements (food, medicine)<br/>
      - oz: used in cooking and packaging
    </p>

    <p class="note">
      Use this tool to compare weight systems or convert values for practical use.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Fitness:</strong> Convert body weight from kg to lb.</li>
      <li><strong>Shipping:</strong> Convert package weight between units.</li>
      <li><strong>Cooking:</strong> Convert grams to ounces for recipes.</li>
    </ul>

    <p class="note"><strong>Examples:</strong></p>
    <ul>
      <li>70 kg ≈ 154.32 lb</li>
      <li>150 lb ≈ 68.04 kg</li>
      <li>500 g ≈ 17.64 oz</li>
      <li>1 kg = 1000 g</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/length/">Length Converter</a></li>
      <li><a href="/converter/temperature-converter/">Temperature Converter</a></li>
      <li><a href="/health/bmi-calculator/">BMI Calculator</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const valueEl = document.getElementById("wc_value");
  const fromEl = document.getElementById("wc_from_unit");
  const toEl = document.getElementById("wc_to_unit");
  const swapBtn = document.getElementById("wc_swap");
  const clearBtn = document.getElementById("wc_clear");
  const resultEl = document.getElementById("wc_result");

  if (!valueEl || !fromEl || !toEl || !swapBtn || !clearBtn || !resultEl) return;

  // Exact-ish base factors in kilograms.
  // - lb exact definition in kg
  // - oz derived from lb (1 lb = 16 oz) => exact in this context
  const toKg = {
    mg: 1e-6,
    g: 1e-3,
    kg: 1,
    lb: 0.45359237,
    oz: 0.45359237 / 16,
  };

  function isFiniteNumber(x) {
    return typeof x === "number" && isFinite(x);
  }

  function fmt(n) {
    if (!isFiniteNumber(n)) return "";
    return n.toLocaleString(undefined, { maximumFractionDigits: 8 });
  }

  function calc() {
    const raw = parseFloat(valueEl.value);
    const from = fromEl.value;
    const to = toEl.value;

    if (!isFiniteNumber(raw)) {
      resultEl.textContent = "Result will appear here.";
      return;
    }

    const fromFactor = toKg[from];
    const toFactor = toKg[to];
    if (!fromFactor || !toFactor) {
      resultEl.textContent = "Unsupported unit.";
      return;
    }

    const kg = raw * fromFactor;
    const out = kg / toFactor;

    const primary = fmt(out);

    resultEl.innerHTML =
      "<strong>" + primary + " " + to + "</strong>" +
      "<div class='note' style='margin-top:6px;'>" +
      fmt(raw) + " " + from + " = " + primary + " " + to +
      "</div>";
  }

  valueEl.addEventListener("input", calc);
  fromEl.addEventListener("change", calc);
  toEl.addEventListener("change", calc);

  swapBtn.addEventListener("click", function () {
    const temp = fromEl.value;
    fromEl.value = toEl.value;
    toEl.value = temp;
    calc();
  });

  clearBtn.addEventListener("click", function () {
    valueEl.value = "";
    resultEl.textContent = "Result will appear here.";
  });

  calc();
});
</script>