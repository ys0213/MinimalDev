---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Minutes to Hours",
  description:
    "Convert minutes to hours instantly. Includes validation, reverse mode, result cards, and FAQ support.",
  href: "/converter/minutes-to-hours/",
  order: 326,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/minutes-to-hours/";

const faqs = [
  {
    q: "How do you convert minutes to hours?",
    a: "Divide minutes by 60, because 60 minutes equal 1 hour.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between minutes to hours and hours to minutes.",
  },
  {
    q: "Can I use decimal minutes?",
    a: "Yes. This tool accepts fractional minute values and returns decimal hours.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Minutes to Hours Converter — ${SITE_NAME}`}
  description="Convert minutes to hours instantly with validation, reverse mode, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="Minutes to Hours Converter"
  intro="Convert time from minutes to hours instantly. Useful for schedules, work logs, time tracking, and duration conversions."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="minutes-to-hours">
    <div class="form" role="form" aria-describedby="m2h_hint m2h_privacy">
      <div class="field">
        <label for="m2h_input">Minutes</label>
        <input id="m2h_input" type="number" inputmode="decimal" placeholder="e.g., 90" />
        <p class="note" id="m2h_hint" style="margin-top:6px;">
          Enter a non-negative value. 60 minutes equal 1 hour.
        </p>
      </div>

      <div class="field">
        <label for="m2h_round">Rounding</label>
        <select id="m2h_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="m2h_convert">Convert</button>
        <button class="btn secondary" type="button" id="m2h_swap">Reverse (hr → min)</button>
        <button class="btn secondary" type="button" id="m2h_clear">Clear</button>
      </div>

      <div class="result" id="m2h_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="m2h_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="m2h_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="m2h_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="m2h_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard time conversion: <strong>60 minutes = 1 hour</strong>.<br />
      Formula: <strong>hours = minutes ÷ 60</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>60 minutes</strong> = <strong>1 hour</strong></li>
      <li><strong>90 minutes</strong> = <strong>1.5 hours</strong></li>
      <li><strong>180 minutes</strong> = <strong>3 hours</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/time-converter/">Time Converter</a></li>
      <li><a href="/converter/hours-to-minutes/">Hours to Minutes</a></li>
      <li><a href="/converter/seconds-to-minutes/">Seconds to Minutes</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("m2h_input");
  const roundEl = document.getElementById("m2h_round");
  const convertBtn = document.getElementById("m2h_convert");
  const swapBtn = document.getElementById("m2h_swap");
  const clearBtn = document.getElementById("m2h_clear");
  const errEl = document.getElementById("m2h_error");
  const outEl = document.getElementById("m2h_result");
  const cardsEl = document.getElementById("m2h_cards");
  const tbodyEl = document.getElementById("m2h_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const MIN_TO_HOUR = 1 / 60;
  const HOUR_TO_MIN = 60;
  let mode = "min-to-hour";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="m2h_input"]');
    if (!label) return;
    if (mode === "min-to-hour") {
      label.textContent = "Minutes";
      inEl.placeholder = "e.g., 90";
      swapBtn.textContent = "Reverse (hr → min)";
    } else {
      label.textContent = "Hours";
      inEl.placeholder = "e.g., 1.5";
      swapBtn.textContent = "Reverse (min → hr)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "min-to-hour"
      ? [
          ["Conversion factor", "60 min = 1 hr"],
          ["Formula", "hr = min ÷ 60"],
          ["Input", fmt(input) + " min"],
          ["Output", fmt(output) + " hr"],
        ]
      : [
          ["Conversion factor", "1 hr = 60 min"],
          ["Formula", "min = hr × 60"],
          ["Input", fmt(input) + " hr"],
          ["Output", fmt(output) + " min"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classifyHours(hours) {
    if (hours < 1) return "Under one hour";
    if (hours < 24) return "Typical duration";
    return "One day or more";
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "min-to-hour" ? input * MIN_TO_HOUR : input * HOUR_TO_MIN;

    if (mode === "min-to-hour") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} hr<br/><span class="note">${fmt(input)} min = ${fmt(output)} hr</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} min<br/><span class="note">${fmt(input)} hr = ${fmt(output)} min</span>`;
    }

    const hours = mode === "min-to-hour" ? output : input;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(mode === "min-to-hour" ? "min → hr" : "hr → min")}
        ${badge("Base ≈ " + fmtSmart(hours) + " hr")}
        ${badge(classifyHours(hours))}
      </div>
    `;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "min-to-hour" ? "hour-to-min" : "min-to-hour";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>