---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Angle Converter",
  description:
    "Convert angle units instantly (degrees, radians, gradians, arcminutes, arcseconds). Validated, accessible UX with result cards, quick table, and FAQ schema.",
  href: "/converter/angle-converter/",
  order: 270,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/angle-converter/";

const units = [
  { key: "deg", label: "Degrees (°)" },
  { key: "rad", label: "Radians (rad)" },
  { key: "grad", label: "Gradians (gon)" },
  { key: "arcmin", label: "Arcminutes (′)" },
  { key: "arcsec", label: "Arcseconds (″)" },
];

const faqs = [
  {
    q: "How do you convert degrees to radians?",
    a: "Multiply degrees by π/180. Example: 180° = π radians.",
  },
  {
    q: "How do you convert radians to degrees?",
    a: "Multiply radians by 180/π. Example: π radians = 180°.",
  },
  {
    q: "What are gradians?",
    a: "Gradians divide a circle into 400 equal parts, so 100 gradians equals a right angle.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. Conversions run locally in your browser. Nothing is stored or transmitted.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Angle Converter — ${SITE_NAME}`}
  description="Convert angle units instantly (degrees, radians, gradians, arcminutes, arcseconds). Includes unit UX, input validation, accessible controls, result cards, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Angle Converter"
  intro="Convert between common angle units. Enter a value, choose “from” and “to” units, and see the converted result with a quick reference table."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="angle-converter">
    <div class="form" role="form" aria-describedby="ac_hint ac_privacy">
      <div class="field">
        <label for="ac_value">Value</label>
        <input
          id="ac_value"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 180"
          aria-describedby="ac_hint"
        />
        <p class="note" id="ac_hint" style="margin-top:6px;">
          Tip: Use decimals if needed. Press <kbd>Ctrl</kbd>/<kbd>Cmd</kbd> + <kbd>Enter</kbd> to convert.
        </p>
      </div>

      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
        <div class="field">
          <label for="ac_from">From</label>
          <select id="ac_from">
            {units.map((u) => <option value={u.key}>{u.label}</option>)}
          </select>
        </div>

        <div class="field">
          <label for="ac_to">To</label>
          <select id="ac_to">
            {units.map((u) => <option value={u.key}>{u.label}</option>)}
          </select>
        </div>
      </div>

      <div class="field">
        <label for="ac_round">Rounding</label>
        <select id="ac_round">
          <option value="2">2 decimals</option>
          <option value="4" selected>4 decimals</option>
          <option value="8">8 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <button class="btn" type="button" id="ac_convert">Convert</button>
        <button class="btn secondary" type="button" id="ac_swap" aria-label="Swap units">Swap</button>
        <button class="btn secondary" type="button" id="ac_clear">Clear</button>
      </div>

      <div class="result" id="ac_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="ac_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="ac_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Unit</th>
              <th scope="col">Equivalent</th>
            </tr>
          </thead>
          <tbody id="ac_table"></tbody>
        </table>
      </div>

      <p class="note" id="ac_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Converts using <strong>radians</strong> as a base unit. Example formulas:
      <br />
      <strong>rad = deg × π / 180</strong>
      <br />
      <strong>deg = rad × 180 / π</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>180°</strong> = <strong>π rad</strong></li>
      <li><strong>90°</strong> = <strong>100 grad</strong></li>
      <li><strong>1°</strong> = <strong>60 arcminutes</strong></li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      {faqs.map((f) => (
        <li><strong>{f.q}</strong> {f.a}</li>
      ))}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/degrees-to-radians/">Degrees to Radians</a></li>
      <li><a href="/converter/radians-to-degrees/">Radians to Degrees</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const valueEl = document.getElementById("ac_value");
  const fromEl = document.getElementById("ac_from");
  const toEl = document.getElementById("ac_to");
  const roundEl = document.getElementById("ac_round");
  const convertBtn = document.getElementById("ac_convert");
  const swapBtn = document.getElementById("ac_swap");
  const clearBtn = document.getElementById("ac_clear");
  const errEl = document.getElementById("ac_error");
  const resEl = document.getElementById("ac_result");
  const cardsEl = document.getElementById("ac_cards");
  const tbodyEl = document.getElementById("ac_table");

  if (!valueEl || !fromEl || !toEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !resEl || !cardsEl || !tbodyEl) return;

  const TO_RAD = {
    deg: Math.PI / 180,
    rad: 1,
    grad: Math.PI / 200,
    arcmin: Math.PI / 10800,
    arcsec: Math.PI / 648000
  };

  const LABEL = {
    deg: "Degrees (°)",
    rad: "Radians (rad)",
    grad: "Gradians (gon)",
    arcmin: "Arcminutes (′)",
    arcsec: "Arcseconds (″)"
  };

  const ORDER = ["deg", "rad", "grad", "arcmin", "arcsec"];

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    if (x === 0) return "0";
    const ax = Math.abs(x);
    if (ax >= 1e12 || ax < 1e-12) return x.toExponential(6);
    const s = x.toPrecision(10);
    return String(Number(s));
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value || "auto");
    if (r === "auto") return fmtSmart(x);
    const d = parseInt(r, 10);
    if (!Number.isFinite(d) || d < 0) return fmtSmart(x);
    const v = Object.is(x, -0) ? 0 : x;
    return v.toLocaleString(undefined, { minimumFractionDigits: d, maximumFractionDigits: d });
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function convert(value, fromU, toU) {
    const f = TO_RAD[fromU];
    const t = TO_RAD[toU];
    if (!Number.isFinite(f) || !Number.isFinite(t)) return NaN;
    const rad = value * f;
    return rad / t;
  }

  function classify(rad) {
    const a = Math.abs(rad);
    if (a === 0) return "Zero angle";
    if (a < Math.PI / 6) return "Small angle";
    if (a < Math.PI / 2) return "Acute";
    if (a < Math.PI) return "Obtuse";
    if (a === Math.PI) return "Straight";
    if (a < 2 * Math.PI) return "Reflex";
    return "Multiple turns";
  }

  function buildTable(value, fromU) {
    tbodyEl.innerHTML = "";
    for (const u of ORDER) {
      const v = convert(value, fromU, u);
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = LABEL[u];
      td2.textContent = fmtSmart(v);
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    }
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(valueEl.value);
    const fromU = String(fromEl.value);
    const toU = String(toEl.value);

    if (!Number.isFinite(raw)) {
      resEl.textContent = "Please enter a valid angle.";
      return;
    }

    if (Math.abs(raw) > 1e18) {
      showError("Value is too large for reliable display. Use a smaller magnitude.");
      resEl.textContent = "Result will appear here.";
      return;
    }

    const out = convert(raw, fromU, toU);
    if (!Number.isFinite(out)) {
      showError("Could not convert with these units.");
      resEl.textContent = "Result will appear here.";
      return;
    }

    const inRad = raw * TO_RAD[fromU];
    resEl.innerHTML =
      "<strong>Result:</strong> " + fmt(out) + " <span class='note'>(" + toU + ")</span><br/>" +
      "<span class='note'>" + fmtSmart(raw) + " (" + fromU + ") = " + fmtSmart(inRad) + " (rad) = " + fmtSmart(out) + " (" + toU + ")</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      `<div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge("From: " + fromU)}
        ${badge("To: " + toU)}
        ${badge("Base: radians")}
        ${badge(classify(inRad))}
      </div>`;

    buildTable(raw, fromU);
  }

  function reset() {
    clearError();
    valueEl.value = "";
    fromEl.value = "deg";
    toEl.value = "rad";
    roundEl.value = "4";
    resEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    const a = fromEl.value;
    fromEl.value = toEl.value;
    toEl.value = a;
    if (String(valueEl.value || "").trim()) compute();
  });
  clearBtn.addEventListener("click", reset);

  fromEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });
  toEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });
  roundEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });

  valueEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  });

  valueEl.addEventListener("input", function () {
    if (!String(valueEl.value || "").trim()) {
      clearError();
      resEl.textContent = "Result will appear here.";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      tbodyEl.innerHTML = "";
    }
  });

  fromEl.value = "deg";
  toEl.value = "rad";
  roundEl.value = "4";
});
</script>