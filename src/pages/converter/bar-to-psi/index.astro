---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Bar to PSI",
  description:
    "Convert bar to PSI instantly with validation, accessible UX, result cards, reference table, and FAQ schema.",
  href: "/converter/bar-to-psi/",
  order: 320,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/bar-to-psi/";
const BAR_TO_PSI = 14.5037738;

const faqs = [
  {
    q: "How do you convert bar to PSI?",
    a: "Multiply bar by 14.5037738 to get PSI.",
  },
  {
    q: "What is 1 bar in PSI?",
    a: "1 bar equals about 14.5038 PSI.",
  },
  {
    q: "Can bar values be negative?",
    a: "The converter supports negative values mathematically, though many real-world pressure uses are non-negative.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Bar to PSI Converter — ${SITE_NAME}`}
  description="Convert bar to PSI with validation, accessible UX, result cards, a reference table, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Bar to PSI Converter"
  intro="Convert pressure from bar to pounds per square inch (PSI). Includes rounding controls, a quick reference table, and input validation."
  faq={faqs}
  categoryName="Converters"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="bar-to-psi">
    <div class="form" role="form" aria-describedby="b2p_help b2p_privacy">
      <div class="field">
        <label for="b2p_bar">Pressure (bar)</label>
        <input id="b2p_bar" type="number" inputmode="decimal" placeholder="e.g., 2" aria-describedby="b2p_help" />
        <p class="note" id="b2p_help" style="margin-top:6px;">
          Enter bar and convert. Press <kbd>Ctrl</kbd>/<kbd>Cmd</kbd> + <kbd>Enter</kbd>.
        </p>
      </div>

      <div class="field">
        <label for="b2p_round">Rounding</label>
        <select id="b2p_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="b2p_convert">Convert</button>
        <button class="btn secondary" type="button" id="b2p_swap">Swap (PSI → bar)</button>
        <button class="btn secondary" type="button" id="b2p_clear">Clear</button>
      </div>

      <div class="result" id="b2p_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="b2p_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="b2p_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">bar</th>
              <th scope="col">PSI</th>
            </tr>
          </thead>
          <tbody id="b2p_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="b2p_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      <strong>PSI = bar × 14.5037738</strong><br />
      Reverse: <strong>bar = PSI × 0.0689475729</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1 bar</strong> ≈ <strong>14.504 PSI</strong></li>
      <li><strong>2 bar</strong> ≈ <strong>29.008 PSI</strong></li>
      <li><strong>6.895 bar</strong> ≈ <strong>100 PSI</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/psi-to-bar/">PSI to Bar</a></li>
      <li><a href="/converter/pressure-converter/">Pressure Converter</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("b2p_bar");
  const roundEl = document.getElementById("b2p_round");
  const convertBtn = document.getElementById("b2p_convert");
  const swapBtn = document.getElementById("b2p_swap");
  const clearBtn = document.getElementById("b2p_clear");
  const errEl = document.getElementById("b2p_error");
  const outEl = document.getElementById("b2p_result");
  const cardsEl = document.getElementById("b2p_cards");
  const tbodyEl = document.getElementById("b2p_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  let modeBarToPsi = true;
  const PSI_TO_BAR = 0.0689475729;
  const BAR_TO_PSI = 14.5037738;

  function toNum(v) { const x = parseFloat(String(v)); return Number.isFinite(x) ? x : NaN; }
  function clearError() { errEl.style.display = "none"; errEl.textContent = ""; }
  function showError(msg) { errEl.style.display = "block"; errEl.textContent = msg; }
  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1e9 || ax < 1e-8) return x.toExponential(6);
    return String(Number(x.toPrecision(10)));
  }
  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    const d = parseInt(r, 10);
    return Number(x).toLocaleString(undefined, { minimumFractionDigits: d, maximumFractionDigits: d });
  }
  function badge(text) {
    return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`;
  }
  function psiToBar(v) { return v * PSI_TO_BAR; }
  function barToPsi(v) { return v * BAR_TO_PSI; }
  function classifyPsi(psi) {
    const a = Math.abs(psi);
    if (a < 14.7) return "Below atmospheric";
    if (a < 60) return "Typical pressure";
    if (a < 200) return "High pressure";
    return "Very high pressure";
  }

  function setUi() {
    const label = document.querySelector('label[for="b2p_bar"]');
    if (!label) return;
    if (modeBarToPsi) {
      label.textContent = "Pressure (bar)";
      inEl.placeholder = "e.g., 2";
      swapBtn.textContent = "Swap (PSI → bar)";
    } else {
      label.textContent = "Pressure (PSI)";
      inEl.placeholder = "e.g., 30";
      swapBtn.textContent = "Swap (bar → PSI)";
    }
  }

  function fillTable(inputValue) {
    tbodyEl.innerHTML = "";
    const refs = [
      { name: "1 atmosphere (approx.)", bar: 1.01325 },
      { name: "Car tire pressure", bar: 2.2 },
      { name: "Industrial pressure", bar: 10 },
    ];
    if (Number.isFinite(inputValue)) {
      const barVal = modeBarToPsi ? inputValue : psiToBar(inputValue);
      refs.push({ name: "Your input", bar: barVal, highlight: true });
    }

    refs.forEach((r) => {
      const tr = document.createElement("tr");
      if (r.highlight) tr.style.fontWeight = "900";
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      const td3 = document.createElement("td");
      td1.textContent = r.name;
      td2.textContent = fmtSmart(r.bar);
      td3.textContent = fmt(barToPsi(r.bar));
      tr.appendChild(td1);
      tr.appendChild(td2);
      tr.appendChild(td3);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid pressure.";
      return;
    }
    if (Math.abs(raw) > 1e18) {
      showError("Value is too large for reliable display.");
      outEl.textContent = "Result will appear here.";
      return;
    }

    let bar, psi;
    if (modeBarToPsi) {
      bar = raw;
      psi = barToPsi(bar);
    } else {
      psi = raw;
      bar = psiToBar(psi);
    }

    outEl.innerHTML = modeBarToPsi
      ? `<strong>Result:</strong> ${fmt(psi)} PSI<br/><span class="note">${fmtSmart(bar)} bar = ${fmt(psi)} PSI</span>`
      : `<strong>Result:</strong> ${fmt(bar)} bar<br/><span class="note">${fmtSmart(psi)} PSI = ${fmt(bar)} bar</span>`;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        ${badge(modeBarToPsi ? "bar → PSI" : "PSI → bar")}
        ${badge("Reference: 1 bar ≈ 14.504 PSI")}
        ${badge(classifyPsi(psi))}
      </div>
    `;

    fillTable(raw);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    modeBarToPsi = !modeBarToPsi;
    setUi();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", function () {
    modeBarToPsi = true;
    setUi();
    reset();
  });
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });
  inEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  });
  inEl.addEventListener("input", function () {
    if (!String(inEl.value || "").trim()) {
      clearError();
      outEl.textContent = "Result will appear here.";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      tbodyEl.innerHTML = "";
    }
  });

  setUi();
});
</script>