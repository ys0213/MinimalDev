---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "MB to GB Converter",
  description:
    "Convert megabytes to gigabytes for storage, file sizes, downloads, and device capacity.",
  href: "/converter/mb-to-gb/",
  order: 150,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/mb-to-gb/";

const faqs = [
  {
    q: "Is 1 GB equal to 1000 MB or 1024 MB?",
    a: "Both are used in different contexts. Decimal storage units use 1 GB = 1000 MB. Binary units use 1 GiB = 1024 MiB. This converter can show decimal GB and binary-equivalent GiB.",
  },
  {
    q: "Which setting should I use for file sizes?",
    a: "Use decimal GB when matching storage labels, download sizes, or manufacturer capacity. Use the binary-equivalent GiB view when comparing with operating system storage displays.",
  },
  {
    q: "Why does my computer show less space than the drive label?",
    a: "One common reason is unit display. A drive sold using decimal GB may be shown by an operating system using binary-style units, which makes the displayed number look smaller.",
  },
  {
    q: "Can I enter decimal MB values?",
    a: "Yes. You can enter values like 12.5 MB, 1500.75 MB, or other decimal file sizes.",
  },
  {
    q: "Does this converter upload my data?",
    a: "No. The calculation runs locally in your browser and your input is not sent to a server.",
  },
];

---

<ToolLayout
  title={`MB to GB Converter — ${SITE_NAME}`}
  description="Convert MB to GB for file sizes, storage usage, download sizes, and device capacity. Compare decimal GB and binary-equivalent GiB."
  canonicalPath={CANONICAL_PATH}
  h1="MB to GB Converter"
  intro="Convert megabytes (MB) to gigabytes (GB) for storage, downloads, backups, and file size checks. Choose decimal GB or binary-equivalent GiB depending on the context."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="mb-to-gb">
    <div class="privacy-note">
      <strong>Privacy First:</strong> This tool runs locally in your browser.
      <strong>Your input values are never sent to any server.</strong>
    </div>

    <div class="form" role="form" aria-describedby="m2g_hint">
      <div class="field">
        <label for="m2g_mb">Megabytes</label>
        <input id="m2g_mb" type="number" inputmode="decimal" placeholder="e.g., 1500" />
        <p class="note" id="m2g_hint" style="margin-top:6px;">
          Enter a size in MB, then choose whether you want decimal GB, binary-equivalent GiB, or both.
        </p>
      </div>

      <div class="field">
        <label for="m2g_mode">Conversion standard</label>
        <select id="m2g_mode">
          <option value="decimal" selected>Decimal (GB): 1 GB = 1000 MB</option>
          <option value="binary">Binary-equivalent (GiB)</option>
          <option value="both">Show both</option>
        </select>
      </div>

      <div class="field">
        <label for="m2g_round">Rounding</label>
        <select id="m2g_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <button class="btn" type="button" id="m2g_calc">Convert</button>
        <button class="btn secondary" type="button" id="m2g_clear">Clear</button>
      </div>

      <div class="result" id="m2g_error" role="alert" style="display:none; margin-top:12px;"></div>

      <div class="result" id="m2g_result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div class="result" id="m2g_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Unit</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="m2g_tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div slot="how">
    <h2>How MB to GB conversion works</h2>

    <p class="note">
      MB to GB conversion depends on whether you are using decimal storage units or binary-style display units. Storage labels, download sizes, and network-related file sizes usually use decimal units, while some operating systems display storage using binary units.
    </p>

    <ul>
      <li><strong>Decimal:</strong> GB = MB ÷ 1000</li>
      <li><strong>Binary-equivalent:</strong> GiB is based on powers of 1024</li>
      <li><strong>Practical rule:</strong> use decimal GB for product labels and download sizes; use binary-equivalent values when comparing with OS storage displays</li>
    </ul>

    <p class="note">
      This page treats the input as decimal MB. For binary comparison, it converts MB to bytes first, then displays the binary-equivalent GiB value.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>500 MB</strong> → <strong>0.5 GB</strong> decimal</li>
      <li><strong>1500 MB</strong> → <strong>1.5 GB</strong> decimal, about <strong>1.397 GiB</strong> binary-equivalent</li>
      <li><strong>2048 MB</strong> → <strong>2.048 GB</strong> decimal, about <strong>1.907 GiB</strong> binary-equivalent</li>
      <li><strong>10000 MB</strong> → <strong>10 GB</strong> decimal</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/gb-to-mb/">GB to MB</a></li>
      <li><a href="/converter/kb-to-mb/">KB to MB</a></li>
      <li><a href="/converter/bytes-converter/">Bytes Converter</a></li>
      <li><a href="/utility/base64/">Base64 Encoder/Decoder</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const mbEl = document.getElementById("m2g_mb");
  const modeEl = document.getElementById("m2g_mode");
  const roundEl = document.getElementById("m2g_round");
  const calcBtn = document.getElementById("m2g_calc");
  const clearBtn = document.getElementById("m2g_clear");
  const errEl = document.getElementById("m2g_error");
  const outEl = document.getElementById("m2g_result");
  const cardsEl = document.getElementById("m2g_cards");
  const tbodyEl = document.getElementById("m2g_tbody");

  if (!mbEl || !modeEl || !roundEl || !calcBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const BYTES_PER_MB_DEC = 1e6;
  const BYTES_PER_GIB_BIN = 1024 * 1024 * 1024;

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1e9) return (Math.round(x * 1e6) / 1e6).toLocaleString();
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toString();
    const rounded = Math.round(x * 1e12) / 1e12;
    return rounded.toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    const d = parseInt(r, 10);
    if (!Number.isFinite(d) || d < 0) return x.toString();
    return x.toFixed(d);
  }

  function badge(text, kind) {
    const border = kind === "warn"
      ? "rgba(251,146,60,0.55)"
      : kind === "good"
      ? "rgba(34,197,94,0.55)"
      : "rgba(255,255,255,0.2)";
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid ${border}; font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setRow(unit, value) {
    const tr = document.createElement("tr");
    const td1 = document.createElement("td");
    const td2 = document.createElement("td");
    td1.textContent = unit;
    td2.textContent = value;
    tr.appendChild(td1);
    tr.appendChild(td2);
    tbodyEl.appendChild(tr);
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(mbEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number of MB.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const mb = Math.min(raw, 1e18);
    if (mb !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const mode = String(modeEl.value);

    const gbDec = mb / 1000;
    const bytes = mb * BYTES_PER_MB_DEC;
    const gib = bytes / BYTES_PER_GIB_BIN;

    const showDec = (mode === "decimal" || mode === "both");
    const showBin = (mode === "binary" || mode === "both");

    let primaryLine = "";
    if (mode === "decimal") primaryLine = `<strong>Result:</strong> ${fmt(gbDec)} GB`;
    else if (mode === "binary") primaryLine = `<strong>Result:</strong> ${fmt(gib)} GiB`;
    else primaryLine = `<strong>Result:</strong> ${fmt(gbDec)} GB · ${fmt(gib)} GiB`;

    outEl.innerHTML =
      primaryLine +
      `<br/><span class="note">${fmt(mb)} MB input</span>`;

    const label = mode === "decimal"
      ? "Decimal (GB)"
      : mode === "binary"
      ? "Binary-equivalent (GiB)"
      : "Both";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge("Input: MB", "neutral")}
        ${badge("Mode: " + label, (mode === "both") ? "good" : "neutral")}
        ${badge("MB→bytes uses decimal", "warn")}
      </div>
      <div class="note" style="margin-top:8px;">
        Assumptions: 1 MB = 1,000,000 bytes · 1 GB = 1,000 MB · 1 GiB = 1,073,741,824 bytes
      </div>
    `;

    if (showDec) setRow("GB (decimal)", `${fmt(gbDec)} GB`);
    if (showBin) setRow("GiB (binary-equivalent)", `${fmt(gib)} GiB`);

    const mib = bytes / (1024 * 1024);
    setRow("Bytes (from MB)", `${fmtSmart(bytes)} B`);
    setRow("MiB (binary-equivalent)", `${fmt(mib)} MiB`);
  }

  function reset() {
    clearError();
    mbEl.value = "";
    modeEl.value = "decimal";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  calcBtn.addEventListener("click", compute);
  clearBtn.addEventListener("click", reset);

  modeEl.addEventListener("change", function () {
    if (String(mbEl.value || "").trim()) compute();
  });
  roundEl.addEventListener("change", function () {
    if (String(mbEl.value || "").trim()) compute();
  });

  mbEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  });

  mbEl.addEventListener("input", function () {
    if (!String(mbEl.value || "").trim()) {
      clearError();
      outEl.textContent = "Result will appear here.";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      tbodyEl.innerHTML = "";
    }
  });
});
</script>