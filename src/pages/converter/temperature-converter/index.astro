---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Temperature Converter",
  description: "Convert Celsius, Fahrenheit, and Kelvin with clear explanations and real-world examples.",
  href: "/converter/temperature-converter/",
  order: 20,
};

const faqs = [
  {
    q: "Why is temperature conversion different?",
    a: "Unlike other units, temperature includes both scaling and offsets (e.g., +32 or +273.15).",
  },
  {
    q: "Can I use negative values?",
    a: "Yes. Temperatures like −10°C or −40°F are valid and handled correctly.",
  },
  {
    q: "Why do results sometimes look rounded?",
    a: "Some conversions produce long decimals, so values are formatted for readability.",
  },
  {
    q: "What is absolute zero?",
    a: "Absolute zero is 0 K (−273.15°C), the lowest possible temperature.",
  },
  {
    q: "Why is −40 the same in C and F?",
    a: "At −40, both Celsius and Fahrenheit scales intersect.",
  },
  {
    q: "Is my data stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title="Temperature Converter — MinimalDev"
  description="Free temperature converter for Celsius (°C), Fahrenheit (°F), and Kelvin (K). Convert C to F, F to C, and more with instant results."
  canonicalPath="/converter/temperature-converter/"
  h1="Temperature Converter"
  intro="Convert Celsius, Fahrenheit, and Kelvin instantly. Supports common conversions like C to F and F to C with live updates."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="temperature-converter">
    <div class="form">
      <div class="field">
        <label for="tc_value">Value</label>
        <input id="tc_value" type="number" inputmode="decimal" placeholder="e.g., 36.6" />
      </div>

      <div class="field">
        <label for="tc_from_unit">From</label>
        <select id="tc_from_unit">
          <option value="c" selected>Celsius (°C)</option>
          <option value="f">Fahrenheit (°F)</option>
          <option value="k">Kelvin (K)</option>
        </select>
      </div>

      <div class="field">
        <label for="tc_to_unit">To</label>
        <select id="tc_to_unit">
          <option value="c">Celsius (°C)</option>
          <option value="f" selected>Fahrenheit (°F)</option>
          <option value="k">Kelvin (K)</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn secondary" type="button" id="tc_swap">Swap</button>
        <button class="btn secondary" type="button" id="tc_clear">Clear</button>
      </div>

      <div class="result" id="tc_result">Result will appear here.</div>

      <p class="note" style="margin-top:8px;">
        Privacy: calculations run locally in your browser. No inputs are stored or sent to a server.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Temperature conversion uses both scaling and offset adjustments.
    </p>

    <p class="note">
      <strong>Formulas:</strong><br/>
      C → F: (°C × 9/5) + 32<br/>
      F → C: (°F − 32) × 5/9<br/>
      C → K: °C + 273.15<br/>
      K → C: K − 273.15
    </p>

    <p class="note">
      <strong>How to interpret results:</strong><br/>
      - Celsius: used in most countries and weather reports<br/>
      - Fahrenheit: used mainly in the United States<br/>
      - Kelvin: used in science and engineering
    </p>

    <p class="note">
      Use this tool when comparing temperatures across regions or converting scientific values.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>Weather:</strong> Convert °F to °C when traveling internationally.</li>
      <li><strong>Cooking:</strong> Convert oven temperatures between systems.</li>
      <li><strong>Science:</strong> Convert °C to Kelvin for experiments.</li>
    </ul>

    <p class="note"><strong>Examples:</strong></p>
    <ul>
      <li>0°C = 32°F = 273.15 K</li>
      <li>100°C = 212°F = 373.15 K</li>
      <li>98.6°F ≈ 37°C (body temperature)</li>
      <li>300 K ≈ 26.85°C</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/c-to-f/">C to F</a></li>
      <li><a href="/converter/f-to-c/">F to C</a></li>
      <li><a href="/converter/kelvin-to-celsius/">Kelvin to Celsius</a></li>
      <li><a href="/converter/length/">Length Converter</a></li>
      <li><a href="/converter/weight-converter/">Weight Converter</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const valueEl = document.getElementById("tc_value");
  const fromEl = document.getElementById("tc_from_unit");
  const toEl = document.getElementById("tc_to_unit");
  const swapBtn = document.getElementById("tc_swap");
  const clearBtn = document.getElementById("tc_clear");
  const resultEl = document.getElementById("tc_result");

  if (!valueEl || !fromEl || !toEl || !swapBtn || !clearBtn || !resultEl) return;

  function isFiniteNumber(x) {
    return typeof x === "number" && isFinite(x);
  }

  function fmt(n) {
    if (!isFiniteNumber(n)) return "";
    return n.toLocaleString(undefined, { maximumFractionDigits: 6 });
  }

  function toCelsius(val, unit) {
    if (unit === "c") return val;
    if (unit === "f") return (val - 32) * 5 / 9;
    if (unit === "k") return val - 273.15;
    return val;
  }

  function fromCelsius(val, unit) {
    if (unit === "c") return val;
    if (unit === "f") return (val * 9 / 5) + 32;
    if (unit === "k") return val + 273.15;
    return val;
  }

  function calc() {
    const raw = parseFloat(valueEl.value);
    const from = fromEl.value;
    const to = toEl.value;

    if (!isFiniteNumber(raw)) {
      resultEl.textContent = "Result will appear here.";
      return;
    }

    const c = toCelsius(raw, from);
    const out = fromCelsius(c, to);

    const primary = fmt(out);
    const approx = String(primary) !== String(out) ? " (approx.)" : "";

    resultEl.innerHTML =
      "<strong>" + primary + " " + to.toUpperCase() + "</strong>" + approx +
      "<div class='note' style='margin-top:6px;'>" +
      fmt(raw) + " " + from.toUpperCase() +
      " = " + primary + " " + to.toUpperCase() +
      "</div>";
  }

  valueEl.addEventListener("input", calc);
  fromEl.addEventListener("change", calc);
  toEl.addEventListener("change", calc);

  swapBtn.addEventListener("click", function () {
    const temp = fromEl.value;
    fromEl.value = toEl.value;
    toEl.value = temp;
    calc();
  });

  clearBtn.addEventListener("click", function () {
    valueEl.value = "";
    resultEl.textContent = "Result will appear here.";
  });

  calc();
});
</script>