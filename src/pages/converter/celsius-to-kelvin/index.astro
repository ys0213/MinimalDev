---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Celsius to Kelvin",
  description:
    "Convert Celsius to Kelvin instantly. Includes validation, reverse mode, result cards, and FAQ support.",
  href: "/converter/celsius-to-kelvin/",
  order: 318,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/celsius-to-kelvin/";

const faqs = [
  {
    q: "How do you convert Celsius to Kelvin?",
    a: "Use the formula K = °C + 273.15.",
  },
  {
    q: "Can Kelvin ever be negative?",
    a: "No. Kelvin cannot go below 0 K.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between Celsius to Kelvin and Kelvin to Celsius.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Celsius to Kelvin Converter — ${SITE_NAME}`}
  description="Convert Celsius to Kelvin instantly with validation, reverse mode, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="Celsius to Kelvin Converter"
  intro="Convert temperature from Celsius to Kelvin instantly. Useful for science, weather references, and absolute temperature comparisons."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="celsius-to-kelvin">
    <div class="form" role="form" aria-describedby="c2k_hint c2k_privacy">
      <div class="field">
        <label for="c2k_input">Celsius (°C)</label>
        <input id="c2k_input" type="number" inputmode="decimal" placeholder="e.g., 0" />
        <p class="note" id="c2k_hint" style="margin-top:6px;">
          Negative Celsius values are allowed. Kelvin output cannot go below 0 K.
        </p>
      </div>

      <div class="field">
        <label for="c2k_round">Rounding</label>
        <select id="c2k_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="c2k_convert">Convert</button>
        <button class="btn secondary" type="button" id="c2k_swap">Reverse (K → °C)</button>
        <button class="btn secondary" type="button" id="c2k_clear">Clear</button>
      </div>

      <div class="result" id="c2k_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="c2k_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="c2k_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="c2k_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="c2k_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard conversion: <strong>K = °C + 273.15</strong>.<br />
      Reverse formula: <strong>°C = K − 273.15</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>0°C</strong> = <strong>273.15 K</strong></li>
      <li><strong>25°C</strong> = <strong>298.15 K</strong></li>
      <li><strong>100°C</strong> = <strong>373.15 K</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/temperature-converter/">Temperature Converter</a></li>
      <li><a href="/converter/kelvin-to-celsius/">Kelvin to Celsius</a></li>
      <li><a href="/converter/f-to-c/">F to C</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("c2k_input");
  const roundEl = document.getElementById("c2k_round");
  const convertBtn = document.getElementById("c2k_convert");
  const swapBtn = document.getElementById("c2k_swap");
  const clearBtn = document.getElementById("c2k_clear");
  const errEl = document.getElementById("c2k_error");
  const outEl = document.getElementById("c2k_result");
  const cardsEl = document.getElementById("c2k_cards");
  const tbodyEl = document.getElementById("c2k_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  let mode = "c-to-k";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function cToK(c) {
    return c + 273.15;
  }

  function kToC(k) {
    return k - 273.15;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) {
      return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    }
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    const d = parseInt(r, 10);
    return x.toFixed(d);
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="c2k_input"]');
    if (!label) return;

    if (mode === "c-to-k") {
      label.textContent = "Celsius (°C)";
      inEl.placeholder = "e.g., 0";
      swapBtn.textContent = "Reverse (K → °C)";
    } else {
      label.textContent = "Kelvin (K)";
      inEl.placeholder = "e.g., 273.15";
      swapBtn.textContent = "Reverse (°C → K)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";

    const rows = mode === "c-to-k"
      ? [
          ["Formula", "K = °C + 273.15"],
          ["Input", fmt(input) + " °C"],
          ["Output", fmt(output) + " K"],
          ["Absolute zero", "0 K = −273.15 °C"],
        ]
      : [
          ["Formula", "°C = K − 273.15"],
          ["Input", fmt(input) + " K"],
          ["Output", fmt(output) + " °C"],
          ["Absolute zero", "0 K = −273.15 °C"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classifyKelvin(k) {
    if (k === 0) return "Absolute zero";
    if (k < 273.15) return "Below freezing";
    if (k < 373.15) return "Liquid-water range";
    return "High temperature";
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }

    if (mode === "k-to-c" && raw < 0) {
      outEl.textContent = "Kelvin cannot be below 0.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "c-to-k" ? cToK(input) : kToC(input);

    if (mode === "c-to-k" && output < 0) {
      outEl.textContent = "Result would be below 0 K, which is not physically valid.";
      return;
    }

    if (mode === "c-to-k") {
      outEl.innerHTML =
        `<strong>Result:</strong> ${fmt(output)} K<br/>` +
        `<span class="note">${fmt(input)} °C = ${fmt(output)} K</span>`;
    } else {
      outEl.innerHTML =
        `<strong>Result:</strong> ${fmt(output)} °C<br/>` +
        `<span class="note">${fmt(input)} K = ${fmt(output)} °C</span>`;
    }

    const kelvin = mode === "c-to-k" ? output : input;
    const state = classifyKelvin(kelvin);

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(mode === "c-to-k" ? "°C → K" : "K → °C")}
        ${badge("Base ≈ " + fmtSmart(kelvin) + " K")}
        ${badge(state)}
      </div>
    `;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "c-to-k" ? "k-to-c" : "c-to-k";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>