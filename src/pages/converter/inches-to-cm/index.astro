---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Inches to CM Converter",
  description: "Convert inches (in) to centimeters (cm) instantly. Includes validation, accessible UX, result cards, and FAQ schema.",
  href: "/converter/inches-to-cm/",
  order: 21,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/inches-to-cm/";

const faqs = [
  {
    q: "What is the inches to cm formula?",
    a: "centimeters = inches × 2.54. (Because 1 inch = 2.54 cm exactly.)",
  },
  {
    q: "Is the conversion exact?",
    a: "Yes. The base relationship is exact; only displayed rounding can differ based on shown digits.",
  },
  {
    q: "Can I convert cm to inches here?",
    a: "Yes. Switch the direction to “Centimeters → Inches”.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Inches to CM Converter — ${SITE_NAME}`}
  description="Convert inches (in) to centimeters (cm) instantly, with an option to reverse (cm → in). Includes validation, accessible controls, result cards, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Inches to CM Converter"
  intro="Convert inches to centimeters (and centimeters to inches) using the exact 2.54 conversion."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="inches-to-cm">
    <div class="form" role="form" aria-describedby="i2c_privacy i2c_help">
      <div class="field">
        <label for="i2c_value">Value</label>
        <input
          id="i2c_value"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 72"
          aria-describedby="i2c_help"
        />
        <p class="note" id="i2c_help" style="margin-top:6px;">
          Uses the exact conversion: <strong>1 in = 2.54 cm</strong>.
        </p>
      </div>

      <div class="field">
        <label for="i2c_mode">Direction</label>
        <select id="i2c_mode">
          <option value="in_to_cm" selected>Inches → Centimeters</option>
          <option value="cm_to_in">Centimeters → Inches</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <button class="btn" type="button" id="i2c_calc">Convert</button>
        <button class="btn secondary" type="button" id="i2c_swap" aria-label="Swap direction">Swap</button>
        <button class="btn secondary" type="button" id="i2c_clear">Clear</button>
      </div>

      <div class="result" id="i2c_error" role="alert" style="display:none; margin-top:12px;"></div>

      <div class="result" id="i2c_result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div class="result" id="i2c_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Quick conversions</th>
              <th scope="col">Result</th>
            </tr>
          </thead>
          <tbody id="i2c_table"></tbody>
        </table>
      </div>

      <p class="note" id="i2c_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      <strong>in → cm:</strong> centimeters = inches × 2.54<br/>
      <strong>cm → in:</strong> inches = centimeters ÷ 2.54
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>72 in</strong> → <strong>182.88 cm</strong> (exact)</li>
      <li><strong>65 in</strong> → <strong>165.10 cm</strong> (approx. display)</li>
      <li><strong>180 cm</strong> → <strong>70.866 in</strong> (approx.)</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      {faqs.map((f) => (
        <li><strong>{f.q}</strong> {f.a}</li>
      ))}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/length/">Length Converter</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const valueEl = document.getElementById("i2c_value");
  const modeEl = document.getElementById("i2c_mode");
  const calcBtn = document.getElementById("i2c_calc");
  const swapBtn = document.getElementById("i2c_swap");
  const clearBtn = document.getElementById("i2c_clear");
  const errEl = document.getElementById("i2c_error");
  const resEl = document.getElementById("i2c_result");
  const cardsEl = document.getElementById("i2c_cards");
  const tbodyEl = document.getElementById("i2c_table");

  if (!valueEl || !modeEl || !calcBtn || !swapBtn || !clearBtn || !errEl || !resEl || !cardsEl || !tbodyEl) return;

  const FACTOR = 2.54;

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }
  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }
  function badge(text, kind) {
    const border = kind === "warn"
      ? "rgba(251,146,60,0.55)"
      : kind === "good"
      ? "rgba(34,197,94,0.55)"
      : "rgba(255,255,255,0.2)";
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid ${border}; font-size:12px; font-weight:900;">${text}</span>`;
  }

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    if (x === 0) return "0";
    const ax = Math.abs(x);
    if (ax >= 1e9 || ax < 1e-6) return x.toExponential(6);
    return (Math.round(x * 1e8) / 1e8).toString();
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const v = toNum(valueEl.value);
    if (!Number.isFinite(v)) {
      resEl.textContent = "Please enter a valid number.";
      return;
    }
    if (Math.abs(v) > 1e18) {
      showError("Value is too large for reliable display. Use a smaller magnitude.");
      resEl.textContent = "Result will appear here.";
      return;
    }

    const mode = String(modeEl.value);
    let out, fromUnit, toUnit;

    if (mode === "in_to_cm") {
      out = v * FACTOR;
      fromUnit = "in";
      toUnit = "cm";
    } else {
      out = v / FACTOR;
      fromUnit = "cm";
      toUnit = "in";
    }

    resEl.innerHTML =
      "<strong>Result:</strong> " + fmt(out) + " " + toUnit + "<br/>" +
      "<span class='note'>" + fmt(v) + " " + fromUnit + " = " + fmt(out) + " " + toUnit + "</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge("From: " + fromUnit, "neutral")}
        ${badge("To: " + toUnit, "neutral")}
        ${badge("1 in = 2.54 cm", "neutral")}
        ${badge("Converted", "good")}
      </div>
    `;

    const steps = mode === "in_to_cm"
      ? [v, v + 0.5, v + 1, v + 2]
      : [v, v + 1, v + 5, v + 10];

    for (const s of steps) {
      const o = mode === "in_to_cm" ? (s * FACTOR) : (s / FACTOR);
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = fmt(s) + " " + fromUnit;
      td2.textContent = fmt(o) + " " + toUnit;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    }
  }

  function reset() {
    clearError();
    valueEl.value = "";
    modeEl.value = "in_to_cm";
    resEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  calcBtn.addEventListener("click", compute);

  swapBtn.addEventListener("click", function () {
    modeEl.value = modeEl.value === "in_to_cm" ? "cm_to_in" : "in_to_cm";
    if (String(valueEl.value || "").trim()) compute();
  });

  clearBtn.addEventListener("click", reset);

  modeEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });

  valueEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  });

  valueEl.addEventListener("input", function () {
    if (!String(valueEl.value || "").trim()) {
      clearError();
      resEl.textContent = "Result will appear here.";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      tbodyEl.innerHTML = "";
    }
  });
});
</script>