---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Pressure Converter",
  description:
    "Convert pressure units instantly (psi, bar, kPa, Pa, atm, mmHg). Validated, accessible UX with result cards, quick table, and FAQ schema.",
  href: "/converter/pressure-converter/",
  order: 300,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/pressure-converter/";

const units = [
  { key: "psi", label: "Pounds per square inch (psi)" },
  { key: "bar", label: "Bar (bar)" },
  { key: "kpa", label: "Kilopascals (kPa)" },
  { key: "pa", label: "Pascals (Pa)" },
  { key: "atm", label: "Standard atmosphere (atm)" },
  { key: "mmhg", label: "Millimeters of mercury (mmHg)" },
];

const faqs = [
  {
    q: "How do you convert psi to bar?",
    a: "Multiply psi by 0.0689475729 to get bar.",
  },
  {
    q: "How do you convert bar to psi?",
    a: "Multiply bar by 14.5037738 to get psi.",
  },
  {
    q: "What is 1 atmosphere in pressure units?",
    a: "1 atm equals 101,325 Pa, 101.325 kPa, 1.01325 bar, 14.6959 psi, and 760 mmHg.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. Conversions run locally in your browser. Nothing is stored or transmitted.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Pressure Converter — ${SITE_NAME}`}
  description="Convert pressure units instantly (psi, bar, kPa, Pa, atm, mmHg). Includes unit UX, input validation, accessible controls, result cards, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Pressure Converter"
  intro="Convert between common pressure units. Enter a value, choose “from” and “to” units, and see the converted result plus a quick reference table."
  faq={faqs}
  categoryName="Converters"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="pressure-converter">
    <div class="form" role="form" aria-describedby="pc_hint pc_privacy">
      <div class="field">
        <label for="pc_value">Value</label>
        <input
          id="pc_value"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 100"
          aria-describedby="pc_hint"
        />
        <p class="note" id="pc_hint" style="margin-top:6px;">
          Tip: Use decimals if needed. Press <kbd>Ctrl</kbd>/<kbd>Cmd</kbd> + <kbd>Enter</kbd> to convert.
        </p>
      </div>

      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
        <div class="field">
          <label for="pc_from">From</label>
          <select id="pc_from">
            {units.map((u) => <option value={u.key}>{u.label}</option>)}
          </select>
        </div>

        <div class="field">
          <label for="pc_to">To</label>
          <select id="pc_to">
            {units.map((u) => <option value={u.key}>{u.label}</option>)}
          </select>
        </div>
      </div>

      <div class="field">
        <label for="pc_round">Rounding</label>
        <select id="pc_round">
          <option value="2">2 decimals</option>
          <option value="4" selected>4 decimals</option>
          <option value="8">8 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <button class="btn" type="button" id="pc_convert">Convert</button>
        <button class="btn secondary" type="button" id="pc_swap" aria-label="Swap units">Swap</button>
        <button class="btn secondary" type="button" id="pc_clear">Clear</button>
      </div>

      <div class="result" id="pc_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="pc_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="pc_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Unit</th>
              <th scope="col">Equivalent</th>
            </tr>
          </thead>
          <tbody id="pc_table"></tbody>
        </table>
      </div>

      <p class="note" id="pc_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Converts using <strong>pascals (Pa)</strong> as a base unit. Example factors:
      <br />
      <strong>1 bar = 100,000 Pa</strong>
      <br />
      <strong>1 psi = 6,894.757293168 Pa</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1 atm</strong> = <strong>101.325 kPa</strong></li>
      <li><strong>1 bar</strong> ≈ <strong>14.5038 psi</strong></li>
      <li><strong>760 mmHg</strong> = <strong>1 atm</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/psi-to-bar/">psi to bar</a></li>
      <li><a href="/converter/bar-to-psi/">bar to psi</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const valueEl = document.getElementById("pc_value");
  const fromEl = document.getElementById("pc_from");
  const toEl = document.getElementById("pc_to");
  const roundEl = document.getElementById("pc_round");
  const convertBtn = document.getElementById("pc_convert");
  const swapBtn = document.getElementById("pc_swap");
  const clearBtn = document.getElementById("pc_clear");
  const errEl = document.getElementById("pc_error");
  const resEl = document.getElementById("pc_result");
  const cardsEl = document.getElementById("pc_cards");
  const tbodyEl = document.getElementById("pc_table");

  if (!valueEl || !fromEl || !toEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !resEl || !cardsEl || !tbodyEl) return;

  const TO_PA = {
    psi: 6894.757293168,
    bar: 100000,
    kpa: 1000,
    pa: 1,
    atm: 101325,
    mmhg: 133.322387415
  };

  const LABEL = {
    psi: "Pounds per square inch (psi)",
    bar: "Bar (bar)",
    kpa: "Kilopascals (kPa)",
    pa: "Pascals (Pa)",
    atm: "Standard atmosphere (atm)",
    mmhg: "Millimeters of mercury (mmHg)"
  };

  const ORDER = ["psi", "bar", "kpa", "pa", "atm", "mmhg"];

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }
  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }
  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }
  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    if (x === 0) return "0";
    const ax = Math.abs(x);
    if (ax >= 1e12 || ax < 1e-12) return x.toExponential(6);
    return String(Number(x.toPrecision(10)));
  }
  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value || "auto");
    if (r === "auto") return fmtSmart(x);
    const d = parseInt(r, 10);
    if (!Number.isFinite(d) || d < 0) return fmtSmart(x);
    return (Object.is(x, -0) ? 0 : x).toLocaleString(undefined, { minimumFractionDigits: d, maximumFractionDigits: d });
  }
  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function convert(value, fromU, toU) {
    const f = TO_PA[fromU];
    const t = TO_PA[toU];
    if (!Number.isFinite(f) || !Number.isFinite(t)) return NaN;
    const pa = value * f;
    return pa / t;
  }

  function classify(pa) {
    const a = Math.abs(pa);
    if (a === 0) return "Zero pressure";
    if (a < 1000) return "Low pressure";
    if (a < 101325) return "Sub-atmospheric range";
    if (a < 1000000) return "Typical industrial range";
    return "High pressure";
  }

  function buildTable(value, fromU) {
    tbodyEl.innerHTML = "";
    for (const u of ORDER) {
      const v = convert(value, fromU, u);
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = LABEL[u];
      td2.textContent = fmtSmart(v);
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    }
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(valueEl.value);
    const fromU = String(fromEl.value);
    const toU = String(toEl.value);

    if (!Number.isFinite(raw)) {
      resEl.textContent = "Please enter a valid pressure value.";
      return;
    }

    if (Math.abs(raw) > 1e18) {
      showError("Value is too large for reliable display. Use a smaller magnitude.");
      resEl.textContent = "Result will appear here.";
      return;
    }

    const out = convert(raw, fromU, toU);
    if (!Number.isFinite(out)) {
      showError("Could not convert with these units.");
      resEl.textContent = "Result will appear here.";
      return;
    }

    const inPa = raw * TO_PA[fromU];
    resEl.innerHTML =
      "<strong>Result:</strong> " + fmt(out) + " <span class='note'>(" + toU + ")</span><br/>" +
      "<span class='note'>" + fmtSmart(raw) + " (" + fromU + ") = " + fmtSmart(inPa) + " (Pa) = " + fmtSmart(out) + " (" + toU + ")</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge("From: " + fromU)}
        ${badge("To: " + toU)}
        ${badge("Base: pascals")}
        ${badge(classify(inPa))}
      </div>
    `;

    buildTable(raw, fromU);
  }

  function reset() {
    clearError();
    valueEl.value = "";
    fromEl.value = "psi";
    toEl.value = "bar";
    roundEl.value = "4";
    resEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    const a = fromEl.value;
    fromEl.value = toEl.value;
    toEl.value = a;
    if (String(valueEl.value || "").trim()) compute();
  });
  clearBtn.addEventListener("click", reset);

  fromEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });
  toEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });
  roundEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });

  valueEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  });

  valueEl.addEventListener("input", function () {
    if (!String(valueEl.value || "").trim()) {
      clearError();
      resEl.textContent = "Result will appear here.";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      tbodyEl.innerHTML = "";
    }
  });

  fromEl.value = "psi";
  toEl.value = "bar";
  roundEl.value = "4";
});
</script>