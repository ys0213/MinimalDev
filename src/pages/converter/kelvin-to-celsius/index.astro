---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Kelvin to Celsius",
  description:
    "Convert Kelvin to Celsius instantly. Includes validation, reverse mode, result cards, and FAQ support.",
  href: "/converter/kelvin-to-celsius/",
  order: 319,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/kelvin-to-celsius/";

const faqs = [
  {
    q: "How do you convert Kelvin to Celsius?",
    a: "Use the formula °C = K − 273.15.",
  },
  {
    q: "Can Kelvin be negative?",
    a: "No. Kelvin cannot be below 0 K.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between Kelvin to Celsius and Celsius to Kelvin.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Kelvin to Celsius Converter — ${SITE_NAME}`}
  description="Convert Kelvin to Celsius instantly with validation, reverse mode, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="Kelvin to Celsius Converter"
  intro="Convert temperature from Kelvin to Celsius instantly. Useful for science, engineering, and absolute temperature comparisons."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="kelvin-to-celsius">
    <div class="form" role="form" aria-describedby="k2c_hint k2c_privacy">
      <div class="field">
        <label for="k2c_input">Kelvin (K)</label>
        <input id="k2c_input" type="number" inputmode="decimal" placeholder="e.g., 273.15" />
        <p class="note" id="k2c_hint" style="margin-top:6px;">
          Kelvin cannot be below 0. Zero kelvin is absolute zero.
        </p>
      </div>

      <div class="field">
        <label for="k2c_round">Rounding</label>
        <select id="k2c_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="k2c_convert">Convert</button>
        <button class="btn secondary" type="button" id="k2c_swap">Reverse (°C → K)</button>
        <button class="btn secondary" type="button" id="k2c_clear">Clear</button>
      </div>

      <div class="result" id="k2c_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="k2c_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="k2c_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="k2c_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="k2c_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard conversion: <strong>°C = K − 273.15</strong>.<br />
      Reverse formula: <strong>K = °C + 273.15</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>273.15 K</strong> = <strong>0°C</strong></li>
      <li><strong>298.15 K</strong> = <strong>25°C</strong></li>
      <li><strong>373.15 K</strong> = <strong>100°C</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/temperature-converter/">Temperature Converter</a></li>
      <li><a href="/converter/celsius-to-kelvin/">Celsius to Kelvin</a></li>
      <li><a href="/converter/c-to-f/">C to F</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("k2c_input");
  const roundEl = document.getElementById("k2c_round");
  const convertBtn = document.getElementById("k2c_convert");
  const swapBtn = document.getElementById("k2c_swap");
  const clearBtn = document.getElementById("k2c_clear");
  const errEl = document.getElementById("k2c_error");
  const outEl = document.getElementById("k2c_result");
  const cardsEl = document.getElementById("k2c_cards");
  const tbodyEl = document.getElementById("k2c_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  let mode = "k-to-c";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function kToC(k) {
    return k - 273.15;
  }

  function cToK(c) {
    return c + 273.15;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) {
      return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    }
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    const d = parseInt(r, 10);
    return x.toFixed(d);
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="k2c_input"]');
    if (!label) return;

    if (mode === "k-to-c") {
      label.textContent = "Kelvin (K)";
      inEl.placeholder = "e.g., 273.15";
      swapBtn.textContent = "Reverse (°C → K)";
    } else {
      label.textContent = "Celsius (°C)";
      inEl.placeholder = "e.g., 0";
      swapBtn.textContent = "Reverse (K → °C)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";

    const rows = mode === "k-to-c"
      ? [
          ["Formula", "°C = K − 273.15"],
          ["Input", fmt(input) + " K"],
          ["Output", fmt(output) + " °C"],
          ["Absolute zero", "0 K = −273.15 °C"],
        ]
      : [
          ["Formula", "K = °C + 273.15"],
          ["Input", fmt(input) + " °C"],
          ["Output", fmt(output) + " K"],
          ["Absolute zero", "0 K = −273.15 °C"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classifyKelvin(k) {
    if (k === 0) return "Absolute zero";
    if (k < 273.15) return "Below freezing";
    if (k < 373.15) return "Liquid-water range";
    return "High temperature";
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }

    if (mode === "k-to-c" && raw < 0) {
      outEl.textContent = "Kelvin cannot be below 0.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "k-to-c" ? kToC(input) : cToK(input);

    if (mode === "c-to-k" && output < 0) {
      outEl.textContent = "Result would be below 0 K, which is not physically valid.";
      return;
    }

    if (mode === "k-to-c") {
      outEl.innerHTML =
        `<strong>Result:</strong> ${fmt(output)} °C<br/>` +
        `<span class="note">${fmt(input)} K = ${fmt(output)} °C</span>`;
    } else {
      outEl.innerHTML =
        `<strong>Result:</strong> ${fmt(output)} K<br/>` +
        `<span class="note">${fmt(input)} °C = ${fmt(output)} K</span>`;
    }

    const kelvin = mode === "k-to-c" ? input : output;
    const state = classifyKelvin(kelvin);

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(mode === "k-to-c" ? "K → °C" : "°C → K")}
        ${badge("Base ≈ " + fmtSmart(kelvin) + " K")}
        ${badge(state)}
      </div>
    `;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "k-to-c" ? "c-to-k" : "k-to-c";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>