---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Hours to Days",
  description:
    "Convert hours to days instantly. Includes validation, reverse mode, result cards, and FAQ support.",
  href: "/converter/hours-to-days/",
  order: 329,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/hours-to-days/";

const faqs = [
  {
    q: "How do you convert hours to days?",
    a: "Divide hours by 24, because 24 hours equal 1 day.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between hours to days and days to hours.",
  },
  {
    q: "Can I use decimal hours?",
    a: "Yes. This tool accepts fractional hour values and returns decimal days.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Hours to Days Converter — ${SITE_NAME}`}
  description="Convert hours to days instantly with validation, reverse mode, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="Hours to Days Converter"
  intro="Convert time from hours to days instantly. Useful for schedules, project planning, travel timing, and duration conversion."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="hours-to-days">
    <div class="form" role="form" aria-describedby="h2d_hint h2d_privacy">
      <div class="field">
        <label for="h2d_input">Hours</label>
        <input id="h2d_input" type="number" inputmode="decimal" placeholder="e.g., 36" />
        <p class="note" id="h2d_hint" style="margin-top:6px;">
          Enter a non-negative value. 24 hours equal 1 day.
        </p>
      </div>

      <div class="field">
        <label for="h2d_round">Rounding</label>
        <select id="h2d_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="h2d_convert">Convert</button>
        <button class="btn secondary" type="button" id="h2d_swap">Reverse (days → hr)</button>
        <button class="btn secondary" type="button" id="h2d_clear">Clear</button>
      </div>

      <div class="result" id="h2d_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="h2d_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="h2d_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="h2d_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="h2d_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard time conversion: <strong>24 hours = 1 day</strong>.<br />
      Formula: <strong>days = hours ÷ 24</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>24 hours</strong> = <strong>1 day</strong></li>
      <li><strong>36 hours</strong> = <strong>1.5 days</strong></li>
      <li><strong>168 hours</strong> = <strong>7 days</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/time-converter/">Time Converter</a></li>
      <li><a href="/converter/days-to-hours/">Days to Hours</a></li>
      <li><a href="/converter/minutes-to-hours/">Minutes to Hours</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("h2d_input");
  const roundEl = document.getElementById("h2d_round");
  const convertBtn = document.getElementById("h2d_convert");
  const swapBtn = document.getElementById("h2d_swap");
  const clearBtn = document.getElementById("h2d_clear");
  const errEl = document.getElementById("h2d_error");
  const outEl = document.getElementById("h2d_result");
  const cardsEl = document.getElementById("h2d_cards");
  const tbodyEl = document.getElementById("h2d_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const HOUR_TO_DAY = 1 / 24;
  const DAY_TO_HOUR = 24;
  let mode = "hour-to-day";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="h2d_input"]');
    if (!label) return;
    if (mode === "hour-to-day") {
      label.textContent = "Hours";
      inEl.placeholder = "e.g., 36";
      swapBtn.textContent = "Reverse (days → hr)";
    } else {
      label.textContent = "Days";
      inEl.placeholder = "e.g., 1.5";
      swapBtn.textContent = "Reverse (hr → days)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "hour-to-day"
      ? [
          ["Conversion factor", "24 hr = 1 day"],
          ["Formula", "days = hr ÷ 24"],
          ["Input", fmt(input) + " hr"],
          ["Output", fmt(output) + " days"],
        ]
      : [
          ["Conversion factor", "1 day = 24 hr"],
          ["Formula", "hr = days × 24"],
          ["Input", fmt(input) + " days"],
          ["Output", fmt(output) + " hr"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classifyDays(days) {
    if (days < 1) return "Under one day";
    if (days < 7) return "Multi-day duration";
    return "One week or more";
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "hour-to-day" ? input * HOUR_TO_DAY : input * DAY_TO_HOUR;

    if (mode === "hour-to-day") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} days<br/><span class="note">${fmt(input)} hr = ${fmt(output)} days</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} hr<br/><span class="note">${fmt(input)} days = ${fmt(output)} hr</span>`;
    }

    const days = mode === "hour-to-day" ? output : input;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(mode === "hour-to-day" ? "hr → days" : "days → hr")}
        ${badge("Base ≈ " + fmtSmart(days) + " days")}
        ${badge(classifyDays(days))}
      </div>
    `;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "hour-to-day" ? "day-to-hour" : "hour-to-day";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>