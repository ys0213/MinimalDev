---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Hours to Minutes",
  description:
    "Convert hours to minutes instantly. Includes validation, reverse mode, result cards, and FAQ support.",
  href: "/converter/hours-to-minutes/",
  order: 327,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/hours-to-minutes/";

const faqs = [
  {
    q: "How do you convert hours to minutes?",
    a: "Multiply hours by 60, because 1 hour equals 60 minutes.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between hours to minutes and minutes to hours.",
  },
  {
    q: "Can I enter decimal hours?",
    a: "Yes. This tool accepts decimal values, so 1.5 hours converts to 90 minutes.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Hours to Minutes Converter — ${SITE_NAME}`}
  description="Convert hours to minutes instantly with validation, reverse mode, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="Hours to Minutes Converter"
  intro="Convert time from hours to minutes instantly. Useful for time tracking, work logs, schedules, and duration conversion."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="hours-to-minutes">
    <div class="form" role="form" aria-describedby="h2m_hint h2m_privacy">
      <div class="field">
        <label for="h2m_input">Hours</label>
        <input id="h2m_input" type="number" inputmode="decimal" placeholder="e.g., 1.5" />
        <p class="note" id="h2m_hint" style="margin-top:6px;">
          Enter a non-negative value. 1 hour equals 60 minutes.
        </p>
      </div>

      <div class="field">
        <label for="h2m_round">Rounding</label>
        <select id="h2m_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="h2m_convert">Convert</button>
        <button class="btn secondary" type="button" id="h2m_swap">Reverse (min → hr)</button>
        <button class="btn secondary" type="button" id="h2m_clear">Clear</button>
      </div>

      <div class="result" id="h2m_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="h2m_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="h2m_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="h2m_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="h2m_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard time conversion: <strong>1 hour = 60 minutes</strong>.<br />
      Formula: <strong>minutes = hours × 60</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1 hour</strong> = <strong>60 minutes</strong></li>
      <li><strong>1.5 hours</strong> = <strong>90 minutes</strong></li>
      <li><strong>3 hours</strong> = <strong>180 minutes</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/time-converter/">Time Converter</a></li>
      <li><a href="/converter/minutes-to-hours/">Minutes to Hours</a></li>
      <li><a href="/converter/hours-to-days/">Hours to Days</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("h2m_input");
  const roundEl = document.getElementById("h2m_round");
  const convertBtn = document.getElementById("h2m_convert");
  const swapBtn = document.getElementById("h2m_swap");
  const clearBtn = document.getElementById("h2m_clear");
  const errEl = document.getElementById("h2m_error");
  const outEl = document.getElementById("h2m_result");
  const cardsEl = document.getElementById("h2m_cards");
  const tbodyEl = document.getElementById("h2m_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const HOUR_TO_MIN = 60;
  const MIN_TO_HOUR = 1 / 60;
  let mode = "hour-to-min";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="h2m_input"]');
    if (!label) return;
    if (mode === "hour-to-min") {
      label.textContent = "Hours";
      inEl.placeholder = "e.g., 1.5";
      swapBtn.textContent = "Reverse (min → hr)";
    } else {
      label.textContent = "Minutes";
      inEl.placeholder = "e.g., 90";
      swapBtn.textContent = "Reverse (hr → min)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "hour-to-min"
      ? [
          ["Conversion factor", "1 hr = 60 min"],
          ["Formula", "min = hr × 60"],
          ["Input", fmt(input) + " hr"],
          ["Output", fmt(output) + " min"],
        ]
      : [
          ["Conversion factor", "60 min = 1 hr"],
          ["Formula", "hr = min ÷ 60"],
          ["Input", fmt(input) + " min"],
          ["Output", fmt(output) + " hr"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classifyHours(hours) {
    if (hours < 1) return "Under one hour";
    if (hours < 24) return "Typical duration";
    return "One day or more";
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "hour-to-min" ? input * HOUR_TO_MIN : input * MIN_TO_HOUR;

    if (mode === "hour-to-min") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} min<br/><span class="note">${fmt(input)} hr = ${fmt(output)} min</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} hr<br/><span class="note">${fmt(input)} min = ${fmt(output)} hr</span>`;
    }

    const hours = mode === "hour-to-min" ? input : output;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(mode === "hour-to-min" ? "hr → min" : "min → hr")}
        ${badge("Base ≈ " + fmtSmart(hours) + " hr")}
        ${badge(classifyHours(hours))}
      </div>
    `;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "hour-to-min" ? "min-to-hour" : "hour-to-min";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>