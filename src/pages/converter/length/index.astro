---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Length Converter",
  description:
    "Convert length units instantly (mm, cm, m, km, in, ft, yd, mi). Includes validation, unit UX, and FAQ schema.",
  href: "/converter/length/",
  order: 10,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/length/";

const units = [
  { key: "mm", label: "Millimeters (mm)" },
  { key: "cm", label: "Centimeters (cm)" },
  { key: "m", label: "Meters (m)" },
  { key: "km", label: "Kilometers (km)" },
  { key: "in", label: "Inches (in)" },
  { key: "ft", label: "Feet (ft)" },
  { key: "yd", label: "Yards (yd)" },
  { key: "mi", label: "Miles (mi)" },
];

// Base unit: meter (m)
const TO_M = {
  mm: 0.001,
  cm: 0.01,
  m: 1,
  km: 1000,
  in: 0.0254,
  ft: 0.3048,
  yd: 0.9144,
  mi: 1609.344,
};

const faqs = [
  {
    q: "Is this length converter accurate?",
    a: "It uses fixed conversion factors (e.g., 1 in = 0.0254 m, 1 mi = 1609.344 m). Results are rounded for display.",
  },
  {
    q: "Does it support negative lengths?",
    a: "You can enter negative values for math purposes, but real-world lengths are usually non-negative.",
  },
  {
    q: "Why do I see rounding differences?",
    a: "The tool formats results with a limited number of significant digits and may trim trailing zeros.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. Conversions run locally in your browser and are not sent to a server.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Length Converter — ${SITE_NAME}`}
  description="Convert length units instantly (mm, cm, m, km, inches, feet, yards, miles). Includes unit UX, input validation, accessible controls, result cards, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Length Converter"
  intro="Convert between common length units. Enter a value, choose “from” and “to” units, and see the converted result with quick reference conversions."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="length-converter">
    <div class="form" role="form" aria-describedby="len_privacy len_help">
      <div class="field">
        <label for="len_value">Value</label>
        <input
          id="len_value"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 12.5"
          aria-describedby="len_help"
        />
        <p class="note" id="len_help" style="margin-top:6px;">
          Tip: Use decimals (e.g., 2.54). For very large/small values, rounding may apply.
        </p>
      </div>

      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
        <div class="field">
          <label for="len_from">From</label>
          <select id="len_from">
            {units.map((u) => <option value={u.key}>{u.label}</option>)}
          </select>
        </div>

        <div class="field">
          <label for="len_to">To</label>
          <select id="len_to">
            {units.map((u) => <option value={u.key}>{u.label}</option>)}
          </select>
        </div>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <button class="btn" type="button" id="len_convert">Convert</button>
        <button class="btn secondary" type="button" id="len_swap" aria-label="Swap units">Swap</button>
        <button class="btn secondary" type="button" id="len_clear">Clear</button>
      </div>

      <div class="result" id="len_error" role="alert" style="display:none; margin-top:12px;"></div>

      <div class="result" id="len_result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div class="result" id="len_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Unit</th>
              <th scope="col">Equivalent</th>
            </tr>
          </thead>
          <tbody id="len_table"></tbody>
        </table>
      </div>

      <p class="note" id="len_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Convert by using meters as a base unit:
      <br />
      <strong>value_in_m = value × (fromUnit → meters)</strong>
      <br />
      <strong>value_in_to = value_in_m ÷ (toUnit → meters)</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>2.54 cm</strong> → <strong>1 in</strong></li>
      <li><strong>1 mi</strong> → <strong>1,609.344 m</strong></li>
      <li><strong>1 m</strong> → <strong>3.28084 ft</strong> (approx.)</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>
      {faqs.map((f) => (
        <li><strong>{f.q}</strong> {f.a}</li>
      ))}
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/">All Converters</a></li>
      <li><a href="/math/">Math Tools</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const valueEl = document.getElementById("len_value");
  const fromEl = document.getElementById("len_from");
  const toEl = document.getElementById("len_to");
  const convertBtn = document.getElementById("len_convert");
  const swapBtn = document.getElementById("len_swap");
  const clearBtn = document.getElementById("len_clear");
  const errEl = document.getElementById("len_error");
  const resEl = document.getElementById("len_result");
  const cardsEl = document.getElementById("len_cards");
  const tbodyEl = document.getElementById("len_table");

  if (!valueEl || !fromEl || !toEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !resEl || !cardsEl || !tbodyEl) return;

  const TO_M = {
    mm: 0.001,
    cm: 0.01,
    m: 1,
    km: 1000,
    in: 0.0254,
    ft: 0.3048,
    yd: 0.9144,
    mi: 1609.344
  };

  const LABEL = {
    mm: "Millimeters (mm)",
    cm: "Centimeters (cm)",
    m: "Meters (m)",
    km: "Kilometers (km)",
    in: "Inches (in)",
    ft: "Feet (ft)",
    yd: "Yards (yd)",
    mi: "Miles (mi)"
  };

  const ORDER = ["mm","cm","m","km","in","ft","yd","mi"];

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }
  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }
  function badge(text, kind) {
    const border = kind === "warn"
      ? "rgba(251,146,60,0.55)"
      : kind === "good"
      ? "rgba(34,197,94,0.55)"
      : "rgba(255,255,255,0.2)";
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid ${border}; font-size:12px; font-weight:900;">${text}</span>`;
  }

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function fmtNumber(x) {
    if (!Number.isFinite(x)) return "—";
    if (x === 0) return "0";
    const ax = Math.abs(x);
    // For very large/small numbers, use scientific notation with 6 sig figs
    if (ax >= 1e9 || ax < 1e-6) {
      return x.toExponential(6);
    }
    // Otherwise show up to 10 significant digits, trim trailing zeros
    const s = x.toPrecision(10);
    const n = Number(s);
    // If Number(...) collapses to scientific with toString, that's fine.
    return n.toString();
  }

  function convert(value, fromU, toU) {
    const f = TO_M[fromU];
    const t = TO_M[toU];
    if (!Number.isFinite(f) || !Number.isFinite(t)) return NaN;
    const m = value * f;
    return m / t;
  }

  function buildTable(value, fromU) {
    tbodyEl.innerHTML = "";
    for (const u of ORDER) {
      const v = convert(value, fromU, u);
      const tr = document.createElement("tr");

      const td1 = document.createElement("td");
      td1.textContent = LABEL[u];

      const td2 = document.createElement("td");
      td2.textContent = fmtNumber(v);

      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    }
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";

    const value = toNum(valueEl.value);
    const fromU = String(fromEl.value);
    const toU = String(toEl.value);

    if (!Number.isFinite(value)) {
      resEl.textContent = "Please enter a valid number.";
      tbodyEl.innerHTML = "";
      return;
    }

    // Reasonable guardrail for UI
    if (Math.abs(value) > 1e18) {
      showError("Value is too large for reliable display. Use a smaller magnitude.");
      resEl.textContent = "Result will appear here.";
      tbodyEl.innerHTML = "";
      return;
    }

    const out = convert(value, fromU, toU);
    if (!Number.isFinite(out)) {
      showError("Could not convert with these units.");
      resEl.textContent = "Result will appear here.";
      tbodyEl.innerHTML = "";
      return;
    }

    const inMeters = value * TO_M[fromU];
    const inTo = out;

    resEl.innerHTML =
      "<strong>Result:</strong> " + fmtNumber(inTo) + " <span class='note'>(" + toU + ")</span><br/>" +
      "<span class='note'>" + fmtNumber(value) + " (" + fromU + ") = " + fmtNumber(inMeters) + " (m) = " + fmtNumber(inTo) + " (" + toU + ")</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge("From: " + fromU, "neutral")}
        ${badge("To: " + toU, "neutral")}
        ${badge("Base: meters", "neutral")}
        ${badge(Number.isFinite(out) ? "Converted" : "Error", Number.isFinite(out) ? "good" : "warn")}
      </div>
    `;

    buildTable(value, fromU);
  }

  function reset() {
    clearError();
    valueEl.value = "";
    fromEl.value = "cm";
    toEl.value = "in";
    resEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);

  swapBtn.addEventListener("click", function () {
    const a = fromEl.value;
    fromEl.value = toEl.value;
    toEl.value = a;
    if (String(valueEl.value || "").trim()) compute();
  });

  clearBtn.addEventListener("click", reset);

  // Unit UX: recompute on changes if a value exists
  fromEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });
  toEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });

  // Optional live compute (lightweight): only when input is non-empty
  valueEl.addEventListener("input", function () {
    if (!String(valueEl.value || "").trim()) {
      clearError();
      resEl.textContent = "Result will appear here.";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      tbodyEl.innerHTML = "";
      return;
    }
  });

  // Ctrl/Cmd+Enter to convert
  const keyHandler = function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  };
  valueEl.addEventListener("keydown", keyHandler);
  fromEl.addEventListener("keydown", keyHandler);
  toEl.addEventListener("keydown", keyHandler);

  // Default selections (good UX)
  fromEl.value = "cm";
  toEl.value = "in";
});
</script>