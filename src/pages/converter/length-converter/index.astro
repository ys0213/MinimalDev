---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Length Converter",
  description: "Convert mm, cm, m, km, in, ft, yd, and mi instantly. Fast and mobile-first.",
  href: "/converter/length-converter/",
  order: 10,
};

const faq = [
  {
    q: "Does it support decimals?",
    a: "Yes. You can enter decimal values and get decimal results.",
  },
  {
    q: "How accurate are the results?",
    a: "It uses standard conversion constants (for example, 1 inch = 0.0254 m and 1 mile = 1609.344 m). Displayed values may be rounded for readability.",
  },
  {
    q: "Why do I see “approx.” in some places?",
    a: "Some conversions produce long or repeating decimals. The tool rounds the display, but the underlying conversion uses standard constants.",
  },
  {
    q: "Does this store my inputs?",
    a: "No. Calculations run locally in your browser and are not sent to a server.",
  },
];
---

<ToolLayout
  title="Length Converter — MinimalDev"
  description="Free length converter for mm, cm, meters, km, inches, feet, yards, and miles. Instant results with standard conversion constants."
  canonicalPath="/converter/length-converter/"
  h1="Length Converter"
  intro="Convert length units instantly between metric and imperial measurements. Results update live as you type."
  faq={faq}
>
  <div slot="tool" data-tool="length-converter">
    <div class="form">
      <div class="field">
        <label for="lc_value">Value</label>
        <input id="lc_value" type="number" inputmode="decimal" placeholder="e.g., 10" />
      </div>

      <div class="field">
        <label for="lc_from_unit">From</label>
        <select id="lc_from_unit">
          <option value="mm">Millimeter (mm)</option>
          <option value="cm">Centimeter (cm)</option>
          <option value="m" selected>Meter (m)</option>
          <option value="km">Kilometer (km)</option>
          <option value="in">Inch (in)</option>
          <option value="ft">Foot (ft)</option>
          <option value="yd">Yard (yd)</option>
          <option value="mi">Mile (mi)</option>
        </select>
      </div>

      <div class="field">
        <label for="lc_to_unit">To</label>
        <select id="lc_to_unit">
          <option value="mm">Millimeter (mm)</option>
          <option value="cm">Centimeter (cm)</option>
          <option value="m">Meter (m)</option>
          <option value="km" selected>Kilometer (km)</option>
          <option value="in">Inch (in)</option>
          <option value="ft">Foot (ft)</option>
          <option value="yd">Yard (yd)</option>
          <option value="mi">Mile (mi)</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn secondary" type="button" id="lc_swap">Swap</button>
        <button class="btn secondary" type="button" id="lc_clear">Clear</button>
      </div>

      <div class="result" id="lc_result">Result will appear here.</div>

      <p class="note" style="margin-top:8px;">
        Privacy: calculations run locally in your browser. No data is sent to a server.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      This length converter supports both metric and imperial units and updates instantly as you type.
      It’s designed to be quick on mobile: one input, two unit selectors, and a clear result.
    </p>

    <p class="note">
      Internally, the tool converts through a base unit (meter). Your input value is first converted to meters,
      then converted to the target unit using standard conversion constants (for example: 1 inch = 0.0254 m,
      1 mile = 1609.344 m).
    </p>

    <p class="note">
      If a conversion produces a long decimal, the result is rounded for display. This keeps the output readable
      while still using correct constants under the hood.
    </p>

    <ul>
      <li><strong>Supported units:</strong> mm, cm, m, km, in, ft, yd, mi</li>
      <li><strong>Decimals:</strong> supported (e.g., 2.54 cm)</li>
      <li><strong>Tip:</strong> use “Swap” to reverse direction without retyping</li>
    </ul>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>10 km</strong> → <strong>6.213712 mi</strong> (approx.)</li>
      <li><strong>180 cm</strong> → <strong>5.905512 ft</strong> (approx.)</li>
      <li><strong>12 in</strong> → <strong>30.48 cm</strong> (exact)</li>
      <li><strong>1 mi</strong> → <strong>1.609344 km</strong> (exact)</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/weight-converter/">Weight Converter</a></li>
      <li><a href="/converter/temperature-converter/">Temperature Converter</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const valueEl = document.getElementById("lc_value");
  const fromEl = document.getElementById("lc_from_unit");
  const toEl = document.getElementById("lc_to_unit");
  const swapBtn = document.getElementById("lc_swap");
  const clearBtn = document.getElementById("lc_clear");
  const resultEl = document.getElementById("lc_result");

  if (!valueEl || !fromEl || !toEl || !swapBtn || !clearBtn || !resultEl) return;

  const toMeters = {
    mm: 0.001,
    cm: 0.01,
    m: 1,
    km: 1000,
    in: 0.0254,
    ft: 0.3048,
    yd: 0.9144,
    mi: 1609.344,
  };

  const labels = {
    mm: "mm",
    cm: "cm",
    m: "m",
    km: "km",
    in: "in",
    ft: "ft",
    yd: "yd",
    mi: "mi",
  };

  function isFiniteNumber(x) {
    return typeof x === "number" && isFinite(x);
  }

  function fmt(n) {
    if (!isFiniteNumber(n)) return "";
    const abs = Math.abs(n);
    const decimals =
      abs === 0 ? 0 :
      abs < 1 ? 8 :
      abs < 10 ? 6 :
      abs < 100 ? 4 :
      2;
    return n.toLocaleString(undefined, { maximumFractionDigits: decimals });
  }

  function calc() {
    const raw = parseFloat(valueEl.value);
    const from = String(fromEl.value);
    const to = String(toEl.value);

    if (!isFiniteNumber(raw)) {
      resultEl.textContent = "Result will appear here.";
      return;
    }

    const fromFactor = toMeters[from];
    const toFactor = toMeters[to];
    if (!isFiniteNumber(fromFactor) || !isFiniteNumber(toFactor) || toFactor === 0) {
      resultEl.textContent = "Unsupported unit selection.";
      return;
    }

    const meters = raw * fromFactor;
    const out = meters / toFactor;

    const primary = fmt(out);
    const approx = (Math.abs(out) > 0 && String(primary) !== String(out)) ? " (approx.)" : "";

    resultEl.innerHTML =
      "<strong>" + primary + " " + labels[to] + "</strong>" + approx +
      "<div class='note' style='margin-top:6px;'>" +
        fmt(raw) + " " + labels[from] + " = " + primary + " " + labels[to] +
      "</div>";
  }

  valueEl.addEventListener("input", calc);
  fromEl.addEventListener("change", calc);
  toEl.addEventListener("change", calc);

  swapBtn.addEventListener("click", function () {
    const a = fromEl.value;
    fromEl.value = toEl.value;
    toEl.value = a;
    calc();
  });

  clearBtn.addEventListener("click", function () {
    valueEl.value = "";
    resultEl.textContent = "Result will appear here.";
  });

  // initial render (in case defaults + value exist)
  calc();
});
</script>