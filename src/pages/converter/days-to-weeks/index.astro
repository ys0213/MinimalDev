---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Days to Weeks",
  description:
    "Convert days to weeks for planning, timelines, and duration comparisons.",
  href: "/converter/days-to-weeks/",
  order: 331,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/days-to-weeks/";

const faqs = [
  {
    q: "How do you convert days to weeks?",
    a: "Divide days by 7, because 7 days equal 1 week.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between days to weeks and weeks to days.",
  },
  {
    q: "Can I use decimal days?",
    a: "Yes. This tool accepts decimal values and can show fractional weeks.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Days to Weeks Converter — ${SITE_NAME}`}
  description="Convert days to weeks with clear results for schedules, project timelines, waiting periods, and duration estimates."
  canonicalPath={CANONICAL_PATH}
  h1="Days to Weeks Converter"
  intro="Convert time from days to weeks instantly. Useful for planning, schedules, project durations, and quick time conversions."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="days-to-weeks">
    <div class="form" role="form" aria-describedby="d2w_hint d2w_privacy">
      <div class="field">
        <label for="d2w_input">Days</label>
        <input id="d2w_input" type="number" inputmode="decimal" placeholder="e.g., 21" />
        <p class="note" id="d2w_hint" style="margin-top:6px;">
          Enter a non-negative value. 7 days equal 1 week.
        </p>
      </div>

      <div class="field">
        <label for="d2w_round">Rounding</label>
        <select id="d2w_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="d2w_convert">Convert</button>
        <button class="btn secondary" type="button" id="d2w_swap">Reverse (weeks → days)</button>
        <button class="btn secondary" type="button" id="d2w_clear">Clear</button>
      </div>

      <div class="result" id="d2w_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="d2w_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="d2w_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="d2w_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="d2w_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard time conversion: <strong>7 days = 1 week</strong>.<br />
      Formula: <strong>weeks = days ÷ 7</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>7 days</strong> = <strong>1 week</strong></li>
      <li><strong>21 days</strong> = <strong>3 weeks</strong></li>
      <li><strong>10.5 days</strong> = <strong>1.5 weeks</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/time-converter/">Time Converter</a></li>
      <li><a href="/converter/weeks-to-days/">Weeks to Days</a></li>
      <li><a href="/converter/days-to-hours/">Days to Hours</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("d2w_input");
  const roundEl = document.getElementById("d2w_round");
  const convertBtn = document.getElementById("d2w_convert");
  const swapBtn = document.getElementById("d2w_swap");
  const clearBtn = document.getElementById("d2w_clear");
  const errEl = document.getElementById("d2w_error");
  const outEl = document.getElementById("d2w_result");
  const cardsEl = document.getElementById("d2w_cards");
  const tbodyEl = document.getElementById("d2w_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const DAY_TO_WEEK = 1 / 7;
  const WEEK_TO_DAY = 7;
  let mode = "day-to-week";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="d2w_input"]');
    if (!label) return;
    if (mode === "day-to-week") {
      label.textContent = "Days";
      inEl.placeholder = "e.g., 21";
      swapBtn.textContent = "Reverse (weeks → days)";
    } else {
      label.textContent = "Weeks";
      inEl.placeholder = "e.g., 3";
      swapBtn.textContent = "Reverse (days → weeks)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "day-to-week"
      ? [
          ["Conversion factor", "7 days = 1 week"],
          ["Formula", "weeks = days ÷ 7"],
          ["Input", fmt(input) + " days"],
          ["Output", fmt(output) + " weeks"],
        ]
      : [
          ["Conversion factor", "1 week = 7 days"],
          ["Formula", "days = weeks × 7"],
          ["Input", fmt(input) + " weeks"],
          ["Output", fmt(output) + " days"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classifyWeeks(weeks) {
    if (weeks < 1) return "Under one week";
    if (weeks < 4) return "Multi-week duration";
    return "Longer duration";
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "day-to-week" ? input * DAY_TO_WEEK : input * WEEK_TO_DAY;

    if (mode === "day-to-week") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} weeks<br/><span class="note">${fmt(input)} days = ${fmt(output)} weeks</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} days<br/><span class="note">${fmt(input)} weeks = ${fmt(output)} days</span>`;
    }

    const weeks = mode === "day-to-week" ? output : input;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(mode === "day-to-week" ? "days → weeks" : "weeks → days")}
        ${badge("Base ≈ " + fmtSmart(weeks) + " weeks")}
        ${badge(classifyWeeks(weeks))}
      </div>
    `;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "day-to-week" ? "week-to-day" : "day-to-week";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>