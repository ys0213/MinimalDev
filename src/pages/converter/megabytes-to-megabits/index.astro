---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Megabytes to Megabits",
  description:
    "Convert megabytes (MB) to megabits (Mb) instantly. Includes validation, reverse mode, result cards, and FAQ support.",
  href: "/converter/megabytes-to-megabits/",
  order: 321,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/megabytes-to-megabits/";

const faqs = [
  {
    q: "How do you convert megabytes to megabits?",
    a: "Multiply megabytes by 8, because 1 byte equals 8 bits.",
  },
  {
    q: "Why is MB different from Mb?",
    a: "MB means megabytes while Mb means megabits. A byte is 8 bits, so MB and Mb are not the same unit.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between megabytes to megabits and megabits to megabytes.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Megabytes to Megabits Converter — ${SITE_NAME}`}
  description="Convert megabytes (MB) to megabits (Mb) instantly with validation, reverse mode, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="Megabytes to Megabits Converter"
  intro="Convert data size from megabytes (MB) to megabits (Mb) instantly. Useful for file sizes, internet plans, and transfer comparisons."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="megabytes-to-megabits">
    <div class="form" role="form" aria-describedby="mbyte2mbit_hint mbyte2mbit_privacy">
      <div class="field">
        <label for="mbyte2mbit_input">Megabytes (MB)</label>
        <input id="mbyte2mbit_input" type="number" inputmode="decimal" placeholder="e.g., 10" />
        <p class="note" id="mbyte2mbit_hint" style="margin-top:6px;">
          Enter a non-negative value. 1 megabyte equals 8 megabits.
        </p>
      </div>

      <div class="field">
        <label for="mbyte2mbit_round">Rounding</label>
        <select id="mbyte2mbit_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="mbyte2mbit_convert">Convert</button>
        <button class="btn secondary" type="button" id="mbyte2mbit_swap">Reverse (Mb → MB)</button>
        <button class="btn secondary" type="button" id="mbyte2mbit_clear">Clear</button>
      </div>

      <div class="result" id="mbyte2mbit_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="mbyte2mbit_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="mbyte2mbit_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="mbyte2mbit_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="mbyte2mbit_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard bit/byte relationship: <strong>1 byte = 8 bits</strong>.<br />
      Formula: <strong>Mb = MB × 8</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1 MB</strong> = <strong>8 Mb</strong></li>
      <li><strong>10 MB</strong> = <strong>80 Mb</strong></li>
      <li><strong>100 MB</strong> = <strong>800 Mb</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/digital-storage-converter/">Digital Storage Converter</a></li>
      <li><a href="/converter/megabits-to-megabytes/">Megabits to Megabytes</a></li>
      <li><a href="/converter/bytes-to-bits/">Bytes to Bits</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("mbyte2mbit_input");
  const roundEl = document.getElementById("mbyte2mbit_round");
  const convertBtn = document.getElementById("mbyte2mbit_convert");
  const swapBtn = document.getElementById("mbyte2mbit_swap");
  const clearBtn = document.getElementById("mbyte2mbit_clear");
  const errEl = document.getElementById("mbyte2mbit_error");
  const outEl = document.getElementById("mbyte2mbit_result");
  const cardsEl = document.getElementById("mbyte2mbit_cards");
  const tbodyEl = document.getElementById("mbyte2mbit_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const MBYTE_TO_MBIT = 8;
  const MBIT_TO_MBYTE = 1 / 8;
  let mode = "mbyte-to-mbit";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="mbyte2mbit_input"]');
    if (!label) return;
    if (mode === "mbyte-to-mbit") {
      label.textContent = "Megabytes (MB)";
      inEl.placeholder = "e.g., 10";
      swapBtn.textContent = "Reverse (Mb → MB)";
    } else {
      label.textContent = "Megabits (Mb)";
      inEl.placeholder = "e.g., 80";
      swapBtn.textContent = "Reverse (MB → Mb)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "mbyte-to-mbit"
      ? [
          ["Conversion factor", "1 MB = 8 Mb"],
          ["Formula", "Mb = MB × 8"],
          ["Input", fmt(input) + " MB"],
          ["Output", fmt(output) + " Mb"],
        ]
      : [
          ["Conversion factor", "8 Mb = 1 MB"],
          ["Formula", "MB = Mb ÷ 8"],
          ["Input", fmt(input) + " Mb"],
          ["Output", fmt(output) + " MB"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classifyMB(mb) {
    if (mb < 1) return "Small data size";
    if (mb < 100) return "Typical size";
    return "Large transfer";
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "mbyte-to-mbit" ? input * MBYTE_TO_MBIT : input * MBIT_TO_MBYTE;

    if (mode === "mbyte-to-mbit") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} Mb<br/><span class="note">${fmt(input)} MB = ${fmt(output)} Mb</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} MB<br/><span class="note">${fmt(input)} Mb = ${fmt(output)} MB</span>`;
    }

    const megaBytes = mode === "mbyte-to-mbit" ? input : output;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(mode === "mbyte-to-mbit" ? "MB → Mb" : "Mb → MB")}
        ${badge("Base ≈ " + fmtSmart(megaBytes) + " MB")}
        ${badge(classifyMB(megaBytes))}
      </div>
    `;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "mbyte-to-mbit" ? "mbit-to-mbyte" : "mbyte-to-mbit";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>