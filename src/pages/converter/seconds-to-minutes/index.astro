---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Seconds to Minutes",
  description:
    "Convert seconds to minutes for duration, timing, and schedule calculations.",
  href: "/converter/seconds-to-minutes/",
  order: 324,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/seconds-to-minutes/";

const faqs = [
  {
    q: "How do you convert seconds to minutes?",
    a: "Divide seconds by 60, because 60 seconds equal 1 minute.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between seconds to minutes and minutes to seconds.",
  },
  {
    q: "Can I enter fractional seconds?",
    a: "Yes. This tool accepts decimal values and can show fractional minutes.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Seconds to Minutes Converter — ${SITE_NAME}`}
  description="Convert seconds to minutes with clear results for timers, work logs, schedules, workouts, and duration reference."
  canonicalPath={CANONICAL_PATH}
  h1="Seconds to Minutes Converter"
  intro="Convert time from seconds to minutes instantly. Useful for timers, workouts, videos, durations, and quick time conversions."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="seconds-to-minutes">
    <div class="form" role="form" aria-describedby="s2m_hint s2m_privacy">
      <div class="field">
        <label for="s2m_input">Seconds</label>
        <input id="s2m_input" type="number" inputmode="decimal" placeholder="e.g., 90" />
        <p class="note" id="s2m_hint" style="margin-top:6px;">
          Enter a non-negative value. 60 seconds equal 1 minute.
        </p>
      </div>

      <div class="field">
        <label for="s2m_round">Rounding</label>
        <select id="s2m_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="s2m_convert">Convert</button>
        <button class="btn secondary" type="button" id="s2m_swap">Reverse (min → sec)</button>
        <button class="btn secondary" type="button" id="s2m_clear">Clear</button>
      </div>

      <div class="result" id="s2m_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="s2m_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="s2m_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="s2m_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="s2m_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard time conversion: <strong>60 seconds = 1 minute</strong>.<br />
      Formula: <strong>minutes = seconds ÷ 60</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>60 seconds</strong> = <strong>1 minute</strong></li>
      <li><strong>90 seconds</strong> = <strong>1.5 minutes</strong></li>
      <li><strong>300 seconds</strong> = <strong>5 minutes</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/time-converter/">Time Converter</a></li>
      <li><a href="/converter/minutes-to-seconds/">Minutes to Seconds</a></li>
      <li><a href="/converter/minutes-to-hours/">Minutes to Hours</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("s2m_input");
  const roundEl = document.getElementById("s2m_round");
  const convertBtn = document.getElementById("s2m_convert");
  const swapBtn = document.getElementById("s2m_swap");
  const clearBtn = document.getElementById("s2m_clear");
  const errEl = document.getElementById("s2m_error");
  const outEl = document.getElementById("s2m_result");
  const cardsEl = document.getElementById("s2m_cards");
  const tbodyEl = document.getElementById("s2m_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const SEC_TO_MIN = 1 / 60;
  const MIN_TO_SEC = 60;
  let mode = "sec-to-min";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="s2m_input"]');
    if (!label) return;
    if (mode === "sec-to-min") {
      label.textContent = "Seconds";
      inEl.placeholder = "e.g., 90";
      swapBtn.textContent = "Reverse (min → sec)";
    } else {
      label.textContent = "Minutes";
      inEl.placeholder = "e.g., 1.5";
      swapBtn.textContent = "Reverse (sec → min)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "sec-to-min"
      ? [
          ["Conversion factor", "60 sec = 1 min"],
          ["Formula", "min = sec ÷ 60"],
          ["Input", fmt(input) + " sec"],
          ["Output", fmt(output) + " min"],
        ]
      : [
          ["Conversion factor", "1 min = 60 sec"],
          ["Formula", "sec = min × 60"],
          ["Input", fmt(input) + " min"],
          ["Output", fmt(output) + " sec"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classifyMinutes(mins) {
    if (mins < 1) return "Less than one minute";
    if (mins < 60) return "Typical duration";
    return "Longer duration";
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "sec-to-min" ? input * SEC_TO_MIN : input * MIN_TO_SEC;

    if (mode === "sec-to-min") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} min<br/><span class="note">${fmt(input)} sec = ${fmt(output)} min</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} sec<br/><span class="note">${fmt(input)} min = ${fmt(output)} sec</span>`;
    }

    const minutes = mode === "sec-to-min" ? output : input;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(mode === "sec-to-min" ? "sec → min" : "min → sec")}
        ${badge("Base ≈ " + fmtSmart(minutes) + " min")}
        ${badge(classifyMinutes(minutes))}
      </div>
    `;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "sec-to-min" ? "min-to-sec" : "sec-to-min";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>