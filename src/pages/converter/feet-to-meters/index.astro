---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Feet to Meters Converter",
  description:
    "Convert feet (ft) to meters (m) instantly. Includes validation, accessible UX, result cards, quick table, and FAQ schema.",
  href: "/converter/feet-to-meters/",
  order: 100,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/feet-to-meters/";

const faqs = [
  {
    q: "What is the feet to meters formula?",
    a: "meters = feet ÷ 3.280839895. (Because 1 ft = 0.3048 m exactly.)",
  },
  {
    q: "Is this conversion exact?",
    a: "Yes. 1 foot = 0.3048 meters is defined exactly. Displayed results may be rounded.",
  },
  {
    q: "Can I convert meters to feet here?",
    a: "Yes. Switch the direction to “Meters → Feet”.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Feet to Meters Converter — ${SITE_NAME}`}
  description="Convert feet (ft) to meters (m) instantly, with an option to reverse (m → ft). Includes validation, accessible controls, result cards, quick conversions, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Feet to Meters Converter"
  intro="Convert feet to meters (and meters to feet) using standard length conversions."
  faq={faqs}
  categoryName="Converters"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="feet-to-meters">
    <div class="form" role="form" aria-describedby="f2m_privacy f2m_help">
      <div class="field">
        <label for="f2m_value">Value</label>
        <input
          id="f2m_value"
          type="number"
          inputmode="decimal"
          placeholder="e.g., 6"
          aria-describedby="f2m_help"
        />
        <p class="note" id="f2m_help" style="margin-top:6px;">
          Reference: <strong>1 ft = 0.3048 m</strong> (exact).
        </p>
      </div>

      <div class="field">
        <label for="f2m_mode">Direction</label>
        <select id="f2m_mode">
          <option value="ft_to_m" selected>Feet → Meters</option>
          <option value="m_to_ft">Meters → Feet</option>
        </select>
      </div>

      <div class="field">
        <label for="f2m_round">Rounding</label>
        <select id="f2m_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="4">4 decimals</option>
          <option value="8">Up to 8 decimals</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <button class="btn" type="button" id="f2m_calc">Convert</button>
        <button class="btn secondary" type="button" id="f2m_swap" aria-label="Swap direction">Swap</button>
        <button class="btn secondary" type="button" id="f2m_clear">Clear</button>
      </div>

      <div class="result" id="f2m_error" role="alert" style="display:none; margin-top:12px;"></div>

      <div class="result" id="f2m_result" role="status" style="margin-top:12px;">
        Result will appear here.
      </div>

      <div class="result" id="f2m_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Quick conversions</th>
              <th scope="col">Result</th>
            </tr>
          </thead>
          <tbody id="f2m_table"></tbody>
        </table>
      </div>

      <p class="note" id="f2m_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      <strong>ft → m:</strong> meters = feet × 0.3048<br/>
      <strong>m → ft:</strong> feet = meters ÷ 0.3048
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>6 ft</strong> → <strong>1.829 m</strong> (approx.)</li>
      <li><strong>10 ft</strong> → <strong>3.048 m</strong> (exact factor)</li>
      <li><strong>2 m</strong> → <strong>6.562 ft</strong> (approx.)</li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/meters-to-feet/">meters to feet</a></li>
      <li><a href="/converter/length/">Length Converter</a></li>
      <li><a href="/converter/miles-to-km/">miles to km</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const valueEl = document.getElementById("f2m_value");
  const modeEl = document.getElementById("f2m_mode");
  const roundEl = document.getElementById("f2m_round");
  const calcBtn = document.getElementById("f2m_calc");
  const swapBtn = document.getElementById("f2m_swap");
  const clearBtn = document.getElementById("f2m_clear");
  const errEl = document.getElementById("f2m_error");
  const resEl = document.getElementById("f2m_result");
  const cardsEl = document.getElementById("f2m_cards");
  const tbodyEl = document.getElementById("f2m_table");

  if (!valueEl || !modeEl || !roundEl || !calcBtn || !swapBtn || !clearBtn || !errEl || !resEl || !cardsEl || !tbodyEl) return;

  const FT_TO_M = 0.3048; // exact

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function clampAbs(x, maxAbs) {
    if (!Number.isFinite(x)) return x;
    if (Math.abs(x) > maxAbs) return Math.sign(x) * maxAbs;
    return x;
  }

  function fmtFixed(x, decimals) {
    if (!Number.isFinite(x)) return "—";
    if (decimals === 8) {
      const r = Math.round(x * 1e8) / 1e8;
      return r.toString();
    }
    return x.toFixed(decimals);
  }

  function badge(text, kind) {
    const border = kind === "warn"
      ? "rgba(251,146,60,0.55)"
      : kind === "good"
      ? "rgba(34,197,94,0.55)"
      : "rgba(255,255,255,0.2)";
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid ${border}; font-size:12px; font-weight:900;">${text}</span>`;
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(valueEl.value);
    if (!Number.isFinite(raw)) {
      resEl.textContent = "Please enter a valid number.";
      return;
    }

    const v = clampAbs(raw, 1e18);
    if (v !== raw) {
      showError("Value is too large for reliable display. Using a clamped value for output.");
    }

    const mode = String(modeEl.value);
    const decimals = parseInt(String(roundEl.value), 10);

    let out, fromUnit, toUnit, factorNote;

    if (mode === "ft_to_m") {
      out = v * FT_TO_M;
      fromUnit = "ft";
      toUnit = "m";
      factorNote = "× 0.3048";
    } else {
      out = v / FT_TO_M;
      fromUnit = "m";
      toUnit = "ft";
      factorNote = "÷ 0.3048";
    }

    const outStr = fmtFixed(out, decimals);
    const inStr = fmtFixed(v, decimals === 8 ? 8 : Math.min(decimals, 6));

    resEl.innerHTML =
      "<strong>Result:</strong> " + outStr + " " + toUnit + "<br/>" +
      "<span class='note'>" + inStr + " " + fromUnit + " " + factorNote + " = " + outStr + " " + toUnit + "</span>";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge("From: " + fromUnit, "neutral")}
        ${badge("To: " + toUnit, "neutral")}
        ${badge("Rounding: " + (decimals === 8 ? "up to 8" : decimals) + " dp", "neutral")}
        ${badge("Converted", "good")}
      </div>
    `;

    // Quick conversions table
    const presets = mode === "ft_to_m"
      ? [1, 3, 6, 10, 20]
      : [0.5, 1, 1.5, 2, 3];

    for (const s0 of presets) {
      const s = s0;
      const o = mode === "ft_to_m" ? (s * FT_TO_M) : (s / FT_TO_M);
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = fmtFixed(s, decimals === 8 ? 8 : Math.min(decimals, 4)) + " " + fromUnit;
      td2.textContent = fmtFixed(o, decimals) + " " + toUnit;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    }
  }

  function reset() {
    clearError();
    valueEl.value = "";
    modeEl.value = "ft_to_m";
    roundEl.value = "3";
    resEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  calcBtn.addEventListener("click", compute);

  swapBtn.addEventListener("click", function () {
    modeEl.value = modeEl.value === "ft_to_m" ? "m_to_ft" : "ft_to_m";
    if (String(valueEl.value || "").trim()) compute();
  });

  clearBtn.addEventListener("click", reset);

  modeEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });

  roundEl.addEventListener("change", function () {
    if (String(valueEl.value || "").trim()) compute();
  });

  valueEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  });

  valueEl.addEventListener("input", function () {
    if (!String(valueEl.value || "").trim()) {
      clearError();
      resEl.textContent = "Result will appear here.";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      tbodyEl.innerHTML = "";
    }
  });
});
</script>