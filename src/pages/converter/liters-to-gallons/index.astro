---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Liters to Gallons",
  description:
    "Convert liters to gallons for liquid volume and fuel measurements.",
  href: "/converter/liters-to-gallons/",
  order: 300,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/liters-to-gallons/";

const faqs = [
  {
    q: "How do you convert liters to gallons?",
    a: "Multiply liters by 0.2641720524 to get US gallons.",
  },
  {
    q: "Does this use US gallons or UK gallons?",
    a: "This tool uses US liquid gallons. UK imperial gallons are larger and use a different conversion factor.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between liters to gallons and gallons to liters.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Liters to Gallons Converter — ${SITE_NAME}`}
  description="Convert liters to gallons with clear results for fuel, containers, recipes, and liquid volume comparisons."
  canonicalPath={CANONICAL_PATH}
  h1="Liters to Gallons Converter"
  intro="Convert volume from liters to US gallons instantly. Useful for fuel, liquids, containers, and everyday volume comparisons."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="liters-to-gallons">
    <div class="form" role="form" aria-describedby="l2g_hint l2g_privacy">
      <div class="field">
        <label for="l2g_input">Liters</label>
        <input id="l2g_input" type="number" inputmode="decimal" placeholder="e.g., 10" />
        <p class="note" id="l2g_hint" style="margin-top:6px;">
          Uses US liquid gallons. Enter a non-negative value.
        </p>
      </div>

      <div class="field">
        <label for="l2g_round">Rounding</label>
        <select id="l2g_round">
          <option value="2">2 decimals</option>
          <option value="4" selected>4 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="l2g_convert">Convert</button>
        <button class="btn secondary" type="button" id="l2g_swap">Reverse (gal → L)</button>
        <button class="btn secondary" type="button" id="l2g_clear">Clear</button>
      </div>

      <div class="result" id="l2g_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="l2g_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="l2g_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="l2g_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="l2g_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard conversion: <strong>1 liter = 0.2641720524 US gallons</strong>.<br />
      Formula: <strong>US gal = L × 0.2641720524</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1 L</strong> ≈ <strong>0.2642 US gal</strong></li>
      <li><strong>10 L</strong> ≈ <strong>2.6417 US gal</strong></li>
      <li><strong>50 L</strong> ≈ <strong>13.2086 US gal</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/volume-converter/">Volume Converter</a></li>
      <li><a href="/converter/gallons-to-liters/">Gallons to Liters</a></li>
      <li><a href="/converter/cubic-meters-to-liters/">Cubic Meters to Liters</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("l2g_input");
  const roundEl = document.getElementById("l2g_round");
  const convertBtn = document.getElementById("l2g_convert");
  const swapBtn = document.getElementById("l2g_swap");
  const clearBtn = document.getElementById("l2g_clear");
  const errEl = document.getElementById("l2g_error");
  const outEl = document.getElementById("l2g_result");
  const cardsEl = document.getElementById("l2g_cards");
  const tbodyEl = document.getElementById("l2g_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const L_TO_GAL = 0.2641720524;
  const GAL_TO_L = 1 / L_TO_GAL;
  let mode = "l-to-gal";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    const d = parseInt(r, 10);
    return x.toFixed(d);
  }

  function badge(text) {
    return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="l2g_input"]');
    if (!label) return;

    if (mode === "l-to-gal") {
      label.textContent = "Liters";
      inEl.placeholder = "e.g., 10";
      swapBtn.textContent = "Reverse (gal → L)";
    } else {
      label.textContent = "US gallons";
      inEl.placeholder = "e.g., 2.5";
      swapBtn.textContent = "Reverse (L → gal)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "l-to-gal"
      ? [
          ["Conversion factor", "1 L = 0.2641720524 US gal"],
          ["Reverse factor", "1 US gal ≈ " + fmtSmart(GAL_TO_L) + " L"],
          ["Input", fmt(input) + " L"],
          ["Output", fmt(output) + " US gal"],
        ]
      : [
          ["Conversion factor", "1 US gal ≈ " + fmtSmart(GAL_TO_L) + " L"],
          ["Reverse factor", "1 L = 0.2641720524 US gal"],
          ["Input", fmt(input) + " US gal"],
          ["Output", fmt(output) + " L"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const output = mode === "l-to-gal" ? raw * L_TO_GAL : raw * GAL_TO_L;

    if (mode === "l-to-gal") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} US gal<br/><span class="note">${fmt(raw)} L = ${fmt(output)} US gal</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} L<br/><span class="note">${fmt(raw)} US gal = ${fmt(output)} L</span>`;
    }

    const liters = mode === "l-to-gal" ? raw : output;
    let scale = "Typical";
    if (liters < 1) scale = "Small volume";
    else if (liters >= 100) scale = "Large volume";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `<div style="display:flex;gap:10px;flex-wrap:wrap;">
      ${badge(mode === "l-to-gal" ? "L → US gal" : "US gal → L")}
      ${badge("Base ≈ " + fmtSmart(liters) + " L")}
      ${badge(scale)}
    </div>`;

    fillTable(raw, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "4";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "l-to-gal" ? "gal-to-l" : "l-to-gal";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>