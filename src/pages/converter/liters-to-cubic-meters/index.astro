---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Liters to Cubic Meters",
  description:
    "Convert liters to cubic meters for large volume and capacity calculations.",
  href: "/converter/liters-to-cubic-meters/",
  order: 313,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/liters-to-cubic-meters/";

const faqs = [
  {
    q: "How do you convert liters to cubic meters?",
    a: "Divide liters by 1,000, or multiply liters by 0.001 to get cubic meters.",
  },
  {
    q: "Why is the factor 0.001?",
    a: "One liter is one-thousandth of a cubic meter.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between liters to cubic meters and cubic meters to liters.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Liters to Cubic Meters Converter — ${SITE_NAME}`}
  description="Convert liters to cubic meters with clear results for tanks, containers, water volume, and storage capacity reference."
  canonicalPath={CANONICAL_PATH}
  h1="Liters to Cubic Meters Converter"
  intro="Convert volume from liters to cubic meters instantly. Useful for tanks, storage systems, industrial volume, and large capacity comparison."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="liters-to-cubic-meters">
    <div class="form" role="form" aria-describedby="l2m3_hint l2m3_privacy">
      <div class="field">
        <label for="l2m3_input">Liters</label>
        <input id="l2m3_input" type="number" inputmode="decimal" placeholder="e.g., 1500" />
        <p class="note" id="l2m3_hint" style="margin-top:6px;">
          Enter a non-negative value. 1,000 liters equals exactly 1 cubic meter.
        </p>
      </div>

      <div class="field">
        <label for="l2m3_round">Rounding</label>
        <select id="l2m3_round">
          <option value="2">2 decimals</option>
          <option value="4" selected>4 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="l2m3_convert">Convert</button>
        <button class="btn secondary" type="button" id="l2m3_swap">Reverse (m³ → L)</button>
        <button class="btn secondary" type="button" id="l2m3_clear">Clear</button>
      </div>

      <div class="result" id="l2m3_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="l2m3_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="l2m3_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="l2m3_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="l2m3_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard conversion: <strong>1,000 L = 1 m³</strong>.<br />
      Formula: <strong>m³ = L ÷ 1,000</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1,000 L</strong> = <strong>1 m³</strong></li>
      <li><strong>1,500 L</strong> = <strong>1.5 m³</strong></li>
      <li><strong>10,000 L</strong> = <strong>10 m³</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/volume-converter/">Volume Converter</a></li>
      <li><a href="/converter/cubic-meters-to-liters/">Cubic Meters to Liters</a></li>
      <li><a href="/converter/liters-to-gallons/">Liters to Gallons</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("l2m3_input");
  const roundEl = document.getElementById("l2m3_round");
  const convertBtn = document.getElementById("l2m3_convert");
  const swapBtn = document.getElementById("l2m3_swap");
  const clearBtn = document.getElementById("l2m3_clear");
  const errEl = document.getElementById("l2m3_error");
  const outEl = document.getElementById("l2m3_result");
  const cardsEl = document.getElementById("l2m3_cards");
  const tbodyEl = document.getElementById("l2m3_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const L_TO_M3 = 0.001;
  const M3_TO_L = 1000;
  let mode = "l-to-m3";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="l2m3_input"]');
    if (!label) return;
    if (mode === "l-to-m3") {
      label.textContent = "Liters";
      inEl.placeholder = "e.g., 1500";
      swapBtn.textContent = "Reverse (m³ → L)";
    } else {
      label.textContent = "Cubic meters (m³)";
      inEl.placeholder = "e.g., 1.5";
      swapBtn.textContent = "Reverse (L → m³)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "l-to-m3"
      ? [
          ["Conversion factor", "1,000 L = 1 m³"],
          ["Reverse factor", "1 m³ = 1,000 L"],
          ["Input", fmt(input) + " L"],
          ["Output", fmt(output) + " m³"],
        ]
      : [
          ["Conversion factor", "1 m³ = 1,000 L"],
          ["Reverse factor", "1,000 L = 1 m³"],
          ["Input", fmt(input) + " m³"],
          ["Output", fmt(output) + " L"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "l-to-m3" ? input * L_TO_M3 : input * M3_TO_L;

    if (mode === "l-to-m3") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} m³<br/><span class="note">${fmt(input)} L = ${fmt(output)} m³</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} L<br/><span class="note">${fmt(input)} m³ = ${fmt(output)} L</span>`;
    }

    const liters = mode === "l-to-m3" ? input : output;
    let scale = "Typical";
    if (liters < 1000) scale = "Small tank";
    else if (liters >= 10000) scale = "Large storage";

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `<div style="display:flex;gap:10px;flex-wrap:wrap;">
      ${badge(mode === "l-to-m3" ? "L → m³" : "m³ → L")}
      ${badge("Base ≈ " + fmtSmart(liters) + " L")}
      ${badge(scale)}
    </div>`;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "4";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "l-to-m3" ? "m3-to-l" : "l-to-m3";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>