---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Energy Converter",
  description:
    "Convert energy units instantly (joules, calories, kilowatt-hours, BTU). Validated, accessible UX with result cards, reference table, and FAQ schema.",
  href: "/converter/energy-converter/",
  order: 330,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/energy-converter/";

const units = [
  { key: "j", label: "Joules (J)" },
  { key: "cal", label: "Calories (cal)" },
  { key: "kwh", label: "Kilowatt-hours (kWh)" },
  { key: "btu", label: "BTU" },
];

const faqs = [
  {
    q: "How do you convert joules to calories?",
    a: "Divide joules by 4.184 to get calories.",
  },
  {
    q: "How many joules are in 1 kilowatt-hour?",
    a: "1 kWh equals 3,600,000 joules.",
  },
  {
    q: "What is BTU?",
    a: "BTU stands for British Thermal Unit, a unit commonly used for heating and cooling energy.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Energy Converter — ${SITE_NAME}`}
  description="Convert joules, calories, kWh, and BTU with validation, accessible UX, result cards, a reference table, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Energy Converter"
  intro="Convert between common energy units used in physics, engineering, and nutrition."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="energy-converter">
    <div class="form" role="form" aria-describedby="ec_help ec_privacy">
      <div class="field">
        <label for="ec_value">Value</label>
        <input id="ec_value" type="number" inputmode="decimal" placeholder="e.g., 1000" aria-describedby="ec_help" />
        <p class="note" id="ec_help" style="margin-top:6px;">
          Enter energy value and choose units. Press <kbd>Ctrl</kbd>/<kbd>Cmd</kbd> + <kbd>Enter</kbd>.
        </p>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
        <div class="field">
          <label for="ec_from">From</label>
          <select id="ec_from">
            {units.map((u) => <option value={u.key}>{u.label}</option>)}
          </select>
        </div>
        <div class="field">
          <label for="ec_to">To</label>
          <select id="ec_to">
            {units.map((u) => <option value={u.key}>{u.label}</option>)}
          </select>
        </div>
      </div>

      <div class="field">
        <label for="ec_round">Rounding</label>
        <select id="ec_round">
          <option value="2">2 decimals</option>
          <option value="4" selected>4 decimals</option>
          <option value="8">8 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="ec_convert">Convert</button>
        <button class="btn secondary" type="button" id="ec_swap">Swap</button>
        <button class="btn secondary" type="button" id="ec_clear">Clear</button>
      </div>

      <div class="result" id="ec_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="ec_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="ec_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Unit</th>
              <th scope="col">Equivalent</th>
            </tr>
          </thead>
          <tbody id="ec_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="ec_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Converts using <strong>joules (J)</strong> as a base unit.
      <br />
      <strong>1 cal = 4.184 J</strong>
      <br />
      <strong>1 kWh = 3,600,000 J</strong>
      <br />
      <strong>1 BTU ≈ 1055.06 J</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1000 J</strong> ≈ <strong>239.006 cal</strong></li>
      <li><strong>1 kWh</strong> = <strong>3,600,000 J</strong></li>
      <li><strong>1 BTU</strong> ≈ <strong>1055.06 J</strong></li>
    </ul>
  </div>

  <div slot="faq">
    <ul>{faqs.map((f) => <li><strong>{f.q}</strong> {f.a}</li>)}</ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/joules-to-calories/">Joules to Calories</a></li>
      <li><a href="/converter/calories-to-joules/">Calories to Joules</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const valueEl = document.getElementById("ec_value");
  const fromEl = document.getElementById("ec_from");
  const toEl = document.getElementById("ec_to");
  const roundEl = document.getElementById("ec_round");
  const convertBtn = document.getElementById("ec_convert");
  const swapBtn = document.getElementById("ec_swap");
  const clearBtn = document.getElementById("ec_clear");
  const errEl = document.getElementById("ec_error");
  const outEl = document.getElementById("ec_result");
  const cardsEl = document.getElementById("ec_cards");
  const tbodyEl = document.getElementById("ec_tbody");

  if (!valueEl || !fromEl || !toEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const TO_J = {
    j: 1,
    cal: 4.184,
    kwh: 3600000,
    btu: 1055.06
  };

  const LABEL = {
    j: "Joules (J)",
    cal: "Calories (cal)",
    kwh: "Kilowatt-hours (kWh)",
    btu: "BTU"
  };

  const ORDER = ["j", "cal", "kwh", "btu"];

  function toNum(v) { const x = parseFloat(String(v)); return Number.isFinite(x) ? x : NaN; }
  function clearError() { errEl.style.display = "none"; errEl.textContent = ""; }
  function showError(msg) { errEl.style.display = "block"; errEl.textContent = msg; }
  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1e12 || ax < 1e-10) return x.toExponential(6);
    return String(Number(x.toPrecision(10)));
  }
  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    const d = parseInt(r, 10);
    return Number(x).toLocaleString(undefined, { minimumFractionDigits: d, maximumFractionDigits: d });
  }
  function badge(text) {
    return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">${text}</span>`;
  }
  function convert(v, fromU, toU) {
    const j = v * TO_J[fromU];
    return j / TO_J[toU];
  }
  function classify(j) {
    const a = Math.abs(j);
    if (a < 10) return "Very small energy";
    if (a < 1000) return "Small energy";
    if (a < 1000000) return "Moderate energy";
    return "Large energy";
  }
  function buildTable(v, fromU) {
    tbodyEl.innerHTML = "";
    ORDER.forEach((u) => {
      const out = convert(v, fromU, u);
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = LABEL[u];
      td2.textContent = fmtSmart(out);
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    tbodyEl.innerHTML = "";

    const raw = toNum(valueEl.value);
    const fromU = String(fromEl.value);
    const toU = String(toEl.value);

    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid energy value.";
      return;
    }
    if (Math.abs(raw) > 1e18) {
      showError("Value is too large for reliable display.");
      outEl.textContent = "Result will appear here.";
      return;
    }

    const j = raw * TO_J[fromU];
    const out = convert(raw, fromU, toU);

    outEl.innerHTML =
      `<strong>Result:</strong> ${fmt(out)} ${toU}<br/><span class="note">${fmtSmart(raw)} ${fromU} = ${fmtSmart(j)} J = ${fmtSmart(out)} ${toU}</span>`;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        ${badge("From: " + fromU)}
        ${badge("To: " + toU)}
        ${badge("Base: joules")}
        ${badge(classify(j))}
      </div>
    `;

    buildTable(raw, fromU);
  }

  function reset() {
    clearError();
    valueEl.value = "";
    fromEl.value = "j";
    toEl.value = "cal";
    roundEl.value = "4";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    const a = fromEl.value;
    fromEl.value = toEl.value;
    toEl.value = a;
    if (String(valueEl.value || "").trim()) compute();
  });
  clearBtn.addEventListener("click", reset);
  fromEl.addEventListener("change", function () { if (String(valueEl.value || "").trim()) compute(); });
  toEl.addEventListener("change", function () { if (String(valueEl.value || "").trim()) compute(); });
  roundEl.addEventListener("change", function () { if (String(valueEl.value || "").trim()) compute(); });
  valueEl.addEventListener("keydown", function (e) {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") compute();
  });
  valueEl.addEventListener("input", function () {
    if (!String(valueEl.value || "").trim()) {
      clearError();
      outEl.textContent = "Result will appear here.";
      cardsEl.style.display = "none";
      cardsEl.innerHTML = "";
      tbodyEl.innerHTML = "";
    }
  });

  fromEl.value = "j";
  toEl.value = "cal";
});
</script>