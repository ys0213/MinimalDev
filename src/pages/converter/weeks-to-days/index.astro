---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Weeks to Days",
  description:
    "Convert weeks to days instantly. Includes validation, reverse mode, result cards, and FAQ support.",
  href: "/converter/weeks-to-days/",
  order: 330,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/converter/weeks-to-days/";

const faqs = [
  {
    q: "How do you convert weeks to days?",
    a: "Multiply weeks by 7, because 1 week equals 7 days.",
  },
  {
    q: "Can I reverse the conversion?",
    a: "Yes. Use the Reverse button to switch between weeks to days and days to weeks.",
  },
  {
    q: "Can I enter fractional weeks?",
    a: "Yes. This tool accepts decimal values, so 1.5 weeks converts to 10.5 days.",
  },
  {
    q: "Are my inputs stored?",
    a: "No. All calculations run locally in your browser.",
  },
];
---

<ToolLayout
  title={`Weeks to Days Converter — ${SITE_NAME}`}
  description="Convert weeks to days instantly with validation, reverse mode, result cards, and FAQ support."
  canonicalPath={CANONICAL_PATH}
  h1="Weeks to Days Converter"
  intro="Convert time from weeks to days instantly. Useful for schedules, planning, project timelines, and quick duration conversions."
  faq={faqs}
  categoryName="Converters"
>
  <div slot="tool" data-tool="weeks-to-days">
    <div class="form" role="form" aria-describedby="w2d_hint w2d_privacy">
      <div class="field">
        <label for="w2d_input">Weeks</label>
        <input id="w2d_input" type="number" inputmode="decimal" placeholder="e.g., 1.5" />
        <p class="note" id="w2d_hint" style="margin-top:6px;">
          Enter a non-negative value. 1 week equals 7 days.
        </p>
      </div>

      <div class="field">
        <label for="w2d_round">Rounding</label>
        <select id="w2d_round">
          <option value="2">2 decimals</option>
          <option value="3" selected>3 decimals</option>
          <option value="6">6 decimals</option>
          <option value="auto">Smart</option>
        </select>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="w2d_convert">Convert</button>
        <button class="btn secondary" type="button" id="w2d_swap">Reverse (days → weeks)</button>
        <button class="btn secondary" type="button" id="w2d_clear">Clear</button>
      </div>

      <div class="result" id="w2d_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="w2d_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="w2d_cards" style="display:none; margin-top:12px;"></div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="w2d_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="w2d_privacy" style="margin-top:10px;">
        Privacy: runs locally in your browser. No inputs are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Uses the standard time conversion: <strong>1 week = 7 days</strong>.<br />
      Formula: <strong>days = weeks × 7</strong>
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li><strong>1 week</strong> = <strong>7 days</strong></li>
      <li><strong>1.5 weeks</strong> = <strong>10.5 days</strong></li>
      <li><strong>4 weeks</strong> = <strong>28 days</strong></li>
    </ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/converter/time-converter/">Time Converter</a></li>
      <li><a href="/converter/days-to-weeks/">Days to Weeks</a></li>
      <li><a href="/converter/days-to-hours/">Days to Hours</a></li>
      <li><a href="/converter/">All Converters</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const inEl = document.getElementById("w2d_input");
  const roundEl = document.getElementById("w2d_round");
  const convertBtn = document.getElementById("w2d_convert");
  const swapBtn = document.getElementById("w2d_swap");
  const clearBtn = document.getElementById("w2d_clear");
  const errEl = document.getElementById("w2d_error");
  const outEl = document.getElementById("w2d_result");
  const cardsEl = document.getElementById("w2d_cards");
  const tbodyEl = document.getElementById("w2d_tbody");

  if (!inEl || !roundEl || !convertBtn || !swapBtn || !clearBtn || !errEl || !outEl || !cardsEl || !tbodyEl) return;

  const WEEK_TO_DAY = 7;
  const DAY_TO_WEEK = 1 / 7;
  let mode = "week-to-day";

  function toNum(v) {
    const x = parseFloat(String(v));
    return Number.isFinite(x) ? x : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function fmtSmart(x) {
    if (!Number.isFinite(x)) return "—";
    const ax = Math.abs(x);
    if (ax === 0) return "0";
    if (ax >= 1) return (Math.round(x * 1e6) / 1e6).toLocaleString(undefined, { maximumFractionDigits: 6 });
    return (Math.round(x * 1e12) / 1e12).toString();
  }

  function fmt(x) {
    if (!Number.isFinite(x)) return "—";
    const r = String(roundEl.value);
    if (r === "auto") return fmtSmart(x);
    return x.toFixed(parseInt(r, 10));
  }

  function badge(text) {
    return `<span style="display:inline-block; padding:2px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.2); font-size:12px; font-weight:900;">${text}</span>`;
  }

  function setLabels() {
    const label = document.querySelector('label[for="w2d_input"]');
    if (!label) return;
    if (mode === "week-to-day") {
      label.textContent = "Weeks";
      inEl.placeholder = "e.g., 1.5";
      swapBtn.textContent = "Reverse (days → weeks)";
    } else {
      label.textContent = "Days";
      inEl.placeholder = "e.g., 10.5";
      swapBtn.textContent = "Reverse (weeks → days)";
    }
  }

  function fillTable(input, output) {
    tbodyEl.innerHTML = "";
    const rows = mode === "week-to-day"
      ? [
          ["Conversion factor", "1 week = 7 days"],
          ["Formula", "days = weeks × 7"],
          ["Input", fmt(input) + " weeks"],
          ["Output", fmt(output) + " days"],
        ]
      : [
          ["Conversion factor", "7 days = 1 week"],
          ["Formula", "weeks = days ÷ 7"],
          ["Input", fmt(input) + " days"],
          ["Output", fmt(output) + " weeks"],
        ];

    rows.forEach(function ([k, v]) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = k;
      td2.textContent = v;
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function classifyDays(days) {
    if (days < 7) return "Under one week";
    if (days < 30) return "Multi-day duration";
    return "Longer duration";
  }

  function compute() {
    clearError();
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";

    const raw = toNum(inEl.value);
    if (!Number.isFinite(raw)) {
      outEl.textContent = "Please enter a valid number.";
      return;
    }
    if (raw < 0) {
      outEl.textContent = "Please enter a non-negative value.";
      return;
    }

    const input = Math.min(raw, 1e15);
    if (input !== raw) showError("Value is very large; output may be rounded due to floating-point limits.");

    const output = mode === "week-to-day" ? input * WEEK_TO_DAY : input * DAY_TO_WEEK;

    if (mode === "week-to-day") {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} days<br/><span class="note">${fmt(input)} weeks = ${fmt(output)} days</span>`;
    } else {
      outEl.innerHTML = `<strong>Result:</strong> ${fmt(output)} weeks<br/><span class="note">${fmt(input)} days = ${fmt(output)} weeks</span>`;
    }

    const days = mode === "week-to-day" ? output : input;

    cardsEl.style.display = "block";
    cardsEl.innerHTML = `
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        ${badge(mode === "week-to-day" ? "weeks → days" : "days → weeks")}
        ${badge("Base ≈ " + fmtSmart(days) + " days")}
        ${badge(classifyDays(days))}
      </div>
    `;

    fillTable(input, output);
  }

  function reset() {
    clearError();
    inEl.value = "";
    roundEl.value = "3";
    outEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    tbodyEl.innerHTML = "";
  }

  convertBtn.addEventListener("click", compute);
  swapBtn.addEventListener("click", function () {
    mode = mode === "week-to-day" ? "day-to-week" : "week-to-day";
    setLabels();
    if (String(inEl.value || "").trim()) compute();
    else reset();
  });
  clearBtn.addEventListener("click", reset);
  roundEl.addEventListener("change", function () {
    if (String(inEl.value || "").trim()) compute();
  });

  setLabels();
});
</script>