---
import BaseLayout from "../../layouts/BaseLayout.astro";

type ToolMeta = {
  title: string;
  description: string;
  href: string;
  order?: number;
};

const CATEGORY = "/generators/";

const modules = await Astro.glob("../**/*.astro");

const tools: ToolMeta[] = modules
  .map((m) => (m as any).tool as ToolMeta | undefined)
  .filter((t): t is ToolMeta => !!t && !!t.href && !!t.title)
  .filter((t) => t.href.startsWith(CATEGORY) && t.href !== CATEGORY)
  .sort((a, b) => (a.order ?? 9999) - (b.order ?? 9999) || a.title.localeCompare(b.title));

const getTool = (href: string) => tools.find((tool) => tool.href === href);
const pickTools = (hrefs: string[]) => hrefs.map(getTool).filter((tool): tool is ToolMeta => !!tool);

const popularTools = pickTools([
  "/generators/fake-email-generator/",
  "/generators/fake-phone-generator/",
  "/generators/random-name-generator/",
  "/generators/random-number-list/",
  "/generators/random-domain-name/",
  "/generators/random-company-name/",
  "/generators/random-paragraph-generator/",
  "/generators/random-sentence-generator/",
]);

const toolGroups = [
  {
    title: "Testing and mock data",
    description: "Generate temporary values for forms, prototypes, QA checks, examples, and development workflows.",
    tools: pickTools([
      "/generators/fake-email-generator/",
      "/generators/fake-phone-generator/",
      "/generators/random-name-generator/",
      "/generators/random-company-name/",
      "/generators/random-domain-name/",
    ]),
  },
  {
    title: "Random values and lists",
    description: "Create random numbers, names, labels, or values for sampling, lightweight testing, or repeat tasks.",
    tools: pickTools([
      "/generators/random-number-list/",
      "/generators/random-city-generator/",
      "/generators/random-country-generator/",
      "/generators/random-language-generator/",
      "/generators/random-license-plate/",
    ]),
  },
  {
    title: "Writing and placeholder content",
    description: "Generate placeholder text, sentences, names, or simple content blocks for drafts and mock layouts.",
    tools: pickTools([
      "/generators/random-paragraph-generator/",
      "/generators/random-sentence-generator/",
      "/generators/random-team-name-generator/",
      "/generators/random-hashtag-generator/",
    ]),
  },
].filter((group) => group.tools.length);
---

<BaseLayout
  title="Generators — MinimalDev"
  description="Free generators for fake email, sample phone numbers, names, random values, domains, placeholder text, mock data, and quick testing data."
  canonicalPath="/generators/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <h1 class="page-title" style="margin:0 0 8px;">Generators</h1>
      <p class="lead" style="margin:0 0 10px;">
        Create quick values for testing, mock data, brainstorming, placeholder content, lightweight planning,
        and repeat workflows. This category includes generators for names, emails, phone numbers, domains,
        random values, text, and sample data.
      </p>
      <p class="lead" style="margin:0;">
        Use the grouped sections below to choose a generator by purpose instead of scanning a flat list of random tools.
      </p>
    </section>

    {popularTools.length ? (
      <section class="section">
        <h2>Start with common generators</h2>
        <div class="grid">
          {popularTools.map((t) => (
            <section class="card">
              <span class="badge">Popular generator</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    {toolGroups.length ? (
      <section class="section">
        <h2>Generators by purpose</h2>
        <div class="grid">
          {toolGroups.map((group) => (
            <section class="card">
              <h2>{group.title}</h2>
              <p>{group.description}</p>
              <ul>
                {group.tools.map((t) => (
                  <li><a href={t.href}>{t.title}</a></li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    <section class="section">
      <h2>What these tools are useful for</h2>
      <div class="grid">
        <section class="card">
          <h2>Testing and placeholders</h2>
          <p>
            Generate mock values, temporary inputs, sample names, identifiers,
            and lightweight test data for development or QA workflows.
          </p>
        </section>

        <section class="card">
          <h2>Brainstorming and idea generation</h2>
          <p>
            Some generators are useful for naming ideas, quick prompts, random combinations,
            or starting points when you want to explore options.
          </p>
        </section>

        <section class="card">
          <h2>Fast repeat tasks</h2>
          <p>
            Use generators for repeat tasks such as creating usernames, random values,
            sample domains, placeholder text, or simple mock content.
          </p>
        </section>
      </div>
    </section>

    <section class="section">
      <h2>Browse all generator tools</h2>
      <p class="lead" style="margin-top:0;">
        Search all available generators below if you already know the kind of output you want to create.
      </p>

      <div class="tool-search" style="margin-bottom:16px;">
        <input
          id="toolSearch"
          type="search"
          placeholder="Search tools..."
          aria-label="Search generator tools"
          style="
            width:100%;
            padding:10px 12px;
            border-radius:10px;
            border:1px solid rgba(0,0,0,0.15);
            font-size:14px;
            box-sizing:border-box;
          "
        />
      </div>

      {tools.length ? (
        <div class="grid" data-search-grid>
          {tools.map((t) => (
            <section class="card">
              <span class="badge">Generator</span>
              <h2>{t.title}</h2>
              <p>{t.description}</p>
              <a class="btn" href={t.href}>Open</a>
            </section>
          ))}
        </div>
      ) : (
        <p class="note">No tools found in this category yet.</p>
      )}
    </section>

    <section class="section">
      <h2>How to choose the right generator</h2>
      <div class="card" style="padding:18px;">
        <p style="margin-top:0;">
          Start by identifying the kind of output you need. For form testing, use fake contact or sample data tools.
          For writing and mock layouts, use text-style generators. For development or QA, choose generators
          that create the exact type of value your workflow requires.
        </p>
        <p style="margin-bottom:0;">
          Generator pages are separated by output type so each result is easier to understand, copy, and reuse.
        </p>
      </div>
    </section>
  </div>

  <script>
    const searchInput = document.getElementById("toolSearch") as HTMLInputElement | null;
    const grid = document.querySelector("[data-search-grid]");

    if (searchInput && grid) {
      const cards = Array.from(grid.querySelectorAll(".card")) as HTMLElement[];

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();

        cards.forEach((card) => {
          const text = card.textContent?.toLowerCase() || "";
          card.style.display = text.includes(query) ? "" : "none";
        });
      });
    }
  </script>
</BaseLayout>