---
import ToolLayout from "../../../components/ToolLayout.astro";

export const tool = {
  title: "Random Username Generator",
  description:
    "Generate random usernames with style options, numeric suffixes, quantity controls, and FAQ schema.",
  href: "/generators/random-username-generator/",
  order: 120,
};

const SITE_NAME = "MinimalDev";
const CANONICAL_PATH = "/generators/random-username-generator/";

const faqs = [
  {
    q: "What does this random username generator do?",
    a: "It generates random usernames using built-in word parts and optional numeric suffixes.",
  },
  {
    q: "Can I generate multiple usernames at once?",
    a: "Yes. You can choose the number of usernames to generate in one batch.",
  },
  {
    q: "Can usernames include numbers?",
    a: "Yes. You can choose whether to append numeric suffixes to the generated usernames.",
  },
  {
    q: "Is any data stored?",
    a: "No. Generation runs locally in your browser and nothing is stored or transmitted.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<ToolLayout
  title={`Random Username Generator — ${SITE_NAME}`}
  description="Generate random usernames with batch controls, optional numeric suffixes, and FAQ schema."
  canonicalPath={CANONICAL_PATH}
  h1="Random Username Generator"
  intro="Generate random usernames for testing, mock accounts, forms, and placeholder profile data."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div slot="tool" data-tool="random-username-generator">
    <style is:inline>
      .rugn-grid-2 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
      }
      .rugn-grid-2 > * {
        min-width: 0;
      }
      #rugn_count,
      #rugn_style,
      #rugn_output {
        width: 100%;
        min-width: 0;
      }
      .rugn-output {
        white-space: pre-wrap;
        word-break: break-word;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 14px;
      }
      @media (min-width: 760px) {
        .rugn-grid-2 {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>

    <div class="form" role="form" aria-describedby="rugn_help rugn_privacy">
      <div class="rugn-grid-2">
        <div class="field">
          <label for="rugn_count">How many usernames</label>
          <input id="rugn_count" type="number" inputmode="numeric" min="1" max="100" value="10" />
        </div>

        <div class="field">
          <label for="rugn_style">Username style</label>
          <select id="rugn_style">
            <option value="dot" selected>word.word</option>
            <option value="concat">wordword</option>
            <option value="underscore">word_word</option>
          </select>
        </div>
      </div>

      <div class="field">
        <label>
          <input id="rugn_numbers" type="checkbox" checked />
          Add numeric suffix
        </label>
      </div>

      <p class="note" id="rugn_help" style="margin-top:6px;">
        Generated usernames use random word combinations and optional numbers for placeholder account data.
      </p>

      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn" type="button" id="rugn_generate">Generate</button>
        <button class="btn secondary" type="button" id="rugn_copy">Copy Results</button>
        <button class="btn secondary" type="button" id="rugn_clear">Clear</button>
      </div>

      <div class="result" id="rugn_error" role="alert" style="display:none; margin-top:12px;"></div>
      <div class="result" id="rugn_result" role="status" style="margin-top:12px;">Result will appear here.</div>
      <div class="result" id="rugn_cards" style="display:none; margin-top:12px;"></div>

      <div class="field" style="margin-top:16px;">
        <label for="rugn_output">Generated usernames</label>
        <textarea id="rugn_output" class="rugn-output" rows="12" readonly spellcheck="false"></textarea>
      </div>

      <div style="margin-top:16px; overflow:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th scope="col">Metric</th>
              <th scope="col">Value</th>
            </tr>
          </thead>
          <tbody id="rugn_tbody"></tbody>
        </table>
      </div>

      <p class="note" id="rugn_privacy" style="margin-top:10px;">
        Privacy: generation runs locally in your browser. No generated usernames are stored or transmitted.
      </p>
    </div>
  </div>

  <div slot="how">
    <p class="note">
      Choose a username style, set the number of results, optionally add numeric suffixes, and generate a batch list instantly.
    </p>
  </div>

  <div slot="examples">
    <ul>
      <li>Generate usernames for placeholder user registration flows</li>
      <li>Create a batch of login IDs for UI demos</li>
      <li>Use numeric suffixes to reduce duplicate-looking names</li>
    </ul>
  </div>

  <div slot="faq">
    <ul>{faqs.map((f) => <li><strong>{f.q}</strong> {f.a}</li>)}</ul>
  </div>

  <div slot="related">
    <ul>
      <li><a href="/generators/random-name-generator/">Random Name Generator</a></li>
      <li><a href="/generators/fake-email-generator/">Fake Email Generator</a></li>
      <li><a href="/generators/random-user-generator/">Random User Generator</a></li>
      <li><a href="/generators/">All Generators</a></li>
    </ul>
  </div>
</ToolLayout>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const countEl = document.getElementById("rugn_count");
  const styleEl = document.getElementById("rugn_style");
  const numbersEl = document.getElementById("rugn_numbers");
  const generateBtn = document.getElementById("rugn_generate");
  const copyBtn = document.getElementById("rugn_copy");
  const clearBtn = document.getElementById("rugn_clear");
  const errEl = document.getElementById("rugn_error");
  const resultEl = document.getElementById("rugn_result");
  const cardsEl = document.getElementById("rugn_cards");
  const outputEl = document.getElementById("rugn_output");
  const tbodyEl = document.getElementById("rugn_tbody");

  if (!countEl || !styleEl || !numbersEl || !generateBtn || !copyBtn || !clearBtn || !errEl || !resultEl || !cardsEl || !outputEl || !tbodyEl) return;

  const firstParts = ["alpha","nova","pixel","echo","lunar","river","quiet","rapid","wild","silver","urban","bright","storm","solar","cloud"];
  const secondParts = ["fox","coder","hawk","pilot","spark","tiger","leaf","wave","stone","orbit","field","path","flare","shadow","drift"];

  let lastOutput = "";

  function randItem(arr) {
    return arr[Math.floor(Math.random() * arr.length)];
  }

  function toInt(v) {
    const n = Number(String(v).trim());
    return Number.isInteger(n) ? n : NaN;
  }

  function clearError() {
    errEl.style.display = "none";
    errEl.textContent = "";
  }

  function showError(msg) {
    errEl.style.display = "block";
    errEl.textContent = msg;
  }

  function badge(text) {
    return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid rgba(255,255,255,0.2);font-size:12px;font-weight:900;">' + text + '</span>';
  }

  function resetOutput() {
    clearError();
    resultEl.textContent = "Result will appear here.";
    cardsEl.style.display = "none";
    cardsEl.innerHTML = "";
    outputEl.value = "";
    tbodyEl.innerHTML = "";
    lastOutput = "";
  }

  function fillTable(rows) {
    tbodyEl.innerHTML = "";
    rows.forEach(function (row) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td");
      const td2 = document.createElement("td");
      td1.textContent = row[0];
      td2.textContent = row[1];
      tr.appendChild(td1);
      tr.appendChild(td2);
      tbodyEl.appendChild(tr);
    });
  }

  function makeUsername(style, withNumbers) {
    const a = randItem(firstParts);
    const b = randItem(secondParts);
    let base = "";

    if (style === "underscore") base = a + "_" + b;
    else if (style === "concat") base = a + b;
    else base = a + "." + b;

    if (withNumbers) base += String(Math.floor(Math.random() * 900) + 100);
    return base;
  }

  function generateUsernames() {
    resetOutput();

    const count = toInt(countEl.value);
    const style = String(styleEl.value || "dot");
    const withNumbers = !!numbersEl.checked;

    if (!Number.isInteger(count) || count < 1 || count > 100) {
      showError("Please enter a quantity from 1 to 100.");
      return;
    }

    const results = [];
    for (let i = 0; i < count; i++) {
      results.push(makeUsername(style, withNumbers));
    }

    lastOutput = results.join("\n");
    outputEl.value = lastOutput;

    resultEl.innerHTML = "<strong>Usernames generated.</strong>";
    cardsEl.style.display = "block";
    cardsEl.innerHTML =
      '<div style="display:flex; gap:10px; flex-wrap:wrap;">' +
      badge("Count: " + count) +
      badge("Style: " + style) +
      badge(withNumbers ? "Numeric suffixes" : "No numbers") +
      "</div>";

    fillTable([
      ["Generated count", String(count)],
      ["Username style", style],
      ["Numeric suffix", withNumbers ? "Yes" : "No"],
      ["Output length", String(lastOutput.length)],
    ]);
  }

  async function copyResults() {
    clearError();
    if (!lastOutput) {
      showError("No generated usernames to copy yet.");
      return;
    }
    try {
      await navigator.clipboard.writeText(lastOutput);
      resultEl.innerHTML = "<strong>Copied generated usernames.</strong>";
    } catch (_) {
      showError("Clipboard copy failed in this browser.");
    }
  }

  function clearAll() {
    countEl.value = "10";
    styleEl.value = "dot";
    numbersEl.checked = true;
    resetOutput();
    countEl.focus();
  }

  generateBtn.addEventListener("click", generateUsernames);
  copyBtn.addEventListener("click", copyResults);
  clearBtn.addEventListener("click", clearAll);
});
</script>