---
import BaseLayout from "../../layouts/BaseLayout.astro";

type Category = {
  title: string;
  description: string;
  href: string;
};

const categories: Category[] = [
  {
    title: "Converters",
    description: "Unit converters for length, weight, temperature, time, speed, area, volume, and data size.",
    href: "/converter/",
  },
  {
    title: "Developer Tools",
    description: "Validators, formatters, encoders, decoders, parsers, metadata tools, and debugging helpers.",
    href: "/developer-tools/",
  },
  {
    title: "Image Tools",
    description: "Resize, compress, crop, convert, inspect, and process images directly in your browser.",
    href: "/image-tools/",
  },
  {
    title: "Text Tools",
    description: "Clean, count, compare, sort, transform, and analyze text for writing or data preparation.",
    href: "/text-tools/",
  },
  {
    title: "Date & Time",
    description: "Date differences, business days, timestamps, ages, countdowns, and time duration tools.",
    href: "/date-time/",
  },
  {
    title: "Math",
    description: "Calculators for percentages, algebra, geometry, statistics, roots, ratios, and formulas.",
    href: "/math/",
  },
  {
    title: "Finance",
    description: "Loan, mortgage, interest, savings, investment, salary, budget, and tax calculators.",
    href: "/finance/",
  },
  {
    title: "Health",
    description: "BMI, BMR, hydration, calorie, sleep, body metrics, and activity-related calculators.",
    href: "/health/",
  },
  {
    title: "Utilities",
    description: "General-purpose helpers including counters, generators, formatters, QR tools, and quick utilities.",
    href: "/utility/",
  },
  {
    title: "Generators",
    description: "Generate names, emails, domains, sample text, placeholders, random values, and mock data.",
    href: "/generators/",
  },
  {
    title: "Design Tools",
    description: "Color, contrast, gradient, palette, shadow, border radius, layout, and CSS design helpers.",
    href: "/design-tools/",
  },
];

const getCategory = (href: string) => categories.find((category) => category.href === href);
const pickCategories = (hrefs: string[]) => hrefs.map(getCategory).filter((category): category is Category => !!category);

const popularCategories = pickCategories([
  "/converter/",
  "/developer-tools/",
  "/image-tools/",
  "/text-tools/",
  "/date-time/",
  "/finance/",
]);

const categoryGroups = [
  {
    title: "Calculate and convert values",
    description: "Use these categories when you need numeric results, unit changes, dates, money estimates, or formulas.",
    categories: pickCategories([
      "/converter/",
      "/math/",
      "/finance/",
      "/date-time/",
      "/health/",
    ]),
  },
  {
    title: "Work with files, images, and text",
    description: "Use these categories for browser-based editing, cleanup, formatting, inspection, and content preparation.",
    categories: pickCategories([
      "/image-tools/",
      "/text-tools/",
      "/utility/",
      "/design-tools/",
    ]),
  },
  {
    title: "Developer and test data workflows",
    description: "Use these categories for validation, encoding, parsing, mock data, placeholders, and technical checks.",
    categories: pickCategories([
      "/developer-tools/",
      "/generators/",
      "/utility/",
    ]),
  },
].filter((group) => group.categories.length);
---

<BaseLayout
  title="All Categories — MinimalDev"
  description="Browse MinimalDev tool categories including converters, developer tools, image tools, text tools, date and time tools, math, finance, health, utilities, generators, and design tools."
  canonicalPath="/categories/"
>
  <div class="container">
    <section class="card" style="padding:18px;">
      <h1 class="page-title" style="margin:0 0 8px;">All Categories</h1>
      <p class="lead" style="margin:0;">
        Browse MinimalDev by task type. Start with a category when you know the kind of work you need to do,
        but not the exact tool name.
      </p>
    </section>

    {popularCategories.length ? (
      <section class="section">
        <h2>Start here</h2>
        <div class="grid">
          {popularCategories.map((category) => (
            <section class="card">
              <span class="badge">Category</span>
              <h2>{category.title}</h2>
              <p>{category.description}</p>
              <a class="btn" href={category.href}>Open</a>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    {categoryGroups.length ? (
      <section class="section">
        <h2>Categories by task</h2>
        <div class="grid">
          {categoryGroups.map((group) => (
            <section class="card">
              <h2>{group.title}</h2>
              <p>{group.description}</p>
              <ul>
                {group.categories.map((category) => (
                  <li><a href={category.href}>{category.title}</a></li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>
    ) : null}

    <section class="section">
      <h2>Find a category</h2>
      <p class="lead" style="margin-top:0;">
        Search by category name, purpose, or description.
      </p>

      <div class="tool-search" style="margin-bottom:16px;">
        <input
          id="categorySearch"
          type="search"
          placeholder="Search categories..."
          aria-label="Search categories"
          style="
            width:100%;
            padding:10px 12px;
            border-radius:10px;
            border:1px solid rgba(0,0,0,0.15);
            font-size:14px;
            box-sizing:border-box;
          "
        />
      </div>

      <div class="grid" data-category-grid>
        {categories.map((category) => (
          <section class="card">
            <span class="badge">Category</span>
            <h2>{category.title}</h2>
            <p>{category.description}</p>
            <a class="btn" href={category.href}>Open</a>
          </section>
        ))}
      </div>
    </section>

    <section class="section">
      <h2>How to choose a category</h2>
      <div class="card" style="padding:18px;">
        <p style="margin-top:0;">
          Choose the category that matches your task first. Use <strong>Converters</strong> for unit changes,
          <strong>Developer Tools</strong> for validation and formatting, <strong>Image Tools</strong> for visual files,
          and <strong>Finance</strong> for money-related estimates.
        </p>
        <p style="margin-bottom:0;">
          If you are unsure, start with a broad category and then use the category search or tool search on that page
          to narrow the list.
        </p>
      </div>
    </section>
  </div>

  <script>
    const searchInput = document.getElementById("categorySearch") as HTMLInputElement | null;
    const grid = document.querySelector("[data-category-grid]");

    if (searchInput && grid) {
      const cards = Array.from(grid.querySelectorAll(".card")) as HTMLElement[];

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();

        cards.forEach((card) => {
          const text = card.textContent?.toLowerCase() || "";
          card.style.display = text.includes(query) ? "" : "none";
        });
      });
    }
  </script>
</BaseLayout>