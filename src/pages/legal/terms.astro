---
import BaseLayout from "../../layouts/BaseLayout.astro";

const updated = "2026-02-24";
---

<BaseLayout
  title="Terms of Service — MinimalDev"
  description="Terms of Service for using MinimalDev free online tools."
  canonicalPath="/legal/terms/"
>
  <div class="container">
    <h1 class="page-title">Terms of Service</h1>
    <p class="note">Last updated: {updated}</p>

    <section class="section">
      <h2>Acceptance of terms</h2>
      <p class="note">
        By accessing or using MinimalDev, you agree to these Terms. If you do not agree, please do not use the site.
      </p>
    </section>

    <section class="section">
      <h2>Use of the tools</h2>
      <ul>
        <li>You may use the tools for personal or business purposes.</li>
        <li>You agree not to misuse the site (e.g., attempting to disrupt services or automated abuse).</li>
      </ul>
    </section>

    <section class="section">
      <h2>No warranties</h2>
      <p class="note">
        Tools and results are provided “as is” without warranties of any kind. While we aim for accuracy, you are responsible for verifying results for your specific use case.
      </p>
    </section>

    <section class="section">
      <h2>Limitation of liability</h2>
      <p class="note">
        MinimalDev will not be liable for any damages arising from your use of the site or tools, including indirect or consequential damages, to the maximum extent permitted by law.
      </p>
    </section>

    <section class="section">
      <h2>Advertising and third-party links</h2>
      <p class="note">
        The site may show ads and may link to third-party sites. We are not responsible for third-party content or practices.
      </p>
    </section>

    <section class="section">
      <h2>Changes</h2>
      <p class="note">
        We may update these Terms from time to time. Continued use of the site means you accept the updated Terms.
      </p>
    </section>

    <section class="section">
      <h2>Contact</h2>
      <p class="note">
        Questions? Use the <a href="/legal/contact/">Contact</a> page.
      </p>
    </section>
  </div>
</BaseLayout>