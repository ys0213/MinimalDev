---
import BaseLayout from "../layouts/BaseLayout.astro";

type FAQItem = { q: string; a: string };

type Props = {
  title: string;
  description: string;
  canonicalPath: string;
  h1: string;
  intro: string;
  faq?: FAQItem[];
  priceCurrency?: string;
  showAds?: boolean;
  categoryName?: string;
};

const {
  title,
  description,
  canonicalPath,
  h1,
  intro,
  faq = [],
  priceCurrency = "USD",
  showAds = false,
  categoryName = "",
} = Astro.props as Props;

function getCategory(path: string | undefined): string {
  if (!path) return "UtilitiesApplication";
  if (path.startsWith("/health/")) return "HealthApplication";
  if (path.startsWith("/math/")) return "EducationalApplication";
  if (path.startsWith("/converter/")) return "UtilitiesApplication";
  if (path.startsWith("/utility/")) return "UtilitiesApplication";
  if (path.startsWith("/date-time/")) return "UtilitiesApplication";
  if (path.startsWith("/finance/")) return "FinanceApplication";
  return "UtilitiesApplication";
}

function getCategoryPath(path: string | undefined): string {
  if (!path) return "/";
  const parts = path.split("/").filter(Boolean);
  if (parts.length === 0) return "/";
  return `/${parts[0]}/`;
}

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": h1,
  "url": `https://minimaldev.dev${canonicalPath}`,
  "description": description,
  "applicationCategory": getCategory(canonicalPath),
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": priceCurrency,
  },
};

const hasFaq = Array.isArray(faq) && faq.length > 0;

const faqSchema = hasFaq
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq.map((item) => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a,
        },
      })),
    }
  : null;

const breadcrumbSchema =
  categoryName && canonicalPath
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://minimaldev.dev/",
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": categoryName,
            "item": `https://minimaldev.dev${getCategoryPath(canonicalPath)}`,
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": h1,
            "item": `https://minimaldev.dev${canonicalPath}`,
          },
        ],
      }
    : null;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webAppSchema)}></script>

  {hasFaq && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  )}

  {breadcrumbSchema && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  )}

  <div class="container">
    <h1 class="page-title">{h1}</h1>
    <p class="lead">{intro}</p>

    <section class="card">
      <slot name="tool" />
    </section>

    <section class="section">
      <h2>How it works</h2>
      <slot name="how" />
    </section>

    <section class="section">
      <h2>Examples</h2>
      <slot name="examples" />
    </section>

    {/* ✅ 핵심 추가 (사이트 전체 품질 레이어) */}
    <section class="section">
      <h2>When to use this tool</h2>
      <p class="note">
        This tool is designed for quick, practical tasks such as everyday calculations, data formatting, or simple conversions.
        It is best used when you need fast results without installing software or using complex tools.
      </p>

      <h3 style="margin-top:12px;">When to use</h3>
      <ul>
        <li>Quick checks or one-time calculations</li>
        <li>Validating or converting data before using it elsewhere</li>
        <li>Simple tasks that do not require advanced software</li>
      </ul>

      <h3 style="margin-top:12px;">When not to use</h3>
      <ul>
        <li>Critical financial, legal, or medical decisions</li>
        <li>Large-scale or automated processing</li>
        <li>Situations requiring guaranteed precision beyond basic validation</li>
      </ul>

      <p class="note" style="margin-top:10px;">
        Always review results before using them in important contexts.
      </p>
    </section>

    {hasFaq && (
      <section class="section">
        <h2>FAQ</h2>
        <ul>
          {faq.map((item) => (
            <li>
              <strong>{item.q}</strong>
              <p>{item.a}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="section">
      <h2>Related tools</h2>
      <slot name="related" />
    </section>
  </div>
</BaseLayout>