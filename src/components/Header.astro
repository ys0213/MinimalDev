---
const currentPath: string = Astro.url.pathname;

const normalizePath = (href: string): string => {
  if (href === "/") return "/";
  return href.endsWith("/") ? href : `${href}/`;
};

const isActive = (href: string): boolean => {
  const normalizedCurrentPath = normalizePath(currentPath);
  const normalizedHref = normalizePath(href);

  return normalizedCurrentPath === normalizedHref || normalizedCurrentPath.startsWith(normalizedHref);
};

const BASE: string = import.meta.env.BASE_URL;

const withBase = (p: string): string => {
  const base = BASE.endsWith("/") ? BASE : `${BASE}/`;
  const path = String(p).replace(/^\//, "");
  return `${base}${path}`;
};

const navLinks = [
  { href: "/converter/", label: "Converters" },
  { href: "/developer-tools/", label: "Developer" },
  { href: "/image-tools/", label: "Images" },
  { href: "/text-tools/", label: "Text" },
  { href: "/date-time/", label: "Date & Time" },
  { href: "/math/", label: "Math" },
  { href: "/finance/", label: "Finance" },
  { href: "/guides/", label: "Guides" },
  { href: "/categories/", label: "Categories" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBase("/")}>
      <img
        src={withBase("/assets/img/logo-512.png")}
        alt="MinimalDev"
        width="28"
        height="28"
      />
      <div>
        MinimalDev
        <small>Free Online Utility Tools</small>
      </div>
    </a>

    <input
      id="siteNavToggle"
      class="nav-toggle-input"
      type="checkbox"
      aria-label="Toggle navigation menu"
    />

    <label class="nav-toggle" for="siteNavToggle">
      Menu
    </label>

    <nav class="nav" aria-label="Primary">
      {navLinks.map((link) => (
        <a
          href={withBase(link.href)}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>