---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { noindexPaths } from "../data/noindexPaths.js";

const {
  title = "MinimalDev — Free Online Utility Tools",
  description = "Fast, free online calculators and utility tools.",
  canonicalPath = "/",
  robots = undefined,
} = Astro.props;

const normalizePath = (path: string) => {
  if (path === "/") return "/";
  return path.endsWith("/") ? path : `${path}/`;
};

const canonical = `https://minimaldev.dev${normalizePath(canonicalPath)}`;

const currentPath = normalizePath(Astro.url.pathname);

const noindexSet = new Set(noindexPaths);
const isNoindex = noindexSet.has(currentPath);
const robotsContent = robots ?? (isNoindex ? "noindex,follow" : "index,follow");

// ✅ base 경로 ("/MinimalDev/" 같은 값)
const BASE: string = import.meta.env.BASE_URL;
// ✅ "/assets/..." 같은 경로를 base 붙여서 만드는 헬퍼
const withBase = (p: string): string => {
  const base = BASE.endsWith("/") ? BASE : `${BASE}/`;
  const path = String(p).replace(/^\//, "");
  return `${base}${path}`;
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content={robotsContent} />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <link rel="stylesheet" href={withBase("/assets/css/main.css")} />

  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4048726417977405"
     crossorigin="anonymous"></script>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-BX1L8JRKYJ"></script>

  <script
    set:html={`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BX1L8JRKYJ');
    `}
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "MinimalDev",
    "url": "https://minimaldev.dev/"
  })}></script>
  <slot name="head" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <Header />

  <main id="main" class="main">
    <slot />
  </main>

  <Footer />

  <script defer src={withBase("/assets/js/main.js")}></script>
</body>
</html>