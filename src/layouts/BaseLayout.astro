  "/generators/random-time-generator/",
  "/generators/random-password-list/",
  "/generators/random-product-name/",
  "/generators/random-username-generator/",
  "/generators/random-hex-generator/",
  "/generators/random-ip-generator/",
  "/generators/random-date-generator/",
  "/generators/random-color-generator/",
  "/generators/random-letter-generator/",
  "/generators/random-user-generator/",
  "/generators/fake-address-generator/",

  "/image-tools/image-blur/",
  "/image-tools/image-to-base64/",
  "/image-tools/image-palette-generator/",
  "/image-tools/base64-to-image/",
  "/image-tools/image-flip/",
  "/image-tools/image-rotate/",

  "/date-time/week-number-calculator/",
  "/date-time/countdown-timer/",
  "/date-time/unix-time-to-date/",
  "/date-time/unix-timestamp-converter/",

  "/math/matrix-calculator/",
  "/math/log2-calculator/",
  "/math/random-prime-generator/",
  "/math/variance-calculator/",
  "/math/factorial-calculator/",

  "/utility/pin-generator/",
]);

const isNoindex = noindexPaths.has(currentPath);
const robotsContent = robots ?? (isNoindex ? "noindex,follow" : "index,follow");

// ✅ base 경로 ("/MinimalDev/" 같은 값)
const BASE: string = import.meta.env.BASE_URL;
// ✅ "/assets/..." 같은 경로를 base 붙여서 만드는 헬퍼
const withBase = (p: string): string => {
  const base = BASE.endsWith("/") ? BASE : `${BASE}/`;
  const path = String(p).replace(/^\//, "");
  return `${base}${path}`;
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content={robotsContent} />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <link rel="stylesheet" href={withBase("/assets/css/main.css")} />

  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4048726417977405"
     crossorigin="anonymous"></script>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-BX1L8JRKYJ"></script>

  <script
    set:html={`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BX1L8JRKYJ');
    `}
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "MinimalDev",
    "url": "https://minimaldev.dev/"
  })}></script>
  <slot name="head" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <Header />

  <main id="main" class="main">
    <slot />
  </main>

  <Footer />

  <script defer src={withBase("/assets/js/main.js")}></script>
</body>
</html>