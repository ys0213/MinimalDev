---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "MinimalDev — Free Online Utility Tools",
  description = "Fast, free online calculators and utility tools.",
  canonicalPath = "/",
} = Astro.props;

const canonical = `https://minimaldev.com${canonicalPath}`;

// ✅ base 경로 ("/MinimalDev/" 같은 값)
const BASE: string = import.meta.env.BASE_URL;
// ✅ "/assets/..." 같은 경로를 base 붙여서 만드는 헬퍼
const withBase = (p: string): string => {
  const base = BASE.endsWith("/") ? BASE : `${BASE}/`;
  const path = String(p).replace(/^\//, "");
  return `${base}${path}`;
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index,follow" />

  <link rel="stylesheet" href={withBase("/assets/css/main.css")} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "MinimalDev",
    "url": "https://minimaldev.com/"
  })}></script>
  <slot name="head" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <Header />

  <main id="main" class="main">
    <slot />
  </main>

  <Footer />

  <script defer src={withBase("/assets/js/main.js")}></script>
</body>
</html>