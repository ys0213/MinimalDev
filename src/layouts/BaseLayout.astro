---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "MinimalDev — Free Online Utility Tools",
  description = "Fast, free online calculators and utility tools.",
  canonicalPath = "/",
  robots = undefined,
} = Astro.props;

const normalizePath = (path: string) => {
  if (path === "/") return "/";
  return path.endsWith("/") ? path : `${path}/`;
};

const canonical = `https://minimaldev.dev${normalizePath(canonicalPath)}`;

const currentPath = normalizePath(Astro.url.pathname);

const noindexPaths = new Set([
  "/design-tools/hsl-to-rgb/",
  "/design-tools/rgb-to-hex/",
  "/design-tools/hex-to-rgb/",
  "/design-tools/box-shadow-generator/",
  "/design-tools/gradient-generator/",
  "/design-tools/svg-to-css-generator/",
  "/design-tools/rgb-to-hsl/",
  "/design-tools/css-gradient-generator/",

  "/text-tools/ascii-converter/",
  "/text-tools/text-reverser/",
  "/text-tools/line-counter/",
  "/text-tools/shuffle-lines/",
  "/text-tools/remove-duplicate-lines/",
  "/text-tools/sort-lines/",
  "/text-tools/text-compare/",
  "/text-tools/sentence-counter/",
  "/text-tools/unicode-converter/",
  "/text-tools/case-converter-advanced/",
  "/text-tools/whitespace-remover/",

  "/developer-tools/jwt-encoder/",
  "/developer-tools/mac-address-validator/",
  "/developer-tools/sha256-generator/",
  "/developer-tools/md5-generator/",
  "/developer-tools/tsv-to-csv/",
  "/developer-tools/uuid-validator/",
  "/developer-tools/base32-decoder/",
  "/developer-tools/bcrypt-generator/",
  "/developer-tools/csv-to-tsv/",
  "/developer-tools/jwt-decoder/",

  "/converter/minutes-to-seconds/",
  "/converter/bits-to-bytes/",
  "/converter/hours-to-days/",
  "/converter/f-to-c/",
  "/converter/mph-to-kmh/",
  "/converter/kelvin-to-fahrenheit/",
  "/converter/degrees-to-radians/",
  "/converter/l-100km-to-mpg/",
  "/converter/feet-to-meters/",
  "/converter/kmh-to-mph/",
  "/converter/megabits-to-megabytes/",
  "/converter/fahrenheit-to-kelvin/",
  "/converter/tons-to-kg/",
  "/converter/seconds-to-minutes/",
  "/converter/watts-to-horsepower/",
  "/converter/joules-to-calories/",
  "/converter/mm-to-inches/",
  "/converter/minutes-to-hours/",
  "/converter/c-to-f/",
  "/converter/years-to-days/",
  "/converter/meters-to-yards/",
  "/converter/megabytes-to-megabits/",
  "/converter/meters-to-feet/",
  "/converter/liters-to-gallons/",
  "/converter/liters-to-cubic-meters/",
  "/converter/km-to-miles/",
  "/converter/kg-to-tons/",
  "/converter/kelvin-to-celsius/",
  "/converter/kb-to-mb/",
  "/converter/gallons-to-liters/",
  "/converter/bytes-to-bits/",
  "/converter/calories-to-joules/",
  "/converter/sq-ft-to-sq-m/",
  "/converter/ounces-to-grams/",
  "/converter/pounds-to-kg/",
  "/converter/mpg-to-l-100km/",
  "/converter/inches-to-mm/",
  "/converter/psi-to-bar/",
  "/converter/grams-to-ounces/",
